import argparse as _argparse

def _canonical_score(d):
    """Score canonico alineado con pipeline/dashboard.
    Recibe el dict completo del JSON del modelo (con metrics_oos y oos_days top-level).
    """
    try:
        m = d.get('metrics_oos') or {}
        cagr = float(m.get('cagr', 0) or 0)
        dd = abs(float(m.get('dd', 0) or 0))
        wr = float(m.get('wr', 0) or 0)
        pf = float(m.get('pf', 0) or 0)
        trades = float(m.get('trades', 0) or 0)
        oos_days = float(d.get('oos_days', 365) or 365)
        ty = trades * 365.0 / max(oos_days, 1)
        s_cagr = min(cagr, 100) / 100 * 0.35
        s_cal = (min(cagr / dd, 8) / 8 * 0.25) if dd > 0 else 0
        s_freq = min(ty / 12, 1) * 0.20
        s_wr = min(max(wr / 100 - 0.5, 0) / 0.35, 1) * 0.15
        s_pf = min(pf, 3) / 3 * 0.05
        return s_cagr + s_cal + s_freq + s_wr + s_pf
    except Exception:
        return 0.0


