def log(msg):
    line = f'[{datetime.now().strftime("%Y-%m-%d %H:%M:%S")}] {msg}'
    print(line, flush=True)
    try:
        with open(LOG_PATH, 'a') as f:
            print(line, file=f)
    except Exception:
        pass


def get_telegram_config():
    # 1) Preferir loader canonico de secrets (audit 2026-05-14)
    token = None
    chat_id = None
    try:
        if _sigma_get_tg_token is not None:
            token = _sigma_get_tg_token()
    except Exception as e:
        log(f'secrets loader error: {e}')
    # 2) CHAT_ID se sigue tomando del notifier (no esta en secrets)
    try:
        text = NOTIFIER_PATH.read_text(encoding='utf-8')
        import re
        if not token:
            m_token = re.search(r"TOKEN\s*=\s*['\"]([^'\"]+)['\"]", text)
            if m_token:
                token = m_token.group(1)
        m_chat  = re.search(r"CHAT_ID\s*=\s*['\"]?(-?\d+)['\"]?", text)
        if m_chat:
            chat_id = m_chat.group(1)
    except Exception as e:
        log(f'config error: {e}')
    if token and chat_id:
        return token, chat_id
    return None, None


def send_telegram(text):
    token, chat_id = get_telegram_config()
    if not token or not chat_id:
        log('No telegram config')
        return False
    try:
        url = f'https://api.telegram.org/bot{token}/sendMessage'
        data = urllib.parse.urlencode({
            'chat_id': chat_id,
            'text': text,
            'parse_mode': 'HTML',
            'disable_web_page_preview': 'true',
        }).encode()
        req = urllib.request.Request(url, data=data)
        urllib.request.urlopen(req, timeout=10)
        return True
    except Exception as e:
        log(f'send error: {e}')
        return False



