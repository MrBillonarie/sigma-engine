def _regen_snapshot():
    """Regenera port_snapshot.json desde los JSONs frescos en /opt/sigma/models.
    Replica el formato escrito por dashboard.py:_write_snapshot pero usando
    SOLO los champions actuales en disco. Si dashboard escribe despues, sobreescribe.
    """
    models_dir = BASE / 'models'
    if not models_dir.exists():
        return False
    champions = {}
    cagrs, wrs, dds, pfs, trades = [], [], [], [], 0
    n_grade_a = 0
    # Por slot (asset|tf) elegir el de mayor CAGR OOS y derivar direction del strategy name
    by_slot = {}
    for tf_dir in models_dir.iterdir():
        if not tf_dir.is_dir() or tf_dir.name == 'archive':
            continue
        tf = tf_dir.name
        for jf in tf_dir.glob('*.json'):
            try:
                d = json.loads(jf.read_text())
            except Exception:
                continue
            sym = (d.get('symbol') or '').replace('/USDT', '').upper()
            strat = d.get('strategy') or jf.stem.split('_', 1)[-1]
            m = d.get('metrics_oos') or {}
            cagr = float(m.get('cagr', 0) or 0)
            score = _canonical_score(d)
            key = f'{sym}|{tf}'
            prev = by_slot.get(key)
            if prev is None or score > prev[0]:
                direction = 'short' if strat in SHORT_STRATEGIES else 'long'
                by_slot[key] = (score, cagr, strat, direction, m)
    trades_per_slot = []  # 2026-05-14: añadido para weighted average
    for key, (_score, cagr, strat, direction, m) in by_slot.items():
        champions[key] = f'{strat}|{direction}'
        slot_trades = int(m.get('trades', 0) or 0)
        cagrs.append(cagr)
        wrs.append(float(m.get('wr', 0) or 0))
        dds.append(float(m.get('dd', 0) or 0))
        pfs.append(float(m.get('pf', 0) or 0))
        trades_per_slot.append(slot_trades)
        trades += slot_trades
        # grado A: CAGR/|DD| >= 0.55 aprox (heuristica simple para mantener n_grade_a)
        if cagr >= 25:
            n_grade_a += 1
    if not champions:
        return False
    n = len(cagrs)
    # 2026-05-14: weighted average por trades — sincroniza con dashboard.py
    weights = [max(t, 1) for t in trades_per_slot]
    total_w = sum(weights)
    if total_w > 0:
        port_cagr = sum(c * w for c, w in zip(cagrs, weights)) / total_w
        port_wr   = sum(w_ * w for w_, w in zip(wrs, weights)) / total_w
        port_dd   = sum(d * w for d, w in zip(dds, weights)) / total_w
        port_pf   = sum(p * w for p, w in zip(pfs, weights)) / total_w if any(p > 0 for p in pfs) else 0
    else:
        port_cagr = sum(cagrs) / n
        port_wr = sum(wrs) / n
        port_dd = sum(dds) / n
        port_pf = sum(pfs) / n
    port_calmar = (port_cagr / abs(port_dd)) if port_dd < 0 else 0
    snap = {
        'port_cagr': port_cagr,
        'port_wr': port_wr,
        'port_dd': port_dd,
        'port_pf': round(port_pf, 2),
        'port_calmar': round(port_calmar, 2),
        'total_trades': trades,
        'n_grade_a': n_grade_a,
        'snapshot_at': datetime.now(timezone.utc).replace(tzinfo=None).isoformat() + 'Z',
        'trigger': 'champion_watcher refresh',
        'champions': champions,
    }
    try:
        SNAPSHOT_PATH.parent.mkdir(parents=True, exist_ok=True)
        SNAPSHOT_PATH.write_text(json.dumps(snap, indent=2))
        return True
    except Exception as e:
        log(f'_regen_snapshot write error: {e}')
        return False


def main():
    # Regenerar snapshot desde JSONs frescos antes de comparar (dashboard.py es on-demand)
    try:
        if _regen_snapshot():
            log('snapshot regenerated from disk')
    except Exception as e:
        log(f'regen error: {e}')
    if not SNAPSHOT_PATH.exists():
        log('No snapshot yet — skip')
        return

    try:
        snap = json.loads(SNAPSHOT_PATH.read_text())
    except Exception as e:
        log(f'snap read error: {e}')
        return

    current = snap.get('champions', {})
    if not current:
        log('Empty champions in snapshot')
        return

    # Leer último estado notificado
    first_run = not NOTIFIED_PATH.exists()
    last = {}
    if not first_run:
        try:
            last = json.loads(NOTIFIED_PATH.read_text()).get('champions', {})
        except Exception:
            pass

    # FIRST RUN: solo guardar baseline, no mandar nada
    if first_run:
        NOTIFIED_PATH.write_text(json.dumps({
            'champions': current,
            'baseline_set_at': datetime.now().isoformat(),
        }, indent=2))
        log(f'Baseline inicial guardado: {len(current)} slots. No se manda nada.')
        return

    # Detectar cambios
    fresh_discoveries = []  # estrategia del UNIVERSO NUEVO (agregadas 2026-05-14)
    discoveries = []        # estrategia avanzada (no en ORIGINAL_9 ni en NEW_2026_05_14)
    rotations = []          # estrategia clásica reemplaza a otra clásica
    for slot, strat_dir in current.items():
        old = last.get(slot)
        if old == strat_dir:
            continue  # sin cambio
        strat_new = str(strat_dir).split('|')[0] if '|' in str(strat_dir) else strat_dir
        strat_old = str(old).split('|')[0] if old and '|' in str(old) else (old or 'nuevo')
        if strat_new in NEW_2026_05_14:
            fresh_discoveries.append((slot, strat_old, strat_new))
        elif strat_new not in ORIGINAL_9:
            discoveries.append((slot, strat_old, strat_new))
        elif old is not None:
            rotations.append((slot, strat_old, strat_new))

    # Si NO hay cambios, no mandar nada (importante para evitar spam)
    if not fresh_discoveries and not discoveries and not rotations:
        log(f'Sin cambios ({len(current)} slots tracked) — no message')
        return

    # UN solo mensaje consolidado
    lines = []
    if fresh_discoveries:
        lines.append('🆕 <b>CAMPEONES DEL NUEVO UNIVERSO (14-05)</b>')
        lines.append('<i>Una de las 23 estrategias agregadas hoy se posicionó como champion.</i>')
        lines.append('')
        for slot, old, new in fresh_discoveries:
            lines.append(f'  🔥 <b>{slot}</b>: {old} → <b>{new}</b>')
    if discoveries:
        if lines:
            lines.append('')
        lines.append('🎉 <b>NUEVOS CAMPEONES — universo expandido (legacy)</b>')
        lines.append('')
        for slot, old, new in discoveries:
            lines.append(f'  • <b>{slot}</b>: {old} → <b>{new}</b>')
    if rotations:
        if lines:
            lines.append('')
        lines.append('🔄 <b>Rotación de estrategias clásicas</b>')
        lines.append('')
        for slot, old, new in rotations:
            lines.append(f'  • <b>{slot}</b>: {old} → <b>{new}</b>')
    lines.append('')
    msg = '\n'.join(lines)

    if SEED_ONLY:
        # Modo seed: NO mandar Telegram, solo sincronizar notified contra snapshot regenerado
        log(f'[seed-only] Skipping Telegram. {len(discoveries)} discoveries + {len(rotations)} rotations detected.')
        for slot, old, new in discoveries:
            log(f'[seed-only] discovery {slot}: {old} -> {new}')
        for slot, old, new in rotations:
            log(f'[seed-only] rotation {slot}: {old} -> {new}')
        NOTIFIED_PATH.write_text(json.dumps({
            'champions': current,
            'seeded_at': datetime.now().isoformat(),
            'seed_changes_summary': {
                'discoveries': len(discoveries),
                'rotations': len(rotations),
            },
        }, indent=2))
        log('[seed-only] champion_notified.json sincronizado con snapshot actual.')
        return

    if send_telegram(msg):
        log(f'Notified: {len(fresh_discoveries)} fresh + {len(discoveries)} discoveries + {len(rotations)} rotations en 1 mensaje')
        # Solo guardar el nuevo baseline SI el send fue exitoso
        NOTIFIED_PATH.write_text(json.dumps({
            'champions': current,
            'last_notified_at': datetime.now().isoformat(),
            'changes_summary': {
                'fresh_discoveries': len(fresh_discoveries),
                'discoveries': len(discoveries),
                'rotations': len(rotations),
            },
        }, indent=2))
    else:
        log('Send falló — no actualizo NOTIFIED_PATH (reintento próximo run)')


if __name__ == '__main__':
    main()
