def log(msg):
    line = f'[{datetime.now().strftime("%Y-%m-%d %H:%M:%S")}] {msg}'
    print(line, flush=True)
    try:
        with open(LOG_PATH, 'a') as f:
            print(line, file=f)
    except Exception:
        pass


def get_telegram_config():
    # 1) Preferir loader canonico de secrets (audit 2026-05-14)
    token = None
    chat_id = None
    try:
        if _sigma_get_tg_token is not None:
            token = _sigma_get_tg_token()
    except Exception as e:
        log(f'secrets loader error: {e}')
    # 2) CHAT_ID se sigue tomando del notifier (no esta en secrets)
    try:
        text = NOTIFIER_PATH.read_text(encoding='utf-8')
        import re
        if not token:
            m_token = re.search(r"TOKEN\s*=\s*['\"]([^'\"]+)['\"]", text)
            if m_token:
                token = m_token.group(1)
        m_chat  = re.search(r"CHAT_ID\s*=\s*['\"]?(-?\d+)['\"]?", text)
        if m_chat:
            chat_id = m_chat.group(1)
    except Exception as e:
        log(f'config error: {e}')
    if token and chat_id:
        return token, chat_id
    return None, None


def send_telegram(text):
    """Envia con HTML; si HTTP 400 (HTML mal formado), reintenta sin parse_mode.
    Loguea preview del body cuando falla, para diagnostico.
    """
    token, chat_id = get_telegram_config()
    if not token or not chat_id:
        log('No telegram config')
        return False
    url = f'https://api.telegram.org/bot{token}/sendMessage'
    for attempt_mode in ('HTML', 'plain'):
        try:
            payload = {
                'chat_id': chat_id,
                'text': text,
                'disable_web_page_preview': 'true',
            }
            if attempt_mode == 'HTML':
                payload['parse_mode'] = 'HTML'
            data = urllib.parse.urlencode(payload).encode()
            req = urllib.request.Request(url, data=data)
            urllib.request.urlopen(req, timeout=10)
            if attempt_mode == 'plain':
                log('send OK con fallback plain (HTML rompia)')
            return True
        except Exception as e:
            code = getattr(e, 'code', None)
            if code == 400 and attempt_mode == 'HTML':
                log(f'send HTTP 400 (HTML) - reintento plain. Body preview (repr): {text[:240]!r}')
                continue
            log(f'send error ({attempt_mode}): {e}')
            return False
    return False



# SHORT_STRATEGIES importado desde utils.strategies (centralizado 2026-05-14)
from utils.strategies import SHORT_STRATEGIES



def _funding_kelly_boost_estimate(champions_data):
    """Estima pp extra de port_cagr por Kelly v2 (solo shorts).
    Cripto funding usualmente positivo → shorts ganan en promedio +3%."""
    SHORT_BOOST_PCT = 0.03
    total_trades = 0
    short_alpha = 0.0
    for ch in champions_data:
        direction = ch.get(chr(100)+chr(105)+chr(114)+chr(101)+chr(99)+chr(116)+chr(105)+chr(111)+chr(110), chr(108)+chr(111)+chr(110)+chr(103))
        trades = ch.get(chr(116)+chr(114)+chr(97)+chr(100)+chr(101)+chr(115), 0) or 0
        cagr = ch.get(chr(99)+chr(97)+chr(103)+chr(114), 0) or 0
        total_trades += trades
        if direction == chr(115)+chr(104)+chr(111)+chr(114)+chr(116):
            short_alpha += cagr * trades * SHORT_BOOST_PCT
    return round(short_alpha / total_trades, 4) if total_trades > 0 else 0.0


def _regen_snapshot():
    """Regenera port_snapshot.json desde los JSONs frescos en /opt/sigma/models.
    Replica el formato escrito por dashboard.py:_write_snapshot pero usando
    SOLO los champions actuales en disco. Si dashboard escribe despues, sobreescribe.
    """
    models_dir = BASE / 'models'
    if not models_dir.exists():
        return False
    champions = {}
    cagrs, wrs, dds, pfs, trades = [], [], [], [], 0
    n_grade_a = 0
    # Por slot (asset|tf) elegir el de mayor CAGR OOS y derivar direction del strategy name
    by_slot = {}
    for tf_dir in models_dir.iterdir():
        if not tf_dir.is_dir() or tf_dir.name == 'archive':
            continue
        tf = tf_dir.name
        for jf in tf_dir.glob('*.json'):
            try:
                d = json.loads(jf.read_text())
            except Exception:
                continue
            sym = (d.get('symbol') or '').replace('/USDT', '').upper()
            strat = d.get('strategy') or jf.stem.split('_', 1)[-1]
            if not sym or not strat: continue  # 2026-05-19: skip JSONs con symbol/strategy vacíos
            m = d.get('metrics_oos') or {}
            cagr = float(m.get('cagr', 0) or 0)
            score = _canonical_score(d)
            # 2026-05-19: ranking (robustness_rank, score) — preferir validados antes que overfit high-score
            try:
                from utils.robustness import robustness_score as _ws_rs
                _rb_action = _ws_rs(d).get('action', '?')
                _rank = {'PASS_LIVE': 3, 'PAPER_ONLY': 2, 'BLOCKED': 1}.get(_rb_action, 0)
            except Exception:
                _rank = 0
            this_rank = (_rank, score)
            key = f'{sym}|{tf}'
            prev = by_slot.get(key)
            if prev is None or this_rank > prev[0]:
                direction = 'short' if strat in SHORT_STRATEGIES else 'long'
                by_slot[key] = (this_rank, cagr, strat, direction, m)
    trades_per_slot = []  # 2026-05-14: añadido para weighted average
    for key, (_rank, cagr, strat, direction, m) in by_slot.items():
        champions[key] = f'{strat}|{direction}'
        slot_trades = int(m.get('trades', 0) or 0)
        cagrs.append(cagr)
        wrs.append(float(m.get('wr', 0) or 0))
        dds.append(float(m.get('dd', 0) or 0))
        pfs.append(float(m.get('pf', 0) or 0))
        trades_per_slot.append(slot_trades)
        trades += slot_trades
        # grado A: CAGR/|DD| >= 0.55 aprox (heuristica simple para mantener n_grade_a)
        if cagr >= 25:
            n_grade_a += 1
    if not champions:
        return False
    n = len(cagrs)
    # 2026-05-14: weighted average por trades — sincroniza con dashboard.py
    weights = [max(t, 1) for t in trades_per_slot]
    total_w = sum(weights)
    if total_w > 0:
        port_cagr = sum(c * w for c, w in zip(cagrs, weights)) / total_w
        port_wr   = sum(w_ * w for w_, w in zip(wrs, weights)) / total_w
        port_dd   = sum(d * w for d, w in zip(dds, weights)) / total_w
        port_pf   = sum(p * w for p, w in zip(pfs, weights)) / total_w if any(p > 0 for p in pfs) else 0
    else:
        port_cagr = sum(cagrs) / n
        port_wr = sum(wrs) / n
        port_dd = sum(dds) / n
        port_pf = sum(pfs) / n
    port_calmar = (port_cagr / abs(port_dd)) if port_dd < 0 else 0
    # Calcular funding Kelly boost
    try:
        _ch_list = []
        for _key, _val in champions.items():
            if '|' in _val:
                _s, _d = _val.split('|', 1)
                _sym, _tf = _key.split('|')
                _ch_list.append({'direction': _d, 'cagr': by_slot[_key][1], 'trades': int(_val and 0)})
        # Mejor: usar trades_per_slot que ya calculamos
        _ch_list2 = []
        for i, (slot, val) in enumerate(champions.items()):
            if '|' in val and i < len(trades_per_slot):
                _, _d = val.split('|', 1)
                _ch_list2.append({'direction': _d, 'cagr': cagrs[i], 'trades': trades_per_slot[i]})
        _kelly_boost = _funding_kelly_boost_estimate(_ch_list2)
    except Exception:
        _kelly_boost = 0.0
    # 2026-05-14: el watcher NO es autoridad de port_cagr / n_grade_a.
    # Si ya existe snapshot del dashboard, PRESERVAMOS sus agregados y
    # solo refrescamos champions + trigger + snapshot_at.
    # Sin esto, watcher y dashboard pisaban con valores distintos (flicker).
    existing = {}
    try:
        if SNAPSHOT_PATH.exists():
            existing = json.loads(SNAPSHOT_PATH.read_text()) or {}
    except Exception:
        existing = {}
    snap = dict(existing)
    snap['champions'] = champions
    snap['snapshot_at'] = datetime.now(timezone.utc).replace(tzinfo=None).isoformat() + 'Z'
    snap['trigger'] = 'champion_watcher refresh'
    if not existing:
        snap.update({
            'port_cagr': port_cagr,
            'port_cagr_kelly_boost': _kelly_boost,
            'port_cagr_with_kelly': round(port_cagr + _kelly_boost, 4),
            'port_wr': port_wr,
            'port_dd': port_dd,
            'port_pf': round(port_pf, 2),
            'port_calmar': round(port_calmar, 2),
            'total_trades': trades,
            'n_grade_a': n_grade_a,
        })
    try:
        SNAPSHOT_PATH.parent.mkdir(parents=True, exist_ok=True)
        SNAPSHOT_PATH.write_text(json.dumps(snap, indent=2))
        return True
    except Exception as e:
        log(f'_regen_snapshot write error: {e}')
        return False


def main():
    # Regenerar snapshot desde JSONs frescos antes de comparar (dashboard.py es on-demand)
    try:
        if _regen_snapshot():
            log('snapshot regenerated from disk')
    except Exception as e:
        log(f'regen error: {e}')
    if not SNAPSHOT_PATH.exists():
        log('No snapshot yet — skip')
        return

    try:
        snap = json.loads(SNAPSHOT_PATH.read_text())
    except Exception as e:
        log(f'snap read error: {e}')
        return

    current = snap.get('champions', {})
    if not current:
        log('Empty champions in snapshot')
        return

    # Leer último estado notificado
    first_run = not NOTIFIED_PATH.exists()
    last = {}
    if not first_run:
        try:
            last = json.loads(NOTIFIED_PATH.read_text()).get('champions', {})
        except Exception:
            pass

    # FIRST RUN: solo guardar baseline, no mandar nada
    if first_run:
        NOTIFIED_PATH.write_text(json.dumps({
            'champions': current,
            'baseline_set_at': datetime.now().isoformat(),
        }, indent=2))
        log(f'Baseline inicial guardado: {len(current)} slots. No se manda nada.')
        return

    # Detectar cambios
    fresh_discoveries = []  # estrategia del UNIVERSO NUEVO (agregadas 2026-05-14)
    discoveries = []        # estrategia avanzada (no en ORIGINAL_9 ni en NEW_2026_05_14)
    rotations = []          # estrategia clásica reemplaza a otra clásica
    new_slots = []          # 2026-05-19: slot que era GAP se lleno (any strategy)
    for slot, strat_dir in current.items():
        old = last.get(slot)
        if old == strat_dir:
            continue  # sin cambio
        strat_new = str(strat_dir).split('|')[0] if '|' in str(strat_dir) else strat_dir
        strat_old = str(old).split('|')[0] if old and '|' in str(old) else (old or 'nuevo')
        if old is None:
            # 2026-05-19: slot que era GAP ahora tiene champion -> notificar SIEMPRE
            new_slots.append((slot, strat_new))
        elif strat_new in NEW_2026_05_14:
            fresh_discoveries.append((slot, strat_old, strat_new))
        elif strat_new not in ORIGINAL_9:
            discoveries.append((slot, strat_old, strat_new))
        else:
            rotations.append((slot, strat_old, strat_new))

    # Si NO hay cambios, no mandar nada (importante para evitar spam)
    if not fresh_discoveries and not discoveries and not rotations and not new_slots:
        log(f'Sin cambios ({len(current)} slots tracked) — no message')
        return

    # UN solo mensaje consolidado
    lines = []
    if fresh_discoveries:
        lines.append('🆕 <b>CAMPEONES DEL NUEVO UNIVERSO (14-05)</b>')
        lines.append('<i>Una de las 23 estrategias agregadas hoy se posicionó como champion.</i>')
        lines.append('')
        for slot, old, new in fresh_discoveries:
            lines.append(f'  🔥 <b>{slot}</b>: {old} → <b>{new}</b>')
    if discoveries:
        if lines:
            lines.append('')
        lines.append('🎉 <b>NUEVOS CAMPEONES — universo expandido (legacy)</b>')
        lines.append('')
        for slot, old, new in discoveries:
            lines.append(f'  • <b>{slot}</b>: {old} → <b>{new}</b>')
    if rotations:
        if lines:
            lines.append('')
        lines.append('🔄 <b>Rotación de estrategias clásicas</b>')
        lines.append('')
        for slot, old, new in rotations:
            lines.append(f'  • <b>{slot}</b>: {old} → <b>{new}</b>')
    # 2026-05-19: slots que eran GAP se llenaron
    if new_slots:
        if lines:
            lines.append('')
        lines.append('🆕 <b>SLOTS GAP llenados (cobertura nueva)</b>')
        lines.append('')
        for slot, new in new_slots:
            lines.append(f'  • <b>{slot}</b>: ahora con <b>{new}</b>')
    lines.append('')
    msg = '\n'.join(lines)

    if SEED_ONLY:
        # Modo seed: NO mandar Telegram, solo sincronizar notified contra snapshot regenerado
        log(f'[seed-only] Skipping Telegram. {len(discoveries)} discoveries + {len(rotations)} rotations detected.')
        for slot, old, new in discoveries:
            log(f'[seed-only] discovery {slot}: {old} -> {new}')
        for slot, old, new in rotations:
            log(f'[seed-only] rotation {slot}: {old} -> {new}')
        NOTIFIED_PATH.write_text(json.dumps({
            'champions': current,
            'seeded_at': datetime.now().isoformat(),
            'seed_changes_summary': {
                'discoveries': len(discoveries),
                'rotations': len(rotations),
            },
        }, indent=2))
        log('[seed-only] champion_notified.json sincronizado con snapshot actual.')
        return

    # 2026-05-14: propagacion DESACOPLADA del Telegram.
    # Matrix/Pine deben reflejar el snapshot real aunque TG falle.
    # NOTIFIED_PATH solo se actualiza si TG OK (asi el reintento sigue vivo).
    send_ok = send_telegram(msg)
    if send_ok:
        log(f'Notified: {len(fresh_discoveries)} fresh + {len(discoveries)} discoveries + {len(rotations)} rotations en 1 mensaje')
    else:
        log('Send Telegram FALLO - sigo con regen dashboard/Pine. NOTIFIED_PATH NO se actualiza (reintento proximo run).')

    import subprocess as _sp
    try:
        _sp.run(['/opt/sigma_env/bin/python', '/opt/sigma/engine/live/dashboard.py'],
                timeout=60, capture_output=True)
        log('dashboard.html regenerated')
    except Exception as _e_d:
        log(f'dashboard regen error: {_e_d}')
    try:
        _sp.run(['/opt/sigma_env/bin/python', '/opt/sigma/engine/live/generate_pine_params.py'],
                timeout=60, capture_output=True)
        log('Pine regenerated')
    except Exception as _e_p:
        log(f'Pine regen error: {_e_p}')

    if send_ok:
        NOTIFIED_PATH.write_text(json.dumps({
            'champions': current,
            'last_notified_at': datetime.now().isoformat(),
            'changes_summary': {
                'fresh_discoveries': len(fresh_discoveries),
                'discoveries': len(discoveries),
                'rotations': len(rotations),
            },
        }, indent=2))


if __name__ == '__main__':
    main()
