# SIGMA ENGINE — .gitignore
# Binarios grandes
ibkr/gateway/jars/
ibkr/gateway/*.jar
*.jar
*.war
*.zip
*.tar.gz
*.tar.bz2

# Datos y modelos (se respaldan por separado en /backups)
models/data_*.csv
models/*.db
models/*.pkl
models/*.h5
*.db
*.sqlite
*.sqlite3
results/lsr.db

# Logs grandes
results/reports/*.log
ibkr/logs/*.log

# Python
__pycache__/
*.pyc
*.pyo
.venv/
sigma_env/

# Temporales
*.tmp
*.bak
*.bak.*
*.bak_*
.DS_Store

# Secrets -- nunca versionar (incidente 2026-06-24: API keys reales expuestas en historial)
engine/config/secrets.json
*.env
.env

# SQLite WAL/SHM -- mutan en sitio (no atomico) mientras Optuna entrena 24/7,
# causaban 'fatal: confused by unstable object source data' en git add -A
# del backup nocturno (4 de las ultimas 6 noches fallo 3/3 reintentos).
# El .db principal si se versiona, estos son solo el log de WAL en curso.
*.db-shm
*.db-wal
*.db-journal

# DBs cuarentenadas/corruptas — jamas al repo (6.4GB rechazado por GitHub 2026-07-02)
*.corrupted
*.db.corrupted
