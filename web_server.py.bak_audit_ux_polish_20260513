_AUTH_FILE = Path('/opt/sigma/engine/config/dashboard_auth.txt')

def _read_auth_config():
    """Lee password y cookie secret del archivo (re-lee en cada request — permite rotar sin restart)."""
    pwd, secret = '0808', 'fallback-secret-change-me'
    try:
        for line in _AUTH_FILE.read_text(encoding='utf-8').splitlines():
            if line.startswith('PASSWORD='):
                pwd = line.split('=',1)[1].strip()
            elif line.startswith('COOKIE_SECRET='):
                secret = line.split('=',1)[1].strip()
    except Exception:
        pass
    return pwd, secret

def _auth_token(secret):
    """Token simple: HMAC del secret. Si el secret cambia, todas las cookies se invalidan."""
    import hmac, hashlib
    return hmac.new(secret.encode(), b'sigma-dashboard', hashlib.sha256).hexdigest()[:32]

def _parse_cookies(header_value):
    out = {}
    if not header_value: return out
    for kv in header_value.split(';'):
        if '=' in kv:
            k, v = kv.split('=', 1)
            out[k.strip()] = v.strip()
    return out

def _is_authenticated(handler):
    """Devuelve True si el request está autenticado.
    Bypass localhost SOLO si no hay headers de proxy (X-Forwarded-For/X-Real-IP).
    Esto previene que nginx reverse proxy bypassee la auth."""
    client_ip = handler.client_address[0]
    has_proxy_header = bool(
        handler.headers.get('X-Forwarded-For') or
        handler.headers.get('X-Real-IP') or
        handler.headers.get('Forwarded')
    )
    # Bypass solo procesos sigma internos (mismo host, sin proxy)
    if client_ip in ('127.0.0.1', '::1', 'localhost') and not has_proxy_header:
        return True
    # Resto: verificar cookie firmada
    cookies = _parse_cookies(handler.headers.get('Cookie', ''))
    token = cookies.get('sigma_auth')
    if not token:
        return False
    _, secret = _read_auth_config()
    return token == _auth_token(secret)

