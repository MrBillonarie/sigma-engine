            # Buscar señales activas con slot asignado que NO tienen trade abierto
            open_keys = set()
            for t in open_trades.values():
                if t.get('status') == 'open':
                    open_keys.add(f"{t['sym']}_{t['tf']}")

            # ── PER-MODEL paper trading: abre TODO lo que tenga signal=True ─────
            # Sin restriccion de slots, CB, regime. Independiente del macro.
            # Skip si has_open_trade — los datos SL/TP estan contaminados (trailed).
            # Per-model se iniciara con datos limpios en el proximo ciclo de signal.
            for sig in _signals_cache.get('models', []):
                if not sig.get('signal'): continue
                if sig.get('has_open_trade'): continue  # evitar SL trailed
                if sig.get('recommendation') not in ('ACTIVAR', 'CONDICIONAL'): continue
                sl_b = sig.get('sl', 0); tp_b = sig.get('tp', 0); bar_p = sig.get('price', 0)
                if not (sl_b and tp_b and bar_p): continue
                try:
                    open_trade_per_model(
                        sig['sym'], sig['tf'], sig.get('strategy', '?'),
                        sig.get('type', 'long'), bar_p, sl_b, tp_b,
                        kelly_pct=float(sig.get('eff_risk_pct') or 5.0)
                    )
                except Exception as _e_pm:
                    print(f'[PER_MODEL OPEN ERROR] {_e_pm}', flush=True)

            # ── MACRO paper trading: maximo 3 slots, todos los filtros ─────────
            for sig in _signals_cache.get('models', []):
                if open_count >= max_slots: break
                if not sig.get('signal'): continue
                if sig.get('slot', 0) <= 0: continue
                if sig.get('recommendation') not in ('ACTIVAR',): continue

                key = f"{sig['sym']}_{sig['tf']}"
                if key in open_keys: continue  # ya tiene trade abierto
                if is_blocked(sig['sym'], sig['tf']): continue

                # BEAR slot 2: requiere CAGR >= 20%
                if regime == 'BEAR' and open_count >= 1 and sig.get('cagr', 0) < 20:
                    continue

                # Obtener precio live
                try:
                    url3 = f"https://fapi.binance.com/fapi/v1/ticker/price?symbol={sig['sym']}USDT"
                    lp   = float(_jw2.loads(_ur2.urlopen(url3, timeout=5).read())['price'])
                except:
