//@version=5
// ════════════════════════════════════════════════════════════════════
//  SIGMA ENGINE — ETH/USDT 1H — BREAKOUT
//  Generado automáticamente por SIGMA Optimizer
// ════════════════════════════════════════════════════════════════════
//  MÉTRICAS OOS (1.6 años out-of-sample):
//    CAGR:       +13.0% (×2 leverage ≈ +26.0%)
//    WR:         69.2%
//    Max DD:     -2.2% (×2 leverage ≈ -4.4%)
//    Profit F:   5.67
//    Trades/año: 7.5
//    RR ratio:   1.41:1
//    Confianza:  MC 98%
//    Grade:      C
//  Risk:         4.9% por trade | Optimizado: 2026-05-10
// ════════════════════════════════════════════════════════════════════
indicator(title="SIGMA ETH 1H breakout", shorttitle="ΣETH1H", overlay=true, max_bars_back=500)

// ══════════════════ PARÁMETROS ═══════════════════════════════════════
sl_mult    = input.float(1.7,  "SL Multiplier (ATR)", step=0.1, minval=0.5)
tp_mult    = input.float(2.4,  "TP Multiplier (ATR)", step=0.1, minval=0.5)
cooldown   = input.int(8,      "Cooldown (barras)", minval=1)
rsi_w_thr  = input.int(62,   "RSI Semanal umbral", minval=20, maxval=80)
lookback   = input.int(31,      "Lookback (barras)",  minval=5)
vol_mult   = input.float(3.4000000000000004,    "Volume Multiplier",  step=0.1)
tma_period = input.int(14,     "TMA Period",         minval=5)
atr_mult   = input.float(1.5,    "ATR Band Mult",      step=0.1)
ema_type   = input.int(21,      "EMA Period",         minval=5)
rsi_entry  = input.int(45,     "RSI Entry",          minval=20, maxval=70)
rsi_os     = input.int(35,     "RSI Oversold",       minval=15, maxval=50)
rsi_max    = input.int(70,     "RSI Max Long",       minval=50, maxval=85)
rsi_min    = input.int(40,    "RSI Min Short",      minval=30, maxval=70)
risk_pct   = input.float(4.9,  "Risk % por trade",   step=0.1)
show_hud   = input.bool(true,     "Mostrar HUD")

// ══════════════════ INDICADORES ══════════════════════════════════════
atr        = ta.atr(14)
ema200     = ta.ema(close, 200)
vol_ma     = ta.sma(volume, 20)
vol_ok     = volume > vol_ma * vol_mult

// RSI Semanal (régimen de mercado)
rsi_w_raw  = request.security(syminfo.tickerid, "W", ta.rsi(close, 14))
rsi_w      = ta.valuewhen(not na(rsi_w_raw), rsi_w_raw, 0)

// Régimen
regime_bull  = rsi_w >= rsi_w_thr and close > ema200
regime_bear  = rsi_w < 45 or close < ema200 * 0.97
regime_range = not regime_bull and not regime_bear
regime_ok_long  = regime_bull or regime_range
regime_ok_short = regime_bear or regime_range

// Cooldown
var int last_sig = -cooldown - 1
bar_dist = bar_index - last_sig

// ── BREAKOUT LONG ─────────────────────────────────────────────────
prev_high   = ta.highest(high, lookback)[1]
raw_signal  = close > prev_high and vol_ok and regime_ok_long and bar_dist >= cooldown
short_signal = false

// Aplicar cooldown
long_signal  = raw_signal   and bar_dist >= cooldown
short_signal_f = short_signal and bar_dist >= cooldown
if long_signal or short_signal_f
    last_sig := bar_index

// ══════════════════ SL / TP ══════════════════════════════════════════
sl_long  = close - atr * sl_mult
tp_long  = close + atr * tp_mult
sl_short = close + atr * sl_mult
tp_short = close - atr * tp_mult

// ══════════════════ VISUALES ══════════════════════════════════════════
bgcolor(regime_bull  ? color.new(color.green,  95) : na, title="Bull")
bgcolor(regime_range ? color.new(color.yellow, 97) : na, title="Range")
bgcolor(regime_bear  ? color.new(color.red,    95) : na, title="Bear")
plot(ema200, "EMA200", color=color.new(color.white, 50), linewidth=2)

plotshape(long_signal,     title="LONG",  location=location.belowbar, color=color.green, style=shape.triangleup,   size=size.normal, text="▲L")
plotshape(short_signal_f,  title="SHORT", location=location.abovebar, color=color.red,   style=shape.triangledown, size=size.normal, text="▼S")

plot(long_signal    ? sl_long  : na, "SL Long",  color=color.red,   style=plot.style_circles, linewidth=2)
plot(long_signal    ? tp_long  : na, "TP Long",  color=color.green, style=plot.style_circles, linewidth=2)
plot(short_signal_f ? sl_short : na, "SL Short", color=color.red,   style=plot.style_circles, linewidth=2)
plot(short_signal_f ? tp_short : na, "TP Short", color=color.green, style=plot.style_circles, linewidth=2)

// ══════════════════ HUD ═══════════════════════════════════════════════
if show_hud
    reg_txt = regime_bull ? "🟢 BULL" : regime_bear ? "🔴 BEAR" : "🟡 RANGE"
    hud_bg  = regime_bull ? color.new(color.green,85) : regime_bear ? color.new(color.red,85) : color.new(color.yellow,90)
    t = table.new(position.top_right, 2, 9, bgcolor=color.new(color.black,75), border_color=color.new(color.gray,50), border_width=1, frame_color=color.gray, frame_width=1)
    table.cell(t, 0, 0, "SIGMA " + syminfo.root + " " + timeframe.period, text_color=color.white, text_size=size.small, colspan=2, bgcolor=color.new(color.navy,60))
    table.cell(t, 0, 1, "Estrategia", text_color=color.gray,   text_size=size.tiny)
    table.cell(t, 1, 1, "breakout",    text_color=color.yellow,  text_size=size.tiny)
    table.cell(t, 0, 2, "Grade",      text_color=color.gray,   text_size=size.tiny)
    table.cell(t, 1, 2, "C — WR 69%", text_color=color.lime, text_size=size.tiny)
    table.cell(t, 0, 3, "OOS CAGR",   text_color=color.gray,   text_size=size.tiny)
    table.cell(t, 1, 3, "+13.0% (1.6y)", text_color=color.yellow, text_size=size.tiny)
    table.cell(t, 0, 4, "Régimen",    text_color=color.gray,   text_size=size.tiny)
    table.cell(t, 1, 4, reg_txt,      text_color=color.white,  text_size=size.tiny, bgcolor=hud_bg)
    table.cell(t, 0, 5, "RSI_W",      text_color=color.gray,   text_size=size.tiny)
    table.cell(t, 1, 5, str.tostring(math.round(rsi_w,1)), text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 6, "RR / Risk",  text_color=color.gray,   text_size=size.tiny)
    table.cell(t, 1, 6, "1.4:1 / " + str.tostring(risk_pct) + "%", text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 7, "Señal",      text_color=color.gray,   text_size=size.tiny)
    act = long_signal ? "▲ LONG" : short_signal_f ? "▼ SHORT" : "— sin señal"
    act_col = long_signal ? color.green : short_signal_f ? color.red : color.gray
    table.cell(t, 1, 7, act, text_color=act_col, text_size=size.tiny)
    table.cell(t, 0, 8, "SL / TP",    text_color=color.gray,   text_size=size.tiny)
    sl_v = long_signal ? sl_long : short_signal_f ? sl_short : close - atr * sl_mult
    tp_v = long_signal ? tp_long : short_signal_f ? tp_short : close + atr * tp_mult
    table.cell(t, 1, 8, str.tostring(math.round(sl_v,2)) + " / " + str.tostring(math.round(tp_v,2)), text_color=color.white, text_size=size.tiny)

// ══════════════════ ALERTAS ══════════════════════════════════════════
alertcondition(long_signal,    "SIGMA ETH 1H LONG",
    "{{ticker}} 1H LONG ▲ | Entry: {{close}} | SL: " + str.tostring(math.round(close-atr*sl_mult,2)) + " | TP: " + str.tostring(math.round(close+atr*tp_mult,2)))
alertcondition(short_signal_f, "SIGMA ETH 1H SHORT",
    "{{ticker}} 1H SHORT ▼ | Entry: {{close}} | SL: " + str.tostring(math.round(close+atr*sl_mult,2)) + " | TP: " + str.tostring(math.round(close-atr*tp_mult,2)))
alertcondition(regime_bull and not regime_bull[1], "SIGMA ETH → BULL", "{{ticker}} cambió a BULL — activar longs")
alertcondition(regime_bear and not regime_bear[1], "SIGMA ETH → BEAR", "{{ticker}} cambió a BEAR — activar shorts")
