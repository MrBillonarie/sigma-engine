//@version=6
// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  SIGMA 15M CASCADE — 4H Bias -> 1H Setup -> 15m Entry                     ║
// ║  TEMPLATE: params pendientes de optimizacion cascade_fast.py               ║
// ║  Logica: SL 15m (0.8xATR) + TP 1H (4xATR) = RR ~13:1                     ║
// ║  Math: WR 50% x RR13 = EV 6R/trade — rentable con 7% WR minimo           ║
// ╚══════════════════════════════════════════════════════════════════════════════╝
strategy("SIGMA 15M CASCADE", overlay=true,
         default_qty_type=strategy.percent_of_equity, default_qty_value=100,
         commission_type=strategy.commission.percent, commission_value=0.04,
         slippage=1, initial_capital=1000, pyramiding=0,
         process_orders_on_close=false, calc_on_every_tick=false)

// ═══════════════════════════════════════════════════════════════════════════════
// INPUTS — ACTUALIZAR CON cascade_fast.py CUANDO TERMINE
// ═══════════════════════════════════════════════════════════════════════════════
sl_mult_15m = input.float(0.8,  "SL x ATR 15m (tight)", group="SL/TP", minval=0.3, maxval=2.0)
tp_mult_1h  = input.float(4.0,  "TP x ATR 1H (wide)",   group="SL/TP", minval=1.5, maxval=8.0)
min_rr_req  = input.float(3.0,  "RR minimo requerido",   group="SL/TP", minval=2.0, maxval=10.0)

window_bars = input.int(16,     "Ventana 1H en barras 15m (16=4h)", group="Cascade", minval=4, maxval=32)
entry_ema   = input.bool(true,  "Entrada: pullback EMA20", group="Cascade")
entry_ob    = input.bool(false, "Entrada: Order Block 15m", group="Cascade")
req_4h      = input.bool(true,  "Requerir alineacion 4H",  group="Cascade")

risk_pct    = input.float(1.5,  "Riesgo % por trade", group="Risk", minval=0.3, maxval=5.0)
capital     = input.float(1000, "Capital ($)",         group="Risk")

// Macro filter (heredado de 1H)
use_macro   = input.bool(true,  "Filtro Macro RSI-W", group="Macro")
rsi_w_thr   = input.int(45,     "Bloquear si RSI-W supera (default 45)", group="Macro", minval=30, maxval=90)

// ═══════════════════════════════════════════════════════════════════════════════
// INDICADORES BASE 15m
// ═══════════════════════════════════════════════════════════════════════════════
atr15   = ta.atr(14)
ema20   = ta.ema(close, 20)
ema50   = ta.ema(close, 50)
ema200  = ta.ema(close, 200)
[ml, sl_m, hist] = ta.macd(close, 12, 26, 9)
rsi15   = ta.rsi(close, 14)
[dp15, dm15, adx15] = ta.dmi(14, 14)

bull15 = ema50 > ema200
bear15 = ema50 < ema200

// ═══════════════════════════════════════════════════════════════════════════════
// HTF: 1H señal proxy (SIGMA EXECUTE en 1H)
// ═══════════════════════════════════════════════════════════════════════════════
[ema50_1h, ema200_1h, atr_1h] = request.security(syminfo.tickerid, "60",
    [ta.ema(close,50), ta.ema(close,200), ta.atr(14)], lookahead=barmerge.lookahead_off)
[ml_1h, sl_1h, hist_1h] = request.security(syminfo.tickerid, "60",
    ta.macd(close,12,26,9), lookahead=barmerge.lookahead_off)
[dp1h, dm1h, adx_1h] = request.security(syminfo.tickerid, "60",
    ta.dmi(14,14), lookahead=barmerge.lookahead_off)
rsi_1h = request.security(syminfo.tickerid, "60",
    ta.rsi(close,14), lookahead=barmerge.lookahead_off)

bull_1h = ema50_1h > ema200_1h
bear_1h = ema50_1h < ema200_1h

// SIGMA 1H signal (EXECUTE + TREND quality)
sig_1h_long  = bull_1h and ml_1h > sl_1h and adx_1h > 20 and rsi_1h < 75
sig_1h_short = bear_1h and ml_1h < sl_1h and adx_1h > 20 and rsi_1h > 25

// Marcar cuando hubo señal 1H en las ultimas N barras
var int bars_since_1h_long  = 9999
var int bars_since_1h_short = 9999
bars_since_1h_long  := sig_1h_long  ? 0 : bars_since_1h_long  + 1
bars_since_1h_short := sig_1h_short ? 0 : bars_since_1h_short + 1

in_1h_long_window  = bars_since_1h_long  <= window_bars
in_1h_short_window = bars_since_1h_short <= window_bars

// ═══════════════════════════════════════════════════════════════════════════════
// HTF: 4H BIAS
// ═══════════════════════════════════════════════════════════════════════════════
[ema50_4h, ema200_4h] = request.security(syminfo.tickerid, "240",
    [ta.ema(close,50), ta.ema(close,200)], lookahead=barmerge.lookahead_off)
bias_4h_bull = ema50_4h > ema200_4h
bias_4h_bear = ema50_4h < ema200_4h

// ═══════════════════════════════════════════════════════════════════════════════
// MACRO FILTER (RSI semanal)
// ═══════════════════════════════════════════════════════════════════════════════
rsi_w = request.security(syminfo.tickerid, "W", ta.rsi(close,14), lookahead=barmerge.lookahead_off)
macro_ok = not use_macro or (rsi_w <= rsi_w_thr)

// ═══════════════════════════════════════════════════════════════════════════════
// ORDER BLOCK 15m (impulso 3 barras atras)
// ═══════════════════════════════════════════════════════════════════════════════
ob_bull_15m = close[3] > open[3] and (high[3]-low[3]) > atr15[3]*1.5
ob_bear_15m = close[3] < open[3] and (high[3]-low[3]) > atr15[3]*1.5

// ═══════════════════════════════════════════════════════════════════════════════
// CONDICION DE ENTRADA 15m (PULLBACK)
// ═══════════════════════════════════════════════════════════════════════════════
// LONG: en ventana 1H long + pullback a EMA20 + vela alcista
pullback_long_ema  = low <= ema20 * 1.003 and close > ema20 and close > open
pullback_short_ema = high >= ema20 * 0.997 and close < ema20 and close < open
pullback_long_ob   = ob_bull_15m and close > open and (close-open)/(high-low+1e-8) > 0.5
pullback_short_ob  = ob_bear_15m and close < open and (open-close)/(high-low+1e-8) > 0.5

pullback_long  = (entry_ema and pullback_long_ema)  or (entry_ob and pullback_long_ob)
pullback_short = (entry_ema and pullback_short_ema) or (entry_ob and pullback_short_ob)

// Filtro 4H
four_h_ok_long  = not req_4h or bias_4h_bull or not bias_4h_bear
four_h_ok_short = not req_4h or bias_4h_bear or not bias_4h_bull

// Calcular RR prospectivo
sl_dist_long  = atr15 * sl_mult_15m
tp_dist_long  = atr_1h * tp_mult_1h
rr_long       = tp_dist_long / math.max(sl_dist_long, 0.0001)
rr_ok_long    = rr_long >= min_rr_req

sl_dist_short = atr15 * sl_mult_15m
tp_dist_short = atr_1h * tp_mult_1h
rr_short      = tp_dist_short / math.max(sl_dist_short, 0.0001)
rr_ok_short   = rr_short >= min_rr_req

// Entrada final
entry_long  = in_1h_long_window  and pullback_long  and four_h_ok_long  and rr_ok_long  and macro_ok
entry_short = in_1h_short_window and pullback_short and four_h_ok_short and rr_ok_short and macro_ok

// ═══════════════════════════════════════════════════════════════════════════════
// GESTION DE POSICION
// ═══════════════════════════════════════════════════════════════════════════════
var float sl_ref = na
var float tp_ref = na

if entry_long and strategy.position_size == 0
    sl_ref := close - atr15 * sl_mult_15m
    tp_ref := close + atr_1h * tp_mult_1h
    strategy.entry("Long", strategy.long)

if entry_short and strategy.position_size == 0
    sl_ref := close + atr15 * sl_mult_15m
    tp_ref := close - atr_1h * tp_mult_1h
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0 and not na(sl_ref)
    strategy.exit("Long_Exit", "Long", stop=sl_ref, limit=tp_ref)

if strategy.position_size < 0 and not na(sl_ref)
    strategy.exit("Short_Exit", "Short", stop=sl_ref, limit=tp_ref)

if strategy.position_size == 0
    sl_ref := na; tp_ref := na

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTAS
// ═══════════════════════════════════════════════════════════════════════════════
sl_pct  = not na(sl_ref) ? math.abs(close - sl_ref) / close * 100 : 0
tp_pct  = not na(tp_ref) ? math.abs(close - tp_ref) / close * 100 : 0
rr_real = sl_pct > 0 ? tp_pct / sl_pct : 0

if entry_long
    _dir  = "LONG"
    _sl   = close - atr15 * sl_mult_15m
    _tp   = close + atr_1h * tp_mult_1h
    _msg  = "CASCADE_15M," + syminfo.ticker + "," + _dir + "," +
            str.tostring(close,"#.##") + "," +
            str.tostring(_sl,"#.##") + "," +
            str.tostring(_tp,"#.##") + "," +
            str.tostring(rr_long,"#.#") + "RR," +
            str.tostring(risk_pct,"#.#") + "%risk"
    alert(_msg, alert.freq_once_per_bar_close)

if entry_short
    _dir  = "SHORT"
    _sl   = close + atr15 * sl_mult_15m
    _tp   = close - atr_1h * tp_mult_1h
    _msg  = "CASCADE_15M," + syminfo.ticker + "," + _dir + "," +
            str.tostring(close,"#.##") + "," +
            str.tostring(_sl,"#.##") + "," +
            str.tostring(_tp,"#.##") + "," +
            str.tostring(rr_short,"#.1") + "RR," +
            str.tostring(risk_pct,"#.#") + "%risk"
    alert(_msg, alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════════════
// VISUALIZACION
// ═══════════════════════════════════════════════════════════════════════════════
plot(ema20,  "EMA20",  color.new(color.cyan,   20), 1)
plot(ema50,  "EMA50",  color.new(color.yellow, 20), 1)
plot(ema200, "EMA200", color.new(color.orange, 20), 2)

// SL/TP activos
plot(strategy.position_size != 0 ? sl_ref : na, "SL",
     color.new(color.red,  0), 2, plot.style_linebr)
plot(strategy.position_size != 0 ? tp_ref : na, "TP",
     color.new(color.lime, 0), 2, plot.style_linebr)

// Ventana activa 1H
bgcolor(in_1h_long_window  and macro_ok ? color.new(color.green, 92) : na)
bgcolor(in_1h_short_window and macro_ok ? color.new(color.red,   92) : na)
bgcolor(not macro_ok ? color.new(color.orange, 94) : na)  // macro block

// Señales
plotshape(entry_long,  "CASCADE LONG",  shape.triangleup,   location.belowbar, color.aqua, size=size.normal)
plotshape(entry_short, "CASCADE SHORT", shape.triangledown, location.abovebar, color.red,  size=size.normal)

// Info table
var table t = table.new(position.top_right, 2, 6, bgcolor=color.new(color.navy,60), border_width=1)
if barstate.islast
    _bias = bias_4h_bull ? "BULL" : bias_4h_bear ? "BEAR" : "RANGE"
    _bias_c = bias_4h_bull ? color.lime : bias_4h_bear ? color.red : color.gray
    _rsi_w_s = str.tostring(math.round(rsi_w))
    _macro_s = macro_ok ? "OK" : "BLOQ RSI-W>" + str.tostring(rsi_w_thr)
    _win_l = in_1h_long_window ? str.tostring(window_bars - bars_since_1h_long) + " bars" : "---"
    _win_s = in_1h_short_window ? str.tostring(window_bars - bars_since_1h_short) + " bars" : "---"

    table.cell(t, 0, 0, "CASCADE 15M", text_color=color.white, bgcolor=color.navy, text_size=size.normal)
    table.cell(t, 1, 0, "1H->15m",  text_color=color.yellow, bgcolor=color.navy, text_size=size.small)
    table.cell(t, 0, 1, "4H Bias",  text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 1, _bias,      text_color=_bias_c, text_size=size.tiny)
    table.cell(t, 0, 2, "1H Window Long",  text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 2, _win_l,            text_color=in_1h_long_window ? color.lime : color.gray, text_size=size.tiny)
    table.cell(t, 0, 3, "1H Window Short", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 3, _win_s,             text_color=in_1h_short_window ? color.red : color.gray, text_size=size.tiny)
    table.cell(t, 0, 4, "Macro RSI-W", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 4, _rsi_w_s + " " + _macro_s, text_color=macro_ok ? color.lime : color.orange, text_size=size.tiny)
    table.cell(t, 0, 5, "RR actual", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 5, str.tostring(rr_long,"#.1") + ":1 L / " + str.tostring(rr_short,"#.1") + ":1 S", text_color=color.white, text_size=size.tiny)
