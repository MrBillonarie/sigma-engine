"""champion_watcher.py — Detecta cambios de campeón en la matriz de modelos y manda UN mensaje
por cambio detectado (sin duplicados).

Flujo:
  - Lee port_snapshot.json (matriz de campeones actuales)
  - Compara con champion_notified.json (último estado notificado)
  - Si hay cambios → 1 mensaje consolidado a Telegram
  - Actualiza champion_notified.json para no repetir

Corre via cron cada 30 min. Si entre runs hay varios cambios, los junta en 1 mensaje.
"""
import json
import sys
import urllib.request
import urllib.parse
from pathlib import Path
from datetime import datetime

BASE = Path('/opt/sigma')
SNAPSHOT_PATH = BASE / 'results' / 'reports' / 'port_snapshot.json'
NOTIFIED_PATH = BASE / 'results' / 'reports' / 'champion_notified.json'
LOG_PATH     = BASE / 'results' / 'reports' / 'champion_watcher.log'
NOTIFIER_PATH = BASE / 'engine' / 'live' / 'telegram_notifier.py'

ORIGINAL_9 = {'breakout', 'pullback', 'tma_bands', 'momentum', 'mean_rev',
              'breakdown', 'pullback_short', 'momentum_short', 'regime_adaptive'}


def log(msg):
    line = f'[{datetime.now().strftime("%Y-%m-%d %H:%M:%S")}] {msg}'
    print(line, flush=True)
    try:
        with open(LOG_PATH, 'a') as f:
            print(line, file=f)
    except Exception:
        pass


def get_telegram_config():
    try:
        text = NOTIFIER_PATH.read_text(encoding='utf-8')
        import re
        m_token = re.search(r"TOKEN\s*=\s*['\"]([^'\"]+)['\"]", text)
        m_chat  = re.search(r"CHAT_ID\s*=\s*['\"]?(-?\d+)['\"]?", text)
        if m_token and m_chat:
            return m_token.group(1), m_chat.group(1)
    except Exception as e:
        log(f'config error: {e}')
    return None, None


def send_telegram(text):
    token, chat_id = get_telegram_config()
    if not token or not chat_id:
        log('No telegram config')
        return False
    try:
        url = f'https://api.telegram.org/bot{token}/sendMessage'
        data = urllib.parse.urlencode({
            'chat_id': chat_id,
            'text': text,
            'parse_mode': 'HTML',
            'disable_web_page_preview': 'true',
        }).encode()
        req = urllib.request.Request(url, data=data)
        urllib.request.urlopen(req, timeout=10)
        return True
    except Exception as e:
        log(f'send error: {e}')
        return False


def main():
    if not SNAPSHOT_PATH.exists():
        log('No snapshot yet — skip')
        return

    try:
        snap = json.loads(SNAPSHOT_PATH.read_text())
    except Exception as e:
        log(f'snap read error: {e}')
        return

    current = snap.get('champions', {})
    if not current:
        log('Empty champions in snapshot')
        return

    # Leer último estado notificado
    first_run = not NOTIFIED_PATH.exists()
    last = {}
    if not first_run:
        try:
            last = json.loads(NOTIFIED_PATH.read_text()).get('champions', {})
        except Exception:
            pass

    # FIRST RUN: solo guardar baseline, no mandar nada
    if first_run:
        NOTIFIED_PATH.write_text(json.dumps({
            'champions': current,
            'baseline_set_at': datetime.now().isoformat(),
        }, indent=2))
        log(f'Baseline inicial guardado: {len(current)} slots. No se manda nada.')
        return

    # Detectar cambios
    discoveries = []   # estrategia NUEVA (no de las 9 originales)
    rotations = []     # estrategia clásica reemplaza a otra clásica
    for slot, strat_dir in current.items():
        old = last.get(slot)
        if old == strat_dir:
            continue  # sin cambio
        strat_new = str(strat_dir).split('|')[0] if '|' in str(strat_dir) else strat_dir
        strat_old = str(old).split('|')[0] if old and '|' in str(old) else (old or 'nuevo')
        if strat_new not in ORIGINAL_9:
            discoveries.append((slot, strat_old, strat_new))
        elif old is not None:
            rotations.append((slot, strat_old, strat_new))

    # Si NO hay cambios, no mandar nada (importante para evitar spam)
    if not discoveries and not rotations:
        log(f'Sin cambios ({len(current)} slots tracked) — no message')
        return

    # UN solo mensaje consolidado
    lines = []
    if discoveries:
        lines.append('🎉 <b>NUEVOS CAMPEONES — del universo expandido</b>')
        lines.append('')
        for slot, old, new in discoveries:
            lines.append(f'  • <b>{slot}</b>: {old} → <b>{new}</b>')
    if rotations:
        if lines:
            lines.append('')
        lines.append('🔄 <b>Rotación de estrategias clásicas</b>')
        lines.append('')
        for slot, old, new in rotations:
            lines.append(f'  • <b>{slot}</b>: {old} → <b>{new}</b>')
    lines.append('')
    msg = '\n'.join(lines)

    if send_telegram(msg):
        log(f'Notified: {len(discoveries)} discoveries + {len(rotations)} rotations en 1 mensaje')
        # Solo guardar el nuevo baseline SI el send fue exitoso
        # (si falla, próximo run reintenta el mismo mensaje)
        NOTIFIED_PATH.write_text(json.dumps({
            'champions': current,
            'last_notified_at': datetime.now().isoformat(),
            'changes_summary': {
                'discoveries': len(discoveries),
                'rotations': len(rotations),
            },
        }, indent=2))
    else:
        log('Send falló — no actualizo NOTIFIED_PATH (reintento próximo run)')


if __name__ == '__main__':
    main()
