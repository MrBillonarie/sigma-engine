# ============================================================================
# 2026-06-07: Limpieza de funciones huerfanas en SIG_FN
# Al renombrar estrategias con sufijo _long/_bull en longs_2026_06_06.py los
# nombres legacy (ema_triple, supertrend, bb_squeeze...) quedaron en SIG_FN pero
# NO en STRATEGIES. optimize_strategy() itera STRATEGIES -> SIG_FN.get() por lo
# que jamas se invocan, pero generan confusion en conteos y auditorias.
# ============================================================================
_orphan_keys = [k for k in list(SIG_FN.keys()) if k not in STRATEGIES]
for _k in _orphan_keys:
    del SIG_FN[_k]
# SIG_FN ahora == len(STRATEGIES) exactamente

