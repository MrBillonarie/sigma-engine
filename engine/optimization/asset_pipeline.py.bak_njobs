# ── REGIME ADAPTIVE STRATEGY ─────────────────────────────────────────────────
# Una sola estrategia que opera en AMBAS direcciones segun el regimen actual.
# Parametros asimetricos: long y short tienen sl/tp diferentes porque
# los mercados bajistas son mas rapidos y violentos que los alcistas.

def sig_regime_adaptive(df, p):
    """
    Estrategia adaptativa: LONG en bull, SHORT en bear, ambos en range.
    Comparte lookback y vol_mult, pero sl/tp son independientes por direccion.

    En BULL:  breakout hacia arriba (igual que sig_breakout)
    En BEAR:  breakdown hacia abajo (igual que sig_breakdown pero invertido)
    En RANGE: mean reversion en ambas direcciones
    """
    c=df['close']; h=df['high']; l=df['low']; v=df['volume']
    lb   = p['lookback']
    vm   = p['vol_mult']
    cd   = p['cooldown']
    # Parametros ASIMETRICOS — bear es mas rapido
    slm_l = p.get('sl_mult_long',  2.0)  # long SL
    tpm_l = p.get('tp_mult_long',  3.0)  # long TP
    slm_s = p.get('sl_mult_short', 1.8)  # short SL (mas ajustado)
    tpm_s = p.get('tp_mult_short', 2.0)  # short TP (bear mueve rapido)
    rsi_w_bull_thr  = p.get('rsi_w_bull',  55)  # umbral para long
    rsi_w_bear_thr  = p.get('rsi_w_bear',  45)  # umbral para short

    atr       = df['atr']
    prev_high = h.rolling(lb).max().shift(1)
    prev_low  = l.rolling(lb).min().shift(1)
    vol_ok    = v > df['vol_ma'] * vm
    above_200 = c > df['ema200']
    below_200 = c < df['ema200']

    # Long: bull regime
    bull_signal = (c > prev_high) & vol_ok & above_200 & (df['rsi_w'] > rsi_w_bull_thr)

    # Short: bear regime
    bear_signal = (c < prev_low) & vol_ok & below_200 & (df['rsi_w'] < rsi_w_bear_thr)

    # Range: mean reversion ambos lados
    in_range    = df.get('regime_range', pd.Series(False, index=df.index))
    rsi14       = df.get('rsi14', pd.Series(50, index=df.index))
    range_long  = in_range & (rsi14 < 35) & above_200  # oversold en range → long
    range_short = in_range & (rsi14 > 68) & below_200  # overbought en range → short

    bl = bull_signal | range_long
    bs = bear_signal | range_short

    # Aplicar gate de regimen (permite ambas direcciones segun contexto)
    bl_f, bs_f = apply_regime_gate(df, bl, bs)

    # Construir señales con parámetros asimétricos
    sig  = pd.Series(0,   index=df.index)
    sl_s = pd.Series(0.0, index=df.index)
    tp_s = pd.Series(0.0, index=df.index)

    sig[bl_f]  = 1;  sl_s[bl_f]  = c[bl_f]  - atr[bl_f]  * slm_l; tp_s[bl_f]  = c[bl_f]  + atr[bl_f]  * tpm_l
    sig[bs_f]  = -1; sl_s[bs_f]  = c[bs_f]  + atr[bs_f]  * slm_s; tp_s[bs_f]  = c[bs_f]  - atr[bs_f]  * tpm_s

    # Cooldown unificado
    final = pd.Series(0, index=df.index)
    last  = -cd - 1
    for i in range(len(sig)):
        if (i - last) >= cd and sig.iloc[i] != 0:
            final.iloc[i] = sig.iloc[i]; last = i

    return final, sl_s, tp_s


STRATEGIES_ADAPTIVE = ['regime_adaptive']

SIG_FN_ADAPTIVE = {'regime_adaptive': sig_regime_adaptive}


# ── 1M SCALPING STRATEGIES ────────────────────────────────────────────────────
# TP/SL fijos en % del precio (no ATR) para mantener profit/loss controlado
# Con comision 0.08% RT: necesita WR > 52% con RR 2:1 para ser rentable

def _fixed_pct_exits(df, direction_mask, tp_pct, sl_pct, cd):
    """Convierte mascara de entradas en sig/sl/tp usando % fijo.
    Para 1m: bloquea solo en bear duro (RSI_W < 35) — permite operar en range."""
    c = df['close']
    # Filtro bear duro para scalping (menos restrictivo que estrategias de TF mayor)
    not_hard_bear = df.get('rsi_w', pd.Series(50, index=df.index)) > 35
    direction_mask = direction_mask & not_hard_bear
    sig = pd.Series(0, index=df.index)
    sl_s = pd.Series(0.0, index=df.index)
    tp_s = pd.Series(0.0, index=df.index)
    sig[direction_mask] = 1
    sl_s[direction_mask] = c[direction_mask] * (1 - sl_pct / 100)
    tp_s[direction_mask] = c[direction_mask] * (1 + tp_pct / 100)
    # Cooldown
    final = pd.Series(0, index=df.index)
    last = -cd - 1
    for i in range(len(sig)):
        if (i - last) >= cd and sig.iloc[i] == 1:
            final.iloc[i] = 1
            last = i
    return final, sl_s, tp_s


def sig_micro_momentum(df, p):
    """3+ velas consecutivas alcistas + volumen + tendencia."""
    c = df['close']; v = df['volume']
    n   = p.get('consec_bars', 3)
    vm  = p.get('vol_mult', 1.3)
    tp  = p.get('tp_pct', 0.25)
    sl  = p.get('sl_pct', 0.15)
    cd  = p.get('cooldown', 5)
    vol_ma = v.rolling(20).mean()
    # N barras consecutivas positivas
    green = (c > c.shift(1)).astype(int)
    consec = green.rolling(n).sum()
    mask = (consec >= n) & (v > vol_ma * vm) & (c > df['ema200'])
    return _fixed_pct_exits(df, mask, tp, sl, cd)


def sig_session_open(df, p):
    """Momentum en apertura de sesion London (7-9 UTC) o NY (13-15 UTC)."""
    c = df['close']; v = df['volume']
    tp = p.get('tp_pct', 0.25)
    sl = p.get('sl_pct', 0.15)
    cd = p.get('cooldown', 10)
    vm = p.get('vol_mult', 1.5)
    vol_ma = v.rolling(30).mean()
    hour = df.index.hour
    # Primeros 20 minutos de London o NY
    in_session = ((hour == 7) | (hour == 8) | (hour == 13) | (hour == 14))
    momentum_up = (c > c.shift(3)) & (c > c.shift(1))
    mask = in_session & momentum_up & (v > vol_ma * vm) & (c > df['ema200'])
    return _fixed_pct_exits(df, mask, tp, sl, cd)


def sig_vwap_bounce(df, p):
    """Rebote desde VWAP cuando RSI sobreventa en tendencia alcista."""
    c = df['close']; v = df['volume']
    tp = p.get('tp_pct', 0.22)
    sl = p.get('sl_pct', 0.14)
    cd = p.get('cooldown', 8)
    # VWAP diario resampleado a 1m
    vwap_d = (c * v).resample('D').sum() / v.resample('D').sum()
    vwap_1m = vwap_d.reindex(df.index, method='ffill')
    near_vwap = (c >= vwap_1m * 0.998) & (c <= vwap_1m * 1.002)
    above_vwap = c > vwap_1m
    rsi = df.get('rsi14', pd.Series(50, index=df.index))
    oversold = rsi < p.get('rsi_os', 38)
    mask = near_vwap & oversold & (c > df['ema200']) & (df['rsi_w'] > 48)
    return _fixed_pct_exits(df, mask, tp, sl, cd)


def sig_range_scalp(df, p):
    """Compra en banda inferior BB cuando precio en rango (baja volatilidad)."""
    c = df['close']
    tp = p.get('tp_pct', 0.20)
    sl = p.get('sl_pct', 0.13)
    cd = p.get('cooldown', 6)
    n  = p.get('bb_period', 20)
    k  = p.get('bb_k', 1.5)
    sma = c.rolling(n).mean()
    std = c.rolling(n).std()
    lower = sma - std * k
    # Solo operar en rango (ATR bajo)
    atr_ratio = df['atr'] / df['atr'].rolling(100).mean()
    low_vol = atr_ratio < 0.8
    mask = (c <= lower) & low_vol & (c > df['ema200']) & (df['rsi_w'] > 45)
    return _fixed_pct_exits(df, mask, tp, sl, cd)


def sig_tick_follow(df, p):
    """Precio cruza EMA5 hacia arriba con volumen y momentum de corto plazo."""
    c = df['close']; v = df['volume']
    tp = p.get('tp_pct', 0.23)
    sl = p.get('sl_pct', 0.15)
    cd = p.get('cooldown', 7)
    vm = p.get('vol_mult', 1.4)
    vol_ma = v.rolling(20).mean()
    ema5  = c.ewm(span=5, adjust=False).mean()
    ema15 = c.ewm(span=15, adjust=False).mean()
    cross_up = (c > ema5) & (c.shift(1) <= ema5.shift(1))
    trend_ok = ema5 > ema15
    mask = cross_up & trend_ok & (v > vol_ma * vm) & (c > df['ema200']) & (df['rsi_w'] > 47)
    return _fixed_pct_exits(df, mask, tp, sl, cd)


SIG_FN_1M = {
    'micro_momentum': sig_micro_momentum,
    'session_open':   sig_session_open,
    'vwap_bounce':    sig_vwap_bounce,
    'range_scalp':    sig_range_scalp,
    'tick_follow':    sig_tick_follow,
}


# ── BACKTEST + METRICS ────────────────────────────────────────────────────────

def kelly_risk(recent_trades, base_risk, min_r=0.5, max_r=2.0):
    """
    Kelly dinamico basado en los ultimos 20 trades.
    Sube el size en rachas buenas, lo reduce en malas.
    Base_risk = risk_pct del modelo. Retorna multiplicador (0.5x - 2.0x).
    """
    if len(recent_trades) < 10:
        return 1.0
    wins = [t for t in recent_trades if t > 0]
    loss = [t for t in recent_trades if t <= 0]
    if not wins or not loss:
        return 1.0
    wr  = len(wins) / len(recent_trades)
    avg_win  = sum(wins) / len(wins)
    avg_loss = abs(sum(loss) / len(loss))
    if avg_loss == 0:
        return max_r
    rr   = avg_win / avg_loss
    # Formula Kelly fraccionada (1/4 Kelly para seguridad)
    kelly = (wr - (1 - wr) / rr) / 4
    mult  = max(min_r, min(max_r, 1.0 + kelly * 2))
    return mult


if _HAS_NUMBA:
    @_numba.jit(nopython=True, cache=True)
    def _bt_core(c, h, lo, sa, sla, tpa, fr, risk_pct_f, cost_f, capital_f):
        n = len(c)
        max_t = n // 2 + 1
        pnl_out = np.zeros(max_t)
        n_t = 0
        eq = np.zeros(n)
        cap = capital_f; eq[0] = cap
        pos = 0; ep = 0.0; slv = 0.0; tpv = 0.0; sz = 0.0
        rpnl = np.zeros(20); ri = 0; rc = 0
        for i in range(1, n):
            pr = c[i]
            if pos != 0:
                if fr[i] != 0.0:
                    cap -= pos * sz * c[i] * fr[i]
                pnl = 0.0; closed = False
                if pos == 1:
                    if lo[i] <= slv:
                        pnl = sz*(slv-ep) - sz*(ep+slv)*cost_f; closed = True
                    elif h[i] >= tpv:
                        pnl = sz*(tpv-ep) - sz*(ep+tpv)*cost_f; closed = True
                else:
                    if h[i] >= slv:
                        pnl = sz*(ep-slv) - sz*(ep+slv)*cost_f; closed = True
                    elif lo[i] <= tpv:
                        pnl = sz*(ep-tpv) - sz*(ep+tpv)*cost_f; closed = True
                if closed:
                    cap += pnl; pnl_out[n_t] = pnl; n_t += 1
                    rpnl[ri % 20] = pnl; ri += 1
                    if rc < 20: rc += 1
                    pos = 0
            if pos == 0 and sa[i-1] != 0 and sla[i-1] > 0.0 and cap > 50.0:
                rsl = abs(pr - sla[i-1])
                if rsl > 0.0:
                    km = 1.0
                    if rc >= 10:
                        wins = 0; tw = 0.0; tl = 0.0
                        for j in range(rc):
                            p = rpnl[j]
                            if p > 0.0: wins += 1; tw += p
                            else: tl -= p
                        lss = rc - wins
                        if wins > 0 and lss > 0 and tw > 0.0 and tl > 0.0:
                            wr_k = wins / rc
                            rk = wr_k - (1.0-wr_k)*(tl/lss)/(tw/wins)
                            km = max(0.5, min(2.0, rk*2.0+1.0))
                    er = risk_pct_f * km
                    sz = (cap * er / 100.0) / rsl
                    pos = sa[i-1]; ep = pr; slv = sla[i-1]; tpv = tpa[i-1]
            eq[i] = cap
        return pnl_out[:n_t], eq
else:
    _bt_core = None


def backtest(df, sig, sl_s, tp_s, risk_pct, use_kelly=True):
    c=df['close'].to_numpy(); h=df['high'].to_numpy(); lo=df['low'].to_numpy()
    sa=sig.to_numpy(); sla=sl_s.to_numpy(); tpa=tp_s.to_numpy()
    # Funding rate por barra (0.0 si no está disponible)
    fr = df['funding_rate'].to_numpy() if 'funding_rate' in df.columns else np.zeros(len(df))
    COST = COMMISSION + SLIPPAGE  # costo total por lado (comisión + slippage)
    # Numba fast path: 50-100x mas rapido que el loop Python
    if _HAS_NUMBA and _bt_core is not None:
        try:
            _p,_e = _bt_core(c,h,lo,sa,sla,tpa,fr,float(risk_pct),float(COST),float(CAPITAL))
            return pd.DataFrame([{"pnl":float(x)} for x in _p]), pd.Series(_e[:len(df)],index=df.index[:len(_e)])
        except Exception: pass
    cap=CAPITAL; eq=[cap]; pos=0; entry_p=slv=tpv=sz=0.0; trades=[]
    recent_pnl = []
    for i in range(1, len(c)):
        pr=c[i]
        if pos != 0:
            # Funding rate: longs pagan, shorts reciben (pos=1→long, pos=-1→short)
            if fr[i] != 0.0:
                cap -= pos * sz * c[i] * fr[i]
            pnl=0.0; closed=False
            if pos==1:
                if lo[i]<=slv: pnl=sz*(slv-entry_p)-sz*(entry_p+slv)*COST; closed=True
                elif h[i]>=tpv: pnl=sz*(tpv-entry_p)-sz*(entry_p+tpv)*COST; closed=True
            else:
                if h[i]>=slv: pnl=sz*(entry_p-slv)-sz*(entry_p+slv)*COST; closed=True
                elif lo[i]<=tpv: pnl=sz*(entry_p-tpv)-sz*(entry_p+tpv)*COST; closed=True
            if closed:
                cap+=pnl; trades.append({'pnl':pnl,'won':pnl>0})
                recent_pnl.append(pnl)
                if len(recent_pnl) > 20: recent_pnl.pop(0)
                pos=0
        if pos==0 and sa[i-1]!=0 and sla[i-1]>0 and cap>50:
            rsl=abs(pr-sla[i-1])
            if rsl>0:
                kelly_mult = kelly_risk(recent_pnl, risk_pct) if use_kelly else 1.0
                effective_risk = risk_pct * kelly_mult
                sz=(cap*effective_risk/100)/rsl
                pos=int(sa[i-1]); entry_p=pr; slv=sla[i-1]; tpv=tpa[i-1]
        eq.append(cap)
    df_t=pd.DataFrame(trades)
    eq_s=pd.Series(eq[:len(df)], index=df.index[:len(eq)])
    return df_t, eq_s


def metrics(df_t, eq_s, days, min_t=15):
    if df_t.empty or len(df_t) < min_t: return None
    w=df_t[df_t['pnl']>0]; l=df_t[df_t['pnl']<=0]
    wr=len(w)/len(df_t)*100
    pf=w['pnl'].sum()/abs(l['pnl'].sum()) if not l.empty and l['pnl'].sum()!=0 else 999
    peak=eq_s.cummax(); dd=((eq_s-peak)/peak*100).min()
    last=float(eq_s.iloc[-1])
    if last<=0: return None
    cagr=((last/CAPITAL)**(365.25/max(days,1))-1)*100
    if cagr!=cagr: return None
    tpa=len(df_t)/max(days/365.25,0.1)
    return {'trades':len(df_t),'wr':round(wr,1),'cagr':round(cagr,1),
            'dd':round(dd,1),'pf':round(pf,2),'trades_year':round(tpa,1)}


def score(m, min_t=15):
    if m is None: return -9999
    t    = m.get('trades', 0)
    wr   = m.get('wr', m.get('winrate', 0))
    cagr = m.get('cagr', 0)
    dd   = m.get('dd', m.get('max_dd', 0))
    pf   = m.get('pf', m.get('profit_factor', 1))
    ty   = m.get('trades_year', m.get('trades_month', 0) * 12)

    if t < min_t or cagr <= 0: return -9999

    if ty <= 0 and t > 0:
        ty = t * (365.0 / 600)

    if ty < 3: return -9999

    if wr <= 0 and cagr > 0:
        wr = 50.0

    s_cagr = min(cagr, 100) / 100 * 0.35          # cap 100%, peso 35%
    s_cal  = min(cagr / abs(dd) if dd < 0 else 0, 8) / 8 * 0.25  # calmar cap 8, peso 25%
    s_freq = min(ty / 12.0, 1.0) * 0.20           # frecuencia, peso 20%
    s_wr   = min(max(wr / 100 - 0.50, 0) / 0.35, 1.0) * 0.15  # cap WR 85%, peso 15%
    s_pf   = min(pf, 3) / 3 * 0.05                # profit factor, peso 5%
    return round(s_cagr + s_cal + s_freq + s_wr + s_pf, 4)


# ── STRATEGY OPTIMIZER ────────────────────────────────────────────────────────

def build_search_space(trial, strategy):
    # 1m scalping: TP/SL en % fijo, no ATR
    if strategy in ('micro_momentum', 'session_open', 'vwap_bounce', 'range_scalp', 'tick_follow'):
        p = {
            'tp_pct':  trial.suggest_float('tp_pct',  0.15, 0.40, step=0.01),
            'sl_pct':  trial.suggest_float('sl_pct',  0.10, 0.25, step=0.01),
            'cooldown':trial.suggest_int('cooldown',   4, 20),
        }
        if strategy == 'micro_momentum':
            p['consec_bars'] = trial.suggest_int('consec_bars', 2, 5)
            p['vol_mult']    = trial.suggest_float('vol_mult',  1.1, 2.5, step=0.1)
        elif strategy == 'session_open':
            p['vol_mult']    = trial.suggest_float('vol_mult',  1.2, 2.5, step=0.1)
        elif strategy == 'vwap_bounce':
            p['rsi_os']      = trial.suggest_int('rsi_os',  28, 45)
        elif strategy == 'range_scalp':
            p['bb_period']   = trial.suggest_int('bb_period', 15, 30)
            p['bb_k']        = trial.suggest_float('bb_k',    1.0, 2.0, step=0.1)
        elif strategy == 'tick_follow':
            p['vol_mult']    = trial.suggest_float('vol_mult', 1.2, 2.5, step=0.1)
        return p

    base = {
        'sl_mult':   trial.suggest_float('sl_mult',  1.5, 3.5, step=0.1),
        'tp_mult':   trial.suggest_float('tp_mult',  1.5, 4.0, step=0.1),
        'cooldown':  trial.suggest_int('cooldown',   3, 14),
        'rsi_w_thr': trial.suggest_int('rsi_w_thr', 44, 62),
    }
    if strategy == 'breakout':
        base.update({
            'lookback':  trial.suggest_int('lookback',  15, 70),
            'vol_mult':  trial.suggest_float('vol_mult', 1.2, 3.5, step=0.1),
        })
    elif strategy == 'pullback':
        base.update({
            'ema_type':  trial.suggest_categorical('ema_type', [21, 34, 50]),
            'rsi_entry': trial.suggest_int('rsi_entry', 30, 52),
        })
    elif strategy == 'tma_bands':
        base.update({
            'tma_period': trial.suggest_int('tma_period', 10, 28),
            'atr_mult':   trial.suggest_float('atr_mult', 1.0, 2.5, step=0.1),
        })
    elif strategy == 'momentum':
        base.update({
            'vol_mult':  trial.suggest_float('vol_mult', 1.2, 2.5, step=0.1),
            'rsi_max':   trial.suggest_int('rsi_max',   60, 75),
        })
    elif strategy == 'mean_rev':
        base.update({
            'rsi_os': trial.suggest_int('rsi_os', 25, 42),
        })
    # ── SHORT STRATEGIES ───────────────────────────────────────────
    elif strategy == 'breakdown':
        # Short version of breakout — busca rupturas hacia abajo
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 50)  # bear threshold
        base.update({
            'lookback':  trial.suggest_int('lookback',  15, 70),
            'vol_mult':  trial.suggest_float('vol_mult', 1.2, 3.5, step=0.1),
        })
    elif strategy == 'pullback_short':
        # Short: rebote a EMA en tendencia bajista
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 50)
        base.update({
            'ema_type':  trial.suggest_categorical('ema_type', [21, 34, 50]),
            'rsi_entry': trial.suggest_int('rsi_entry', 55, 75),  # overbought for short
        })
    elif strategy == 'momentum_short':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 50)
        base.update({
            'vol_mult':  trial.suggest_float('vol_mult', 1.2, 2.5, step=0.1),
            'rsi_min':   trial.suggest_int('rsi_min',   25, 45),
        })
    elif strategy == 'rsi_overbought_short':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 55)
        base.update({'rsi_top': trial.suggest_int('rsi_top', 65, 80),
                     'vol_mult': trial.suggest_float('vol_mult', 1.0, 2.5, step=0.1)})
    elif strategy == 'death_cross_short':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 55)
    elif strategy == 'ema200_rejection_short':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 55)
        base.update({'touch_tol_pct': trial.suggest_float('touch_tol_pct', 0.2, 1.0, step=0.1),
                     'vol_mult': trial.suggest_float('vol_mult', 1.0, 2.0, step=0.1)})
    elif strategy == 'macd_bear_cross':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 55)
        base.update({'rsi_min': trial.suggest_int('rsi_min', 20, 40)})
    elif strategy == 'lower_high_break_short':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 55)
        base.update({'lookback': trial.suggest_int('lookback', 5, 30),
                     'vol_mult': trial.suggest_float('vol_mult', 1.0, 2.5, step=0.1)})
    elif strategy == 'wedge_breakdown_short':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 55)
        base.update({'lookback': trial.suggest_int('lookback', 8, 30),
                     'low_flat_pct': trial.suggest_float('low_flat_pct', 1.5, 5.0, step=0.5),
                     'vol_mult': trial.suggest_float('vol_mult', 1.0, 2.5, step=0.1)})
    elif strategy == 'supply_zone_rejection':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 35, 60)
        base.update({'lookback': trial.suggest_int('lookback', 20, 100),
                     'zone_tol_pct': trial.suggest_float('zone_tol_pct', 0.3, 2.0, step=0.1),
                     'reject_pct': trial.suggest_float('reject_pct', 0.1, 1.0, step=0.1),
                     'vol_mult': trial.suggest_float('vol_mult', 1.0, 2.0, step=0.1)})
    elif strategy == 'bearish_rsi_divergence':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 35, 60)
        base.update({'lookback': trial.suggest_int('lookback', 5, 20),
                     'rsi_min_div': trial.suggest_int('rsi_min_div', 50, 65)})
    elif strategy == 'volume_climax_top':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 35, 60)
        base.update({'lookback': trial.suggest_int('lookback', 5, 20),
                     'climax_mult': trial.suggest_float('climax_mult', 2.5, 5.0, step=0.25)})
    elif strategy == 'range_break_down':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 55)
        base.update({'lookback': trial.suggest_int('lookback', 10, 30),
                     'atr_compress': trial.suggest_float('atr_compress', 0.5, 0.9, step=0.05),
                     'vol_mult': trial.suggest_float('vol_mult', 1.2, 2.5, step=0.1)})
    elif strategy == 'macd_zero_cross_down':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 55)
        base.update({'rsi_min': trial.suggest_int('rsi_min', 25, 45),
                     'vol_mult': trial.suggest_float('vol_mult', 0.8, 2.0, step=0.1)})
    elif strategy == 'stoch_rsi_short':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 55)
        base.update({'stoch_period': trial.suggest_int('stoch_period', 10, 20),
                     'stoch_thr_short': trial.suggest_int('stoch_thr_short', 70, 85)})
    elif strategy == 'williams_r_short':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 55)
        base.update({'wr_period': trial.suggest_int('wr_period', 10, 21),
                     'wr_thr_short': trial.suggest_int('wr_thr_short', -30, -15)})
    elif strategy == 'cci_reversal_short':
        base['rsi_w_thr'] = trial.suggest_int('rsi_w_thr', 30, 55)
        base.update({'cci_period': trial.suggest_int('cci_period', 14, 30),
                     'cci_thr_short': trial.suggest_int('cci_thr_short', 80, 150)})
    elif strategy == 'engulfing_short':
