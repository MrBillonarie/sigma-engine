# ── SHORT STRATEGIES (bear market) ───────────────────────────────────────────
# Misma logica que long pero invertida: entra cuando el precio CAE con volumen
# Solo activas cuando el activo esta en BEAR segun su propio regimen

def sig_breakdown(df, p):
    """Short: precio rompe minimo de N barras hacia abajo con volumen."""
    c=df['close']; l=df['low']; v=df['volume']
    lb=p['lookback']; vm=p['vol_mult']; slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    prev_low  = l.rolling(lb).min().shift(1)
    vol_ok    = v > df['vol_ma'] * vm
    below_200 = c < df['ema200']
    bear_ok   = df['rsi_w'] < p.get('rsi_w_thr', 45)
    htf_ok    = df.get('htf_bear', pd.Series(True, index=df.index)) | \
                df.get('htf_range', pd.Series(True, index=df.index))
    bs = (c < prev_low) & vol_ok & below_200 & bear_ok & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_pullback_short(df, p):
    """Short: precio rebota a EMA en tendencia bajista (oportunidad de venta)."""
    c=df['close']; slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    ema_t    = p.get('ema_type', 21)
    ema_line = c.ewm(span=ema_t, adjust=False).mean()
    at_ema   = (c >= ema_line * 0.995) & (c <= ema_line * 1.005)
    downtrend= df['ema50'] < df['ema200']
    bear_ok  = df['rsi_w'] < p.get('rsi_w_thr', 45)
    overbought = df['rsi14'] > p.get('rsi_entry', 58)
    htf_ok   = df.get('htf_bear', pd.Series(True, index=df.index)) | \
               df.get('htf_range', pd.Series(True, index=df.index))
    bs = at_ema & downtrend & bear_ok & overbought & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_momentum_short(df, p):
    """Short: MACD histogram negativo y acelerando — momentum bajista."""
    c=df['close']; v=df['volume']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    vm       = p.get('vol_mult', 1.5)
    vol_ok   = v > df['vol_ma'] * vm
    macd_dn  = (df['macd_h'] < 0) & (df['macd_h'] < df['macd_h'].shift(1))
    below_200= c < df['ema200']
    bear_ok  = df['rsi_w'] < p.get('rsi_w_thr', 45)
    not_ob   = df['rsi14'] > p.get('rsi_min', 30)  # no sobrevendido extremo
    htf_ok   = df.get('htf_bear', pd.Series(True, index=df.index)) | \
               df.get('htf_range', pd.Series(True, index=df.index))
    bs = macd_dn & below_200 & bear_ok & not_ob & vol_ok & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)



def sig_rsi_overbought_short(df, p):
    """Short: RSI14 cruza desde sobrecomprado (>=70) hacia abajo."""
    c=df['close']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    rsi_top = p.get('rsi_top', 70)
    rsi_cross = (df['rsi14'].shift(1) >= rsi_top) & (df['rsi14'] < rsi_top)
    below_50  = c < df['ema50']
    bear_ok   = df['rsi_w'] < p.get('rsi_w_thr', 50)
    vol_ok    = df['volume'] > df['vol_ma'] * p.get('vol_mult', 1.2)
    htf_ok    = df.get('htf_bear', pd.Series(True, index=df.index)) | \
                df.get('htf_range', pd.Series(True, index=df.index))
    bs = rsi_cross & below_50 & bear_ok & vol_ok & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_death_cross_short(df, p):
    """Short: EMA50 cruza por debajo de EMA200 (death cross)."""
    c=df['close']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    cross_dn  = (df['ema50'].shift(1) >= df['ema200'].shift(1)) & (df['ema50'] < df['ema200'])
    below_200 = c < df['ema200']
    bear_ok   = df['rsi_w'] < p.get('rsi_w_thr', 50)
    macd_dn   = df['macd_h'] < 0
    htf_ok    = df.get('htf_bear', pd.Series(True, index=df.index)) | \
                df.get('htf_range', pd.Series(True, index=df.index))
    bs = cross_dn & below_200 & bear_ok & macd_dn & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_ema200_rejection_short(df, p):
    """Short: precio toca EMA200 desde abajo y rechaza."""
    c=df['close']; h=df['high']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    tol = p.get('touch_tol_pct', 0.5) / 100
    touched    = (h >= df['ema200'] * (1 - tol)) & (h <= df['ema200'] * (1 + tol))
    rejected   = c < df['ema200']
    prev_below = df['close'].shift(1) < df['ema200'].shift(1)
    bear_ok    = df['rsi_w'] < p.get('rsi_w_thr', 50)
    vol_ok     = df['volume'] > df['vol_ma'] * p.get('vol_mult', 1.1)
    htf_ok     = df.get('htf_bear', pd.Series(True, index=df.index)) | \
                 df.get('htf_range', pd.Series(True, index=df.index))
    bs = touched & rejected & prev_below & bear_ok & vol_ok & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_macd_bear_cross(df, p):
    """Short: MACD cruza por debajo de signal line con histogram negativo."""
    c=df['close']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    cross_dn  = (df['macd'].shift(1) >= df['macd_s'].shift(1)) & (df['macd'] < df['macd_s'])
    hist_neg  = df['macd_h'] < 0
    below_200 = c < df['ema200']
    bear_ok   = df['rsi_w'] < p.get('rsi_w_thr', 50)
    not_os    = df['rsi14'] > p.get('rsi_min', 25)
    htf_ok    = df.get('htf_bear', pd.Series(True, index=df.index)) | \
                df.get('htf_range', pd.Series(True, index=df.index))
    bs = cross_dn & hist_neg & below_200 & bear_ok & not_os & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_lower_high_break_short(df, p):
    """Short: rompe debajo del valle entre dos lower highs consecutivos."""
    c=df['close']; h=df['high']; l=df['low']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    lb = p['lookback']
    high_prev = h.rolling(lb).max().shift(lb)
    high_curr = h.rolling(lb).max()
    lh = high_curr < high_prev
    valley = l.rolling(lb).min()
    break_dn = c < valley.shift(1)
    bear_ok = df['rsi_w'] < p.get('rsi_w_thr', 50)
    below_200 = c < df['ema200']
    vol_ok = df['volume'] > df['vol_ma'] * p.get('vol_mult', 1.3)
    htf_ok = df.get('htf_bear', pd.Series(True, index=df.index)) | \
             df.get('htf_range', pd.Series(True, index=df.index))
    bs = lh & break_dn & below_200 & bear_ok & vol_ok & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_wedge_breakdown_short(df, p):
    """Short: cuña descendente — highs bajando + ruptura de soporte."""
    c=df['close']; h=df['high']; l=df['low']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    lb = p['lookback']
    high_slope = (h.rolling(lb).max() - h.rolling(lb).max().shift(lb)) < 0
    low_range  = (l.rolling(lb).max() - l.rolling(lb).min()) / c < p.get('low_flat_pct', 3.0) / 100
    support    = l.rolling(lb).min()
    break_dn   = c < support.shift(1)
    bear_ok    = df['rsi_w'] < p.get('rsi_w_thr', 50)
    vol_ok     = df['volume'] > df['vol_ma'] * p.get('vol_mult', 1.2)
    htf_ok     = df.get('htf_bear', pd.Series(True, index=df.index)) | \
                 df.get('htf_range', pd.Series(True, index=df.index))
    bs = high_slope & low_range & break_dn & bear_ok & vol_ok & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_supply_zone_rejection(df, p):
    """Short: precio retesta máximo histórico de N barras atrás y rechaza."""
    c=df['close']; h=df['high']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    lb_supply = p['lookback']
    tol = p.get('zone_tol_pct', 1.0) / 100
    supply = h.rolling(lb_supply).max().shift(lb_supply)
    touched = (h >= supply * (1 - tol)) & (h <= supply * (1 + tol))
    rejected = c < h * (1 - p.get('reject_pct', 0.3) / 100)
    bear_ok = df['rsi_w'] < p.get('rsi_w_thr', 55)
    vol_ok = df['volume'] > df['vol_ma'] * p.get('vol_mult', 1.2)
    htf_ok = df.get('htf_bear', pd.Series(True, index=df.index)) | \
             df.get('htf_range', pd.Series(True, index=df.index))
    bs = touched & rejected & bear_ok & vol_ok & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_bearish_rsi_divergence(df, p):
    """Short: precio hace HH pero RSI hace LH (divergencia bajista)."""
    c=df['close']; h=df['high']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    lb = p['lookback']
    price_hh = h > h.rolling(lb).max().shift(1)
    rsi_lh = df['rsi14'] < df['rsi14'].rolling(lb).max().shift(1)
    rsi_high = df['rsi14'] > p.get('rsi_min_div', 55)
    bear_ok = df['rsi_w'] < p.get('rsi_w_thr', 55)
    htf_ok = df.get('htf_bear', pd.Series(True, index=df.index)) | \
             df.get('htf_range', pd.Series(True, index=df.index))
    bs = price_hh & rsi_lh & rsi_high & bear_ok & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_volume_climax_top(df, p):
    """Short: vela alcista con volumen extremo en máximo local (capitulación)."""
    c=df['close']; h=df['high']; o=df['open']; v=df['volume']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    lb = p['lookback']
    climax_mult = p.get('climax_mult', 3.0)
    is_local_max = h == h.rolling(lb*2+1, center=False).max()
    bull_candle = c > o
    vol_climax = v > df['vol_ma'] * climax_mult
    climax_prev = (is_local_max & bull_candle & vol_climax).shift(1).fillna(False)
    bear_followup = c < o
    bear_ok = df['rsi_w'] < p.get('rsi_w_thr', 55)
    htf_ok = df.get('htf_bear', pd.Series(True, index=df.index)) | \
             df.get('htf_range', pd.Series(True, index=df.index))
    bs = climax_prev & bear_followup & bear_ok & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_range_break_down(df, p):
    """Short: rango estrecho (vol baja) + ruptura bajista con volumen."""
    c=df['close']; l=df['low']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    lb = p['lookback']
    atr_pct = df['atr'] / c
    atr_low = atr_pct < atr_pct.rolling(lb*2).mean() * p.get('atr_compress', 0.7)
    support = l.rolling(lb).min()
    break_dn = c < support.shift(1)
    bear_ok = df['rsi_w'] < p.get('rsi_w_thr', 50)
    vol_ok = df['volume'] > df['vol_ma'] * p.get('vol_mult', 1.5)
    below_200 = c < df['ema200']
    htf_ok = df.get('htf_bear', pd.Series(True, index=df.index)) | \
             df.get('htf_range', pd.Series(True, index=df.index))
    bs = atr_low.shift(1).fillna(False) & break_dn & bear_ok & vol_ok & below_200 & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_macd_zero_cross_down(df, p):
    """Short: MACD cruza desde arriba a debajo de cero (cambio momentum macro)."""
    c=df['close']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    cross_zero = (df['macd'].shift(1) >= 0) & (df['macd'] < 0)
    hist_neg = df['macd_h'] < 0
    below_200 = c < df['ema200']
    bear_ok = df['rsi_w'] < p.get('rsi_w_thr', 50)
    not_os = df['rsi14'] > p.get('rsi_min', 28)
    vol_ok = df['volume'] > df['vol_ma'] * p.get('vol_mult', 1.0)
    htf_ok = df.get('htf_bear', pd.Series(True, index=df.index)) | \
             df.get('htf_range', pd.Series(True, index=df.index))
    bs = cross_zero & hist_neg & below_200 & bear_ok & not_os & vol_ok & htf_ok
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)



def sig_stoch_rsi_short(df, p):
    """Short: Stoch-RSI cruza desde >=80 hacia abajo (overbought reversion)."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    rsi = df["rsi14"]; period = int(p.get("stoch_period", 14))
    stoch = ((rsi - rsi.rolling(period).min()) / (rsi.rolling(period).max() - rsi.rolling(period).min() + 1e-9)) * 100
    thr = p.get("stoch_thr_short", 80)
    bs = (stoch < thr) & (stoch.shift(1) >= thr) & (df["close"] < df["ema200"]) & (df["rsi_w"] < p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_williams_r_short(df, p):
    """Short: Williams %R cruza desde >=-20 hacia abajo (overbought)."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("wr_period", 14))
    h_max = df["high"].rolling(period).max(); l_min = df["low"].rolling(period).min()
    wr = -100 * (h_max - df["close"]) / (h_max - l_min + 1e-9)
    thr = p.get("wr_thr_short", -20)
    bs = (wr < thr) & (wr.shift(1) >= thr) & (df["close"] < df["ema50"]) & (df["rsi_w"] < p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_cci_reversal_short(df, p):
    """Short: CCI cruza desde >=+100 hacia abajo (extremo superior)."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("cci_period", 20))
    tp_price = (df["high"] + df["low"] + df["close"]) / 3
    tp_ma = tp_price.rolling(period).mean()
    md = (tp_price - tp_ma).abs().rolling(period).mean()
    cci = (tp_price - tp_ma) / (0.015 * md + 1e-9)
    thr = p.get("cci_thr_short", 100)
    bs = (cci < thr) & (cci.shift(1) >= thr) & (df["close"] < df["ema200"]) & (df["rsi_w"] < p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_engulfing_short(df, p):
    """Short: vela bear engulfing — prev verde, current rojo y traga al anterior."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    prev_bull = df["close"].shift(1) > df["open"].shift(1)
    curr_bear = df["close"] < df["open"]
    engulf = (df["open"] > df["close"].shift(1)) & (df["close"] < df["open"].shift(1))
    bs = prev_bull & curr_bear & engulf & (df["close"] < df["ema50"]) & (df["rsi_w"] < p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_three_candles_short(df, p):
    """Short: 3 velas rojas consecutivas con volumen."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    bear1 = df["close"] < df["open"]
    bear2 = df["close"].shift(1) < df["open"].shift(1)
    bear3 = df["close"].shift(2) < df["open"].shift(2)
    bs = bear1 & bear2 & bear3 & (df["close"] < df["ema50"]) & (df["rsi_w"] < p.get("rsi_w_thr", 50)) & (df["volume"] > df["vol_ma"] * p.get("vol_mult", 1.1))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_inside_bar_short(df, p):
    """Short: inside bar seguida de ruptura bajista."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    inside = (df["high"] < df["high"].shift(1)) & (df["low"] > df["low"].shift(1))
    breakout_dn = (df["close"] < df["low"].shift(1)) & inside.shift(1).fillna(False)
    bs = breakout_dn & (df["close"] < df["ema50"]) & (df["rsi_w"] < p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_zscore_rich_short(df, p):
    """Short: precio en z-score >= +2σ del media móvil (rich, reversion al medio)."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("zs_period", 20))
    ma = df["close"].rolling(period).mean()
    sd = df["close"].rolling(period).std()
    z = (df["close"] - ma) / (sd + 1e-9)
    thr = p.get("z_thr_short", 2.0)
    bs = (z < thr) & (z.shift(1) >= thr) & (df["close"] < df["ema200"] * 1.03) & (df["rsi_w"] < p.get("rsi_w_thr", 55))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_heikin_ashi_short(df, p):
    """Short: 3 velas Heikin Ashi rojas consecutivas tras 2+ velas alcistas."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    ha_close = (df["open"] + df["high"] + df["low"] + df["close"]) / 4
    ha_open  = ((df["open"].shift(1) + df["close"].shift(1)) / 2).fillna(df["open"])
    ha_bear  = ha_close < ha_open
    bs = ha_bear & ~ha_bear.shift(1).fillna(True) & ~ha_bear.shift(2).fillna(True) & (df["close"] < df["ema50"]) & (df["rsi_w"] < p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_roc_negative_short(df, p):
    """Short: Rate of Change cruza desde >=-thr hacia abajo (momentum negativo acelerando)."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("roc_period", 10))
    roc = (df["close"] / df["close"].shift(period) - 1) * 100
    thr = p.get("roc_thr_short", -2.0)
    bs = (roc < thr) & (roc.shift(1) >= thr) & (df["close"] < df["ema200"]) & (df["rsi_w"] < p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_dmi_bear(df, p):
    """Short: ADX>=25 + -DI > +DI (DMI bear con tendencia confirmada)."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("dmi_period", 14))
    h, l, c = df["high"], df["low"], df["close"]
    up_move   = h.diff()
    down_move = -l.diff()
    plus_dm   = ((up_move > down_move) & (up_move > 0)).astype(float) * up_move
    minus_dm  = ((down_move > up_move) & (down_move > 0)).astype(float) * down_move
    tr = pd.concat([(h - l), (h - c.shift(1)).abs(), (l - c.shift(1)).abs()], axis=1).max(axis=1)
    atr_d = tr.ewm(alpha=1/period, adjust=False).mean()
    plus_di  = 100 * plus_dm.ewm(alpha=1/period, adjust=False).mean()  / (atr_d + 1e-9)
    minus_di = 100 * minus_dm.ewm(alpha=1/period, adjust=False).mean() / (atr_d + 1e-9)
    dx       = 100 * (plus_di - minus_di).abs() / (plus_di + minus_di + 1e-9)
    adx      = dx.ewm(alpha=1/period, adjust=False).mean()
    adx_thr  = p.get("adx_thr", 25)
    bs = (adx >= adx_thr) & (minus_di > plus_di) & (df["close"] < df["ema200"]) & (df["rsi_w"] < p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_vwap_overpriced_short(df, p):
    """Short: precio >X% sobre VWAP rolling (overpriced, reversion al VWAP)."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("vwap_period", 50))
    tp_price = (df["high"] + df["low"] + df["close"]) / 3
    vwap = (tp_price * df["volume"]).rolling(period).sum() / (df["volume"].rolling(period).sum() + 1e-9)
    thr_pct = p.get("vwap_over_pct", 2.0) / 100
    bs = (df["close"] > vwap * (1 + thr_pct)) & (df["close"].shift(1) <= vwap.shift(1) * (1 + thr_pct)) & (df["rsi_w"] < p.get("rsi_w_thr", 55))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_keltner_breakdown_short(df, p):
    """Short: precio rompe canal Keltner inferior con volumen (volatility expansion bajista)."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    lower = df["ema21"] - p.get("kelt_mult", 2.0) * df["atr"]
    bs = (df["close"] < lower) & (df["close"].shift(1) >= lower.shift(1)) & (df["close"] < df["ema200"]) & (df["rsi_w"] < p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)



# ── NUEVOS SHORTS 2026-05-14 NOCHE — Balance vs +5 longs activados ──────────

def sig_atr_channel_short(df, p):
    """Short: precio rompe canal ATR inferior. Mirror de sig_atr_channel."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    lower = df["ema50"] - p.get("atr_mult", 1.5) * df["atr"]
    bs = (df["close"] < lower) & (df["close"].shift(1) >= lower.shift(1)) & (df["close"] < df["ema200"]) & (df["rsi_w"] < p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_supertrend_short(df, p):
    """Short: flip bajista del Supertrend bajo EMA200. Mirror de sig_supertrend."""
    c = df["close"]
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    mult = p.get("st_mult", 3.0)
    hl2 = (df["high"] + df["low"]) / 2
    upper = hl2 + mult * df["atr"]
    trend_down = c < upper.shift(1)
    flip_down = trend_down & ~trend_down.shift(1).fillna(False)
    below_200 = c < df["ema200"]
    bear_ok = df["rsi_w"] < p.get("rsi_w_thr", 50)
    bs = flip_down & below_200 & bear_ok & df.get("htf_bear", pd.Series(True, index=df.index))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_bb_squeeze_short(df, p):
    """Short: salida de squeeze BB hacia abajo con volumen. Mirror de sig_bb_squeeze."""
    c = df["close"]
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("bb_period", 20))
    bb_ma = c.rolling(period).mean()
    bb_std = c.rolling(period).std()
    bb_width = (bb_std * 2) / bb_ma
    squeezing = bb_width <= bb_width.rolling(50).quantile(0.2)
    expanding = (bb_width > bb_width.shift(1)) & squeezing.shift(1).fillna(False)
    bs = expanding & (c < bb_ma) & (df["volume"] > df["vol_ma"] * p.get("vol_mult", 1.5))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_donchian_breakdown(df, p):
    """Short: precio rompe minimo Donchian N-barras. Mirror de sig_donchian_break."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("don_period", 20))
    lower = df["low"].rolling(period).min().shift(1)
    bs = (df["close"] < lower) & (df["volume"] > df["vol_ma"] * p.get("vol_mult", 1.3)) & (df["rsi_w"] < p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_rsi_trend_short(df, p):
    """Short: RSI en tendencia bajista con rally tecnico. Mirror de sig_rsi_trend."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    rsi_downtrend = (df["rsi14"] < 50) & (df["rsi14"] < df["rsi14"].shift(3))
    rally = df["rsi14"] > p.get("rsi_rally", 45)
    bs = rsi_downtrend & rally & (df["close"] < df["ema50"]) & (df["rsi_w"] < p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, pd.Series(False, index=df.index), bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


