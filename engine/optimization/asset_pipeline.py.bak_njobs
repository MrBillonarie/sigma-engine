    'roc_momentum':      sig_roc_momentum,
    'open_close_cross':  sig_open_close_cross,
    'atr_channel':       sig_atr_channel,
    'inside_bar':        sig_inside_bar,
    'engulfing':         sig_engulfing,
    'three_candles':     sig_three_candles,
    'zscore_reversion':  sig_zscore_reversion,
    'heikin_ashi':       sig_heikin_ashi,
    'rsi_trend':         sig_rsi_trend,
    'ema_ribbon':        sig_ema_ribbon,
    'wma_momentum':      sig_wma_momentum,
    'linear_reg_break':  sig_linear_reg_break,
    'bb_bandwidth':      sig_bb_bandwidth,
    'lower_lows':        sig_lower_lows,
    'pin_bar':           sig_pin_bar,
    'break_of_structure':sig_break_of_structure,
    'volume_exhaustion': sig_volume_exhaustion,
