# ── DATA ─────────────────────────────────────────────────────────────────────

def _download_ohlcv(ex, symbol, tf, since_ms):
    """Descarga todos los candles disponibles desde since_ms."""
    all_ohlcv, since = [], since_ms
    while True:
        try:
            data = ex.fetch_ohlcv(symbol, tf, since=since, limit=1000)
        except:
            break
        if not data: break
        all_ohlcv.extend(data)
        if len(data) < 1000: break
        since = data[-1][0] + 1
    return all_ohlcv



def load_asset_csv(path):
    """Carga OHLCV desde CSV pre-descargado (para activos sin soporte Binance como XAU)."""
    import pandas as pd
    df = pd.read_csv(path, index_col=0, parse_dates=True)
    df.columns = [c.lower() for c in df.columns]
    needed = ['open', 'high', 'low', 'close', 'volume']
    for col in needed:
        if col not in df.columns:
            df[col] = 0.0
    extra = [col for col in ['dxy', 'yield_10y'] if col in df.columns]
    df = df[needed + extra]
    df = df[~df.index.duplicated(keep='last')].sort_index()
    df.index.name = 'timestamp'
    df = df.dropna(subset=['close'])
    # Funding rate = 0 para activos no-Binance
    df['funding_rate'] = 0.0
    return df

def fetch_asset(symbol, tf='1h', days=4000):
    """
    Descarga el maximo historial disponible.
    Estrategia: primero spot (mas historia), luego futuros para completar
    con datos recientes si hay diferencia. Para BTC usa spot (8.7yr).
    Para alts: spot da 2+ años extra vs futuros.
    """
    import ccxt
    ex_spot = ccxt.binance({'timeout': 30000})
    ex_fut  = ccxt.binance({'timeout': 30000, 'options': {'defaultType': 'future'}})

    # Intentar maximo historial posible (desde 2017 para los que tienen)
    since_max = int((pd.Timestamp('2017-01-01')).timestamp() * 1000)

    frames = []

    # 1. Spot — mayor historial
    try:
        raw = _download_ohlcv(ex_spot, symbol, tf, since_max)
        if raw:
            df = pd.DataFrame(raw, columns=['ts','open','high','low','close','volume'])
            df['ts'] = pd.to_datetime(df['ts'], unit='ms')
            df.set_index('ts', inplace=True)
            frames.append(df)
    except:
        pass

    # 2. Futuros — puede tener datos mas recientes o diferir ligeramente
    try:
        raw = _download_ohlcv(ex_fut, symbol, tf, since_max)
        if raw:
            df = pd.DataFrame(raw, columns=['ts','open','high','low','close','volume'])
            df['ts'] = pd.to_datetime(df['ts'], unit='ms')
            df.set_index('ts', inplace=True)
            frames.append(df)
    except:
        pass

    if not frames:
        return None

    # Combinar: spot para historia antigua, futuros para lo reciente
    if len(frames) == 2:
        df_spot, df_fut = frames
        split_ts = df_fut.index[0]
        df_hist  = df_spot[df_spot.index < split_ts]
        combined = pd.concat([df_hist, df_fut])
        # Fix 3: descartar 20 barras alrededor del punto de unión spot→futuros
        # evita artefactos de precio (basis) que generan señales falsas
        join_mask = (combined.index >= split_ts - pd.Timedelta(hours=8)) & \
                    (combined.index <= split_ts + pd.Timedelta(hours=8))
        combined = combined[~join_mask]
    else:
        combined = frames[0]

    combined = combined[~combined.index.duplicated(keep='last')].sort_index()
    combined = combined.dropna(subset=['close'])

    # Funding rates — descargar y agregar como columna
    combined['funding_rate'] = _fetch_funding_resampled(symbol, tf, combined)

    print(f'  [{symbol} {tf}] {len(combined):,} velas | '
          f'{combined.index[0].strftime("%Y-%m-%d")} -> {combined.index[-1].strftime("%Y-%m-%d")} '
          f'({(combined.index[-1]-combined.index[0]).days}d)', flush=True)
    return combined


def _fetch_funding_resampled(symbol, tf, df):
    """
    Descarga el historial de funding rates de Binance Futuros y los
    resamplea al TF del OHLCV. Retorna una Series indexada igual que df.
    Funding rate se paga cada 8h — promediamos por barra.
    Si falla, retorna cero (sin funding cost) para no bloquear el pipeline.
    """
    try:
        import ccxt
        ex  = ccxt.binance({'timeout': 20000, 'options': {'defaultType': 'future'}})
        since = int(df.index[0].timestamp() * 1000)
        raw   = []
        while True:
            batch = ex.fetch_funding_rate_history(symbol, since=since, limit=1000)
            if not batch: break
            raw.extend(batch)
            if len(batch) < 1000: break
            since = batch[-1]['timestamp'] + 1
        if not raw:
            return pd.Series(0.0, index=df.index)
        fr = pd.DataFrame(raw)[['timestamp', 'fundingRate']].copy()
        fr['ts'] = pd.to_datetime(fr['timestamp'], unit='ms')
        fr = fr.set_index('ts')['fundingRate'].astype(float)
        # Resamplear al TF del OHLCV: sumar las tasas que caen en cada barra
        fr_r = fr.resample(tf if tf != '15m' else '15min').sum().reindex(df.index, fill_value=0.0)
        return fr_r.fillna(0.0)
    except:
        return pd.Series(0.0, index=df.index)


def add_features(df):
    c = df['close']; h = df['high']; l = df['low']; v = df['volume']
    tr = pd.concat([h-l, (h-c.shift()).abs(), (l-c.shift()).abs()], axis=1).max(axis=1)
    df['atr']    = tr.ewm(alpha=1/14, adjust=False).mean()
    df['ema200'] = c.ewm(span=200, adjust=False).mean()
    df['ema50']  = c.ewm(span=50, adjust=False).mean()
    df['ema21']  = c.ewm(span=21, adjust=False).mean()
    df['vol_ma'] = v.rolling(20).mean()
    # RSI
    d = c.diff()
    g = d.clip(lower=0).ewm(alpha=1/14, adjust=False).mean()
    ll = (-d.clip(upper=0)).ewm(alpha=1/14, adjust=False).mean()
    df['rsi14'] = 100 - 100 / (1 + g / (ll + 1e-9))
    # RSI semanal
    cw = c.resample('W').last().ffill()
    dw = cw.diff()
    gw = dw.clip(lower=0).ewm(alpha=1/14, adjust=False).mean()
    lw = (-dw.clip(upper=0)).ewm(alpha=1/14, adjust=False).mean()
    rsiw = 100 - 100 / (1 + gw / (lw + 1e-9))
    df['rsi_w'] = rsiw.reindex(df.index, method='ffill').fillna(50)
    # MACD
    df['macd']   = c.ewm(span=12, adjust=False).mean() - c.ewm(span=26, adjust=False).mean()
    df['macd_s'] = df['macd'].ewm(span=9, adjust=False).mean()
    df['macd_h'] = df['macd'] - df['macd_s']
    # Regimen del activo (bull/range/bear) calculado sobre sus propios datos
    # INDEPENDIENTE por activo — ETH puede ser bull mientras BNB es bear
    df['regime_bull']  = (df['rsi_w'] > 55) & (c > df['ema200'])
    df['regime_range'] = (df['rsi_w'] >= 40) & (df['rsi_w'] <= 55)
    df['regime_bear']  = (df['rsi_w'] < 40) | (c < df['ema200'] * 0.97)
    # Gate de trading bidireccional
    # Long: solo en bull/range | Short: solo en bear/range
    df['tradeable_long']  = df['regime_bull'] | df['regime_range']
    df['tradeable_short'] = df['regime_bear']  | df['regime_range']
    df['tradeable']       = df['tradeable_long'] | df['tradeable_short']
    # Multi-TF: confirmación del timeframe superior via resampling adaptativo
    # 5m/15m → confirma con 1H | 1H → confirma con 4H | 4H → confirma con 1D
    try:
        # Detectar TF del DataFrame por frecuencia media entre barras
        freq_min = (df.index[-1] - df.index[0]).total_seconds() / 60 / max(len(df)-1, 1)
        if freq_min <= 30:       # 5m o 15m → HTF = 1H
            htf_rule = '1h'
        elif freq_min <= 90:     # 1H → HTF = 4H
            htf_rule = '4h'
        else:                    # 4H o superior → HTF = 1D
            htf_rule = '1D'

        c_htf = c.resample(htf_rule).last().ffill()
        ema200_htf = c_htf.ewm(span=200, adjust=False).mean()
        d_htf = c_htf.diff()
        g_htf = d_htf.clip(lower=0).ewm(alpha=1/14, adjust=False).mean()
        ll_htf = (-d_htf.clip(upper=0)).ewm(alpha=1/14, adjust=False).mean()
        rsi_htf = (100 - 100/(1 + g_htf/(ll_htf+1e-9))).reindex(df.index, method='ffill').fillna(50)
        ema200_htf_r = ema200_htf.reindex(df.index, method='ffill')
        df['htf_bull']  = (rsi_htf > 52) & (c > ema200_htf_r)
        df['htf_bear']  = (rsi_htf < 45) | (c < ema200_htf_r * 0.97)
        df['htf_range'] = ~df['htf_bull'] & ~df['htf_bear']
    except:
        df['htf_bull']  = True  # fallback: sin filtro HTF
        df['htf_bear']  = False
        df['htf_range'] = False

    # Macro features — solo si existen en el CSV (commodities: XAU/XAG)
    if 'dxy' in df.columns:
        _dxy = df['dxy'].ffill().bfill()
        df['dxy_ema50']  = _dxy.ewm(span=50, adjust=False).mean()
        df['dxy_bull']   = (_dxy > df['dxy_ema50']).astype(float)   # USD fuerte: malo para oro
        df['dxy_chg5']   = _dxy.pct_change(5).fillna(0)
    if 'yield_10y' in df.columns:
        _y10 = df['yield_10y'].ffill().bfill()
        df['yield_ema20']  = _y10.ewm(span=20, adjust=False).mean()
        df['yield_rising'] = (_y10 > df['yield_ema20']).astype(float)  # yields subiendo: malo para oro
        df['yield_chg5']   = _y10.pct_change(5).fillna(0)

    df.dropna(subset=['atr', 'ema200'], inplace=True)
    return df


# ── REGIME GATE ───────────────────────────────────────────────────────────────

def apply_regime_gate(df, bl, bs=None):
    """
    Gate bidireccional por regimen del activo:
    - Bull:  solo LONGS
    - Range: longs Y shorts (mercado oscila)
    - Bear:  solo SHORTS
    """
    long_ok  = df.get('tradeable_long',  pd.Series(True, index=df.index))
    short_ok = df.get('tradeable_short', pd.Series(False, index=df.index))

    # En range solo entrar con confirmacion adicional
    range_ok     = df.get('regime_range', pd.Series(False, index=df.index))
    rsi14        = df.get('rsi14', pd.Series(50, index=df.index))
    range_long_ok  = ~range_ok | (rsi14 < 50)   # long en range: RSI14 no sobrecomprado
    range_short_ok = ~range_ok | (rsi14 > 52)   # short en range: RSI14 no sobrevendido

    bl_filtered = bl & long_ok  & range_long_ok  if bl is not None else pd.Series(False, index=df.index)
    bs_filtered = bs & short_ok & range_short_ok if bs is not None else pd.Series(False, index=df.index)
    return bl_filtered, bs_filtered


# ── SIGNAL GENERATORS ────────────────────────────────────────────────────────

def sig_breakout(df, p):
    c=df['close']; h=df['high']; v=df['volume']
    lb=p['lookback']; vm=p['vol_mult']; slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    prev_high = h.rolling(lb).max().shift(1)
    vol_ok    = v > df['vol_ma'] * vm
    bull_ok   = df['rsi_w'] > p['rsi_w_thr']
    above_200 = c > df['ema200']
    htf_ok    = df.get('htf_bull', pd.Series(True, index=df.index)) | \
                df.get('htf_range', pd.Series(True, index=df.index))
    bl = (c > prev_high) & vol_ok & above_200 & bull_ok & htf_ok
    bl, bs = apply_regime_gate(df, bl)  # filtro de regimen del activo
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_pullback(df, p):
    c=df['close']; h=df['high']; l=df['low']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    ema_t = p.get('ema_type', 21)
    ema_line = c.ewm(span=ema_t, adjust=False).mean()
    at_ema   = (c <= ema_line * 1.005) & (c >= ema_line * 0.995)
    trend    = df['ema50'] > df['ema200']
    bull_ok  = df['rsi_w'] > p.get('rsi_w_thr', 50)
    oversold = df['rsi14'] < p.get('rsi_entry', 45)
    htf_ok   = df.get('htf_bull', pd.Series(True, index=df.index)) | \
               df.get('htf_range', pd.Series(True, index=df.index))
    bl = at_ema & trend & bull_ok & oversold & htf_ok
    bl, bs = apply_regime_gate(df, bl)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_tma_bands(df, p):
    c=df['close']
    period=p.get('tma_period', 14); am=p.get('atr_mult', 1.5)
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    sma  = c.rolling(period).mean()
    tma  = sma.rolling(period).mean()
    lower= tma - df['atr'] * am
    upper= tma + df['atr'] * am
    bull_ok = df['rsi_w'] > p.get('rsi_w_thr', 48)
    above_200= c > df['ema200']
    htf_ok_l = df.get('htf_bull', pd.Series(True, index=df.index)) | \
               df.get('htf_range', pd.Series(True, index=df.index))
    bl = (c <= lower) & above_200 & bull_ok & htf_ok_l
    bs = (c >= upper) & (c < df['ema200']) & (~bull_ok)
    bl, bs = apply_regime_gate(df, bl, bs)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_momentum(df, p):
    c=df['close']; v=df['volume']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    vm = p.get('vol_mult', 1.5)
    vol_ok  = v > df['vol_ma'] * vm
    macd_up = (df['macd_h'] > 0) & (df['macd_h'] > df['macd_h'].shift(1))
    above_200= c > df['ema200']
    bull_ok = df['rsi_w'] > p.get('rsi_w_thr', 52)
    not_ob  = df['rsi14'] < p.get('rsi_max', 70)
    htf_ok  = df.get('htf_bull', pd.Series(True, index=df.index)) | \
              df.get('htf_range', pd.Series(True, index=df.index))
    bl = macd_up & above_200 & bull_ok & not_ob & vol_ok & htf_ok
    bl, bs = apply_regime_gate(df, bl)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_mean_rev(df, p):
    c=df['close']
    slm=p['sl_mult']; tpm=p['tp_mult']; cd=p['cooldown']
    oversold = df['rsi14'] < p.get('rsi_os', 35)
    above_200= c > df['ema200']
    bull_ok  = df['rsi_w'] > p.get('rsi_w_thr', 48)
    htf_ok   = df.get('htf_bull', pd.Series(True, index=df.index)) | \
               df.get('htf_range', pd.Series(True, index=df.index))
    bl = oversold & above_200 & bull_ok & htf_ok
    bl, bs = apply_regime_gate(df, bl)
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def _apply_cd(df, bl, bs, slm, tpm, cd):
    c=df['close']; atr=df['atr']
    sig=pd.Series(0, index=df.index)
    sl_s=pd.Series(0.0, index=df.index)
    tp_s=pd.Series(0.0, index=df.index)
    sig[bl]=1;  sl_s[bl]=c[bl]-atr[bl]*slm; tp_s[bl]=c[bl]+atr[bl]*tpm
    sig[bs]=-1; sl_s[bs]=c[bs]+atr[bs]*slm; tp_s[bs]=c[bs]-atr[bs]*tpm
    final=pd.Series(0, index=df.index)
    last=-cd-1
    for i in range(len(sig)):
        if (i-last) >= cd and sig.iloc[i] != 0:
            final.iloc[i]=sig.iloc[i]; last=i
    return final, sl_s, tp_s



# ── NEW STRATEGIES — TOTAL OVERNIGHT BATCH (added 2026-05-12) ────────────────

def sig_ema_triple(df, p):
    c = df["close"]
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    aligned = (df["ema21"] > df["ema50"]) & (df["ema50"] > df["ema200"])
    pullback = (c <= df["ema21"] * 1.005) & (c >= df["ema21"] * 0.99)
    rsi_ok = df["rsi14"] < p.get("rsi_max", 65)
    vol_ok = df["volume"] > df["vol_ma"] * p.get("vol_mult", 1.2)
    htf_ok = df.get("htf_bull", pd.Series(True, index=df.index)) | df.get("htf_range", pd.Series(True, index=df.index))
    bl = aligned & pullback & rsi_ok & vol_ok & htf_ok
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_supertrend(df, p):
    c = df["close"]
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    mult = p.get("st_mult", 3.0)
    hl2 = (df["high"] + df["low"]) / 2
    lower = hl2 - mult * df["atr"]
    trend_up = c > lower.shift(1)
    flip_up = trend_up & ~trend_up.shift(1).fillna(False)
    above_200 = c > df["ema200"]
    bull_ok = df["rsi_w"] > p.get("rsi_w_thr", 50)
    bl = flip_up & above_200 & bull_ok & df.get("htf_bull", pd.Series(True, index=df.index))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_bb_squeeze(df, p):
    c = df["close"]
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("bb_period", 20))
    bb_ma = c.rolling(period).mean()
    bb_std = c.rolling(period).std()
    bb_width = (bb_std * 2) / bb_ma
    squeezing = bb_width <= bb_width.rolling(50).quantile(0.2)
    expanding = (bb_width > bb_width.shift(1)) & squeezing.shift(1).fillna(False)
    bl = expanding & (c > bb_ma) & (df["volume"] > df["vol_ma"] * p.get("vol_mult", 1.5))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_stoch_rsi(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    rsi = df["rsi14"]; period = int(p.get("stoch_period", 14))
    stoch = ((rsi - rsi.rolling(period).min()) / (rsi.rolling(period).max() - rsi.rolling(period).min() + 1e-9)) * 100
    thr = p.get("stoch_thr", 20)
    bl = (stoch > thr) & (stoch.shift(1) <= thr) & (df["close"] > df["ema200"]) & (df["rsi_w"] > p.get("rsi_w_thr", 45))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_williams_r(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("wr_period", 14))
    h_max = df["high"].rolling(period).max(); l_min = df["low"].rolling(period).min()
    wr = -100 * (h_max - df["close"]) / (h_max - l_min + 1e-9)
    thr = p.get("wr_thr", -80)
    bl = (wr > thr) & (wr.shift(1) <= thr) & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 45))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_cci_reversal(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("cci_period", 20))
    tp_price = (df["high"] + df["low"] + df["close"]) / 3
    tp_ma = tp_price.rolling(period).mean()
    md = (tp_price - tp_ma).abs().rolling(period).mean()
    cci = (tp_price - tp_ma) / (0.015 * md + 1e-9)
    thr = p.get("cci_thr", -100)
    bl = (cci > thr) & (cci.shift(1) <= thr) & (df["close"] > df["ema200"]) & (df["rsi_w"] > p.get("rsi_w_thr", 45))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_macd_divergence(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    lb = int(p.get("div_lookback", 10))
    price_at_min = df["close"] <= df["close"].rolling(lb).min() * 1.005
    div_bull = price_at_min & (df["macd_h"] > df["macd_h"].shift(lb)) & (df["macd_h"] < 0)
    bl = div_bull & (df["close"] > df["ema200"] * 0.97) & (df["rsi_w"] > p.get("rsi_w_thr", 45))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_rsi_divergence(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    lb = int(p.get("div_lookback", 12))
    price_at_min = df["close"] <= df["close"].rolling(lb).min() * 1.003
    bl = price_at_min & (df["rsi14"] > df["rsi14"].shift(lb)) & (df["rsi14"] < p.get("rsi_max_div", 45)) & (df["rsi_w"] > p.get("rsi_w_thr", 42))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_volume_climax(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    capitulation = (df["volume"] > df["vol_ma"] * p.get("vol_climax_mult", 3.0)) & (df["close"] < df["close"].shift(1))
    bl = (df["close"] > df["close"].shift(1)) & capitulation.shift(1).fillna(False) & (df["rsi_w"] > p.get("rsi_w_thr", 38))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_keltner_breakout(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    upper = df["ema21"] + p.get("kelt_mult", 2.0) * df["atr"]
    bl = (df["close"] > upper) & (df["close"].shift(1) <= upper.shift(1)) & (df["close"] > df["ema200"]) & (df["rsi_w"] > p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_ema50_bounce(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    in_up = (df["ema21"] > df["ema50"]) & (df["ema50"] > df["ema200"])
    bl = in_up & (df["low"] <= df["ema50"] * 1.005) & (df["close"] > df["ema50"]) & (df["rsi14"] > p.get("rsi_min_bounce", 35)) & (df["rsi14"] < p.get("rsi_max_bounce", 60)) & (df["rsi_w"] > p.get("rsi_w_thr", 48))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


# ── ROUND 3 — 15 estrategias adicionales ─────────────────────────────────────

def sig_donchian_break(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("don_period", 20))
    upper = df["high"].rolling(period).max().shift(1)
    bl = (df["close"] > upper) & (df["volume"] > df["vol_ma"] * p.get("vol_mult", 1.3)) & (df["rsi_w"] > p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_higher_highs(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("hh_period", 5))
    rolling_high = df["high"].rolling(period).max()
    bl = (rolling_high > rolling_high.shift(period)) & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 50)) & (df["volume"] > df["vol_ma"])
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_roc_momentum(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("roc_period", 10))
    roc = (df["close"] / df["close"].shift(period) - 1) * 100
    thr = p.get("roc_thr", 2.0)
    bl = (roc > thr) & (roc.shift(1) <= thr) & (df["close"] > df["ema200"]) & (df["rsi_w"] > p.get("rsi_w_thr", 48))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_open_close_cross(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    above_open = df["close"] > df["open"]
    bl = above_open & ~above_open.shift(1).fillna(False) & (df["close"] > df["ema50"]) & (df["volume"] > df["vol_ma"] * p.get("vol_mult", 1.2)) & (df["rsi_w"] > p.get("rsi_w_thr", 48))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_atr_channel(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    upper = df["ema50"] + p.get("atr_mult", 1.5) * df["atr"]
    bl = (df["close"] > upper) & (df["close"].shift(1) <= upper.shift(1)) & (df["close"] > df["ema200"]) & (df["rsi_w"] > p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_inside_bar(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    inside = (df["high"] < df["high"].shift(1)) & (df["low"] > df["low"].shift(1))
    breakout_up = (df["close"] > df["high"].shift(1)) & inside.shift(1).fillna(False)
    bl = breakout_up & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 48))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_engulfing(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    prev_bear = df["close"].shift(1) < df["open"].shift(1)
    curr_bull = df["close"] > df["open"]
    engulf = (df["open"] < df["close"].shift(1)) & (df["close"] > df["open"].shift(1))
    bl = prev_bear & curr_bull & engulf & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 45))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_three_candles(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    bull1 = df["close"] > df["open"]
    bull2 = df["close"].shift(1) > df["open"].shift(1)
    bull3 = df["close"].shift(2) > df["open"].shift(2)
    bl = bull1 & bull2 & bull3 & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 48)) & (df["volume"] > df["vol_ma"] * p.get("vol_mult", 1.1))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_zscore_reversion(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("zs_period", 20))
    ma = df["close"].rolling(period).mean()
    sd = df["close"].rolling(period).std()
    z = (df["close"] - ma) / (sd + 1e-9)
    thr = p.get("z_thr", -2.0)
    bl = (z > thr) & (z.shift(1) <= thr) & (df["close"] > df["ema200"] * 0.97) & (df["rsi_w"] > p.get("rsi_w_thr", 42))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_heikin_ashi(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    ha_close = (df["open"] + df["high"] + df["low"] + df["close"]) / 4
    ha_open = ((df["open"].shift(1) + df["close"].shift(1)) / 2).fillna(df["open"])
    ha_bull = ha_close > ha_open
    bl = ha_bull & ~ha_bull.shift(1).fillna(False) & ~ha_bull.shift(2).fillna(False) & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 48))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_rsi_trend(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    rsi_uptrend = (df["rsi14"] > 50) & (df["rsi14"] > df["rsi14"].shift(3))
    pullback = df["rsi14"] < p.get("rsi_pull", 55)
    bl = rsi_uptrend & pullback & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_ema_ribbon(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    aligned = (df["ema21"] > df["ema50"]) & (df["ema50"] > df["ema200"])
    expanding = (df["ema21"] - df["ema50"]) > (df["ema21"].shift(5) - df["ema50"].shift(5))
    bl = aligned & expanding & (df["close"] > df["ema21"]) & (df["volume"] > df["vol_ma"]) & (df["rsi_w"] > p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_wma_momentum(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("wma_period", 20))
    weights = pd.Series(range(1, period + 1))
    def wma(s):
        return s.rolling(period).apply(lambda x: (x * weights).sum() / weights.sum(), raw=True)
    wma_short = wma(df["close"])
    bl = (df["close"] > wma_short) & (df["close"].shift(1) <= wma_short.shift(1)) & (df["close"] > df["ema200"]) & (df["rsi_w"] > p.get("rsi_w_thr", 48))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_linear_reg_break(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("lr_period", 20))
    # Simple lin reg approximation: slope of MA difference
    ma = df["close"].rolling(period).mean()
    slope = ma - ma.shift(period)
    upward = (slope > 0) & (slope > slope.shift(1))
    bl = upward & ~upward.shift(1).fillna(False) & (df["close"] > df["ema200"]) & (df["rsi_w"] > p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_bb_bandwidth(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("bbb_period", 20))
    ma = df["close"].rolling(period).mean()
    sd = df["close"].rolling(period).std()
    bw = (sd * 2) / ma
    expanding = bw > bw.shift(1) * 1.05
    bl = expanding & (df["close"] > ma) & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)




def sig_lower_lows(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("ll_period", 5))
    rolling_low = df["low"].rolling(period).min()
    bl = (rolling_low > rolling_low.shift(period)) & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 50)) & (df["volume"] > df["vol_ma"])
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_pin_bar(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    body = (df["close"] - df["open"]).abs()
    range_ = df["high"] - df["low"]
    lower_wick = df[["open","close"]].min(axis=1) - df["low"]
    upper_wick = df["high"] - df[["open","close"]].max(axis=1)
    bullish_pin = (lower_wick > body * 2) & (lower_wick > upper_wick * 2) & (range_ > df["atr"] * 0.5)
    bl = bullish_pin & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 45))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_break_of_structure(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("bos_period", 20))
    swing_high = df["high"].rolling(period).max().shift(1)
    bl = (df["close"] > swing_high) & (df["volume"] > df["vol_ma"] * p.get("vol_mult", 1.4)) & (df["rsi_w"] > p.get("rsi_w_thr", 48))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_volume_exhaustion(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("ve_period", 5))
    vol_declining = df["volume"].rolling(period).mean() < df["volume"].rolling(period * 2).mean()
    bullish_candle = df["close"] > df["open"]
    bl = vol_declining & bullish_candle & (df["close"] > df["ema50"]) & (df["rsi14"] < p.get("rsi_max", 60)) & (df["rsi_w"] > p.get("rsi_w_thr", 45))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_consecutive_wick(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    lower_wick = df[["open","close"]].min(axis=1) - df["low"]
    body = (df["close"] - df["open"]).abs()
    has_wick = lower_wick > body * 1.5
    triple_wick = has_wick & has_wick.shift(1).fillna(False) & has_wick.shift(2).fillna(False)
    bl = triple_wick & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 45))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_hull_cross(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("hma_period", 21))
    half = period // 2
    wma_half = df["close"].rolling(half).apply(lambda x: sum(x * range(1, len(x)+1)) / sum(range(1, len(x)+1)), raw=True)
    wma_full = df["close"].rolling(period).apply(lambda x: sum(x * range(1, len(x)+1)) / sum(range(1, len(x)+1)), raw=True)
    raw_hma = 2 * wma_half - wma_full
    sqrt_period = int(period ** 0.5)
    hma = raw_hma.rolling(sqrt_period).mean()
    bl = (df["close"] > hma) & (df["close"].shift(1) <= hma.shift(1)) & (df["close"] > df["ema200"]) & (df["rsi_w"] > p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_aroon_cross(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("aroon_period", 14))
    rolling_high_idx = df["high"].rolling(period).apply(lambda x: period - x.argmax() - 1, raw=True)
    rolling_low_idx = df["low"].rolling(period).apply(lambda x: period - x.argmin() - 1, raw=True)
    aroon_up = 100 * (period - rolling_high_idx) / period
    aroon_down = 100 * (period - rolling_low_idx) / period
    cross = (aroon_up > aroon_down) & (aroon_up.shift(1) <= aroon_down.shift(1)) & (aroon_up > 70)
    bl = cross & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 48))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_psar_flip(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    # PSAR approximation: trend up if price above EMA21 + ATR multiplier band
    band = df["ema21"] - p.get("psar_mult", 2.0) * df["atr"]
    flip = (df["close"] > band) & (df["close"].shift(1) <= band.shift(1))
    bl = flip & (df["close"] > df["ema200"]) & (df["volume"] > df["vol_ma"]) & (df["rsi_w"] > p.get("rsi_w_thr", 48))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_dmi_trend(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("dmi_period", 14))
    up_move = df["high"] - df["high"].shift(1)
    down_move = df["low"].shift(1) - df["low"]
    plus_dm = pd.Series([um if um > dm and um > 0 else 0 for um, dm in zip(up_move.fillna(0), down_move.fillna(0))], index=df.index)
    minus_dm = pd.Series([dm if dm > um and dm > 0 else 0 for um, dm in zip(up_move.fillna(0), down_move.fillna(0))], index=df.index)
    atr_smooth = df["atr"].rolling(period).mean()
    plus_di = 100 * plus_dm.rolling(period).mean() / (atr_smooth + 1e-9)
    minus_di = 100 * minus_dm.rolling(period).mean() / (atr_smooth + 1e-9)
    bullish_dmi = plus_di > minus_di
    cross = bullish_dmi & ~bullish_dmi.shift(1).fillna(False)
    bl = cross & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_mfi_reversal(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("mfi_period", 14))
    tp_price = (df["high"] + df["low"] + df["close"]) / 3
    mf = tp_price * df["volume"]
    pos_mf = mf.where(tp_price > tp_price.shift(1), 0).rolling(period).sum()
    neg_mf = mf.where(tp_price < tp_price.shift(1), 0).rolling(period).sum()
    mfi = 100 - (100 / (1 + pos_mf / (neg_mf + 1e-9)))
    thr = p.get("mfi_thr", 25)
    cross_up = (mfi > thr) & (mfi.shift(1) <= thr)
    bl = cross_up & (df["close"] > df["ema200"]) & (df["rsi_w"] > p.get("rsi_w_thr", 45))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)




def sig_tema_cross(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("tema_period", 21))
    ema1 = df["close"].ewm(span=period, adjust=False).mean()
    ema2 = ema1.ewm(span=period, adjust=False).mean()
    ema3 = ema2.ewm(span=period, adjust=False).mean()
    tema = 3 * ema1 - 3 * ema2 + ema3
    bl = (df["close"] > tema) & (df["close"].shift(1) <= tema.shift(1)) & (df["close"] > df["ema200"]) & (df["rsi_w"] > p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_ichimoku(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    tenkan_p = int(p.get("tenkan", 9))
    kijun_p = int(p.get("kijun", 26))
    senkou_p = int(p.get("senkou", 52))
    tenkan = (df["high"].rolling(tenkan_p).max() + df["low"].rolling(tenkan_p).min()) / 2
    kijun = (df["high"].rolling(kijun_p).max() + df["low"].rolling(kijun_p).min()) / 2
    senkou_a = ((tenkan + kijun) / 2).shift(kijun_p)
    senkou_b = ((df["high"].rolling(senkou_p).max() + df["low"].rolling(senkou_p).min()) / 2).shift(kijun_p)
    cloud_top = senkou_a.combine(senkou_b, max)
    above_cloud = df["close"] > cloud_top
    bullish_break = above_cloud & ~above_cloud.shift(1).fillna(False)
    bl = bullish_break & (tenkan > kijun) & (df["rsi_w"] > p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_pivot_bounce(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("pivot_period", 24))
    pivot = (df["high"].rolling(period).max() + df["low"].rolling(period).min() + df["close"]) / 3
    s1 = 2 * pivot - df["high"].rolling(period).max()
    near_s1 = (df["low"] <= s1 * 1.005) & (df["close"] > s1)
    bull_ok = df["rsi_w"] > p.get("rsi_w_thr", 45)
    bl = near_s1 & (df["close"] > df["ema200"]) & bull_ok & (df["volume"] > df["vol_ma"] * p.get("vol_mult", 1.0))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_trend_strength(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("adx_period", 14))
    up_move = (df["high"] - df["high"].shift(1)).clip(lower=0)
    down_move = (df["low"].shift(1) - df["low"]).clip(lower=0)
    plus_di = 100 * up_move.rolling(period).mean() / (df["atr"] + 1e-9)
    minus_di = 100 * down_move.rolling(period).mean() / (df["atr"] + 1e-9)
    dx = 100 * (plus_di - minus_di).abs() / (plus_di + minus_di + 1e-9)
    adx = dx.rolling(period).mean()
    bull_trend = (plus_di > minus_di) & (adx > p.get("adx_thr", 25))
    bl = bull_trend & ~bull_trend.shift(1).fillna(False) & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_elder_impulse(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    ema_rising = df["ema21"] > df["ema21"].shift(1)
    macd_rising = df["macd_h"] > df["macd_h"].shift(1)
    impulse_up = ema_rising & macd_rising
    bl = impulse_up & ~impulse_up.shift(1).fillna(False) & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 48))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_squeeze_pro(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("sq_period", 20))
    bb_std = df["close"].rolling(period).std()
    bb_upper = df["close"].rolling(period).mean() + 2 * bb_std
    bb_lower = df["close"].rolling(period).mean() - 2 * bb_std
    kc_upper = df["ema21"] + 1.5 * df["atr"]
    kc_lower = df["ema21"] - 1.5 * df["atr"]
    squeezed = (bb_upper < kc_upper) & (bb_lower > kc_lower)
    release = ~squeezed & squeezed.shift(1).fillna(False)
    bl = release & (df["close"] > df["close"].rolling(period).mean()) & (df["rsi_w"] > p.get("rsi_w_thr", 50))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_obv_divergence(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    direction = (df["close"] - df["close"].shift(1)).apply(lambda x: 1 if x > 0 else (-1 if x < 0 else 0))
    obv = (direction * df["volume"]).cumsum()
    lb = int(p.get("div_lookback", 14))
    price_at_min = df["close"] <= df["close"].rolling(lb).min() * 1.005
    obv_higher = obv > obv.shift(lb)
    bl = price_at_min & obv_higher & (df["rsi_w"] > p.get("rsi_w_thr", 45)) & (df["close"] > df["ema200"] * 0.97)
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_chaikin_mf(df, p):
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("cmf_period", 20))
    mfm = ((df["close"] - df["low"]) - (df["high"] - df["close"])) / (df["high"] - df["low"] + 1e-9)
    mfv = mfm * df["volume"]
    cmf = mfv.rolling(period).sum() / (df["volume"].rolling(period).sum() + 1e-9)
    thr = p.get("cmf_thr", 0.05)
    cross_up = (cmf > thr) & (cmf.shift(1) <= thr)
    bl = cross_up & (df["close"] > df["ema50"]) & (df["rsi_w"] > p.get("rsi_w_thr", 45))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)




def sig_htf_divergence(df, p):
    """Long: HTF (ema200) sube pero precio actual hace lower low (divergencia con HTF)."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    lb = int(p.get("div_lookback", 20))
    ema200_rising = df["ema200"] > df["ema200"].shift(lb)
    price_at_min = df["close"] <= df["close"].rolling(lb).min() * 1.005
    # Divergencia: HTF (ema200) sube pero precio inmediato hace mínimo
    div = ema200_rising & price_at_min
    rsi_oversold = df["rsi14"] < p.get("rsi_max", 50)
    htf_ok = df.get("htf_bull", pd.Series(True, index=df.index)) | df.get("htf_range", pd.Series(True, index=df.index))
    bl = div & rsi_oversold & htf_ok & (df["rsi_w"] > p.get("rsi_w_thr", 45))
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_vwap_deviation(df, p):
    """Long: precio cae N% bajo VWAP cumulativo, rebota."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("vwap_period", 30))
    tp_price = (df["high"] + df["low"] + df["close"]) / 3
    vwap_num = (tp_price * df["volume"]).rolling(period).sum()
    vwap_den = df["volume"].rolling(period).sum()
    vwap = vwap_num / (vwap_den + 1e-9)
    deviation = (df["close"] - vwap) / vwap * 100
    thr = p.get("dev_thr", -2.0)
    bounce = (deviation > thr) & (deviation.shift(1) <= thr)
    above_200 = df["close"] > df["ema200"] * 0.97
    bull_ok = df["rsi_w"] > p.get("rsi_w_thr", 45)
    bl = bounce & above_200 & bull_ok
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


def sig_volatility_breakout(df, p):
    """Long: ATR expande (vol creciente) + precio rompe arriba con momentum."""
    slm = p["sl_mult"]; tpm = p["tp_mult"]; cd = p["cooldown"]
    period = int(p.get("vb_period", 14))
    atr_now = df["atr"]
    atr_avg = df["atr"].rolling(period).mean()
    vol_expanding = atr_now > atr_avg * p.get("vol_expand", 1.3)
    range_high = df["high"].rolling(period).max().shift(1)
    breakout = (df["close"] > range_high) & vol_expanding
    macd_bull = df["macd_h"] > 0
    bull_ok = df["rsi_w"] > p.get("rsi_w_thr", 50)
    bl = breakout & macd_bull & bull_ok & (df["close"] > df["ema200"])
    bl, bs = apply_regime_gate(df, bl, pd.Series(False, index=df.index))
    return _apply_cd(df, bl, bs, slm, tpm, cd)


SIG_FN = {
    'breakout':          sig_breakout,
