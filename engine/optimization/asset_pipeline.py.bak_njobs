        base.update({'bb_period': trial.suggest_int('bb_period', 14, 30),

                     'bb_k': trial.suggest_float('bb_k', 1.5, 2.5),

                     'squeeze_bars': trial.suggest_int('squeeze_bars', 3, 12),

                     'vol_mult': trial.suggest_float('vol_mult', 1.0, 2.5)})

    elif strategy in ['bos_long', 'bos_short']:

        base.update({'lookback': trial.suggest_int('lookback', 10, 40),

                     'vol_mult': trial.suggest_float('vol_mult', 1.0, 2.5)})


    return base


def _cleanup_optuna_storage():
    """Elimina trials muy viejos del storage para evitar que crezca indefinidamente.
    Mantiene los últimos 500 trials por study. Corre esporádicamente."""
    try:
        import random
        if random.random() > 0.02:  # solo 2% de las veces
            return
        storage_path = str(OUTPUT_DIR / 'models' / 'optuna_studies.db')
        storage_url  = f"sqlite:///{storage_path}?timeout=30"
        summaries = optuna.get_all_study_summaries(storage=storage_url)
        for s in summaries:
            study = optuna.load_study(study_name=s.study_name, storage=storage_url)
            trials = sorted(study.trials, key=lambda t: t.number)
            if len(trials) > 500:
                # Eliminar los más viejos manteniendo los 500 mejores/recientes
                to_delete = trials[:-500]
                for t in to_delete:
                    try:
                        study._storage.delete_trial(study._study_id, t._trial_id)
                    except:
                        pass
    except:
        pass


def optimize_strategy(df_is, strategy, n_trials, days_is, symbol='?', tf='?'):
    sig_fn = SIG_FN.get(strategy) or SIG_FN_SHORT.get(strategy) or SIG_FN_ADAPTIVE.get(strategy) or SIG_FN_1M.get(strategy)
    if not sig_fn:
        return {}, 3.3, -9999

    # per_study DBs son pequeños (100-200KB) y no necesitan cleanup central
    # _cleanup_optuna_storage()  # disabled: lee 19GB shared DB en cada ciclo

    best_score = [-9999]

    def objective(trial):
        p  = build_search_space(trial, strategy)
        rp = trial.suggest_float('risk_pct', 2.0, 5.0, step=0.1)
        try:
            sig, sl, tp = sig_fn(df_is, p)
            if (sig != 0).sum() < 20: return -9999
            # Pruning: evalua primer 33% IS (activa MedianPruner)
            try:
                _n3 = max(len(df_is)//3, 200)
                _df3 = df_is.iloc[:_n3]
                _days3 = max((_df3.index[-1] - _df3.index[0]).days, 1)
                _sig3 = sig.iloc[:_n3]; _sl3 = sl.iloc[:_n3]; _tp3 = tp.iloc[:_n3]
                if (_sig3 != 0).sum() >= 5:
                    _dt3, _eq3 = backtest(_df3, _sig3, _sl3, _tp3, rp)
                    _m3 = metrics(_dt3, _eq3, _days3, min_t=3)
                    _s3 = float(score(_m3)) if _m3 else -9999
                    trial.report(_s3, step=0)
                    if trial.should_prune():
                        raise optuna.TrialPruned()
            except optuna.TrialPruned:
                raise
            except: pass
            dt, eq = backtest(df_is, sig, sl, tp, rp)
            m = metrics(dt, eq, days_is)
            s = float(score(m)) if m else -9999
            # 2026-06-11: penalizacion DD para 15m — guia Optuna hacia soluciones mas limpias
            # Penalty crece de 0% (DD 25%) a 30% (DD 50%+). No afecta otros TFs.
            if s > -9999 and m and tf == '15m':
                _dd_val = abs(m.get('dd', 0) or 0)
                if _dd_val > 25:
                    _dd_pen = min((_dd_val - 25) / 25 * 0.30, 0.30)
                    s = round(s * (1 - _dd_pen), 4)
            if _db_ok and m and m['trades'] >= 10 and s >= best_score[0] - 0.03:
                try: save_run(tf, strategy, p, m, s, symbol=symbol)
                except: pass
            if s > best_score[0]:
                best_score[0] = s
            return s
        except:
            return -9999

    # Progreso cada 30 trials
    def cb(study, trial):
        if trial.number > 0 and trial.number % 30 == 0:
            best = study.best_value if study.best_value and study.best_value > -9999 else 0
            print(f'    [{symbol} {tf}] T{trial.number}/{n_trials} | mejor score={best:.3f}', flush=True)
        if trial.number >= 60 and trial.number % 5 == 0:
            _rv = [t.value for t in study.trials[-55:] if t.value is not None and t.value > -9999]
            if len(_rv) >= 50 and max(_rv) < study.best_value - 0.0005: study.stop()

    # Storage persistente: cada (symbol, tf, strategy) acumula conocimiento entre ciclos
    sym_clean   = (symbol or '').replace('/USDT','').replace('/','').lower()
    study_name  = f"{sym_clean}_{tf}_{strategy}"
    # SQLite por estudio: elimina lock contention entre workers paralelos
    _optuna_dir = OUTPUT_DIR / 'models' / 'optuna_per_study'
    _optuna_dir.mkdir(parents=True, exist_ok=True)
    storage_path = str(_optuna_dir / f'{sym_clean}_{tf}_{strategy}.db')
    storage_url  = f"sqlite:///{storage_path}?timeout=30"
    # WAL: reduce write contention con workers paralelos
    try:
        import sqlite3 as _s3
        _wc = _s3.connect(storage_path, timeout=10)
        _wc.execute("PRAGMA journal_mode=WAL")
        _wc.close()
    except: pass

    try:
        study = optuna.create_study(
            direction     = 'maximize',
            study_name    = study_name,
            storage       = storage_url,
            load_if_exists= True,
            sampler       = (optuna.samplers.CmaEsSampler(seed=42, restart_strategy="ipop") if strategy in {"regime_adaptive"} else optuna.samplers.TPESampler(seed=42, n_startup_trials=20)),
            pruner        = optuna.pruners.MedianPruner(n_startup_trials=10, n_warmup_steps=5),
        )
    except Exception:
        # Fallback in-memory si SQLite falla (permisos, disco lleno, etc.)
        study = optuna.create_study(
            direction='maximize',
            sampler=optuna.samplers.TPESampler(seed=42),
        )

    # Warm-start solo si el study es nuevo (< 20 trials guardados)
    # Si ya tiene historia, el sampler ya sabe qué funciona
    if len(study.trials) < 20 and _db_ok:
        try:
            top = get_top_runs_by_strategy(tf, strategy, n=10, min_trades=10)
            if len(top) < 5:
                top += get_top_runs(tf, n=8, min_trades=10)
            enqueued = 0
            for run in top:
                try:
                    p = json.loads(run['params']) if isinstance(run['params'], str) else run['params']
                    if len(p) >= 2:
                        study.enqueue_trial(p, skip_if_invalid=True)
                        enqueued += 1
                        if enqueued >= 8:
                            break
                except:
                    continue
        except:
            pass

    import gc as _gc; _gc.disable()
    try:
        study.optimize(objective, n_trials=n_trials, callbacks=[cb], show_progress_bar=False, n_jobs=2)
    finally:
        _gc.enable(); _gc.collect()

    bp = {k: v for k, v in study.best_params.items() if k != 'risk_pct'}
    rp = study.best_params.get('risk_pct', 3.3)
    return bp, rp, study.best_value


# ── PIPELINE CORE ─────────────────────────────────────────────────────────────

EVENTS_FILE = OUTPUT_DIR / 'results' / 'reports' / 'pipeline_events.jsonl'

def log(symbol, tf, msg):
    ts = datetime.now().strftime('%H:%M:%S')
    print(f'  [{ts}] [{symbol} {tf.upper()}] {msg}', flush=True)


def log_event(asset, tf, strategy, result, cagr_oos=None, wr=None, note='', trades_oos=None):
    """Escribe un evento estructurado al feed del dashboard."""
    ev = {
        'ts':       datetime.now().strftime('%H:%M'),
        'asset':    asset,
        'tf':       tf.upper(),
        'strategy': strategy,
        'result':   result,       # GUARDADO / NUEVO_RECORD / OOS_NEG / SIN_TRADES / ERROR
        'cagr_oos': round(cagr_oos, 1) if cagr_oos is not None else None,
        'wr':       round(wr, 1)  if wr       is not None else None,
        'trades_oos': int(trades_oos) if trades_oos is not None else None,
        'note':     note,
    }
    try:
        EVENTS_FILE.parent.mkdir(parents=True, exist_ok=True)
        # Lock-protected append + trim (audit 2026-05-14)
        with open(EVENTS_FILE, 'a+', encoding='utf-8') as f:
            fcntl.flock(f.fileno(), fcntl.LOCK_EX)
            try:
                f.write(json.dumps(ev) + '\n')
                f.flush()
                lines = EVENTS_FILE.read_text(encoding='utf-8').splitlines()
                if len(lines) > 200:
                    EVENTS_FILE.write_text('\n'.join(lines[-200:]) + '\n', encoding='utf-8')
            finally:
                fcntl.flock(f.fileno(), fcntl.LOCK_UN)
    except:
        pass




# ============================================================
# Telegram notification — nuevo campeon de modelo
# ============================================================
import urllib.request as _urlreq, urllib.parse as _urlparse
import json as _json_tg

_TG_TOKEN   = _sigma_get_tg_token()
_TG_CHAT_ID = "-1003787411069"
_TG_COOLDOWN_FILE = "/opt/sigma/results/reports/tg_champion_cooldown.json"

def _tg_send_champion(text):
    """Manda mensaje al grupo, silencioso para no despertar."""
    try:
        url = f"https://api.telegram.org/bot{_TG_TOKEN}/sendMessage"
        data = _urlparse.urlencode({
            "chat_id": _TG_CHAT_ID,
            "text": text,
            "parse_mode": "HTML",
            "disable_web_page_preview": "true",
            "disable_notification": "false",
        }).encode("utf-8")
        req = _urlreq.Request(url, data=data)
        _urlreq.urlopen(req, timeout=10)
        return True
    except Exception:
        return False


def _read_prev_cagr(symbol, tf, strategy):
    """Lee el CAGR del modelo anterior (si existe) antes de sobrescribir."""
    try:
        from pathlib import Path as _P
        sym_clean = symbol.replace('/', '').replace('USDT', '').replace('USD', '').lower()
        out_dir   = OUTPUT_DIR / 'models' / tf
        fname     = f'{sym_clean}_{strategy}.json'
        p = out_dir / fname
        if not p.exists():
            return None
        d = _json_tg.loads(p.read_text())
        return d.get('metrics_oos', {}).get('cagr', None)
    except Exception:
        return None


def _check_cooldown_and_set(key, hours=24):
    """True si paso el cooldown desde el ultimo envio de esa key."""
    import time as _t, os as _os
    now = _t.time()
    try:
        if _os.path.exists(_TG_COOLDOWN_FILE):
            with open(_TG_COOLDOWN_FILE) as f:
                cd = _json_tg.load(f)
        else:
            cd = {}
        last = cd.get(key, 0)
        if now - last < hours * 3600:
            return False
        cd[key] = now
        try:
            with open(_TG_COOLDOWN_FILE, 'w') as f:
                _json_tg.dump(cd, f)
        except: pass
        return True
    except Exception:
        return True


def _tg_new_champion(symbol, tf, strategy, m_oos, prev_cagr, params):
    """Notifica al grupo cuando se guarda un nuevo campeon."""
    try:
        # Sin cooldown: cada save_model = 1 aviso independiente
        cagr  = m_oos.get('cagr', 0)
        wr    = m_oos.get('wr', 0)
        dd    = m_oos.get('dd', 0)
        pf    = m_oos.get('pf', 0)
        ty    = m_oos.get('trades_year', 0)
        tr    = m_oos.get('trades', 0)
        sl_m  = params.get('sl_mult', 0)
        tp_m  = params.get('tp_mult', 0)
        if prev_cagr is not None:
            diff = cagr - prev_cagr
            comp = f"<b>{cagr:.1f}%</b> (antes {prev_cagr:.1f}% → {diff:+.1f}pp)"
        else:
            comp = f"<b>{cagr:.1f}%</b> (primer modelo positivo)"
        grade = "A+" if cagr >= 40 else ("A" if cagr >= 25 else ("B" if cagr >= 15 else "C"))
        msg = (
            "⭐ <b>NUEVO CAMPEÓN — " + symbol.replace("/USDT","") + " " + tf.upper() + "</b>" + chr(10) + chr(10) +
            "Estrategia: <code>" + strategy + "</code>" + chr(10) +
            "Grade: <b>" + grade + "</b>" + chr(10) + chr(10) +
            "CAGR OOS: " + comp + chr(10) +
            "WR: <code>" + str(int(wr)) + "%</code>  DD: <code>" + str(round(dd, 1)) + "%</code>" + chr(10) +
            "Profit Factor: <code>" + str(round(pf, 2)) + "</code>  Trades/año: <code>" + str(round(ty, 1)) + "</code>" + chr(10) +
            "Trades OOS: <code>" + str(int(tr)) + "</code>  Score: <code>" + str(round(score(m_oos), 3)) + "</code>" + chr(10) +
            "sl_mult=" + str(sl_m) + "  tp_mult=" + str(tp_m) + "  (SL/TP se calculan al firmar señal)" + chr(10) + chr(10) +
            "Reemplaza al modelo anterior automáticamente."
        )
        _ok = _tg_send_champion(msg)
        try:
            with open("/opt/sigma/results/reports/tg_champion_sent.log", "a") as _lf:
                _status = "SENT" if _ok else "FAILED"
                _lf.write(f"{datetime.now(timezone.utc).replace(tzinfo=None).isoformat()} {_status} symbol={symbol} tf={tf} strategy={strategy} cagr={cagr:.2f}\n")
        except Exception:
            pass
    except Exception as _tg_err:
        try:
            with open("/opt/sigma/results/reports/tg_champion_sent.log", "a") as _lf:
                _lf.write(f"{datetime.now(timezone.utc).replace(tzinfo=None).isoformat()} FAILED symbol={symbol} tf={tf} strategy={strategy} err={_tg_err!r}\n")
        except Exception:
            pass


def save_model(symbol, tf, strategy, params, risk_pct, m_is, m_oos, oos_days=0):
    sym_clean = symbol.replace('/', '').replace('USDT', '').lower()
    out_dir   = OUTPUT_DIR / 'models' / tf
    out_dir.mkdir(parents=True, exist_ok=True)
    fname = f'{sym_clean}_breakout.json' if strategy == 'breakout' else f'{sym_clean}_{strategy}.json'
    result = {
        'symbol': symbol, 'tf': tf, 'strategy': strategy,
        'params': params, 'risk_pct': risk_pct,
        'metrics_is': m_is, 'metrics_oos': m_oos,
        'oos_days': oos_days,
        'saved_at': str(datetime.now()),
    }
    with open(out_dir / fname, 'w') as f:
        json.dump(result, f, indent=2, default=str)
    log(symbol, tf, f'[SAVED] models/{tf}/{fname} — OOS {m_oos["cagr"]:+.1f}% WR {m_oos["wr"]:.1f}%')
    # Regenerar Pine Script en background para no bloquear el pipeline
    try:
        import threading
        def _regen():
            try:
                import subprocess, sys
                subprocess.run(
                    [sys.executable, str(OUTPUT_DIR / 'engine' / 'live' / 'pine_generator.py')],
                    cwd=str(OUTPUT_DIR), capture_output=True, timeout=120
                )
            except: pass
        threading.Thread(target=_regen, daemon=True).start()
    except: pass
    return out_dir / fname


def _all_model_names(sym):
    """Lista de nombres de archivo de modelos para un símbolo."""
    strategies = [
        # STRATEGIES — originales core
        'breakout', 'pullback', 'tma_bands', 'momentum', 'mean_rev', 'regime_adaptive',
        # STRATEGIES_SHORT
        'breakdown', 'pullback_short', 'momentum_short',
        'rsi_overbought_short', 'death_cross_short', 'ema200_rejection_short', 'macd_bear_cross',
        'lower_high_break_short', 'wedge_breakdown_short', 'supply_zone_rejection', 'bearish_rsi_divergence',
        'volume_climax_top', 'range_break_down', 'macd_zero_cross_down',
        # STRATEGIES_1M — scalping
        'micro_momentum', 'session_open', 'vwap_bounce', 'range_scalp', 'tick_follow',
        # STRATEGIES_EXPLORE — indicadores avanzados
        'funding_reversal', 'volatility_breakout', 'htf_divergence', 'rsi_divergence',
        'bb_squeeze', 'ema_triple', 'supertrend', 'break_of_structure',
        'cvd_divergence', 'vwap_deviation', 'inside_bar', 'pin_bar',
        'heikin_ashi', 'macd_divergence', 'keltner_breakout', 'rsi_trend',
        'ema50_bounce', 'volume_climax',
        # STRATEGIES_NEW — sistemas completos
        'ema_ribbon', 'hull_cross', 'tema_cross', 'wma_momentum',
        'stoch_rsi', 'cci_reversal', 'williams_r', 'mfi_reversal', 'roc_momentum',
        'dmi_trend', 'higher_highs', 'lower_lows', 'aroon_cross',
        'psar_flip', 'donchian_break', 'trend_strength', 'elder_impulse',
        'engulfing', 'three_candles', 'consecutive_wick', 'volume_exhaustion',
        'chaikin_mf', 'obv_divergence', 'zscore_reversion', 'bb_bandwidth',
        'ichimoku', 'pivot_bounce', 'atr_channel', 'linear_reg_break',
        'squeeze_pro', 'open_close_cross', 'funding_momentum',
    ]
    names = [f'{sym}_{s}.json' for s in strategies]
    # Nombres legacy de BTC por compatibilidad con archivos viejos en disco
    if sym in ('btc', 'btcusdt'):
        names += [
            'best_bull_breakout.json', 'best_validated.json', 'best_bull_pullback.json',
            'best_bull_tma_bands.json', 'best_bull_momentum.json', 'best_bull_mean_rev.json',
        ]
    return names


def _load_current_best_score(symbol, tf):
    """Score ponderado (40%CAGR+20%WR+20%freq+15%Cal+5%PF) del mejor modelo guardado."""
    sym = symbol.replace('/USDT','').replace('/','').lower()
    d   = OUTPUT_DIR / 'models' / tf
    best = -999.0
    for fname in _all_model_names(sym):
        p = d / fname
        if not p.exists(): continue
        try:
            data = json.loads(p.read_text())
            m    = data.get('metrics_oos') or {}
            if not m: continue
            s = score(m)
            if s > best:
                best = s
        except:
            continue
    return best


def _quick_wft(df, sig_fn, params, n_windows=None, min_pass_rate=0.55):
    """
    Walk-Forward rápido adaptado al TF. Retorna True si >= min_pass_rate ventanas son positivas.
    Ajusta ventanas y mínimo de trades según frecuencia del TF para evitar ruido estadístico.
    """
    n = len(df)
    if n < 200: return True

    # Detectar frecuencia para ajustar parámetros del WFT
    freq_min = (df.index[-1] - df.index[0]).total_seconds() / 60 / max(n-1, 1)
    if freq_min <= 30:       # 5m/15m — alta frecuencia, muchos trades por ventana
        n_windows  = n_windows or 5
        min_trades = 5
    elif freq_min <= 90:     # 1H — frecuencia media
        n_windows  = n_windows or 4
        min_trades = 4
    else:                    # 4H/1D — baja frecuencia, pocas trades
        n_windows  = n_windows or 3
        min_trades = 3   # mínimo muy bajo para no descartar por mala suerte

    window   = n // (n_windows + 1)
    positive = 0
    tried    = 0
    for i in range(n_windows):
        start = i * window
        split = start + window
        end   = split + window
        if end > n: break
        df_oos_w = df.iloc[split:end]
        days_w   = max((df_oos_w.index[-1] - df_oos_w.index[0]).days, 1)
        try:
            sig, sl, tp = sig_fn(df_oos_w, params)
            dt, eq = backtest(df_oos_w, sig, sl, tp, 1.0, use_kelly=False)
            m = metrics(dt, eq, days_w, min_t=min_trades)
            if m and m['cagr'] > 0:
                positive += 1
            tried += 1
        except:
            tried += 1
    if tried == 0: return True
    return (positive / tried) >= min_pass_rate


def run_pipeline(symbol, tf, n_trials=350, loop=False, max_cycles=99, csv_path=None):
    sym_clean = symbol.replace('/', '').replace('USDT', '').lower()
    asset     = symbol.replace('/USDT', '').replace('/', '')  # "ETH", "XRP", etc.
    log_path  = OUTPUT_DIR / 'results' / 'reports' / f'{sym_clean}_{tf}_pipeline.log'
    log_path.parent.mkdir(parents=True, exist_ok=True)

    # Seleccionar estrategias y funciones segun TF
    is_1m      = (tf == '1m')
    # Rotacion completa: long (5) + short (3) + scalping (5 para 1m)
    if is_1m:
        strategies = STRATEGIES_1M
        sig_map    = SIG_FN_1M
    else:
        # Adaptive PRIMERO — opera en cualquier regimen, especialmente valioso en BEAR
        # Luego long, luego short
        strategies = STRATEGIES_ADAPTIVE + STRATEGIES + STRATEGIES_SHORT
        sig_map    = {**SIG_FN_ADAPTIVE, **SIG_FN, **SIG_FN_SHORT}
    # 1m=400d, 15m=1000d (suficiente sin exceder disponible en alts), resto=3200d
    days_data  = 400 if is_1m else (1000 if tf == '15m' else 3200)

    print(f'\n{"="*65}')
    print(f'  SIGMA ASSET PIPELINE — {symbol} {tf.upper()}')
    n_long  = len(STRATEGIES)
    n_short = len(STRATEGIES_SHORT)
    n_adapt = len(STRATEGIES_ADAPTIVE)
    print(f'  {n_long} long + {n_short} short + {n_adapt} adaptive = {n_long+n_short+n_adapt} estrategias | {n_trials} trials c/u')
    if is_1m:
        print(f'  Modo SCALPING: TP/SL fijo en % | busca WR > 55%')
    print(f'{"="*65}\n')

    # Download data once
    log(symbol, tf, 'Descargando datos...')
    if csv_path:
        log(symbol, tf, f'Cargando desde CSV: {csv_path}')
        df_raw = load_asset_csv(csv_path)
    else:
        df_raw = fetch_asset(symbol, tf, days=days_data)
    if df_raw is None or len(df_raw) < 500:
        log(symbol, tf, 'ERROR: sin datos suficientes')
        return

    df = add_features(df_raw)
    n  = len(df); split = int(n * 0.80)
    df_is  = df.iloc[:split]
    # Pre-cast a float64 una vez: evita conversiones repetidas en cada trial
    for _col in ("close","high","low","open","volume"):
        if _col in df_is.columns and df_is[_col].dtype != __import__("numpy").float64:
            df_is = df_is.copy(); df_is[_col] = df_is[_col].astype(__import__("numpy").float64); break
    df_is = df_is.astype({c: __import__("numpy").float64 for c in ("close","high","low","open","volume") if c in df_is.columns})
    df_oos = df.iloc[split:]
    days_is  = (df_is.index[-1] - df_is.index[0]).days
    days_oos = (df_oos.index[-1] - df_oos.index[0]).days

    log(symbol, tf, f'{len(df):,} velas | IS {days_is}d | OOS {days_oos}d')

    # Cargar el score del modelo guardado actualmente — solo mejoramos si lo superamos
    best_oos_score = _load_current_best_score(symbol, tf)
    if best_oos_score > 0:
        log(symbol, tf, f'Modelo actual: score {best_oos_score:.4f} — solo guardo si lo supero')
    else:
        log(symbol, tf, f'Sin modelo previo — guardo el primero positivo que encuentre')
    best_strategy = None
    cycle = 0

    while cycle < max_cycles:
        cycle += 1
        log(symbol, tf, f'--- Ciclo {cycle} ---')

        for strategy in strategies:
            # Para estrategias SHORT: optimizar solo en períodos BEAR/RANGE del IS
            # Esto da más densidad de trades bajistas a Optuna, que solo ve ~20-25% bear en IS completo
            if strategy in STRATEGIES_SHORT:
                if 'regime_bear' in df_is.columns and 'regime_range' in df_is.columns:
                    df_opt = df_is[df_is['regime_bear'] | df_is['regime_range']]
                elif 'regime_bear' in df_is.columns:
                    df_opt = df_is[df_is['regime_bear']]
                else:
                    df_opt = df_is
                # Fallback: si hay muy pocas barras usar IS completo
                if len(df_opt) < 500:
                    df_opt = df_is
                days_opt = max((df_opt.index[-1] - df_opt.index[0]).days, 30) if len(df_opt) > 10 else days_is
                # Más trials para shorts: necesitan más búsqueda con datos escasos
                n_trials_this = int(n_trials * 1.5)
            else:
                # LONG y ADAPTIVE: usar IS completo (ya tienen suficiente bull)
                df_opt = df_is
                days_opt = days_is
                n_trials_this = n_trials

            log(symbol, tf, f'Probando: {strategy} ({n_trials_this} trials)...')
            try:
                bp, rp, best_is_score = optimize_strategy(df_opt, strategy, n_trials_this, days_opt, symbol, tf)
            except Exception as e:
                log(symbol, tf, f'  {strategy} ERROR: {e}')
                continue

            if best_is_score <= 0:
                log(symbol, tf, f'  {strategy}: IS score {best_is_score:.3f} — sin edge en IS, skip')
                log_event(asset, tf, strategy, 'SIN_EDGE_IS', note='IS score <= 0')
                continue

            # Eval IS
            try:
                sig_is, sl_is, tp_is = sig_map[strategy](df_is, bp)
                dt_is, eq_is = backtest(df_is, sig_is, sl_is, tp_is, rp)
                m_is = metrics(dt_is, eq_is, days_is)
            except:
                m_is = None

            if not m_is:
                log(symbol, tf, f'  {strategy}: IS sin trades suficientes, skip')
                continue

            # Eval OOS
            try:
                sig_oos, sl_oos, tp_oos = sig_map[strategy](df_oos, bp)
                dt_oos, eq_oos = backtest(df_oos, sig_oos, sl_oos, tp_oos, rp)
                m_oos = metrics(dt_oos, eq_oos, days_oos, min_t=10)
            except:
                m_oos = None

            if not m_oos:
                log(symbol, tf, f'  {strategy}: OOS sin trades (<10), probando siguiente...')
                log_event(asset, tf, strategy, 'SIN_TRADES', note='OOS < 5 trades, params muy selectivos')
                continue

            cagr_oos = m_oos['cagr']
            log(symbol, tf,
                f'  {strategy}: IS {m_is["trades"]}T WR{m_is["wr"]:.0f}% CAGR{m_is["cagr"]:+.1f}% '
                f'-> OOS {m_oos["trades"]}T WR{m_oos["wr"]:.0f}% CAGR{cagr_oos:+.1f}%')

            # Anti-overfitting: si IS >> OOS por más de 2.5x, el modelo memorizó el IS
            if m_is and m_oos and m_is.get('cagr', 0) > 0 and cagr_oos > 0:
                overfit_ratio = m_is['cagr'] / cagr_oos
                if overfit_ratio > 2.0:
                    log(symbol, tf,
                        f'  {strategy}: OVERFIT detectado — IS {m_is["cagr"]:+.1f}% vs OOS {cagr_oos:+.1f}% '
                        f'(ratio {overfit_ratio:.1f}x > 2.0) — descartando')
                    log_event(asset, tf, strategy, 'OVERFIT',
                              cagr_oos=cagr_oos, wr=m_oos['wr'],
                              note=f'IS/OOS ratio {overfit_ratio:.1f}x')
                    continue

            if cagr_oos > 0:
                # Soft guard: primer champion requiere N>=20 trades OOS para evitar muestras chicas.
                # Reemplazos de un champion ya existente siguen rigiendose por score.
                trades_oos_n = m_oos.get('trades', 0) if isinstance(m_oos, dict) else 0
                is_first_champion = best_oos_score <= -900
                min_n_required = 20 if is_first_champion else 12
                if trades_oos_n < min_n_required:
                    log(symbol, tf, f'  {strategy}: CAGR+ pero N OOS insuficiente ({trades_oos_n} < {min_n_required}), descartando')
                    log_event(asset, tf, strategy, 'LOW_N_OOS',
                              cagr_oos=cagr_oos, wr=m_oos.get('wr'),
                              note=f'N OOS insuficiente ({trades_oos_n} < {min_n_required})',
                              trades_oos=trades_oos_n)
                    continue
                # Gate: CAGR extremo requiere validacion MC robusta
                if cagr_oos > 150:
                    mc_data = (champ_mc.get((asset, tf, strategy), {}) if 'champ_mc' in vars() or 'champ_mc' in globals() else {})
                    mc_p = mc_data.get('p_pos', 100) if mc_data else 100
                    try:
                        from engine.analysis.auto_validator import quick_mc
                        mc_p = quick_mc(dt_oos['pnl'].tolist())
                    except Exception:
                        pass
                    if mc_p < 70:
                        log(symbol, tf,
                            f'  {strategy}: CAGR irreal ({cagr_oos:+.1f}%) con MC p_pos={mc_p:.0f}% < 70%, descartando')
                        log_event(asset, tf, strategy, 'CAGR_TOO_HIGH_MC',
                                  cagr_oos=cagr_oos, wr=m_oos['wr'],
                                  note=f'CAGR {cagr_oos:.0f}% pero MC p_pos {mc_p:.0f}%')
                        continue
                new_score = score(m_oos)
                if new_score > best_oos_score:
                    prev = best_oos_score
                    best_oos_score = new_score
                    best_strategy  = strategy
                    # Walk-Forward rápido — solo guardar si >= 55% de ventanas son positivas
                    wft_ok = _quick_wft(df, sig_map[strategy], bp, n_windows=4)
                    if not wft_ok:
                        log(symbol, tf,
                            f'  {strategy}: WFT rápido FALLÓ — modelo no es robusto entre períodos, descartando')
                        log_event(asset, tf, strategy, 'WFT_FAIL',
                                  cagr_oos=cagr_oos, wr=m_oos['wr'],
                                  note='Quick WFT < 55% ventanas positivas',
                                  trades_oos=m_oos.get('trades'))
                        continue
                    log(symbol, tf, f'  {strategy}: WFT rápido OK — guardando modelo...')
                    _prev_cagr_tg = _read_prev_cagr(symbol, tf, strategy)
                    model_path = save_model(symbol, tf, strategy, bp, rp, m_is, m_oos, oos_days=days_oos)
                    note = (f'Supera modelo anterior (score {prev:.4f})' if prev > 0
                            else 'Primer modelo positivo')
                    log_event(asset, tf, strategy, 'NUEVO_RECORD',
                              cagr_oos=cagr_oos, wr=m_oos['wr'], note=note,
                              trades_oos=m_oos.get('trades'))
                    # Notificacion Telegram (con cooldown 2h por key sym_tf_strategy)
                    try:
                        _tg_new_champion(symbol, tf, strategy, m_oos, _prev_cagr_tg, bp)
                    except Exception:
                        pass
                    log(symbol, tf,
                        f'  NUEVO MEJOR: {strategy} score={new_score:.4f} '
                        f'OOS {cagr_oos:+.1f}% WR{m_oos["wr"]:.0f}% — validando...')
                    try:
                        from engine.analysis.auto_validator import validate
                        pnl_list   = dt_oos['pnl'].tolist() if not dt_oos.empty else []
                        asset_code = symbol.replace('/USDT', '')
                        passed, confidence, _ = validate(
                            model_path, df, sig_map[strategy], bp, rp,
                            pnl_list, asset_code, tf
                        )
                        log(symbol, tf, f'  Validacion completa: {confidence}')
                        log_event(asset, tf, strategy, f'VALIDADO_{confidence}',
                                  cagr_oos=cagr_oos, wr=m_oos['wr'])
                    except Exception as e:
                        log(symbol, tf, f'  Validacion error (modelo guardado igual): {e}')
                else:
                    log(symbol, tf,
                        f'  Positivo score={new_score:.4f} pero no mejor que '
                        f'{best_strategy} (score={best_oos_score:.4f})')
                    log_event(asset, tf, strategy, 'POSITIVO_NO_MEJOR',
                              cagr_oos=cagr_oos, wr=m_oos['wr'],
                              note=f'No supera score record {best_oos_score:.4f}',
                              trades_oos=m_oos.get('trades'))
            else:
                log(symbol, tf, f'  {strategy}: OOS negativo ({cagr_oos:+.1f}%), probando siguiente...')
                log_event(asset, tf, strategy, 'OOS_NEG',
                          cagr_oos=cagr_oos, note='Probando siguiente estrategia')

        # Summary after full cycle
        current_score = _load_current_best_score(symbol, tf)
        if best_strategy:
            log(symbol, tf,
                f'Ciclo {cycle} completo. Mejor: {best_strategy} score={best_oos_score:.4f} | '
                f'Guardado: {current_score:.4f}')
        else:
            log(symbol, tf,
                f'Ciclo {cycle} completo. Sin mejora. Mejor guardado: score={current_score:.4f}')
        best_oos_score = max(best_oos_score, current_score)

        if not loop:
            break

        # Refresh data for next cycle
        log(symbol, tf, f'Esperando 30min antes del siguiente ciclo...')
        time.sleep(1800)

        log(symbol, tf, 'Actualizando datos...')
        df_new = fetch_asset(symbol, tf, days=3200)
        if df_new is not None and len(df_new) > len(df_raw):
            df_raw = df_new
            df     = add_features(df_raw)
            n      = len(df); split = int(n * 0.80)
            df_is  = df.iloc[:split]; df_oos = df.iloc[split:]
            days_is  = (df_is.index[-1]-df_is.index[0]).days
            days_oos = (df_oos.index[-1]-df_oos.index[0]).days
            log(symbol, tf, f'Datos actualizados: {len(df):,} velas')

    print(f'\n{"="*65}')
    print(f'  PIPELINE FINALIZADO — {symbol} {tf.upper()}')
    if best_strategy:
        print(f'  Mejor estrategia: {best_strategy} | OOS score: {best_oos_score:.4f}')
    else:
        print(f'  Sin estrategia OOS positiva encontrada')
    print(f'{"="*65}\n')


# ==============================================================================
# Commodity strategies: 38 estrategias (19L+19S) con routing por activo
# XAU/XAG/PL -> precious_metals | WTI/NG -> energy | HG -> industrial
# Cada familia recibe 28 estrategias relevantes, no las 38 totales.
# Para escalar CPU: aumentar M2_PARALLEL en pipeline.py. No tocar aqui.
# ==============================================================================
try:
    _comm_opt_path = '/opt/sigma/engine/optimization'
    if _comm_opt_path not in sys.path:
        sys.path.insert(0, _comm_opt_path)
    import commodity_strategies as _comm_strats_mod
    _comm_strats_mod._bind(sys.modules[__name__])

    # Routing: estrategias especificas para este activo
    _sym_idx  = next((i+1 for i, a in enumerate(sys.argv) if a == '--symbol'), None)
    _sym_raw  = sys.argv[_sym_idx] if _sym_idx else ''
    _asset_cd = _sym_raw.split('/')[0].upper()
    _routed   = _comm_strats_mod.get_strategies_for(_asset_cd)

    # Registrar TODAS las funciones en globals
    for _fn_name in _comm_strats_mod.COMMODITY_STRATEGIES:
        _fn = getattr(_comm_strats_mod, 'sig_' + _fn_name, None)
        if _fn is not None:
            globals()['sig_' + _fn_name] = _fn

    # Solo agregar al pipeline las del routing del activo actual
    _comm_longs  = [n for n in _routed if not n.endswith('_short')]
    _comm_shorts = [n for n in _routed if n.endswith('_short')]

    for _fn_name in _comm_longs:
        if 'sig_' + _fn_name in globals():
            SIG_FN[_fn_name] = globals()['sig_' + _fn_name]
            if _fn_name not in STRATEGIES:
                STRATEGIES.append(_fn_name)
    for _fn_name in _comm_shorts:
        if 'sig_' + _fn_name in globals():
            SIG_FN_SHORT[_fn_name] = globals()['sig_' + _fn_name]
            if _fn_name not in STRATEGIES_SHORT:
                STRATEGIES_SHORT.append(_fn_name)

    print('[commodity_strategies] ' + _asset_cd + ': ' + str(len(_routed)) + ' estrategias (' + str(len(_comm_longs)) + 'L/' + str(len(_comm_shorts)) + 'S)', flush=True)

except Exception as _e_comm:
    print('[commodity_strategies] load error: ' + str(_e_comm), flush=True)

if __name__ == '__main__':
    p = argparse.ArgumentParser()
    p.add_argument('--symbol',  default='XRP/USDT')
    p.add_argument('--tf',      default='1h', choices=['4h','1h','15m','5m','1d'])
    p.add_argument('--trials',  type=int, default=350)
    p.add_argument('--loop',    action='store_true', help='Corre indefinidamente')
    p.add_argument('--focus',   choices=['long','short','both','all'], default='both', help='Direction filter (all accepted as compatibility)')
    p.add_argument('--csv_path', type=str, default=None, help='Cargar OHLCV desde CSV (bypass Binance) para activos como XAU')
    args = p.parse_args()
    run_pipeline(args.symbol, args.tf, args.trials, args.loop, csv_path=args.csv_path)


