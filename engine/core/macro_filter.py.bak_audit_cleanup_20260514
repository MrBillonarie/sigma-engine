def print_upcoming():
    """Muestra los proximos eventos macro."""
    print("\n  PROXIMOS EVENTOS MACRO (48h)")
    print(f"  {'Evento':<35} {'Pais':>6} {'Fecha UTC':>17} {'En':>8} {'Impacto':>8}")
    print(f"  {'-'*80}")
    events = get_upcoming_events(48)
    if not events:
        print("  Sin eventos de alto impacto en las proximas 48h")
        return
    for e in events[:10]:
        mins = e["minutes_away"]
        time_str = f"{mins//60}h {mins%60}m" if mins > 60 else f"{mins}min"
        print(f"  {e['event'][:34]:<35} {e['country']:>6} {e['time_utc']:>17} "
              f"{time_str:>8} {e.get('impact','?'):>8}")


if __name__ == "__main__":
    blocked, reason = is_blocked_now()
    if blocked:
        print(f"BLOQUEADO: {reason}")
    else:
        print("OK — Sin eventos macro activos")
    print_upcoming()
