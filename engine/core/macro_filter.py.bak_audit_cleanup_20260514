"""
SIGMA ENGINE — Macro Events Filter
Bloquea trading durante eventos de alto impacto: FOMC, CPI, NFP, etc.
Fuente: api gratuita de eventos economicos.

Regla: bloquear 30 min antes y 30 min despues de cada evento.
"""

import json
import requests
from datetime import datetime, timedelta
from pathlib import Path
import warnings
warnings.filterwarnings("ignore")

EVENTS_CACHE = Path(__file__).parent.parent.parent / "results" / "reports" / "macro_events.json"
EVENTS_CACHE.parent.mkdir(parents=True, exist_ok=True)

# Eventos de alto impacto que afectan BTC
HIGH_IMPACT_EVENTS = [
    "FOMC", "Federal Funds Rate", "Interest Rate Decision",
    "CPI", "Consumer Price Index",
    "NFP", "Non-Farm Payroll", "Nonfarm",
    "GDP", "Gross Domestic Product",
    "PCE", "Personal Consumption",
    "PPI", "Producer Price Index",
    "Unemployment Rate",
    "Initial Jobless Claims",
    "Retail Sales",
    "ISM Manufacturing",
    "Jackson Hole",
]

BLOCK_MINUTES_BEFORE = 30
BLOCK_MINUTES_AFTER  = 30


def fetch_events(days_ahead=7):
    """
    Descarga eventos economicos de la API gratuita de TradingEconomics/FMP.
    Fallback: lista hardcodeada de fechas conocidas.
    """
    # Intentar API publica gratuita (financialmodelingprep)
    try:
        url = "https://financialmodelingprep.com/api/v3/economic_calendar"
        params = {
            "from": datetime.utcnow().strftime("%Y-%m-%d"),
            "to":   (datetime.utcnow() + timedelta(days=days_ahead)).strftime("%Y-%m-%d"),
        }
        resp = requests.get(url, params=params, timeout=10)
        if resp.status_code == 200:
            events = resp.json()
            # Filtrar alto impacto
            high_impact = [
                e for e in events
                if e.get("impact") == "High" or
                any(kw.lower() in e.get("event","").lower() for kw in HIGH_IMPACT_EVENTS)
            ]
            # Guardar cache
            with open(EVENTS_CACHE, "w") as f:
                json.dump(high_impact, f, indent=2)
            return high_impact
    except Exception:
        pass

    # Fallback: cargar desde cache
    if EVENTS_CACHE.exists():
        with open(EVENTS_CACHE) as f:
            return json.load(f)

    return []


def is_blocked_now(buffer_before=BLOCK_MINUTES_BEFORE, buffer_after=BLOCK_MINUTES_AFTER):
    """
    Verifica si el momento actual esta bloqueado por un evento macro.
    Retorna (bool, str) — (bloqueado, razon)
    """
    now    = datetime.utcnow()
    events = fetch_events(days_ahead=3)

    for event in events:
        try:
            event_time = datetime.fromisoformat(
                event.get("date", "").replace("Z","").replace(" ","T")
            )
            delta = (event_time - now).total_seconds() / 60  # minutos

            if -buffer_after <= delta <= buffer_before:
                return True, f"Evento macro: {event.get('event','?')} ({event.get('country','?')})"
        except Exception:
            continue

    return False, "OK"


def get_upcoming_events(hours_ahead=48):
    """Lista de proximos eventos de alto impacto."""
    now    = datetime.utcnow()
    cutoff = now + timedelta(hours=hours_ahead)
    events = fetch_events(days_ahead=int(hours_ahead/24)+1)

    upcoming = []
    for event in events:
        try:
            event_time = datetime.fromisoformat(
                event.get("date","").replace("Z","").replace(" ","T")
            )
            if now <= event_time <= cutoff:
                upcoming.append({
                    "event":   event.get("event","?"),
                    "country": event.get("country","?"),
                    "time_utc":event_time.strftime("%Y-%m-%d %H:%M"),
                    "minutes_away": int((event_time-now).total_seconds()/60),
                    "impact":  event.get("impact","?"),
                })
        except Exception:
            continue

    return sorted(upcoming, key=lambda x: x["minutes_away"])


