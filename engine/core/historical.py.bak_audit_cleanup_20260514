"""
SIGMA ENGINE — Descargador de datos historicos masivos
Fuentes combinadas (todo gratis):
  1. Binance Futures data.binance.vision  → desde Sept 2019
  2. Binance Spot   data.binance.vision   → desde Jul  2017 (rellena 2017-2019)
  3. CryptoDataDownload (Bitstamp/Gemini) → desde 2014 (rellena 2014-2017)

Total posible: ~9 anos de datos OHLCV en 1h/4h/1d
Para 5m/15m: desde 2017 (Binance spot) = 9 anos

Ventaja vs API actual:
  API 5m  → 180 dias → 36 dias OOS (no confiable)
  Historico 5m → ~9 anos → 2+ anos OOS (muy confiable)

Uso:
  python core/historical.py --tf 5m       # 5m completo
  python core/historical.py --all         # todos los TFs
  python core/historical.py --deep        # incluye pre-2017 (Bitstamp)
"""

import sys, os
sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

import requests, zipfile, io, time
import pandas as pd
import numpy as np
from pathlib import Path
from datetime import datetime, timedelta

OUTPUT_DIR = Path(__file__).parent.parent.parent
MODELS_DIR = OUTPUT_DIR / "models"
MODELS_DIR.mkdir(parents=True, exist_ok=True)

BASE_URL_FUT  = "https://data.binance.vision/data/futures/um/monthly/klines"
BASE_URL_SPOT = "https://data.binance.vision/data/spot/monthly/klines"
SYMBOL        = "BTCUSDT"

# Primer mes con datos de futuros perpetuos BTCUSDT
TF_START = {
    "1m":  (2020, 1),
    "3m":  (2020, 1),
    "5m":  (2020, 1),
    "15m": (2019, 9),
    "30m": (2019, 9),
    "1h":  (2019, 9),
    "2h":  (2019, 9),
    "4h":  (2019, 9),
    "6h":  (2019, 9),
    "8h":  (2019, 9),
    "12h": (2019, 9),
    "1d":  (2019, 9),
    "1w":  (2019, 9),
}

COLS = ["timestamp","open","high","low","close","volume",
        "close_time","quote_vol","n_trades","taker_buy_vol",
        "taker_buy_quote","ignore"]


def _download_month(tf, year, month, source="futures", retries=3):
    """Descarga un mes. source: 'futures' o 'spot'."""
    fname   = f"{SYMBOL}-{tf}-{year}-{month:02d}.zip"
    base    = BASE_URL_FUT if source == "futures" else BASE_URL_SPOT
    url     = f"{base}/{SYMBOL}/{tf}/{fname}"

    for attempt in range(retries):
        try:
            r = requests.get(url, timeout=30)
            if r.status_code == 404:
                return None
            if r.status_code != 200:
                time.sleep(2)
                continue
            z = zipfile.ZipFile(io.BytesIO(r.content))
            csv_name = z.namelist()[0]
            raw = z.open(csv_name).read().decode("utf-8")
            first_line = raw.split("\n")[0]
            # Detectar si tiene header (Binance cambio formato en 2022)
            has_header = any(c.isalpha() for c in first_line.split(",")[0])
            if has_header:
                from io import StringIO
                df = pd.read_csv(StringIO(raw))
                # Renombrar columnas al formato comun
                rename = {}
                for c in df.columns:
                    cl = c.lower().replace(" ","_")
                    if "open_time" in cl or cl == "timestamp": rename[c] = "timestamp"
                    elif cl == "open":   rename[c] = "open"
                    elif cl == "high":   rename[c] = "high"
                    elif cl == "low":    rename[c] = "low"
                    elif cl == "close":  rename[c] = "close"
                    elif cl == "volume": rename[c] = "volume"
                df.rename(columns=rename, inplace=True)
            else:
                from io import StringIO
                df = pd.read_csv(StringIO(raw), header=None, names=COLS)
            df["timestamp"] = pd.to_datetime(df["timestamp"], unit="ms")
            df.set_index("timestamp", inplace=True)
            df = df[["open","high","low","close","volume"]].astype(float)
            return df
        except Exception as e:
            if attempt < retries-1:
                time.sleep(2)
            else:
                print(f"    Error {year}-{month:02d}: {e}")
                return None
    return None


def _fetch_bitstamp_old(tf="1h"):
    """
    Descarga datos pre-2017 de Bitstamp via CryptoDataDownload.
    Solo disponible para TFs 1h, 4h, 1d (no 5m/15m).
    Cubre 2014-2017 para rellenar antes de Binance spot.
    """
    # CryptoDataDownload URLs para Bitstamp BTCUSD (hourly)
    cdd_urls = {
        "1h": "https://www.cryptodatadownload.com/cdd/Bitstamp_BTCUSD_1h.csv",
        "1d": "https://www.cryptodatadownload.com/cdd/Bitstamp_BTCUSD_d.csv",
    }
    url = cdd_urls.get(tf)
    if not url:
        return None

    try:
        print(f"  [CDD] Descargando Bitstamp {tf} (pre-2017)...")
        r = requests.get(url, timeout=60)
        if r.status_code != 200:
            print(f"  [CDD] Error {r.status_code}")
            return None

        # CDD tiene una linea de header extra
        lines = r.text.strip().split('\n')
        start_line = 1  # skip first header line
        from io import StringIO
        df = pd.read_csv(StringIO('\n'.join(lines[start_line:])))

        # Detectar columna de fecha
        date_col = [c for c in df.columns if 'date' in c.lower() or 'time' in c.lower()]
        if not date_col:
            return None
        df["timestamp"] = pd.to_datetime(df[date_col[0]])
        df.set_index("timestamp", inplace=True)

        # Mapear columnas (pueden variar)
        col_map = {}
        for c in df.columns:
            cl = c.lower()
            if 'open'   in cl: col_map['open']   = c
            elif 'high' in cl: col_map['high']   = c
            elif 'low'  in cl: col_map['low']    = c
            elif 'close'in cl and 'volume' not in cl: col_map['close'] = c
            elif 'volume' in cl and 'usd' not in cl.replace('vol',''):
                if 'volume btc' in cl or cl == 'volume':
                    col_map['volume'] = c

        needed = ['open','high','low','close','volume']
        if not all(k in col_map for k in needed):
            # Intentar por posicion
            num_cols = [c for c in df.columns if df[c].dtype in ['float64','int64']]
            if len(num_cols) >= 5:
                for i, k in enumerate(needed):
                    col_map[k] = num_cols[i]
            else:
                print(f"  [CDD] No se pudieron mapear columnas: {list(df.columns)}")
                return None

        df = df[[col_map[k] for k in needed]].copy()
        df.columns = needed
        df = df.astype(float)
        df.sort_index(inplace=True)

        # Para 4h: resamplear desde 1h
        if tf == "4h":
            df = df.resample("4h").agg({
                "open":"first","high":"max","low":"min",
                "close":"last","volume":"sum"
            }).dropna()

        print(f"  [CDD] {len(df):,} velas Bitstamp {df.index[0].year}-{df.index[-1].year}")
        return df

    except Exception as e:
        print(f"  [CDD] Error: {e}")
        return None


def fetch_historical_max(tf="5m", force=False, deep=False):
    """
    Descarga TODO el historial disponible para el TF dado.
    Guarda en models/data_{tf}_max.csv
    Combina con datos recientes via API para estar al dia.
    """
    out_path = MODELS_DIR / f"data_{tf}_max.csv"

    # Determinar desde donde arrancar
    start_year, start_month = TF_START.get(tf, (2020, 1))

    tf_start_dt = datetime(start_year, start_month, 1)

    if out_path.exists() and not force:
        existing = pd.read_csv(out_path, index_col=0, parse_dates=True)
        existing.index.name = "timestamp"
        first_date = existing.index[0]
        last_date  = existing.index[-1]

        # Si los datos existentes no llegan hasta TF_START, descargar todo desde el inicio
        months_missing = (first_date.year - tf_start_dt.year)*12 + (first_date.month - tf_start_dt.month)
        if months_missing > 3:
            print(f"  [HIST] {tf}: datos existentes solo desde {first_date.strftime('%Y-%m-%d')}")
            print(f"  [HIST] Faltan {months_missing} meses de historia. Descargando desde {start_year}-{start_month:02d}...")
            frames = []  # no usar existente, descargar todo
        else:
            # Solo actualizar desde el ultimo mes
            start_year  = last_date.year
            start_month = last_date.month
            print(f"  [HIST] {tf}: actualizado hasta {last_date.strftime('%Y-%m-%d')}, ampliando...")
            frames = [existing]
    else:
        print(f"  [HIST] {tf}: descarga completa desde {start_year}-{start_month:02d}...")
        frames = []

    now = datetime.utcnow()
    # Fecha de inicio de Binance Spot (para rellenar 2017-2019)
    SPOT_START  = datetime(2017, 7, 1)
    FUT_START   = datetime(2019, 9, 1)

    # FASE 1: Binance Spot para 2017-2019 (si TF no es 1m o 3m)
    if deep or tf in ["5m","15m","1h","4h","1d","1w"]:
        spot_needed = (datetime(start_year, start_month, 1) > SPOT_START or
                       (not frames))
        if spot_needed and len(frames) == 0:
            print(f"  [SPOT] Descargando Binance Spot {tf} (2017-2019)...")
            sy, sm = 2017, 7
            while (sy, sm) < (2019, 9):
                df_m = _download_month(tf, sy, sm, source="spot")
                if df_m is not None and len(df_m) > 0:
                    frames.append(df_m)
                    print(f"    SPOT {sy}-{sm:02d}: {len(df_m):,} velas OK", flush=True)
                sm += 1
                if sm > 12: sm = 1; sy += 1

    # FASE 2: Binance Futures desde Sept 2019
    fut_start_y, fut_start_m = 2019, 9
    if frames:
        # Si ya tenemos datos, empezar donde terminamos
        combined_so_far = pd.concat(frames)
        last_so_far = combined_so_far.index[-1]
        fut_start_y = last_so_far.year
        fut_start_m = last_so_far.month

    print(f"  [FUT] Descargando Binance Futures {tf} (desde {fut_start_y}-{fut_start_m:02d})...")
    year, month = fut_start_y, fut_start_m
    while (year, month) <= (now.year, now.month):
        label = f"{year}-{month:02d}"
        df_m  = _download_month(tf, year, month, source="futures")
        if df_m is not None and len(df_m) > 0:
            frames.append(df_m)
            print(f"    FUT {label}: {len(df_m):,} velas OK", flush=True)
        else:
            if (year, month) < (now.year, now.month):
                print(f"    FUT {label}: sin datos", flush=True)
        month += 1
        if month > 12:
            month = 1; year += 1

    if not frames:
        print(f"  [HIST] Sin datos descargados para {tf}")
        return None

    # Combinar y deduplicar
    df_all = pd.concat(frames)
    df_all = df_all[~df_all.index.duplicated(keep="last")]
    df_all.sort_index(inplace=True)
    df_all = df_all.astype(float)

    # FASE 3: Pre-Binance (Bitstamp 2014-2017) si --deep y TF compatible
    if deep and tf in ["1h","4h","1d"]:
        df_old = _fetch_bitstamp_old(tf)
        if df_old is not None:
            # Solo usar el periodo pre-Binance (antes de 2017-07)
            df_old = df_old[df_old.index < pd.Timestamp("2017-07-01")]
            if len(df_old) > 0:
                frames.insert(0, df_old)
                print(f"  [CDD] Prepend {len(df_old):,} velas Bitstamp pre-2017")

    if not frames:
        print(f"  [HIST] Sin datos descargados para {tf}")
        return None

    # Combinar y normalizar index a formato uniforme (sin milisegundos, sin timezone)
    df_all = pd.concat(frames)
    idx = pd.to_datetime(df_all.index, format='mixed')
    if hasattr(idx, 'tz') and idx.tz is not None:
        idx = idx.tz_localize(None)
    df_all.index = idx.floor('s')   # normalizar: quitar milisegundos
    df_all.index.name = "timestamp"
    df_all = df_all[~df_all.index.duplicated(keep="last")]
    df_all.sort_index(inplace=True)
    df_all = df_all.astype(float)

    # Completar con API reciente (ultimos 5 dias para asegurar continuidad)
    try:
        from core.data import fetch_ohlcv
        df_recent = fetch_ohlcv(tf=tf, days=5, use_cache=False)
        if df_recent is not None and len(df_recent) > 0:
            df_all = pd.concat([df_all, df_recent])
            df_all = df_all[~df_all.index.duplicated(keep="last")]
            df_all.sort_index(inplace=True)
    except Exception as e:
        print(f"  [HIST] Sin actualizacion reciente via API: {e}")

    # Guardar
    df_all.to_csv(out_path)
    days_total = (df_all.index[-1] - df_all.index[0]).days
    print(f"\n  [HIST] {tf} COMPLETO: {len(df_all):,} velas | {days_total}d ({days_total/365:.1f} anos)")
    print(f"  [HIST] {df_all.index[0].strftime('%Y-%m-%d')} -> {df_all.index[-1].strftime('%Y-%m-%d')}")
    print(f"  [SAVED] {out_path}")
    return df_all


def fetch_all_critical(deep=False):
    """Descarga los TFs mas importantes para backtest."""
    tfs = ["5m", "15m", "1h", "4h", "1d"]
    print(f"\n{'='*65}")
    print("  SIGMA — DESCARGA HISTORICO COMPLETO")
    print(f"  Fuentes: Binance Futures + Spot + {'Bitstamp pre-2017' if deep else 'N/A (usa --deep para pre-2017)'}")
    print(f"{'='*65}")
    results = {}
    for tf in tfs:
        print(f"\n[{tf.upper()}]")
        try:
            df = fetch_historical_max(tf, deep=deep)
            if df is not None:
                results[tf] = {
                    "bars": len(df),
                    "days": (df.index[-1]-df.index[0]).days,
                    "from": df.index[0].strftime("%Y-%m-%d"),
                    "to":   df.index[-1].strftime("%Y-%m-%d"),
                }
        except Exception as e:
            print(f"  Error en {tf}: {e}")

    print(f"\n{'='*65}")
    print(f"  {'TF':<8} {'Velas':>10} {'Anos':>6} {'Desde':<12} {'Hasta':<12}")
    print(f"  {'-'*55}")
    for tf, info in results.items():
        yrs = info['days']/365
        bar = '#' * int(yrs)
        print(f"  {tf:<8} {info['bars']:>10,} {yrs:>5.1f}y  {info['from']:<12} {info['to']:<12}  {bar}")
    print(f"{'='*65}")
    return results


if __name__ == "__main__":
    import argparse
    p = argparse.ArgumentParser()
    p.add_argument("--tf",   default=None, help="Timeframe especifico (ej: 5m)")
    p.add_argument("--all",  action="store_true", help="Descargar todos los TFs")
    p.add_argument("--deep", action="store_true", help="Incluir Bitstamp pre-2017 (1h/4h/1d)")
    p.add_argument("--force",action="store_true", help="Re-descargar aunque existan")
    a = p.parse_args()

    if a.all or (not a.tf):
        fetch_all_critical(deep=a.deep)
    elif a.tf:
        fetch_historical_max(a.tf, force=a.force, deep=a.deep)
