    ])


def get_direction_coverage(asset, tf):
    """Devuelve (long_ok, short_ok) — True si existe al menos un modelo OOS+ en esa direccion."""
    sym = asset.lower()
    d   = OUTPUT_DIR / 'models' / tf
    if not d.exists():
        return (False, False)
    long_ok = short_ok = False
    for p in d.glob(sym + '_*.json'):
        try:
            data = json.loads(p.read_text())
            oos  = data.get('metrics_oos') or {}
            cagr = oos.get('cagr')
            if not cagr or cagr <= 0:
                continue
            strat = data.get('strategy','') or ''
            if strat in _PIPE_SHORTS:
                short_ok = True
            else:
                long_ok = True
            if long_ok and short_ok:
                break
        except Exception:
            continue
    return (long_ok, short_ok)


TF_PRIORITY = {'1h': 60, '4h': 55, '2h': 52, '15m': 25, '5m': 10, '1m': 5}
# 1H y 4H tienen la mayor prioridad — estadisticamente mas confiables
# 5m y 1m son exploratorios, van al final de cada ciclo

def priority_score(asset, tf):
    """Cuanto mas alto, mayor prioridad. 1H y 4H primero, luego TFs menores.
    2026-05-14: ahora distingue por DIRECCION (long vs short).
    Slot con UNA direccion faltante = high priority (gap direccional).
    """
    long_ok, short_ok = get_direction_coverage(asset, tf)
    tf_bonus = TF_PRIORITY.get(tf, 0)

    # GAP TOTAL: ninguna direccion cubierta -> maxima prioridad
    if not long_ok and not short_ok:
        return 100 + tf_bonus

    # GAP DIRECCIONAL: una direccion falta -> alta prioridad (abajo del gap total)
    if not (long_ok and short_ok):
        # Bonus si la direccion faltante coincide con el regime actual
        try:
            import json as _json_pr
            _sc = _json_pr.load(open('/opt/sigma/results/signals_cache.json'))
            _reg = _sc.get('regime', 'UNKNOWN')
            _missing = 'short' if long_ok else 'long'
            _regime_bonus = 15 if ((_reg=='BEAR' and _missing=='short') or (_reg=='BULL' and _missing=='long')) else 0
        except:
            _regime_bonus = 0
        return 80 + tf_bonus + _regime_bonus

    # Ambas direcciones cubiertas: prioridad por edad/cagr (logica historica)
    cagr, age = get_model_info(asset, tf)
    if cagr is None:
        return 100 + tf_bonus  # safety
    score = tf_bonus // 3
    if age > 7:   score += 40
    if age > 3:   score += 20
    if cagr < 5:  score += 30
    if cagr < 10: score += 15
    return score


def build_queue():
    """Construye la cola de (asset, tf) ordenada por prioridad."""
    slots = []
    for asset in ASSETS:
        for tf in TIMEFRAMES:
            p = priority_score(asset, tf)
            slots.append((p, asset, tf))
    slots.sort(reverse=True)
    return [(a, tf) for _, a, tf in slots]


def is_running(asset, tf):
    key = f'{asset}_{tf}'
    if key in running_procs:
        proc = running_procs[key]
        if proc.poll() is None:
            return True
        del running_procs[key]
    # Check ps aux for external processes (gap_auto_launcher may have launched it)
    import subprocess as _sp
    symbol_map = SYMBOLS.get(asset, asset)
    r = _sp.run(['ps', '-eo', 'cmd'], capture_output=True, text=True)
    for line in r.stdout.splitlines():
        if 'asset_pipeline.py' not in line:
            continue
        if f'--symbol {symbol_map}' in line and f'--tf {tf}' in line:
            return True
    return False


def launch_slot(asset, tf):
    key    = f'{asset}_{tf}'
    symbol = SYMBOLS[asset]
    trials = TRIALS_BY_TF.get(tf, 300)
    log_f  = OUTPUT_DIR / 'results' / 'reports' / f'{asset.lower()}_{tf}_pipeline.log'
    python = '/opt/sigma_env/bin/python'
    script = str(OUTPUT_DIR / 'engine' / 'optimization' / 'asset_pipeline.py')

    cmd = [
        python, '-u', script,
        '--symbol', symbol,
        '--tf', tf,
        '--trials', str(trials),
        # No --loop: el master controla los ciclos
    ]

    # 2026-05-14: dirigir --focus si hay gap direccional, para que asset_pipeline
    # invierta los trials en la direccion faltante en vez de re-optimizar la ya cubierta.
    long_ok, short_ok = get_direction_coverage(asset, tf)
    focus = None
    if long_ok and not short_ok:
        focus = 'short'
    elif short_ok and not long_ok:
        focus = 'long'
    elif not long_ok and not short_ok:
        focus = 'all'
    if focus:
        cmd += ['--focus', focus]

    # XAU y otros activos con CSV override
    if asset in CSV_PATHS:
        _csv = CSV_PATHS[asset].format(tf=tf)
        from pathlib import Path as _P
        if _P(_csv).exists():
            cmd += ['--csv_path', _csv]
        else:
            log(f'[SKIP] {asset} {tf}: CSV no disponible ({_csv})')
            return None

    cagr, age = get_model_info(asset, tf)
    status = f'sin modelo' if cagr is None else f'actual OOS {cagr:+.1f}% ({age}d)'
    if focus:
        status += f' [focus={focus}]'
    log(f'Lanzando {asset} {tf.upper()} — {status}')

    # Limitar RAM del subprocess a 2.5GB para evitar OOM kills del sistema
    cmd = ['prlimit', '--as=2684354560', '--'] + cmd  # 2.5GB virtual mem cap
    with open(log_f, 'a') as lf:
        proc = subprocess.Popen(
            cmd,
            stdout=lf, stderr=lf,
            cwd=str(OUTPUT_DIR),
        )
    running_procs[key] = proc
    return proc


def run():
    log('=' * 60)
    log('SIGMA MASTER PIPELINE — Iniciando')
    log(f'  {len(ASSETS)} activos x 4 TFs = {len(ASSETS)*4} slots | {MAX_PARALLEL} paralelos max')
    log('=' * 60)

    cycle = 0

    while True:
        cycle += 1
        queue = build_queue()
        log(f'--- Ciclo {cycle} | Queue: {len(queue)} slots ---')

        # Show current state
        for asset, tf in queue[:6]:
            cagr, age = get_model_info(asset, tf)
            p = priority_score(asset, tf)
            status = f'sin modelo' if cagr is None else f'OOS {cagr:+.1f}% ({age}d)'
            log(f'  [{p:3d}] {asset} {tf.upper():4s} — {status}')
        if len(queue) > 6:
            log(f'  ... y {len(queue)-6} slots mas')

        # Process queue
        idx = 0
        while idx < len(queue):
            # Fill up to MAX_PARALLEL slots
            launched_this_round = []
            while len([k for k,p in running_procs.items() if p.poll() is None]) < MAX_PARALLEL and idx < len(queue):
                ram_avail = psutil.virtual_memory().available / 1073741824
                if ram_avail < MIN_RAM_GB:
                    log('  RAM baja (' + str(round(ram_avail, 1)) + 'GB libre) - pausa 60s')
                    time.sleep(60)
                    break
                asset, tf = queue[idx]
                idx += 1
                if not is_running(asset, tf):
                    launch_slot(asset, tf)
                    launched_this_round.append(f'{asset} {tf}')

            if launched_this_round:
                log(f'  Activos: {", ".join(launched_this_round)}')

            # Wait for at least one to finish
            while True:
                active = {k: p for k, p in running_procs.items() if p.poll() is None}
                if len(active) < MAX_PARALLEL:
                    break
                time.sleep(30)

        # Wait for all running to finish before next cycle
        log('Esperando que terminen los slots activos...')
        while any(p.poll() is None for p in running_procs.values()):
            time.sleep(30)
        running_procs.clear()

        # Summary after full cycle
        log(f'Ciclo {cycle} completado. Estado actual:')
        found = 0
        for asset in ASSETS:
            parts = []
            for tf in TIMEFRAMES:
                cagr, _ = get_model_info(asset, tf)
                if cagr:
                    parts.append(f'{tf}:{cagr:+.1f}%')
                    found += 1
                else:
                    parts.append(f'{tf}:---')
            log(f'  {asset}: {" | ".join(parts)}')

        log(f'Total modelos OOS positivos: {found}/20')

        # Pause between cycles
        wait = 300 if found < 10 else 600  # 5min si pocos modelos, 10min si muchos
        log(f'Pausa {wait//60}min antes del siguiente ciclo...')
        time.sleep(wait)


def handle_signal(sig, frame):
    log('Signal recibido, cerrando procesos hijos...')
    for proc in running_procs.values():
        try: proc.terminate()
        except: pass
    sys.exit(0)


if __name__ == '__main__':
    signal.signal(signal.SIGTERM, handle_signal)
    signal.signal(signal.SIGINT,  handle_signal)

    # Crear directorio de logs si no existe
    log_path.parent.mkdir(parents=True, exist_ok=True)

    run()
