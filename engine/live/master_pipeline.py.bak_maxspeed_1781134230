"""
SIGMA MASTER PIPELINE
Orquestador autonomo: rota los 5 pares x 4 TFs, prueba 5 estrategias
en cada slot, guarda si mejora el OOS actual. Nunca se detiene.

Logica de prioridad:
  1. Slots sin ningun modelo OOS → maxima prioridad
  2. Slots con modelo >7 dias de antigüedad → re-testear
  3. Slots con CAGR OOS < 10% → intentar mejorar
  4. El resto → ciclo normal

Sistema completo: 5 activos x 4 TFs = 20 slots
  Cada slot prueba: breakout, pullback, tma_bands, momentum, mean_rev
  Si mejora → sobreescribe el modelo guardado
  Si no mejora → sigue al siguiente slot

Se registra como servicio systemd: sigma-pipeline
"""
import sys, os, time, json, subprocess, signal
import psutil
sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from pathlib import Path
from datetime import datetime, timedelta

OUTPUT_DIR = Path(__file__).parent.parent.parent

ASSETS = ['BTC', 'ETH', 'LTC', 'SOL', 'BNB']  # Motor 1: solo crypto
SYMBOLS = {
    'BTC': 'BTC/USDT',
    'ETH': 'ETH/USDT',
    'LTC': 'LTC/USDT',   # reemplaza XRP — patrones mas limpios, halving propio
    'SOL': 'SOL/USDT',
    'BNB': 'BNB/USDT',
    # 'XAU': 'XAU/USD',  # Motor 2 (commodities)
}
# Prioridad de TF: 1H y 4H primero (probados y valiosos), luego 15m, 5m y 1m al final
TIMEFRAMES = ['1h', '4h', '15m']  # 5m/1m deshabilitados 2026-05-11: sin edge consistente

# Trials reducidos — Optuna TPE encuentra soluciones buenas antes de trial 120

# Activos que usan CSV pre-descargado en lugar de Binance (ej: XAU)
CSV_PATHS = {}  # Motor 2 handles commodities CSVs_max.csv',

TRIALS_BY_TF = {'4h': 250, '1h': 300, '15m': 300, '5m': 150, '1m': 35}  # 2026-06-07: upgrade 8 cores, maximizar calidad
# 5m y 1m tienen 600K+ candles — cada trial es 10x mas lento que 1H
# Con 60 trials Optuna TPE igual encuentra buenas soluciones

# 4 slots paralelos — sigma-trainer pausado, tenemos 3.5+ cores libres
MAX_PARALLEL = 1  # M2 activo: 1 M1 + 1 M2 = 2 jobs max
MIN_RAM_GB  = 2.5   # No lanzar si RAM libre < 2.5GB

running_procs = {}
log_path = OUTPUT_DIR / 'results' / 'reports' / 'master_pipeline.log'


def log(msg, level='INFO'):
    ts   = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    line = f'[{ts}][{level}] {msg}'
    print(line, flush=True)


def get_model_info(asset, tf):
    """Devuelve (cagr_oos, age_days) del mejor modelo guardado para asset+tf."""
    sym = asset.lower()
    d   = OUTPUT_DIR / 'models' / tf
    if not d.exists():
        return None, 9999

    best_cagr = None
    best_age  = 9999

    # Buscar todos los JSON del asset en este TF (cualquier estrategia)
    for p in d.glob(sym + '_*.json'):
        try:
            data = json.loads(p.read_text())
            oos  = data.get('metrics_oos') or {}
            cagr = oos.get('cagr')
            if cagr and cagr > 0:
                age = (datetime.now() - datetime.fromtimestamp(p.stat().st_mtime)).days
                if best_cagr is None or cagr > best_cagr:
                    best_cagr = cagr
                    best_age  = age
        except:
            continue

    return best_cagr, best_age

