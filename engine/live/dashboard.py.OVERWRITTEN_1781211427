def load_wft():
    p = OUTPUT_DIR / 'results' / 'reports' / 'wft_1h.log'
    if not p.exists():
        return []
    rows = []
    pat  = re.compile(r'(\d{4}-\d{2})\s+\d+d\s+\d+d\s+(\d+)\s+([\d.]+)%\s+([+-][\d.]+)%\s+(\w+)')
    for line in p.read_text(encoding='utf-8', errors='replace').splitlines():
        m = pat.search(line)
        if m:
            rows.append({
                'window': m.group(1),
                'trades': int(m.group(2)),
                'wr':     float(m.group(3)),
                'cagr':   float(m.group(4)),
                'ok':     m.group(5) == 'OK',
            })
    return rows


