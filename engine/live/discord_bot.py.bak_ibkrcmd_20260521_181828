@bot.tree.command(name="portfolio", description="Vistas del CAGR del portafolio")
async def cmd_portfolio(interaction: discord.Interaction):
    await interaction.response.defer(thinking=True)
    signals = fetch_json("/api/signals") or {}
    ms = signals.get("models", [])
    operables = [m for m in ms if m.get("grade") in ("A+", "A", "B") and m.get("slot", 0) == 0]

    if operables:
        sum_cagr = sum(m.get("cagr", 0) for m in operables)
        sum_trades = sum(m.get("trades", 1) for m in operables)
        weighted = sum(m.get("cagr", 0) * m.get("trades", 1) for m in operables) / max(sum_trades, 1)
        top5 = sorted(operables, key=lambda m: m.get("cagr", 0) or 0, reverse=True)[:5]
        top_avg = sum(m.get("cagr", 0) for m in top5) / max(len(top5), 1)
        simple = sum_cagr / len(operables)
    else:
        weighted = top_avg = simple = 0

    embed = discord.Embed(
        title="💼 Portfolio — 3 Vistas del CAGR",
        description="Tres formas de ver el mismo portafolio, ninguna escondida:",
        color=SIGMA_BLUE,
    )
    embed.add_field(name="Real (weighted by trades)", value=f"**`{weighted:+.2f}%`**", inline=True)
    embed.add_field(name="Top 5 promedio", value=f"`{top_avg:+.2f}%`", inline=True)
    embed.add_field(name="Simple (avg todos)", value=f"`{simple:+.2f}%`", inline=True)
    embed.set_footer(text=f"Basado en {len(operables)} champions operables · CAGR sin leverage")
    await interaction.followup.send(embed=embed)


@bot.tree.command(name="fire", description="FIRE tracker - progreso al objetivo de capital")
async def cmd_fire(interaction: discord.Interaction):
    await interaction.response.defer(thinking=True)
    fire_cfg = {}
    try:
        fire_cfg = json.loads(Path("/opt/sigma/results/fire_config.json").read_text())
    except Exception:
        pass
    trades = fetch_json("/api/trades") or {}
    equity = trades.get("equity", 10000)
