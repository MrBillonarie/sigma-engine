@tasks.loop(minutes=5)
async def watch_champions():
    """Detect newly-saved champion JSONs (file-based, not API churn)."""
    import os, glob
    models_dir = "/opt/sigma/models"
    ch = bot.get_channel(CHANNELS["estrategias"])
    if not ch:
        return

    # Iterate champion JSON files; track mtime to detect SAVE events
    for jf in sorted(glob.glob(f"{models_dir}/*/*.json")):
        if "/archive/" in jf:
            continue
        try:
            mt = os.path.getmtime(jf)
        except Exception:
            continue
        prev_mt = bot.last_champion_seen.get(jf, 0)
        if prev_mt == 0:
            # First time seeing this file — just seed, no announce
            bot.last_champion_seen[jf] = mt
            continue
        if mt <= prev_mt:
            continue
        # NEW save detected — read and announce
        try:
            d = json.loads(Path(jf).read_text())
            sym  = d.get("symbol", "?").replace("/USDT", "")
            tf   = d.get("tf", "?")
            strat = d.get("strategy", "?")
            moos = d.get("metrics_oos", {})
            cagr = moos.get("cagr", 0) or 0
            wr   = moos.get("wr", 0) or 0
            dd   = moos.get("dd", 0) or 0
            pf   = moos.get("pf", 0) or 0
            conf = d.get("validation", {}).get("confidence", "?")
            grade = "A+" if cagr >= 40 else ("A" if cagr >= 25 else ("B" if cagr >= 15 else "C"))
            embed = discord.Embed(
                title=f"⭐ Nuevo Champion — {sym} {tf.upper()}",
                description=f"Estrategia: **`{strat}`**",
                color=SIGMA_GREEN if cagr >= 15 else SIGMA_ORANGE,
            )
            embed.add_field(name="Grade", value=f"`{grade}`", inline=True)
            embed.add_field(name="CAGR OOS", value=f"`{cagr:+.1f}%`", inline=True)
            embed.add_field(name="Win Rate", value=f"`{wr:.0f}%`", inline=True)
            embed.add_field(name="Drawdown", value=f"`{dd:.1f}%`", inline=True)
            embed.add_field(name="Profit Factor", value=f"`{pf:.2f}`", inline=True)
            embed.add_field(name="Confianza", value=f"`{conf}`", inline=True)
            embed.set_footer(text=f"Validacion: MC + walk-forward + cross-asset")
            await ch.send(embed=embed)
            print(f"[CHAMPION] {sym} {tf} {strat} (cagr {cagr})")
        except Exception as e:
            print(f"champion announce err for {jf}: {e}")
        bot.last_champion_seen[jf] = mt


@tasks.loop(seconds=45)
async def watch_trades():
    """Watch trade_state.json — announce new opens and closes."""
    import os
    state_path = "/opt/sigma/results/trade_state.json"
    try:
        mt = os.path.getmtime(state_path)
    except Exception:
        return
    if mt <= bot.last_trade_state_mt:
        return
    bot.last_trade_state_mt = mt
    try:
        state = json.loads(Path(state_path).read_text())
    except Exception as e:
        print(f"trade state read err: {e}")
        return

    open_t = state.get("open", {}) or {}
    history = state.get("history", []) or []

    # ===== detect NEW OPENS =====
    current_keys = set()
    for key, t in open_t.items():
        if t.get("status") != "open":
            continue
        current_keys.add(key)
        if key in bot.seen_open_keys:
            continue
        # New open detected
        ch = bot.get_channel(CHANNELS.get("resultados_pnl") or CHANNELS["general"])
        if not ch:
            continue
        sym = t.get("sym", "?")
        tf  = t.get("tf", "?")
        strat = t.get("strategy", "?")
        direction = t.get("direction", "long")
        entry = t.get("entry", 0)
        sl    = t.get("sl", 0)
        tp    = t.get("tp", 0)
        kelly = t.get("kelly_pct") or t.get("kelly_pct_used") or 5.0
        grade = t.get("grade", "?")
        is_long = direction != "short"
        arrow = "🟢 LONG" if is_long else "🔴 SHORT"
        color = SIGMA_GREEN if is_long else SIGMA_RED
        rr = round(abs(tp - entry) / max(abs(entry - sl), 1e-6), 2) if sl and tp else 0
        embed = discord.Embed(
            title=f"📥 Trade ABIERTO — {sym} {tf.upper()}",
            description=f"{arrow}  ·  `{strat}`  ·  Grade `{grade}`",
            color=color,
        )
        embed.add_field(name="Entry", value=f"`{entry}`", inline=True)
        embed.add_field(name="SL", value=f"`{sl}`", inline=True)
        embed.add_field(name="TP", value=f"`{tp}`", inline=True)
        embed.add_field(name="RR", value=f"`{rr:.2f}:1`", inline=True)
        embed.add_field(name="Kelly", value=f"`{kelly}%`", inline=True)
        embed.add_field(name="Opened", value=f"`{t.get('opened_at','?')[:19]}`", inline=True)
        embed.set_footer(text="Paper trading · SIGMA ENGINE")
        try:
            await ch.send(embed=embed)
            print(f"[TRADE OPEN] {key} {direction} {strat}")
        except Exception as e:
            print(f"trade open announce err: {e}")
    bot.seen_open_keys = current_keys

    # ===== detect NEW CLOSES (look at recent history) =====
    ch_pnl = bot.get_channel(CHANNELS.get("resultados_pnl") or CHANNELS["general"])
    if not ch_pnl:
        return
    for t in history[-10:]:
        sig = f"{t.get('sym')}_{t.get('tf')}_{t.get('strategy')}_{t.get('opened_at','')}_{t.get('closed_at','')}"
        if sig in bot.seen_closed_ids:
            continue
        # Must have closed_at to be considered "closed"
        if not t.get("closed_at"):
            continue
        bot.seen_closed_ids.add(sig)
        sym = t.get("sym", "?")
        tf  = t.get("tf", "?")
        strat = t.get("strategy", "?")
        direction = t.get("direction", "long")
        is_long = direction != "short"
        arrow = "🟢 LONG" if is_long else "🔴 SHORT"
        reason = t.get("reason") or t.get("status") or "CLOSED"
        pnl_pct = t.get("pnl_pct", 0) or 0
        pnl_usd = t.get("pnl_dollar", 0) or 0
        equity_after = t.get("equity_after")
        won = pnl_pct > 0
