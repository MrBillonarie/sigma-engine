#!/usr/bin/env python3
"""
SIGMA Discord Bot — persistent service
Slash commands + background notifications mirrored from Telegram.

Channels:
  estrategias-algo  ← champions nuevos
  backtesting       ← milestones
  data-feeds        ← regime/funding updates
  sigma-broadcasts  ← high-priority anuncios
  market-alerts     ← funding emergency / drawdown / watchdog
  sigma-reports     ← morning/evening daily reports
"""
import asyncio, json, urllib.request, datetime, time
from pathlib import Path

import discord
from discord import app_commands
from discord.ext import tasks

CONFIG = json.loads(Path("/opt/sigma/config/settings.json").read_text())
TOKEN     = CONFIG["discord"]["bot_token"]
GUILD_ID  = CONFIG["discord"]["guild_id"]
CHANNELS  = CONFIG["discord"]["channel_ids"]

SIGMA_GREEN  = 0x00E676
SIGMA_BLUE   = 0x2196F3
SIGMA_ORANGE = 0xFF9800
SIGMA_RED    = 0xF85149
SIGMA_PURPLE = 0xA78BFA
SIGMA_GOLD   = 0xFFD700

API_BASE = "http://localhost:8080"


def fetch_json(path, timeout=10):
    """Fetch json from local web_server API."""
    try:
        r = urllib.request.urlopen(f"{API_BASE}{path}", timeout=timeout)
        return json.loads(r.read())
    except Exception as e:
        return None


def chile_now():
    return datetime.datetime.utcnow() - datetime.timedelta(hours=4)


# ============================================================================
# Bot setup
# ============================================================================
intents = discord.Intents.default()
intents.message_content = True
intents.members = True
intents.presences = True

class SigmaBot(discord.Client):
    def __init__(self):
        super().__init__(intents=intents)
        self.tree = app_commands.CommandTree(self)
        self.last_champion_seen = {}      # key: champion json path -> mtime
        self.last_milestone_seen = 0
        self.last_emergency_alert = 0
        self.last_trade_state_mt = 0
        self.seen_open_keys = set()
        self.seen_closed_ids = set()
        self.last_dd_tier = 0             # tracks DD tier already alerted (0 / -5 / -10 / -15)
        self.daily_brief_sent = {}        # date -> set(slot) so morning/evening posts once

    async def setup_hook(self):
        # Sync commands to the guild (fast — instant vs global which takes 1h)
        guild = discord.Object(id=GUILD_ID)
        self.tree.copy_global_to(guild=guild)
        await self.tree.sync(guild=guild)
        print(f"[BOOT] Synced {len(self.tree.get_commands())} commands to guild {GUILD_ID}")

bot = SigmaBot()


