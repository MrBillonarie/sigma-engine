        title="🔥 FIRE Tracker",
        description=f"Objetivo: `${target:,}` USD",
        color=SIGMA_GOLD,
    )
    embed.add_field(name="Equity actual", value=f"`${equity:,.2f}`", inline=True)
    embed.add_field(name="Progreso", value=f"`{pct:.1f}%`", inline=True)
    embed.add_field(name="Falta", value=f"`${max(0, target-equity):,.2f}`", inline=True)
    embed.add_field(name="Visual", value=f"`[{bar}]`", inline=False)
    embed.set_footer(text="Use /fire para actualizar manualmente")
    await interaction.followup.send(embed=embed)


@bot.tree.command(name="performance", description="Rendimiento historico de trades")
async def cmd_performance(interaction: discord.Interaction):
    await interaction.response.defer(thinking=True)
    trades = fetch_json("/api/trades") or {}
    hist = trades.get("history", [])
    if not hist:
        await interaction.followup.send("Sin historial de trades aun.")
        return
    closed = [t for t in hist if t.get("status") in ("TP_HIT", "SL_HIT") or t.get("pnl_pct") is not None]
    n = len(closed)
    if n == 0:
        await interaction.followup.send("Sin trades cerrados aun.")
        return
    wins = [t for t in closed if (t.get("pnl_pct") or 0) > 0]
    wr = len(wins) / n * 100
    total_pnl = sum(t.get("pnl_pct", 0) for t in closed)
    embed = discord.Embed(title="📈 Performance Historica", color=SIGMA_PURPLE)
    embed.add_field(name="Trades cerrados", value=f"`{n}`", inline=True)
    embed.add_field(name="Win rate", value=f"`{wr:.1f}%`", inline=True)
    embed.add_field(name="PnL acumulado", value=f"`{total_pnl:+.2f}%`", inline=True)
    last5 = closed[-5:]
    if last5:
        lines = []
        for t in last5:
            sym = t.get("sym", "?")
            tf = t.get("tf", "?")
            pnl = t.get("pnl_pct", 0)
            emoji = "✅" if pnl > 0 else "❌"
            lines.append(f"{emoji} {sym} {tf.upper()} `{pnl:+.2f}%`")
        embed.add_field(name="Ultimos 5", value="\n".join(lines), inline=False)
    await interaction.followup.send(embed=embed)


