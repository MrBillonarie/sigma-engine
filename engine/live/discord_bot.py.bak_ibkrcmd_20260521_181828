# Slash commands
# ============================================================================

@bot.tree.command(name="trades", description="Posiciones abiertas + cola de senales")
async def cmd_trades(interaction: discord.Interaction):
    await interaction.response.defer(thinking=True)
    signals = fetch_json("/api/signals") or {}
    trades  = fetch_json("/api/trades")  or {}

    regime = signals.get("regime", "?")
    models = signals.get("models", [])

    # Posiciones abiertas
    open_t = {}
    raw = trades.get("open_trades", trades.get("open", {}))
    if isinstance(raw, dict):
        open_t = {k: v for k, v in raw.items() if v.get("status") == "open"}
    elif isinstance(raw, list):
        open_t = {f"{t['sym']}_{t['tf']}": t for t in raw if t.get("status") == "open"}

    embed = discord.Embed(
        title=f"📊 Trades · Regimen {regime}",
        color=SIGMA_GREEN if regime == "BULL" else SIGMA_RED if regime == "BEAR" else SIGMA_ORANGE,
    )

    if open_t:
        lines = []
        for t in open_t.values():
            isL = t.get("direction", "long") != "short"
            arrow = "🟢 LONG" if isL else "🔴 SHORT"
            lines.append(
                f"{arrow} **{t.get('sym')} {t.get('tf','').upper()}** `{t.get('strategy','?')}` · "
                f"Entry `{t.get('entry')}` SL `{t.get('sl')}` TP `{t.get('tp')}`"
            )
        embed.add_field(name=f"Posiciones abiertas ({len(open_t)})", value="\n".join(lines), inline=False)
    else:
        embed.add_field(name="Posiciones abiertas", value="_Sin posiciones abiertas_", inline=False)

    # Cola
    cola = []
    for m in models:
        if m.get("slot", 0) != 0:
            continue
        if not (m.get("signal") or m.get("recommendation") == "ACTIVAR"):
            continue
        if m.get("grade") not in ("A+", "A", "B"):
            continue
        cola.append(m)
    cola.sort(key=lambda m: (1 if m.get("signal") else 0, m.get("score", 0)), reverse=True)
    cola = cola[:8]
    if cola:
        lines = []
        for m in cola:
            isL = m.get("type") != "short"
            arrow = "🟢 LONG" if isL else "🔴 SHORT"
            badge = "⚡" if m.get("signal") else "⏳"
            lines.append(
                f"{badge} {arrow} **{m.get('sym')} {m.get('tf','').upper()}** `{m.get('strategy','?')}` · "
                f"Grade {m.get('grade')} · CAGR {m.get('cagr',0):+.1f}%"
            )
        embed.add_field(name=f"En cola ({len(cola)})", value="\n".join(lines), inline=False)

    # Armados por regimen
    armed = [m for m in models
             if m.get("recommendation") == "ESPERAR"
             and "regimen" in (m.get("reason") or "").lower()
             and m.get("grade") in ("A+", "A", "B")]
    armed.sort(key=lambda m: m.get("cagr", 0) or 0, reverse=True)
    armed = armed[:6]
    if armed:
        lines = []
        for m in armed:
            isL = m.get("type") != "short"
            arrow = "🟢 LONG" if isL else "🔴 SHORT"
            lines.append(
                f"{arrow} **{m.get('sym')} {m.get('tf','').upper()}** `{m.get('strategy','?')}` · "
                f"CAGR {m.get('cagr',0):+.1f}%"
            )
        embed.add_field(name=f"🎯 Armados por regimen ({len(armed)})", value="\n".join(lines), inline=False)

    embed.set_footer(text=f"SIGMA ENGINE · {chile_now().strftime('%H:%M')} Chile")
    await interaction.followup.send(embed=embed)


