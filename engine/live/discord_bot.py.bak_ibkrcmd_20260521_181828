        watch_drawdown.start()
    if not watch_daily_brief.is_running():
        watch_daily_brief.start()
    if not watch_grade_transitions.is_running():
        watch_grade_transitions.start()
    # Set presence
    await bot.change_presence(
        activity=discord.Activity(
            type=discord.ActivityType.watching,
            name="121 estrategias · /ayuda"
        ),
        status=discord.Status.online,
    )
    # Seed last_champion_seen with current file mtimes so first poll is silent
    import os, glob
    for jf in glob.glob("/opt/sigma/models/*/*.json"):
        if "/archive/" in jf:
            continue
        try:
            bot.last_champion_seen[jf] = os.path.getmtime(jf)
        except Exception:
            pass
    # Seed trade state to avoid replaying historical trades on first run
    try:
        state_path = "/opt/sigma/results/trade_state.json"
        bot.last_trade_state_mt = os.path.getmtime(state_path)
        st = json.loads(Path(state_path).read_text())
        open_t = st.get("open", {}) or {}
        bot.seen_open_keys = set(k for k, v in open_t.items() if v.get("status") == "open")
        # Seed all existing history as already-seen so we only announce future closes
        for t in (st.get("history", []) or []):
            sig = f"{t.get('sym')}_{t.get('tf')}_{t.get('strategy')}_{t.get('opened_at','')}_{t.get('closed_at','')}"
            bot.seen_closed_ids.add(sig)
        print(f"[SEED] open_keys={len(bot.seen_open_keys)} closed_seen={len(bot.seen_closed_ids)}")
    except Exception as e:
        print(f"trade seed err: {e}")
    # Seed milestone mtime
    try:
        bot.last_milestone_seen = os.path.getmtime("/opt/sigma/last_milestone.txt")
    except Exception:
        pass
    # Seed dd tier
    try:
        tr = fetch_json("/api/trades") or {}
        eq = tr.get("equity"); pk = tr.get("peak_equity")
        if eq and pk and pk > 0:
            dd0 = (eq - pk) / pk * 100
            if dd0 <= -15: bot.last_dd_tier = -15
            elif dd0 <= -10: bot.last_dd_tier = -10
            elif dd0 <= -5: bot.last_dd_tier = -5
            else: bot.last_dd_tier = 0
            print(f"[SEED] dd_tier={bot.last_dd_tier} (actual {dd0:+.2f}%)")
    except Exception as e:
        print(f"dd seed err: {e}")


