@tasks.loop(minutes=15)
async def watch_grade_transitions():
    """Detecta cuando un champion cruza de grade (B → A, A → A+).
    Lee port_snapshot.json y compara grade por slot.
    """
    snap_path = "/opt/sigma/results/reports/port_snapshot.json"
    try:
        snap = json.loads(Path(snap_path).read_text())
    except Exception:
        return
    champions = snap.get("champions", {})
    n_grade_a = snap.get("n_grade_a", 0)

    # Fetch fresh signals to get current grades per slot
    sig = fetch_json("/api/signals") or {}
    ms = sig.get("models", [])
    # Map slot -> best (highest score) grade
    by_slot = {}
    for m in ms:
        key = f"{m.get('sym')}|{m.get('tf')}"
        score = m.get("score", 0) or 0
        prev = by_slot.get(key)
        if prev is None or score > prev["score"]:
            by_slot[key] = {
                "strategy": m.get("strategy"),
                "grade":    m.get("grade"),
                "score":    score,
                "cagr":     m.get("cagr", 0),
                "wr":       m.get("wr", 0),
                "sym":      m.get("sym"),
                "tf":       m.get("tf"),
            }

    # Compare against previous state stored on bot
    if not hasattr(bot, "last_grades"):
        bot.last_grades = {k: v["grade"] for k, v in by_slot.items()}
        return  # seed silently, no announcement on first run

    ch = bot.get_channel(CHANNELS.get("estrategias"))
    if not ch:
        return

    GRADE_ORDER = {"D": 0, "C": 1, "B": 2, "A": 3, "A+": 4}
    for key, info in by_slot.items():
        prev = bot.last_grades.get(key)
        curr = info["grade"]
        if prev == curr:
            continue
        prev_n = GRADE_ORDER.get(prev, 0)
        curr_n = GRADE_ORDER.get(curr, 0)
        if curr_n > prev_n:
            # ASCENSO
            color = SIGMA_GOLD if curr == "A+" else (SIGMA_GREEN if curr == "A" else SIGMA_BLUE)
            emoji = "🏆" if curr == "A+" else ("⭐" if curr == "A" else "📈")
            embed = discord.Embed(
                title=f"{emoji} ASCENSO de grade — {info['sym']} {info['tf'].upper()}",
                description=f" subió de **{prev}** a **{curr}**",
                color=color,
            )
            embed.add_field(name="Score",  value=f"", inline=True)
            embed.add_field(name="CAGR",   value=f"", inline=True)
            embed.add_field(name="WR",     value=f"", inline=True)
            embed.set_footer(text="Más champions grade A = más entradas operables en paper trading")
            try:
                await ch.send(embed=embed)
                print(f"[GRADE UP] {key} {prev} → {curr}")
            except Exception as e:
                print(f"grade announce err: {e}")
        elif curr_n < prev_n:
            # DEGRADACION
            embed = discord.Embed(
                title=f"⚠️ DEGRADACION — {info['sym']} {info['tf'].upper()}",
                description=f" bajó de **{prev}** a **{curr}**",
                color=SIGMA_ORANGE,
            )
            embed.add_field(name="Score",  value=f"", inline=True)
            embed.add_field(name="CAGR",   value=f"", inline=True)
            embed.add_field(name="WR",     value=f"", inline=True)
            embed.set_footer(text="El motor sigue evaluando — probablemente rote a otra estrategia")
            try:
                await ch.send(embed=embed)
                print(f"[GRADE DOWN] {key} {prev} → {curr}")
            except Exception as e:
                print(f"grade announce err: {e}")
        bot.last_grades[key] = curr


