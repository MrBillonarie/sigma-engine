@tasks.loop(minutes=3)
async def watch_drawdown():
    """Alert when portfolio drawdown crosses a new tier (-5%, -10%, -15%)."""
    trades = fetch_json("/api/trades") or {}
    eq = trades.get("equity")
    peak = trades.get("peak_equity")
    if not eq or not peak or peak <= 0:
        return
    dd = (eq - peak) / peak * 100
    # Tiers: 0 (no alert), -5, -10, -15
    new_tier = 0
    if dd <= -15:
        new_tier = -15
    elif dd <= -10:
        new_tier = -10
    elif dd <= -5:
        new_tier = -5
    # Only alert when crossing INTO a worse tier (not when recovering)
    if new_tier == bot.last_dd_tier:
        return
    if new_tier == 0 and bot.last_dd_tier < 0:
        # recovery — announce recovery
        bot.last_dd_tier = 0
        ch = bot.get_channel(CHANNELS.get("risk_management"))
        if not ch:
            return
        embed = discord.Embed(
            title="✅ DD recuperado",
            description=f"El portafolio salió de zona drawdown. DD actual: `{dd:+.2f}%`",
            color=SIGMA_GREEN,
        )
        embed.add_field(name="Equity", value=f"`${eq:,.2f}`", inline=True)
        embed.add_field(name="Peak", value=f"`${peak:,.2f}`", inline=True)
        try:
            await ch.send(embed=embed)
        except Exception:
            pass
        return
    if new_tier >= bot.last_dd_tier:
        return  # nothing worse than before
    bot.last_dd_tier = new_tier
    ch = bot.get_channel(CHANNELS.get("risk_management"))
    if not ch:
        return
    severity_color = SIGMA_ORANGE if new_tier == -5 else (SIGMA_RED if new_tier <= -10 else SIGMA_RED)
    embed = discord.Embed(
        title=f"⚠️ DRAWDOWN tier {new_tier}%",
        description=f"El portafolio cruzó {new_tier}% de drawdown desde el peak.",
        color=severity_color,
    )
    embed.add_field(name="DD actual", value=f"`{dd:+.2f}%`", inline=True)
    embed.add_field(name="Equity", value=f"`${eq:,.2f}`", inline=True)
    embed.add_field(name="Peak", value=f"`${peak:,.2f}`", inline=True)
    if new_tier == -5:
        embed.add_field(name="Kelly mult", value="`×0.70` (auto)", inline=True)
    elif new_tier == -10:
        embed.add_field(name="Kelly mult", value="`×0.50` (auto)", inline=True)
        embed.add_field(name="Regla anti-pánico", value="Solo bugfixes permitidos", inline=False)
    elif new_tier == -15:
        embed.add_field(name="Kelly mult", value="`×0.25` modo supervivencia", inline=True)
        embed.add_field(name="Acción manual", value="Revisar regime + champions", inline=False)
    embed.set_footer(text="SIGMA Risk Management · Reglas automáticas del Premortem")
    try:
        await ch.send(embed=embed)
        print(f"[DRAWDOWN] tier {new_tier}% · dd {dd:+.2f}%")
    except Exception as e:
        print(f"dd announce err: {e}")


