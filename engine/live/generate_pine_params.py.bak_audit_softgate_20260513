def log(msg):
    from datetime import timezone, timedelta
    cl = datetime.now(tz=timezone(timedelta(hours=-4)))
    line = f"[{cl:%H:%M:%S} CLT] {msg}"
    print(line, flush=True)
    try:
        with open(LOG, 'a') as f:
            f.write(line + '\n')
    except: pass


def compute_grade(score):
    if score >= 0.70: return 'A+', 4
    if score >= 0.55: return 'A',  3
    if score >= 0.40: return 'B',  2
    if score >= 0.25: return 'C',  1
    return 'D', 0


def _score_fn(m, tf='1h'):
    """Score canónico — IDÉNTICO a dashboard._compute_score (commit c2ff162).
    Mantener sincronizado para evitar drift de grades entre Pine y dashboard."""
    t=m.get('trades',0); ty=m.get('trades_year',0)
    wr=m.get('wr',0); cagr=m.get('cagr',0); dd=m.get('dd',0); pf=m.get('pf',1)
    if t < 10 or cagr <= 0: return -9999
    if ty <= 0 and t > 0: ty = t * (365 / 600)
    # Mínimo de trades/año según TF — scalping necesita más frecuencia
    min_ty = 50 if tf in ('5m','1m') else 20 if tf == '15m' else 5
    if ty < min_ty: return -9999
    if wr <= 0 and cagr > 0: wr = 50
    # Fórmula canónica (idéntica al dashboard):
    # CAGR cap 100 weight 0.35 | Calmar cap 8 weight 0.25 | Freq 0.20 | WR 0.15 | PF 0.05
    s_cagr = min(cagr, 100) / 100 * 0.35
    s_cal  = min(cagr / abs(dd) if dd < 0 else 0, 8) / 8 * 0.25
    s_freq = min(ty / 12.0, 1.0) * 0.20
    s_wr   = min(max(wr / 100 - 0.50, 0) / 0.35, 1.0) * 0.15
    s_pf   = min(pf, 3) / 3 * 0.05
    return round(s_cagr + s_cal + s_freq + s_wr + s_pf, 4)


_WFT_CACHE = {}  # (symbol, tf, strategy) -> 'OK'|'FAIL'|'--'

def _load_wft_data():
    """Carga todos los archivos WFT del directorio reports."""
    global _WFT_CACHE
    reports = BASE / 'results' / 'reports'
    for jf in sorted(reports.glob('wft_*.json'), reverse=True):
        try:
            data = json.loads(jf.read_text(encoding='utf-8'))
            for r in data.get('results', []):
                key = (r.get('symbol',''), r.get('tf',''), r.get('strategy',''))
                v   = r.get('verdict','')
                wr  = r.get('oos_win_rate', 0)
                status = 'OK' if (v.upper()=='PASS' or wr>=55) else ('FAIL' if v.upper()=='FAIL' else '--')
                if key not in _WFT_CACHE:  # primera aparición (archivo más reciente)
                    _WFT_CACHE[key] = status
        except: pass


def _wft_status(d, symbol='', tf='', strategy=''):
    """Busca WFT en caché o en el JSON del modelo."""
    if not _WFT_CACHE:
        _load_wft_data()
    # Buscar en caché WFT
    status = _WFT_CACHE.get((symbol, tf, strategy), '')
    if status: return status
    # Fallback: campo wft dentro del JSON
    wft = d.get('wft', {})
    if not wft: return '--'
    verdict = wft.get('verdict','')
    rate    = wft.get('oos_win_rate', 0)
    if verdict.upper() == 'PASS' or rate >= 55: return 'OK'
    if verdict.upper() == 'FAIL' or (0 < rate < 50): return 'FAIL'
    return '--'


def get_best_models():
    """Lee JSON de modelos — sin DB, sin locking. Igual que el dashboard."""
    models = {}
    models_dir = BASE / 'models'
    if not models_dir.exists():
        log(f"Directorio modelos no encontrado: {models_dir}")
        return models

    from datetime import timezone, timedelta
    chile_tz = timezone(timedelta(hours=-4))
    now_cl   = datetime.now(tz=chile_tz)
    best_score = {}

    for tf_dir in sorted(models_dir.iterdir()):
        if not tf_dir.is_dir() or tf_dir.name == 'archive': continue
        tf = tf_dir.name
        if tf not in TF_MINS:
            continue  # ignorar TFs no estandar (2h, 3h, etc)
        for jf in sorted(tf_dir.glob('*.json')):
            if jf.name in SKIP_JSON: continue
            try:
                d      = json.loads(jf.read_text(encoding='utf-8'))
                m      = d.get('metrics_oos', {})
                if not m or m.get('cagr', 0) <= 0: continue
                symbol   = d.get('symbol', '')
                strategy = d.get('strategy', '')
                params   = d.get('params', {})
                if not symbol or not strategy: continue

                score = _score_fn(m, tf)
                if score <= -9999: continue

                key = (symbol, tf)
                if key in best_score and score <= best_score[key]: continue
                best_score[key] = score

                grade_txt, _ = compute_grade(score)
                cagr    = round(m.get('cagr', 0), 1)
                wr_raw  = m.get('wr', 0)
                wr_pct  = round(wr_raw * 100, 1) if wr_raw <= 1.0 else round(wr_raw, 1)

                age_days = 0
                try:
                    mtime = datetime.fromtimestamp(
                        jf.stat().st_mtime, tz=timezone.utc)
                    age_days = max(0, (now_cl - mtime.astimezone(chile_tz)).days)
                except: pass

                wft_st = _wft_status(d, symbol, tf, strategy)
                models[key] = (strategy, params, cagr, wr_pct, score, grade_txt, age_days, wft_st)
            except:
                continue

    for (symbol, tf), (strategy, params, cagr, wr_pct, score, grade_txt, age_days, wft_st) in sorted(models.items()):
        log(f"  {symbol} {tf}: {strategy} CAGR:{cagr:+.1f}% WR:{wr_pct:.0f}% Grade:{grade_txt} WFT:{wft_st} Edad:{age_days}d")
    return models


def gen_f_strat(models):
    lines = ['// Función 1: nombre de estrategia según ticker+TF\n',
             'f_strat(_tk, _tf_m) =>\n', '    string _r = "tma_bands"\n']
    for (symbol, tf), (strategy, params, cagr, wr, score, grade, age, wft) in sorted(models.items()):
        key  = SYMBOL_KEY.get(symbol, symbol.split('/')[0])
        mins = TF_MINS.get(tf, 60)
        lines.append(f'    if str.contains(_tk,"{key}") and _tf_m=={mins}\n')
        lines.append(f'        _r := "{strategy}"\n')
    lines.append('    _r\n')
    return ''.join(lines)


def gen_f_nums(models):
    lines = ['// Función 2: parámetros numéricos — índices: '
             '0=sl 1=tp 2=cd 3=rw 4=lb 5=vm 6=tp2 7=am 8=et 9=re 10=ros 11=rmx 12=sl_s 13=tp_s 14=rwb 15=rwbr\n',
             'f_nums(_tk, _tf_m) =>\n',
             '    float[] _p = array.new<float>(16, 0.0)\n', '    // defaults\n']
    for param, idx in PINE_IDX.items():
        lines.append(f'    array.set(_p, {idx}, {DEFAULTS.get(param, 0.0)})  // {param}\n')
    for (symbol, tf), (strategy, params, cagr, wr, score, grade, age, wft) in sorted(models.items()):
        key  = SYMBOL_KEY.get(symbol, symbol.split('/')[0])
        mins = TF_MINS.get(tf, 60)
        lines.append(f'    // {symbol} {tf} {strategy} CAGR:{cagr:+.1f}% WR:{wr:.0f}% Grade:{grade}\n')
        lines.append(f'    if str.contains(_tk,"{key}") and _tf_m=={mins}\n')
        for param, idx in PINE_IDX.items():
            if param in params:
                lines.append(f'        array.set(_p,{idx},{round(float(params[param]),1)})\n')
    lines.append('    _p\n')
    return ''.join(lines)


def gen_f_meta(models):
    lines = ['// Función 3: metadata del modelo (Grade|dias|WR%|WFT)\n',
             'f_meta(_tk, _tf_m) =>\n', '    string _r = "B|0|50|--"\n']
    for (symbol, tf), (strategy, params, cagr, wr, score, grade, age, wft) in sorted(models.items()):
        key  = SYMBOL_KEY.get(symbol, symbol.split('/')[0])
        mins = TF_MINS.get(tf, 60)
        lines.append(f'    if str.contains(_tk,"{key}") and _tf_m=={mins}\n')
        lines.append(f'        _r := "{grade}|{age}|{int(round(wr))}|{wft}"\n')
    lines.append('    _r\n')
    return ''.join(lines)


def gen_indicators(models):
    lbs  = set()
    tmas = set()
    for (_, _), (_, params, _, _, _, _, _, _) in models.items():
        lbs.add(int(round(params.get('lookback', 30))))
        tmas.add(int(round(params.get('tma_period', 14))))
    lbs |= {29, 30}; tmas |= {14}
    lbs = sorted(lbs); tmas = sorted(tmas)

    lines = ['// [SIGMA-GEN-INDICATORS-START]\n']
    for t in tmas: lines.append(f'_tl{t} = ta.sma(ta.sma(close, {t}), {t})\n')
    def_tma = tmas[len(tmas)//2]
    lines.append('m_tma_line  = ' + ' : '.join(f'm_tma_per=={t}?_tl{t}' for t in tmas) + f' : _tl{def_tma}\n')
    lines.append('m_tma_lower = m_tma_line - atr * m_atr_mult\n')
    lines.append('m_tma_upper = m_tma_line + atr * m_atr_mult\n\n')
    for lb in lbs: lines.append(f'_hi{lb} = ta.highest(high, {lb})\n')
    for lb in lbs: lines.append(f'_lo{lb} = ta.lowest(low,   {lb})\n')
    def_lb = 30 if 30 in lbs else lbs[0]
    lines.append('_m_hi = ' + ' : '.join(f'm_lookback=={lb}?_hi{lb}' for lb in lbs) + f' : _hi{def_lb}\n')
    lines.append('_m_lo = ' + ' : '.join(f'm_lookback=={lb}?_lo{lb}' for lb in lbs) + f' : _lo{def_lb}\n')
    lines.append('// [SIGMA-GEN-INDICATORS-END]\n')
    return ''.join(lines)


def update_pine(models):
    if not PINE_SRC.exists():
        log(f"Pine no encontrado: {PINE_SRC}"); return False
    content = PINE_SRC.read_text(encoding='utf-8')
    _old_pine_for_changelog = content  # snapshot ANTES de mutar (fix audit 2026-05-13)

    # Limpiar cabecera vieja formato ═══
    content = re.sub(r'// ═══+[^\n]*\n(//[^\n]*\n)*// ═══+[^\n]*\n', '', content)

    # Cabecera nueva
    from datetime import timezone, timedelta
    chile_tz = timezone(timedelta(hours=-4))
    now_cl   = datetime.now(tz=chile_tz)
    now_str  = now_cl.strftime('%d/%m/%Y  %H:%M') + ' hrs (Chile)'
    top = sorted(models.items(), key=lambda x: x[1][4], reverse=True)[:8]
    summary = '  '.join(f"{s.split('/')[0]} {tf}:{strat[:3].upper()} {grade} {cagr:+.0f}%"
                        for (s,tf),(strat,_,cagr,_,_,grade,_,_) in top)
    header = (f"// [SIGMA-HEADER-START]\n"
              f"// ╔══════════════════════════════════════════════════════════╗\n"
              f"// ║  SIGMA TERMINAL v13  —  Auto-generado desde VPS         ║\n"
              f"// ║  Actualizado : {now_str:<42}║\n"
              f"// ║  Modelos     : {str(len(models))+' activos':<42}║\n"
              f"// ║  Top modelos : {summary[:42]:<42}║\n"
              f"// ╚══════════════════════════════════════════════════════════╝\n"
              f"// [SIGMA-HEADER-END]\n")
    if '[SIGMA-HEADER-START]' in content:
        content = re.sub(r'// \[SIGMA-HEADER-START\].*?// \[SIGMA-HEADER-END\]\n',
                         header, content, count=1, flags=re.DOTALL)
    else:
        content = re.sub(r'(//@version)', header + r'\1', content, count=1)

    # f_meta
    new_meta = gen_f_meta(models)
    pat_meta = r'// Función 3:.*?\n    _r\n'
    if re.search(pat_meta, content, re.DOTALL):
        content = re.sub(pat_meta, new_meta, content, count=1, flags=re.DOTALL)
    else:
        content = re.sub(r'(// Función 1:)', new_meta + r'\1', content, count=1)

    # f_strat
    new_strat = gen_f_strat(models)
    pat_strat = r'// Función 1:.*?\n    _r\n'
    m = re.search(pat_strat, content, re.DOTALL)
    if not m: log("No se encontró f_strat()"); return False
    content = content[:m.start()] + new_strat + content[m.end():]

    # f_nums
    new_nums = gen_f_nums(models)
    pat_nums = r'// Función 2:.*?\n    _p\n'
    m = re.search(pat_nums, content, re.DOTALL)
    if not m: log("No se encontró f_nums()"); return False
    content = content[:m.start()] + new_nums + content[m.end():]

    # Indicadores pre-computados
    new_ind = gen_indicators(models)
    pat_ind = r'// \[SIGMA-GEN-INDICATORS-START\].*?// \[SIGMA-GEN-INDICATORS-END\]\n'
    if re.search(pat_ind, content, re.DOTALL):
        content = re.sub(pat_ind, new_ind, content, count=1, flags=re.DOTALL)
    else:
        log("Advertencia: marcadores SIGMA-GEN-INDICATORS no encontrados")

    PINE_SRC.write_text(content, encoding='utf-8')
    log(f"Pine actualizado: {len(content.splitlines())} lineas")

    # Changelog: registrar cambios en estrategias
    try:
        changelog = BASE / 'results' / 'reports' / 'pine_changes.log'
        old_pine  = _old_pine_for_changelog  # fix audit 2026-05-13: leer ANTES del write, no despues
        changes   = []
        for (symbol, tf), (strategy, _, cagr, wr, _, grade, _, wft) in sorted(models.items()):
            key  = SYMBOL_KEY.get(symbol, symbol.split('/')[0])
            mins = TF_MINS.get(tf, 60)
            old_strat = re.search(
                rf'str\.contains\(_tk,"{key}"\) and _tf_m=={mins}\s*\n\s*_r := "([^"]+)"',
                old_pine)
            if old_strat:
                old_s = old_strat.group(1)
                if old_s != strategy:
                    changes.append(f"  {symbol} {tf}: {old_s} -> {strategy} ({grade} CAGR:{cagr:+.0f}% WR:{wr:.0f}% WFT:{wft})")
        if changes:
            from datetime import timezone, timedelta
            cl = datetime.now(tz=timezone(timedelta(hours=-4)))
            with open(changelog, 'a', encoding='utf-8') as f:
                f.write(f"\n[{cl:%Y-%m-%d %H:%M} CLT] CAMBIOS DE ESTRATEGIA:\n")
                f.write('\n'.join(changes) + '\n')
            for c in changes:
                log(f"CAMBIO:{c}")
    except: pass

    return True


def _tg_notify_pine(models, changes):
    """Envia notificacion Telegram cuando el Pine Script se actualiza."""
    # Cooldown 2h — evita spam
    import time as _time
    _ts_file = str(BASE / 'results' / 'reports' / 'pine_last_tg.ts')
    try:
        _last = float(open(_ts_file).read().strip())
        if _time.time() - _last < 7200:
            log("TG skip — cooldown 2h activo")
            return
    except: pass
    try: open(_ts_file, 'w').write(str(_time.time()))
    except: pass
    try:
        import urllib.request, json as _json
        TOKEN   = _sigma_get_tg_token()
        CHAT_ID = "-1003787411069"
        from datetime import timezone, timedelta
        cl = datetime.now(tz=timezone(timedelta(hours=-4)))

        top = sorted(models.items(), key=lambda x: x[1][4], reverse=True)[:5]
        top_lines = "\n".join(
            ("  📈 " if cagr >= 20 else "  📊 ") +
            s.replace('/USDT', '') + " " + tf + " " +
            strat[:3].upper() + " " + grade +
            " +" + str(int(cagr)) + "%" +
            " WR " + str(int(wr)) + "%"
            for (s, tf), (strat, _, cagr, wr, _, grade, _, _) in top
        )

        cambios_block = ""
        if changes:
            cambios_block = "\n\n🔄 <b>Cambios de estrategia:</b>\n" + "\n".join(
                "  • " + c.strip() for c in changes[:5]
            )

        msg = (
            "📋 <b>CODIGO ACTUALIZADO</b>\n" +
            cl.strftime('%d/%m/%Y %H:%M') + " (Chile)\n\n" +
            "<b>" + str(len(models)) + " modelos activos</b>\n\n" +
            top_lines +
            cambios_block + "\n\n" +
            "<i>Sube SIGMA_v13_COMPLETO.pine a TradingView</i>"
        )
        url  = "https://api.telegram.org/bot" + TOKEN + "/sendMessage"
        data = _json.dumps({
            "chat_id": CHAT_ID, "text": msg,
            "parse_mode": "HTML", "disable_notification": False
        }, ensure_ascii=False).encode("utf-8")
        req = urllib.request.Request(url, data=data,
              headers={"Content-Type": "application/json; charset=utf-8"})
        urllib.request.urlopen(req, timeout=10)
        log("Notificacion Telegram enviada")
    except Exception as e:
        log("Telegram error: " + str(e))


def run():
    log('=' * 50)
    log('SIGMA Pine Generator — leyendo modelos desde JSON')
    models = get_best_models()
    if not models:
        log("Sin modelos válidos — Pine no modificado"); return
    log(f"Modelos encontrados: {len(models)}")

    ok = update_pine(models)
    if ok:
        log("✓ f_strat(), f_nums(), f_meta() actualizados")
        changes = []
        try:
            changelog = BASE / 'results' / 'reports' / 'pine_changes.log'
            if changelog.exists():
                lines = changelog.read_text(encoding='utf-8').splitlines()
                last_block = []
                for line in reversed(lines):
                    if line.strip().startswith('['): break
                    if line.strip().startswith('  '): last_block.insert(0, line)
                changes = last_block
        except: pass
        _tg_notify_pine(models, changes)
    else:
        log("✗ No se pudo actualizar el Pine")


if __name__ == '__main__':
    run()
