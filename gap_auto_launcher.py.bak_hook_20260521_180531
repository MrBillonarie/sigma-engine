#!/usr/bin/env python3
'''gap_auto_launcher.py — auto-lanza trials para GAPS direccionales cuando RAM disponible.

Corre como cron */15min. Idempotente: no relanza si ya hay trial activo para ese slot.
'''
import json, os, subprocess, time, sys
from pathlib import Path
sys.path.insert(0, '/opt/sigma')

LOG = '/opt/sigma/results/reports/gap_auto_launcher.log'
def log(msg):
    ts = time.strftime('%Y-%m-%d %H:%M:%S')
    line = '[' + ts + '] ' + msg
    print(line)
    try:
        with open(LOG, 'a') as f:
            f.write(line + chr(10))
    except: pass

# Config
MIN_RAM_FREE_MB = 800   # no lanzar si free < 800MB
MAX_PARALLEL = 6        # max trials simultaneos (que terminen sin OOM kill)
TRIALS_PER_SLOT = 100

try:
    from utils.strategies import SHORT_STRATEGIES
except Exception as e:
    log('FATAL importing SHORT_STRATEGIES: ' + str(e))
    sys.exit(1)

SYMS = ['BTC','ETH','SOL','BNB','LTC']
TFS = ['5m','15m','1h','4h']  # 2026-05-20: incluye 5m para llegar a 40 sub-portafolios
DIRS = ['long','short']

# 1. Calcular GAPS
covered = set()
for tf in TFS:
    for fp in Path('/opt/sigma/models/' + tf).glob('*.json'):
        try:
            d = json.load(open(fp))
            m = d.get('metrics_oos') or {}
            if (m.get('cagr',0) or 0) <= 0: continue
            sym = (d.get('symbol','') or '').replace('/USDT','').upper()
            strat = d.get('strategy','')
            if not (sym and strat): continue
            direction = 'short' if strat in SHORT_STRATEGIES else 'long'
            covered.add((sym, tf, direction))
        except: pass

gaps = [(s,t,d) for s in SYMS for t in TFS for d in DIRS if (s,t,d) not in covered]
log('GAPS detectados: ' + str(len(gaps)) + ' (' + ', '.join([g[0]+g[1][:2]+g[2][:1].upper() for g in gaps]) + ')')

if not gaps:
    log('OK: cobertura completa, nada que lanzar')
    sys.exit(0)

# 2. Ver trials activos
r = subprocess.run(['ps','-eo','pid,cmd'], capture_output=True, text=True)
active_slots = set()
n_active = 0
for line in r.stdout.split(chr(10)):
    if 'asset_pipeline.py' not in line or 'grep' in line: continue
    n_active += 1
    ts = line.split()
    sym = tf = focus = None
    for i,t in enumerate(ts):
        if t == '--symbol' and i+1 < len(ts): sym = ts[i+1].replace('/USDT','')
        if t == '--tf' and i+1 < len(ts): tf = ts[i+1]
        if t == '--focus' and i+1 < len(ts): focus = ts[i+1]
    if sym and tf and focus and focus in ('long','short'):
        active_slots.add((sym, tf, focus))

log('Trials activos: ' + str(n_active) + ' / max ' + str(MAX_PARALLEL))
log('  Slots cubiertos por trials: ' + str(sorted(active_slots)))

# 3. RAM check
r = subprocess.run(['free','-m'], capture_output=True, text=True)
mem_line = r.stdout.split(chr(10))[1].split()
free_mb = int(mem_line[3])
avail_mb = int(mem_line[6])
log('RAM free=' + str(free_mb) + 'MB avail=' + str(avail_mb) + 'MB')

# 4. Filtrar GAPS no en trial activo
todo = [g for g in gaps if g not in active_slots]
log('GAPS sin trial activo: ' + str(len(todo)))

if not todo:
    log('OK: todos los GAPS estan siendo atacados')
    sys.exit(0)

# 5. Lanzar
slots_to_launch = MAX_PARALLEL - n_active
if avail_mb < MIN_RAM_FREE_MB:
    log('STOP: RAM insuficiente (avail ' + str(avail_mb) + 'MB < ' + str(MIN_RAM_FREE_MB) + 'MB)')
    sys.exit(0)

if slots_to_launch <= 0:
    log('STOP: ya estamos en max parallel')
    sys.exit(0)

launched = 0
for sym, tf, direction in todo[:slots_to_launch]:
    log_path = '/tmp/sprint_' + sym + '_' + tf + '_' + direction + '.log'
    full_sym = sym + '/USDT'
    cmd = (
        'cd /opt/sigma && (nohup prlimit --as=2400000000 /opt/sigma_env/bin/python -u '
        '/opt/sigma/engine/optimization/asset_pipeline.py '
        '--symbol ' + full_sym + ' --tf ' + tf + ' --focus ' + direction + ' '
        '--trials ' + str(TRIALS_PER_SLOT) + ' '
        '> ' + log_path + ' 2>&1 & )'
    )
    rc = subprocess.run(['bash','-c', cmd], capture_output=True, text=True)
    if rc.returncode == 0:
        log('  LAUNCHED ' + sym + ' ' + tf + ' ' + direction + ' -> ' + log_path)
        launched += 1
        time.sleep(3)
        # Re-check RAM antes de proximo
        r = subprocess.run(['free','-m'], capture_output=True, text=True)
        avail_mb = int(r.stdout.split(chr(10))[1].split()[6])
        if avail_mb < MIN_RAM_FREE_MB:
            log('  STOP intra-loop: avail ' + str(avail_mb) + 'MB')
            break
    else:
        log('  FAIL ' + sym + ' ' + tf + ' ' + direction + ': ' + rc.stderr[:200])

log('TICK end — lanzados=' + str(launched) + ' GAPS pendientes=' + str(len(todo)-launched))
