PER_MODEL_FILE = Path('/opt/sigma/results/per_model_state.json')

# Pausa flag — si existe, opener bloquea nuevas entradas (macro y per-model)

_PAUSA_FLAG_FILE = '/opt/sigma/results/pausa.flag'

def _is_paused_flag():

    import os as _os_p

    return _os_p.path.exists(_PAUSA_FLAG_FILE)







def _load_per_model():

    try:

        if PER_MODEL_FILE.exists():

            import json as _j

            return _j.loads(PER_MODEL_FILE.read_text())

    except Exception as _e:

        print(f'[PER_MODEL LOAD ERROR] {_e}', flush=True)

    return {}



def _save_per_model(state):

    import json as _j, os as _os

    try:

        PER_MODEL_FILE.parent.mkdir(parents=True, exist_ok=True)

        tmp = str(PER_MODEL_FILE) + '.tmp'

        with open(tmp, 'w') as f: _j.dump(state, f, default=str, indent=2)

        os.replace(tmp, str(PER_MODEL_FILE))

    except Exception as _e:

        print(f'[PER_MODEL SAVE ERROR] {_e}', flush=True)



_PER_MODEL_TG_TOKEN  = _sigma_get_tg_token()

_PER_MODEL_TG_CHAT   = "-1003787411069"

_PER_MODEL_TG_ENABLED = True  # 2026-06-12: M2 activo — notificaciones reactivadas para trades reales

# -- BTC Cold Storage Auto-Tracker (15% per profit) --
_BTC_CS_ALLOC_PCT = 0.15
_BTC_PRICE_CACHE  = {'price': 0.0, 'ts': 0.0}
_CS_FILE          = Path('/opt/sigma/results/reports/btc_cold_storage.json')

def _get_btc_price_fast():
    import time as _t_cs
    now = _t_cs.time()
    if now - _BTC_PRICE_CACHE['ts'] < 60 and _BTC_PRICE_CACHE['price'] > 0:
        return _BTC_PRICE_CACHE['price']
    try:
        import urllib.request as _ur_cs, json as _j_cs
        url = 'https://fapi.binance.com/fapi/v1/ticker/price?symbol=BTCUSDT'
        p = float(_j_cs.loads(_ur_cs.urlopen(url, timeout=4).read())['price'])
        _BTC_PRICE_CACHE['price'] = p
        _BTC_PRICE_CACHE['ts']    = now
        return p
    except Exception:
        return _BTC_PRICE_CACHE.get('price', 0.0)


def _track_btc_cold_storage(pnl_dollar, sym, tf, reason, exit_price=0):
    """Registra 15% del profit en btc_cold_storage.json y notifica Telegram."""
    if pnl_dollar <= 0:
        return
    try:
        import json as _j_cs2
        alloc_usd  = round(pnl_dollar * _BTC_CS_ALLOC_PCT, 4)
        btc_price  = exit_price if (sym == 'BTC' and exit_price > 0) else _get_btc_price_fast()
        btc_amount = round(alloc_usd / btc_price, 8) if btc_price > 0 else 0.0
        sats       = int(btc_amount * 1e8)
        cs = {'entries': [], 'total_btc': 0.0, 'total_usd': 0.0, 'goal_btc': 1.0}
        if _CS_FILE.exists():
            try:
                cs = _j_cs2.loads(_CS_FILE.read_text())
            except Exception:
                pass
        entry = {
            'date': _strftime_chile('%Y-%m-%d %H:%M:%S'),
            'trade': f'{sym}_{tf}',
            'reason': reason,
            'pnl_usd': round(pnl_dollar, 2),
            'alloc_usd': alloc_usd,
            'btc_price': round(btc_price, 2),
            'btc': btc_amount,
            'sats': sats,
        }
        cs.setdefault('entries', []).append(entry)
        cs['total_btc'] = round(sum(e.get('btc', 0) for e in cs['entries']), 8)
        cs['total_usd'] = round(sum(e.get('alloc_usd', 0) for e in cs['entries']), 4)
        _CS_FILE.parent.mkdir(parents=True, exist_ok=True)
        _CS_FILE.write_text(_j_cs2.dumps(cs, indent=2))
        pct_goal = round(cs['total_btc'] / max(cs.get('goal_btc', 1.0), 1e-10) * 100, 4)
        msg = (
            f"\U0001fa99 <b>BTC Cold Storage +{sats:,} sats</b>\n"
            f"Trade: {sym}_{tf} | {reason}\n"
            f"Profit: +${pnl_dollar:.2f} -> 15% = ${alloc_usd:.2f}\n"
            f"BTC precio: ${btc_price:,.0f}\n"
            f"<b>Total acumulado: {cs['total_btc']:.8f} BTC</b>\n"
            f"Meta 1.0 BTC: {pct_goal:.4f}% completado"
        )
        try:
            import urllib.request as _ur_tg, urllib.parse as _up_tg
            url_tg = f"https://api.telegram.org/bot{_PER_MODEL_TG_TOKEN}/sendMessage"
            data_tg = _up_tg.urlencode({
                'chat_id': _PER_MODEL_TG_CHAT,
                'text': msg,
                'parse_mode': 'HTML',
                'disable_web_page_preview': 'true',
            }).encode()
            _ur_tg.urlopen(_ur_tg.Request(url_tg, data=data_tg), timeout=5)
        except Exception as _et_cs:
            print(f'[COLD STORAGE TG ERROR] {_et_cs}', flush=True)
    except Exception as _ecs:
        print(f'[COLD STORAGE ERROR] {_ecs}', flush=True)

# -- fin BTC Cold Storage --

_NOTIF_FEED_FILE = Path('/opt/sigma/results/notifications.jsonl')



def _append_notification(event):

    """Append evento al feed JSONL para que el dashboard lo muestre."""

    try:

        _NOTIF_FEED_FILE.parent.mkdir(parents=True, exist_ok=True)

        with open(_NOTIF_FEED_FILE, 'a', encoding='utf-8') as f:

            import json as _j

            f.write(_j.dumps(event, default=str) + '\n')

        # Mantener solo ultimas 200 lineas

        try:

            lines = _NOTIF_FEED_FILE.read_text(encoding='utf-8').splitlines()

            if len(lines) > 200:

                _NOTIF_FEED_FILE.write_text('\n'.join(lines[-200:]) + '\n', encoding='utf-8')

        except: pass

    except Exception as _e:

        print(f'[NOTIF FEED ERROR] {_e}', flush=True)



def get_recent_notifications(limit=50):

    """Lee las ultimas N notificaciones para el dashboard."""

    try:

        if not _NOTIF_FEED_FILE.exists(): return []

        import json as _j

        lines = _NOTIF_FEED_FILE.read_text(encoding='utf-8').splitlines()

        evs = []

        for line in lines[-limit:]:

            try: evs.append(_j.loads(line))

            except: pass

        return list(reversed(evs))  # mas reciente primero

    except: return []



def _notify_per_model_open(sym, tf, strategy, direction, entry, sl, tp, kelly_pct, grade='?', cagr_bt=0, wr_bt=0):

    """Notifica a Telegram + persiste en feed para el dashboard."""

    is_short = direction == 'short'

    arrow = '▼ SHORT' if is_short else '▲ LONG'

    sl_dist_pct = abs(sl - entry) / entry * 100 if entry > 0 else 0

    rr = abs(tp - entry) / max(abs(entry - sl), 1e-6)

    # Persistir al feed (siempre, independiente de Telegram)

    try:

        _append_notification({

            'ts': _strftime_chile('%Y-%m-%d %H:%M:%S'),

            'type': 'per_model_open',

            'sym': sym, 'tf': tf, 'strategy': strategy, 'direction': direction,

            'grade': grade, 'cagr_bt': cagr_bt, 'wr_bt': wr_bt,

            'entry': entry, 'sl': sl, 'tp': tp, 'kelly_pct': kelly_pct,

            'sl_dist_pct': round(sl_dist_pct, 2), 'rr': round(rr, 2),

            'title': f'{sym} {tf.upper()} {arrow.split()[1]}',

            'subtitle': f'{strategy} [{grade}]'

        })

    except: pass

    # Telegram (silenciado del grupo publico - 2026-05-31)

    if not _PER_MODEL_TG_ENABLED:

        return

    try:

        import urllib.request as _ur, urllib.parse as _up

        msg = (

            f"📊 <b>Per-Model TRADE</b>\n"

            f"<i>Sub-cuenta de estudio individual</i>\n\n"

            f"{arrow} <b>{sym} {tf.upper()}</b>\n"

            f"Estrategia: <code>{strategy}</code> [{grade}]\n\n"

            f"Entrada: <code>{entry}</code>\n"

            f"Stop Loss: <code>{sl}</code> ({sl_dist_pct:.2f}%)\n"

            f"Take Profit: <code>{tp}</code>\n"

            f"Ratio RR: <code>{rr:.1f}:1</code>\n"

            f"Kelly: <code>{kelly_pct}%</code>\n\n"

            f"Backtest: WR <code>{wr_bt:.0f}%</code> · CAGR <code>{cagr_bt:+.1f}%</code>"

        )

        url = f"https://api.telegram.org/bot{_PER_MODEL_TG_TOKEN}/sendMessage"

        data = _up.urlencode({

            'chat_id': _PER_MODEL_TG_CHAT,

            'text': msg, 'parse_mode': 'HTML',

            'disable_web_page_preview': 'true',

            'disable_notification': 'false',

        }).encode()

        _ur.urlopen(_ur.Request(url, data=data), timeout=8)

    except Exception as _e:

        print(f'[PER_MODEL NOTIFY ERROR] {_e}', flush=True)







def _notify_per_model_close(sym, tf, strategy, direction, pnl_pct, reason, equity_after=0):

    """Notify per-model trade close: Telegram + feed."""

    try:

        _append_notification({

            'ts': _strftime_chile('%Y-%m-%d %H:%M:%S'),

            'type': 'per_model_close',

            'sym': sym, 'tf': tf, 'strategy': strategy, 'direction': direction,

            'pnl_pct': pnl_pct, 'reason': reason, 'equity_after': equity_after,

            'title': f'{sym} {tf.upper()} {"WIN" if pnl_pct > 0 else "LOSS"}',

            'subtitle': f'{strategy} {pnl_pct:+.2f}% [{reason}]'

        })

    except: pass

    if not _PER_MODEL_TG_ENABLED:  # 2026-05-31: silenciado del grupo publico

        return

    try:

        import urllib.request as _ur, urllib.parse as _up

        icon = '✅' if pnl_pct > 0 else '❌'

        msg = (

            f"{icon} <b>Per-Model CLOSE</b>\n"

            f"{sym} {tf.upper()} {direction.upper()} · <code>{strategy}</code>\n\n"

            f"P&L: <b>{pnl_pct:+.3f}%</b>\n"

            f"Reason: <code>{reason}</code>\n"

            f"Equity sub-cuenta: <code>${equity_after:,.2f}</code>"

        )

        url = f"https://api.telegram.org/bot{_PER_MODEL_TG_TOKEN}/sendMessage"

        data = _up.urlencode({

            'chat_id': _PER_MODEL_TG_CHAT, 'text': msg, 'parse_mode': 'HTML',

            'disable_notification': 'true'  # cierres mas silenciosos que aperturas

        }).encode()

        _ur.urlopen(_ur.Request(url, data=data), timeout=8)

    except Exception as _e:

        print(f'[PER_MODEL CLOSE NOTIFY ERROR] {_e}', flush=True)



def open_trade_per_model(sym, tf, strategy, direction, entry, sl, tp, kelly_pct=5.0):

    """Abre trade en sub-account del modelo. Sin restriccion macro. Notifica via Telegram."""

    if not (sym and tf and strategy and entry and sl and tp): return None

    state = _load_per_model()

    key = f"{sym}_{tf}_{strategy}"

    if key not in state:

        state[key] = {'equity': 10000, 'initial': 10000, 'open': None, 'history': [],

                      'created_at': _strftime_chile('%Y-%m-%d %H:%M:%S')}

    if state[key].get('open'):

        return None  # ya tiene trade abierto, no duplicar

    sl_dist = abs(sl - entry) / entry * 100 if entry > 0 else 0

    state[key]['open'] = {

        'sym': sym, 'tf': tf, 'strategy': strategy, 'direction': direction,

        'entry': entry, 'sl': sl, 'tp': tp,

        'sl_dist_pct_at_open': round(sl_dist, 4), 'kelly_pct': kelly_pct,

        'opened_at': _strftime_chile('%Y-%m-%d %H:%M:%S')

    }

    _save_per_model(state)

    # Notify Telegram (con datos del backtest del cache)

    try:

        bt = next((sm for sm in _signals_cache.get('models', [])

                   if sm.get('sym')==sym and sm.get('tf')==tf and sm.get('strategy')==strategy), {})

        _notify_per_model_open(

            sym, tf, strategy, direction, entry, sl, tp, kelly_pct,

            grade=bt.get('grade', '?'),

            cagr_bt=bt.get('cagr', 0), wr_bt=bt.get('wr', 0)

        )

    except: pass

    return state[key]['open']



def close_trade_per_model(sym, tf, strategy, exit_price, reason='AUTO'):

    """Cierra trade per_model. Usa formula backtest: pnl = raw × kelly/sl_dist."""

    state = _load_per_model()

    key = f"{sym}_{tf}_{strategy}"

    if key not in state or not state[key].get('open'): return None

    ot = state[key]['open']

    entry = ot.get('entry', 0); direction = ot.get('direction', 'long')

    kelly = ot.get('kelly_pct', 5.0); sl_dist = ot.get('sl_dist_pct_at_open', 0)

    if entry > 0 and exit_price > 0:

        raw = ((exit_price - entry)/entry if direction == 'long' else (entry - exit_price)/entry) * 100

        if sl_dist > 0:

            raw -= PAPER_SLIPPAGE_BPS * 2 * 0.01  # slippage drag
            pnl_pct = round(raw * (kelly/sl_dist), 4)

        else:

            print(f"[PNL FALLBACK] sl_dist invalid={sl_dist} sym={sym} tf={tf} strat={strategy} -> formula simple (1/100)", flush=True)

            pnl_pct = round(raw * kelly/100, 4)

    else:

        pnl_pct = 0.0; raw = 0.0

    eq_before = state[key].get('equity', 10000)

    pnl_dollar = round(eq_before * pnl_pct / 100, 4)

    eq_after = round(eq_before + pnl_dollar, 2)

    state[key]['equity'] = eq_after

    closed = {**ot, 'exit_price': exit_price, 'reason': reason,

              'pnl_pct_raw': round(raw, 4), 'pnl_pct': pnl_pct,

              'pnl_dollar': pnl_dollar, 'equity_after': eq_after,

              'closed_at': _strftime_chile('%Y-%m-%d %H:%M:%S')}

    state[key]['history'] = (state[key].get('history', []) + [closed])[-200:]

    state[key]['open'] = None

    _save_per_model(state)

    try:

        _notify_per_model_close(sym, tf, strategy, direction, pnl_pct, reason, eq_after)

    except: pass

    return closed



def check_auto_close_per_model(sym, tf, current_price):

    """Verifica todos los modelos para sym/tf, cierra los que toquen SL/TP.

    Skipea trades marcados como _fake_test (no contaminar historia real)."""

    state = _load_per_model()

    closed_list = []

    prefix = f"{sym}_{tf}_"

    for key, m in list(state.items()):

        if not key.startswith(prefix): continue

        ot = m.get('open')

        if not ot: continue

        if ot.get('_fake_test'): continue   # proteger fakes de prueba

        entry = ot.get('entry', 0); sl = ot.get('sl', 0); tp = ot.get('tp', 0)

        direction = ot.get('direction', 'long')

        if not (entry and sl and tp): continue

        hit = None

        if direction == 'long':

            if current_price <= sl:   hit = 'SL_HIT'

            elif current_price >= tp: hit = 'TP_HIT'

        else:

            if current_price >= sl:   hit = 'SL_HIT'

            elif current_price <= tp: hit = 'TP_HIT'

        if hit:

            strategy = key[len(prefix):]

            r = close_trade_per_model(sym, tf, strategy, current_price, hit)

            if r: closed_list.append(r)

    return closed_list



def get_per_model_stats():

    """Devuelve stats por modelo + comparativa backtest + Sharpe + ranking score + retired detection."""

    from datetime import datetime as _dt

    state = _load_per_model()

    bt_index = {}

    # Tambien indexar por sym_tf (ignorando strategy) para detectar champions activos

    active_champions = {}  # sym_tf -> strategy actualmente activo

    for sm in _signals_cache.get('models', []):

        k = f"{sm.get('sym','')}_{sm.get('tf','')}_{sm.get('strategy','')}"

        bt_index[k] = sm

        sym_tf = f"{sm.get('sym','')}_{sm.get('tf','')}"

        # Si tiene recommendation operable, es champion activo de ese sym_tf

        if sm.get('recommendation') in ('ACTIVAR', 'CONDICIONAL', 'ESPERAR'):

            # Preferir el de mejor grade/score

            existing = active_champions.get(sym_tf)

            if not existing or (sm.get('score', 0) > existing.get('score', 0)):

                active_champions[sym_tf] = sm

    out = {}

    for key, m in state.items():

        hist = m.get('history', [])

        eq = m.get('equity', 10000); initial = m.get('initial', 10000)

        wins = sum(1 for h in hist if h.get('pnl_pct', 0) > 0)

        losses = sum(1 for h in hist if h.get('pnl_pct', 0) < 0)

        n = len(hist)

        wr = round(wins/n*100, 1) if n else 0

        gains = sum(h.get('pnl_pct', 0) for h in hist if h.get('pnl_pct', 0) > 0)

        losses_amt = abs(sum(h.get('pnl_pct', 0) for h in hist if h.get('pnl_pct', 0) < 0))

        pf = round(gains/losses_amt, 2) if losses_amt > 0 else (round(gains, 2) if gains > 0 else 0)



        # DD

        peak = initial; max_dd = 0; running = initial

        eq_curve = [initial]

        for h in hist:

            running = h.get('equity_after', running)

            eq_curve.append(running)

            peak = max(peak, running)

            if peak > 0:

                dd = (running - peak)/peak * 100

                max_dd = min(max_dd, dd)

        parts = key.split('_', 2)



        # Backtest

        bt = bt_index.get(key, {})

        wr_bt = bt.get('wr', 0)

        cagr_bt = bt.get('cagr', 0)

        dd_bt = bt.get('dd', 0)

        grade_bt = bt.get('grade', '?')

        wr_delta = round(wr - wr_bt, 1) if (n > 0 and wr_bt > 0) else 0



        # Status divergencia

        if n == 0: status = 'NEW'

        elif n < 5: status = 'EARLY'

        elif wr_bt > 0:

            ratio = wr / wr_bt

            if ratio >= 0.85:   status = 'OK'

            elif ratio >= 0.60: status = 'DEGRADING'

            else:               status = 'FAILING'

        else: status = 'OK'



        # Sharpe (anualizado simple): avg/std × sqrt(N_anual) — usar N_anual proxy = trades_year del backtest

        pnls = [h.get('pnl_pct', 0) for h in hist]

        sharpe = 0.0

        if len(pnls) >= 2:

            avg = sum(pnls)/len(pnls)

            var = sum((p-avg)**2 for p in pnls) / max(len(pnls)-1, 1)

            std = var**0.5

            if std > 0:

                # asume ~50 trades/año (proxy razonable para multi-modelo, conservador)

                sharpe = round(avg/std * (50**0.5), 2)



        # Best / worst trade %

        best_pct = round(max(pnls), 3) if pnls else 0

        worst_pct = round(min(pnls), 3) if pnls else 0



        # Hold time promedio (en horas)

        avg_hold_h = 0

        try:

            holds = []

            for h in hist:

                op = h.get('opened_at', ''); cl = h.get('closed_at', '')

                if op and cl:

                    o_dt = _dt.strptime(op[:19], '%Y-%m-%d %H:%M:%S')

                    c_dt = _dt.strptime(cl[:19], '%Y-%m-%d %H:%M:%S')

                    holds.append((c_dt - o_dt).total_seconds() / 3600)

            if holds: avg_hold_h = round(sum(holds)/len(holds), 1)

        except: pass



        # Trades/mes proyectado (extrapolado de la velocidad actual)

        trades_per_month = 0

        if n > 0 and hist:

            try:

                first = hist[0].get('opened_at', hist[0].get('closed_at', ''))[:19]

                last  = hist[-1].get('closed_at', hist[-1].get('opened_at', ''))[:19]

                f_dt = _dt.strptime(first, '%Y-%m-%d %H:%M:%S')

                l_dt = _dt.strptime(last, '%Y-%m-%d %H:%M:%S')

                days = max((l_dt - f_dt).total_seconds() / 86400, 1)

                trades_per_month = round(n/days * 30, 1)

            except: pass



        # Dias desde ultimo trade

        days_since_last = None

        if hist:

            try:

                last_str = hist[-1].get('closed_at', '')[:10]

                if last_str:

                    last_dt = _dt.strptime(last_str, '%Y-%m-%d')

                    days_since_last = (_dt.now() - last_dt).days

            except: pass



        # Score compuesto (0-100) — combina varias dimensiones

        # Componentes: status (40), return live (20), WR delta (15), PF (15), DD (10)

        score = 0

        if status == 'OK':         score += 40

        elif status == 'EARLY':    score += 25

        elif status == 'NEW':      score += 15

        elif status == 'DEGRADING':score += 10

        elif status == 'FAILING':  score += 0

        ret = (eq/initial - 1) * 100

        score += min(20, max(0, ret * 2))  # +2 puntos por % de return, cap 20

        if n > 0 and wr_bt > 0:

            score += max(0, min(15, 15 + wr_delta * 0.5))  # delta vs backtest

        if pf >= 2:    score += 15

        elif pf >= 1.5: score += 10

        elif pf >= 1.2: score += 5

        if max_dd >= -5:   score += 10

        elif max_dd >= -10: score += 5

        score = round(min(100, max(0, score)), 1)



        # Detectar RETIRED: el modelo ya no esta en signals_cache (champion rotado)

        # Solo si bt_index tiene contenido (sino signals esta cargando — no marcar todos retired)

        sym_tf = f"{parts[0] if len(parts)>0 else ''}_{parts[1] if len(parts)>1 else ''}"

        retired = False

        replaced_by = None

        if len(bt_index) > 0 and parts[0] and parts[1]:

            if key not in bt_index:

                retired = True

                new_champion = active_champions.get(sym_tf)

                if new_champion and new_champion.get('strategy') != (parts[2] if len(parts)>2 else ''):

                    replaced_by = new_champion.get('strategy', '?')



        out[key] = {

            'sym': parts[0] if len(parts) > 0 else key,

            'tf':  parts[1] if len(parts) > 1 else '?',

            'strategy': parts[2] if len(parts) > 2 else '?',

            'grade_backtest': grade_bt,

            'recommendation': bt.get('recommendation', m.get('recommendation_at_init', '?')),

            'reason': bt.get('reason', ''),

            'direction': bt.get('type', 'long'),

            'equity': eq, 'initial': initial,

            'return_pct': round((eq/initial - 1) * 100, 3),

            'trades_closed': n, 'wins': wins, 'losses': losses,

            'wr': wr, 'pf': pf, 'max_dd_pct': round(max_dd, 2),

            'wr_backtest': wr_bt, 'cagr_backtest': cagr_bt, 'dd_backtest': dd_bt,

            'wr_delta': wr_delta,

            'sharpe': sharpe,

            'best_pct': best_pct, 'worst_pct': worst_pct,

            'avg_hold_h': avg_hold_h,

            'trades_per_month': trades_per_month,

            'score': score,

            'status': status,

            'retired': retired,

            'replaced_by': replaced_by,

            'days_since_last': days_since_last,

            'has_open': m.get('open') is not None,

            'open': m.get('open'),

            'last_trade': hist[-1] if hist else None,

            'history_recent': hist[-10:],

            'equity_curve': eq_curve[-50:],

            'created_at': m.get('created_at', ''),

        }

    return out

# ╚══════════════════════════════════════════════════════════════════════════╝





def check_auto_close(sym, tf, current_price):
    """Verifica si SL o TP fue tocado. Incluye trailing stop activo."""
    state = _load_trades()
    key   = f'{sym}_{tf}'
    trade = state.get('open', {}).get(key)
    if not trade or trade.get('status') != 'open':
        return None

    entry     = trade.get('entry', 0)
    sl        = trade.get('sl', 0)
    tp        = trade.get('tp', 0)
    direction = trade.get('direction', 'long')

    if not (entry and sl and tp and current_price):
        return None

    # Trailing stop: activa tras 1xR favorable, sigue a 0.5xR del watermark
    TRAIL_ACTIVATE = 1.0   # multiplicador de sl_dist para activar
    TRAIL_KEEP     = 0.5   # multiplicador de sl_dist para la distancia de trail
    sl_dist_pct = float(trade.get('sl_dist_pct_at_open') or 0)
    _trail_updated = False
    if sl_dist_pct > 0.1:
        if direction == 'long':
            unrealized = (current_price - entry) / entry * 100
            if unrealized >= TRAIL_ACTIVATE * sl_dist_pct:
                hw = max(float(trade.get('trail_high_water') or entry), current_price)
                trail_sl = round(hw * (1.0 - TRAIL_KEEP * sl_dist_pct / 100.0), 4)
                if trail_sl > sl:
                    state['open'][key]['sl']               = trail_sl
                    state['open'][key]['trail_high_water'] = hw
                    state['open'][key]['trail_active']     = True
                    sl = trail_sl
                    _trail_updated = True
        else:
            unrealized = (entry - current_price) / entry * 100
            if unrealized >= TRAIL_ACTIVATE * sl_dist_pct:
                lw = min(float(trade.get('trail_low_water') or entry), current_price)
                trail_sl = round(lw * (1.0 + TRAIL_KEEP * sl_dist_pct / 100.0), 4)
                if trail_sl < sl:
                    state['open'][key]['sl']              = trail_sl
                    state['open'][key]['trail_low_water'] = lw
                    state['open'][key]['trail_active']    = True
                    sl = trail_sl
                    _trail_updated = True
    if _trail_updated:
        _save_trades(state)
        print(f'[TRAIL] {sym}/{tf} {direction} trail_sl={sl:.4f}', flush=True)

    hit = None
    if direction == 'long':
        if current_price <= sl:    hit = 'SL_HIT'
        elif current_price >= tp:  hit = 'TP_HIT'
    else:
        if current_price >= sl:    hit = 'SL_HIT'
        elif current_price <= tp:  hit = 'TP_HIT'

    if hit:
        reason = 'TRAIL_HIT' if trade.get('trail_active') else hit
        return close_trade(sym, tf, current_price, reason)
    return None
def is_blocked(sym, tf):

    """True si hay trade abierto o cooldown activo para este sym/tf."""

    state = _load_trades()

    key   = f'{sym}_{tf}'

    trade = state.get('open', {}).get(key)

    if not trade:

        return False

    if trade.get('status') == 'open':

        return True

    if trade.get('status') == 'cooldown':

        if time.time() < trade.get('cooldown_until', 0):

            return True

        del state['open'][key]

        _save_trades(state)

    return False





def check_circuit_breaker():

    """True si el circuit breaker esta activo. Auto-reset tras 72h sin nuevas operaciones."""

    state = _load_trades()

    cb = state.get('circuit_breaker', {})

    if not cb or not cb.get('active', False):

        return False

    # Auto-reset: si lleva >72h activo sin nuevas pérdidas, desactivar

    try:

        from datetime import datetime as _dt_cb

        _activated = str(cb.get('activated_at', ''))[:19]

        if _activated:

            _hours = (_dt_cb.now() - _dt_cb.fromisoformat(_activated)).total_seconds() / 3600

            if _hours >= 72:

                state['circuit_breaker'] = {

                    'active': False,

                    'reason': f'Auto-reset tras {_hours:.0f}h sin nuevas operaciones',

                    'reset_at': _strftime_chile('%Y-%m-%d %H:%M:%S.%f'),

                    'prev_reason': cb.get('reason', ''),

                }

                _save_trades(state)

                print(f'[CIRCUIT BREAKER] AUTO-RESET tras {_hours:.0f}h', flush=True)

                return False

    except Exception:

        pass

    return True





_signals_cache = {}
_ohlcv_cache = {}  # {(symbol, tf): (ts, df)} — persists between _compute_signals calls

_deriv_cache = {}  # {symbol: (ts, data)} — 5-min TTL for LSR/OI/FG context


def _get_deriv_context(symbol):
    """Return latest LSR/OI/FG context for a symbol (read-only, never blocks signals)."""
    import time as _tm, sqlite3 as _sq, os as _os
    _now = _tm.time()
    _cached = _deriv_cache.get(symbol)
    if _cached and _now - _cached[0] < 300:
        return _cached[1]

    _out = {}
    _sym_usdt = symbol if symbol.endswith("USDT") else symbol + "USDT"

    # LSR — global long/short ratio for 1h timeframe
    _lsr_db = "/opt/sigma/results/lsr.db"
    if _os.path.exists(_lsr_db):
        try:
            _conn = _sq.connect(_lsr_db, timeout=2)
            _row = _conn.execute(
                "SELECT long_ratio, ls_ratio FROM lsr "
                "WHERE symbol=? AND tf='1h' AND kind='global' ORDER BY ts DESC LIMIT 1",
                (_sym_usdt,)
            ).fetchone()
            _conn.close()
            if _row:
                _out["lsr"] = round(_row[1], 3)
                _out["lsr_long_pct"] = round(_row[0] * 100, 1)
        except Exception:
            pass

    # OI — open interest change % in last 15m candle
    _oi_db = "/opt/sigma/results/oi.db"
    if _os.path.exists(_oi_db):
        try:
            _conn = _sq.connect(_oi_db, timeout=2)
            _rows = _conn.execute(
                "SELECT sum_open_interest FROM oi WHERE symbol=? AND tf='15m' ORDER BY ts DESC LIMIT 2",
                (_sym_usdt,)
            ).fetchall()
            _conn.close()
            if len(_rows) == 2 and _rows[1][0]:
                _out["oi_change_pct"] = round((_rows[0][0] - _rows[1][0]) / _rows[1][0] * 100, 3)
        except Exception:
            pass

    # FG — Fear & Greed (BTC global, same for all symbols)
    _fg_db = "/opt/sigma/results/fng.db"
    if _os.path.exists(_fg_db):
        try:
            _conn = _sq.connect(_fg_db, timeout=2)
            _row = _conn.execute("SELECT value, classification FROM fng ORDER BY ts DESC LIMIT 1").fetchone()
            _conn.close()
            if _row:
                _out["fg"] = _row[0]
                _out["fg_label"] = _row[1]
        except Exception:
            pass

    _deriv_cache[symbol] = (_now, _out)
    return _out


# Load cached signals from disk (warm start after restart)

try:

    _disk_cache_path = Path('/opt/sigma/results/signals_cache.json')

    if _disk_cache_path.exists():

        with open(_disk_cache_path) as _f:

            _disk_cache = json.load(_f)

        # Solo usar si tiene < 10 min de edad

        _ok_ts_disk = _disk_cache.get('_last_compute_ok_ts', 0)

        if _ok_ts_disk and (time.time() - _ok_ts_disk) < 600:

            _signals_cache = _disk_cache

            print(f'[STARTUP] signals_cache cargado de disco (edad {time.time()-_ok_ts_disk:.0f}s, {len(_disk_cache.get("models",[]))} modelos)', flush=True)

        else:

            print(f'[STARTUP] signals_cache en disco DEMASIADO viejo (edad {time.time()-_ok_ts_disk:.0f}s) - se descarta', flush=True)

except Exception as _ec:

    print(f'[STARTUP] No se pudo cargar signals_cache de disco: {_ec}', flush=True)

_signals_ts    = 0



def _refresh_signals():

    global _signals_cache, _signals_ts

    import json as _jp

    time.sleep(2)  # pequena pausa inicial

    _cache_disk = Path('/opt/sigma/results/signals_cache.json')

    while True:

        t0 = time.time()

        try:

            result = _compute_signals()

            elapsed = time.time() - t0

            if result and result.get('models') is not None:

                result['_last_compute_ok_ts'] = time.time()

                result['_last_compute_duration_s'] = round(elapsed, 2)

                _signals_cache = result

                _signals_ts    = time.time()

                # Pre-inicializar per_model state para modelos operables (sin trades aun)

                try:

                    _init_per_model_for_operable(result.get('models', []))

                except Exception as _epm:

                    print(f'[PER_MODEL INIT ERROR] {_epm}', flush=True)

                # Persistir cache a disco (atomico)

                try:

                    _tmp = str(_cache_disk) + '.tmp'

                    with open(_tmp, 'w') as _f: _jp.dump(result, _f, default=str)

                    os.replace(_tmp, str(_cache_disk))

                except Exception as _epers:

                    print(f'[SIGNALS PERSIST ERROR] {_epers}', flush=True)

                if elapsed > 60:

                    print(f'[SIGNALS WARN] _compute_signals tardo {elapsed:.1f}s (>60s)', flush=True)

            else:

                print(f'[SIGNALS WARN] _compute_signals devolvio vacio en {elapsed:.1f}s', flush=True)

        except Exception as _e:

            elapsed = time.time() - t0

            import traceback as _tb

            print(f'[SIGNALS ERROR after {elapsed:.1f}s] {_e}\n{_tb.format_exc()}', flush=True)

        try:
            import gc as _gc_sigma
            _gc_sigma.collect()
        except Exception:
            pass
        time.sleep(5)   # cada 5 segundos - refresh acelerado



def _init_per_model_for_operable(models):

    """Pre-inicializa per_model state con $10k para TODOS los modelos del universo.

    Incluye ACTIVAR, CONDICIONAL, ESPERAR (regime bloqueado) y NO_ACTIVAR.

    Asi en /models se ven los 20+ modelos juntos, cada uno como sub-portfolio."""

    state = _load_per_model()

    changed = False

    for m in models:

        sym = m.get('sym',''); tf = m.get('tf',''); strat = m.get('strategy','')

        if not (sym and tf and strat): continue

        if strat == '?': continue

        key = f"{sym}_{tf}_{strat}"

        if key not in state:

            state[key] = {

                'equity': 10000, 'initial': 10000, 'open': None, 'history': [],

                'created_at': _strftime_chile('%Y-%m-%d %H:%M:%S'),

                'pre_initialized': True,

                'recommendation_at_init': m.get('recommendation', '?'),

            }

            changed = True

    if changed:

        _save_per_model(state)



def _compute_signals():

    """Chequea señal activa en último candle cerrado para cada modelo guardado."""

    import glob, json as _j

    try:

        import ccxt, pandas as pd

        ex = ccxt.binance({'timeout': 20000, 'options': {'defaultType': 'future'}})

    except:

        return {}



    SKIP = {'config.json','adaptive_params.json','walk_forward_v2.json',

            'current_params.json','regime_params.json','config_aggressive.json',

            'new_strategy.json','conservative.json'}



    GRADES = [(0.58,'A+'),(0.46,'A'),(0.34,'B'),(0.22,'C')]

    GRADES_LOWR= [(0.34,'B'),(0.22,'C')]  # WR<50% nunca mejor que B

    def grade(s, wr=100):

        caps = GRADES_LOWR if (0 < wr < 50) else GRADES

        for t,g in caps:

            if s >= t: return g

        return 'D'



    def score_fn(m):

        t  = m.get('trades', 0);      ty  = m.get('trades_year', 0)

        wr = m.get('wr', 0);          cagr= m.get('cagr', 0)

        dd = m.get('dd', 0);          pf  = m.get('pf', 1)

        if t < 10 or cagr <= 0: return -9999

        if ty <= 0 and t > 0: ty = t * (365 / 600)

        if ty < 3: return -9999

        if wr <= 0 and cagr > 0: wr = 50



        # Base score -- pesos rebalanceados para hacer espacio a mejoras

        base = (

            min(ty / 12, 1)                         * 0.15 +   # frecuencia

            min(cagr, 70) / 70                       * 0.32 +   # CAGR

            min(max(wr / 100 - 0.45, 0) / 0.25, 1)  * 0.15 +   # WR

            min(cagr / abs(dd) if dd < 0 else 0, 6) / 6 * 0.13 +  # Calmar

            min(pf, 3) / 3                           * 0.10 +   # Profit factor

            min(cagr / max(abs(dd), 5), 8) / 8       * 0.07     # Risk-adj

        )



        # Confianza estadistica: penalizar modelos con pocos trades OOS

        stat_conf = min(t / 25.0, 1.0)            # 100% desde 25 trades

        base *= (0.65 + 0.35 * stat_conf)



        # Recencia: modelos recientes valen mas (mercado evoluciona)

        try:

            saved_at = m.get('_saved_at', '')

            if saved_at:

                from datetime import datetime as _dtx

                age_days = (_dtx.now() - _dtx.fromisoformat(saved_at[:19])).days

                recency = max(0.80, 1.0 - age_days * 0.004)  # -0.4%/dia, min 80%

                base *= recency

        except Exception:

            pass



        # Ajuste live: si el modelo tiene trades en produccion, usar esa data

        try:

            import sqlite3 as _sq_sf

            sym_sf  = m.get('_symbol', '')

            tf_sf   = m.get('_tf', '')

            strat_sf= m.get('_strategy', '')

            if sym_sf and tf_sf and strat_sf:

                _c = _sq_sf.connect('/opt/sigma/models/sigma.db', timeout=2)

                _r = _c.execute(

                    'SELECT wins,losses FROM model_live_stats WHERE sym=? AND tf=? AND strategy=?',

                    (sym_sf, tf_sf.lower(), strat_sf)

                ).fetchone()

                _c.close()

                if _r and (_r[0] + _r[1]) >= 5:

                    live_wr  = _r[0] / (_r[0] + _r[1]) * 100

                    live_adj = (live_wr - wr) / 100   # positivo si live > backtest

                    base    *= max(0.5, 1.0 + live_adj * 0.40)  # +/-40% max ajuste

        except Exception:

            pass



        # Bonus consistencia: WR alta + CAGR alto + frecuente

        if wr >= 58 and cagr >= 22 and ty >= 8:

            base += 0.03



        return round(base, 4)



    def recommend(m, mtype, regime):

        """Calcula si un modelo debe activarse. Extrae todos los valores

        con conversion explicita para evitar bugs de closure con variables globales."""

        try:

            # Extraccion segura — convierte explicitamente a tipos numericos

            _tr   = float(m.get('trades')      or 0)

            _wr   = float(m.get('wr')          or 0)

            _dd   = float(m.get('dd')          or 0)

            _cagr = float(m.get('cagr')        or 0)

            _ty   = float(m.get('trades_year') or 0)

            if _ty <= 0 and _tr > 0:

                _ty = _tr * (365.0 / 600)

            _g = grade(score_fn(m), float(m.get('wr') or 0))

        except Exception as _ex:

            return 'NO_ACTIVAR', f'Error extrayendo metricas: {_ex}'



        # Filtros de calidad

        if _g == 'D':                        return 'NO_ACTIVAR', 'Grade D — sin edge'

        # 2026-05-19: umbrales relajados para PAPER TRADING (mas modelos elegibles)

        # Live aun requiere PASS_LIVE robustness (filtrado por gate aparte)

        if _cagr > 0 and _cagr < 8:         return 'NO_ACTIVAR', f'CAGR {_cagr:.1f}% insuf. (menor 8%)'

        if _cagr > 0 and _cagr < 12:        return 'CONDICIONAL', f'CAGR {_cagr:.1f}% bajo (paper-only)'

        if _tr < 10:                         return 'NO_ACTIVAR', f'Solo {int(_tr)} trades OOS'

        if _wr > 0 and _wr < 42:            return 'NO_ACTIVAR', f'WR {_wr:.0f}% muy bajo'

        # 2026-06-11: umbrales DD TF-aware (15m opera mas frecuente = DD estructuralmente mayor)
        _tf_raw   = m.get('_tf', '')
        _is_15m   = '15m' in str(_tf_raw)
        _no_act_dd = -50.0 if _is_15m else -35.0
        _cond_dd   = -35.0 if _is_15m else -25.0

        if _dd < _no_act_dd:                 return 'NO_ACTIVAR', f'DD {_dd:.0f}% excesivo'

        if _g == 'C':                        return 'CONDICIONAL', 'Grade C'

        if _dd < _cond_dd:                   return 'CONDICIONAL', f'DD {_dd:.0f}% alto'

        if _ty > 0 and _ty < 4:             return 'CONDICIONAL', f'{_ty:.0f} trades/ano — pocas senales'

        if _wr > 0 and _wr < 50:            return 'CONDICIONAL', f'WR {_wr:.0f}% — monitorear'

        # Regimen incompatible

        if regime == 'BULL' and mtype == 'short': return "CONDICIONAL", "Régimen BULL — paper-only para shorts (live: solo si gana en bull)"

        if regime == 'BEAR' and mtype == 'long':  return "CONDICIONAL", "Régimen BEAR — paper-only para longs (live: solo si gana en bear)"

        return 'ACTIVAR', f'Grade {_g} | WR {_wr:.0f}% | DD {_dd:.0f}%'



    def _feats(df):

        """Features completos del backtest: ATR, EMAs, RSI14, RSI_w, MACD-h, vol_ma."""

        c=df['close']; h=df['high']; l=df['low']; v=df['volume']

        tr=pd.concat([h-l,(h-c.shift()).abs(),(l-c.shift()).abs()],axis=1).max(axis=1)

        df['atr']=tr.ewm(alpha=1/14,adjust=False).mean()

        df['ema200']=c.ewm(span=200,adjust=False).mean()

        df['ema50']=c.ewm(span=50,adjust=False).mean()

        df['ema21']=c.ewm(span=21,adjust=False).mean()

        df['vol_ma']=v.rolling(20).mean()

        d=c.diff(); g=d.clip(lower=0).ewm(alpha=1/14,adjust=False).mean()

        ll=(-d.clip(upper=0)).ewm(alpha=1/14,adjust=False).mean()

        df['rsi14']=100-100/(1+g/(ll+1e-9))

        cw=c.resample('W').last().ffill(); dw=cw.diff()

        gw=dw.clip(lower=0).ewm(alpha=1/14,adjust=False).mean()

        lw=(-dw.clip(upper=0)).ewm(alpha=1/14,adjust=False).mean()

        rsiw=100-100/(1+gw/(lw+1e-9))

        df['rsi_w']=rsiw.reindex(df.index,method='ffill').fillna(50)

        df['macd']   = c.ewm(span=12,adjust=False).mean() - c.ewm(span=26,adjust=False).mean()

        df['macd_s'] = df['macd'].ewm(span=9,adjust=False).mean()

        df['macd_h'] = df['macd'] - df['macd_s']

        return df



    def _signal(df, strategy, params):

        """True si hay señal LIVE en la última barra cerrada.

        Replica la lógica de asset_pipeline.py sig_<strategy>. Sin HTF (fallback True)."""

        try:

            if len(df) < 30: return False

            row  = df.iloc[-2]

            prev = df.iloc[-3] if len(df) >= 3 else row

            c    = df['close']; h = df['high']; l = df['low']

            p    = params or {}



            # LONG strategies

            if strategy == 'breakout':

                lb = int(p.get('lookback', 30)); vm = p.get('vol_mult', 1.5)

                prev_high = h.iloc[-lb-2:-2].max()

                return bool(row['close'] > prev_high

                            and row['volume'] > row['vol_ma'] * vm

                            and row['close'] > row['ema200']

                            and row['rsi_w']  > p.get('rsi_w_thr', 50))



            elif strategy == 'pullback':

                et = int(p.get('ema_type', 21))

                ecol = f'ema{et}' if f'ema{et}' in df.columns else 'ema21'

                ema_v = row[ecol]

                return bool(ema_v * 0.995 <= row['close'] <= ema_v * 1.005

                            and row['ema50'] > row['ema200']

                            and row['rsi_w'] > p.get('rsi_w_thr', 50)

                            and row['rsi14'] < p.get('rsi_entry', 45))



            elif strategy == 'tma_bands':

                period = int(p.get('tma_period', 14))

                am = p.get('atr_mult', 1.5)

                sma_v = c.rolling(period).mean()

                tma_v = sma_v.rolling(period).mean()

                lower = tma_v.iloc[-2] - row['atr'] * am

                return bool(row['close'] <= lower

                            and row['close'] > row['ema200']

                            and row['rsi_w']  > p.get('rsi_w_thr', 48))



            elif strategy == 'momentum':

                vm = p.get('vol_mult', 1.5)

                return bool(row['macd_h'] > 0

                            and row['macd_h'] > prev['macd_h']

                            and row['close'] > row['ema200']

                            and row['rsi_w'] > p.get('rsi_w_thr', 52)

                            and row['rsi14'] < p.get('rsi_max', 70)

                            and row['volume'] > row['vol_ma'] * vm)



            elif strategy == 'mean_rev':

                return bool(row['rsi14'] < p.get('rsi_os', 35)

                            and row['close'] > row['ema200']

                            and row['rsi_w'] > p.get('rsi_w_thr', 48))



            elif strategy == 'dmi_trend':

                # Aproximación: cruce alcista usando rsi14 ascendente como proxy de +DI > -DI

                return bool(row['rsi14'] > 50

                            and row['rsi14'] > prev['rsi14']

                            and row['close'] > row['ema50']

                            and row['rsi_w']  > p.get('rsi_w_thr', 50))



            elif strategy == 'ichimoku':

                tenkan_p = int(p.get('tenkan', 9))

                kijun_p  = int(p.get('kijun', 26))

                tenkan_now  = (h.rolling(tenkan_p).max() + l.rolling(tenkan_p).min()) / 2

                kijun_now   = (h.rolling(kijun_p).max()  + l.rolling(kijun_p).min()) / 2

                return bool(row['close'] > tenkan_now.iloc[-2]

                            and tenkan_now.iloc[-2] > kijun_now.iloc[-2]

                            and row['rsi_w'] > p.get('rsi_w_thr', 50))



            elif strategy == 'regime_adaptive':

                # Long en bull, short en bear (simplificado por rsi14)

                return bool(row['rsi14'] < 45 and row['close'] > row['ema50'])



            # SHORT strategies

            elif strategy == 'breakdown':

                lb = int(p.get('lookback', 30)); vm = p.get('vol_mult', 1.5)

                prev_low = l.iloc[-lb-2:-2].min()

                return bool(row['close'] < prev_low

                            and row['volume'] > row['vol_ma'] * vm

                            and row['close'] < row['ema200']

                            and row['rsi_w']  < p.get('rsi_w_thr', 45))



            elif strategy == 'pullback_short':

                et = int(p.get('ema_type', 21))

                ecol = f'ema{et}' if f'ema{et}' in df.columns else 'ema21'

                ema_v = row[ecol]

                return bool(ema_v * 0.995 <= row['close'] <= ema_v * 1.005

                            and row['ema50'] < row['ema200']

                            and row['rsi_w'] < p.get('rsi_w_thr', 45)

                            and row['rsi14'] > p.get('rsi_entry', 58))



            elif strategy == 'momentum_short':

                vm = p.get('vol_mult', 1.5)

                return bool(row['macd_h'] < 0

                            and row['macd_h'] < prev['macd_h']

                            and row['close'] < row['ema200']

                            and row['rsi_w'] < p.get('rsi_w_thr', 45)

                            and row['rsi14'] > p.get('rsi_min', 30)

                            and row['volume'] > row['vol_ma'] * vm)



            elif strategy == 'break_of_structure':

                period = int(p.get('bos_period', 20))

                vm = p.get('vol_mult', 1.4)

                swing_high = h.iloc[-period-2:-2].max()

                return bool(row['close'] > swing_high

                            and row['volume'] > row['vol_ma'] * vm

                            and row['rsi_w'] > p.get('rsi_w_thr', 48))



            elif strategy == 'mfi_reversal':

                period = int(p.get('mfi_period', 14))

                thr = p.get('mfi_thr', 25)

                tp_price = (df['high'] + df['low'] + df['close']) / 3

                mf = tp_price * df['volume']

                pos_mf = mf.where(tp_price > tp_price.shift(1), 0).rolling(period).sum()

                neg_mf = mf.where(tp_price < tp_price.shift(1), 0).rolling(period).sum()

                mfi = 100 - (100 / (1 + pos_mf / (neg_mf + 1e-9)))

                cross_up = (mfi.iloc[-2] > thr) and (mfi.iloc[-3] <= thr)

                return bool(cross_up

                            and row['close'] > row['ema200']

                            and row['rsi_w'] > p.get('rsi_w_thr', 45))



            elif strategy == 'consecutive_wick':

                lower_wick = df[['open','close']].min(axis=1) - df['low']

                body = (df['close'] - df['open']).abs()

                has_wick = lower_wick > body * 1.5

                triple = bool(has_wick.iloc[-2] and has_wick.iloc[-3] and has_wick.iloc[-4]) if len(df) >= 4 else False

                return bool(triple

                            and row['close'] > row['ema50']

                            and row['rsi_w'] > p.get('rsi_w_thr', 45))



            elif strategy == 'psar_flip':

                psar_mult = p.get('psar_mult', 2.0)

                band_now = row['ema21'] - psar_mult * row['atr']

                band_prev = prev['ema21'] - psar_mult * prev['atr']

                flip = (row['close'] > band_now) and (prev['close'] <= band_prev)

                return bool(flip

                            and row['close'] > row['ema200']

                            and row['volume'] > row['vol_ma']

                            and row['rsi_w'] > p.get('rsi_w_thr', 48))



            elif strategy == 'volatility_breakout':

                period = int(p.get('vb_period', 14))

                vol_expand = p.get('vol_expand', 1.3)

                atr_avg = df['atr'].iloc[-period-2:-2].mean()

                range_high = df['high'].iloc[-period-2:-2].max()

                vol_expanding = row['atr'] > atr_avg * vol_expand

                breakout = (row['close'] > range_high) and vol_expanding

                return bool(breakout

                            and row['macd_h'] > 0

                            and row['rsi_w'] > p.get('rsi_w_thr', 50)

                            and row['close'] > row['ema200'])



            elif strategy == 'cci_reversal_short':

                period = int(p.get('cci_period', 20))

                thr = p.get('cci_thr_short', 100)

                tp_price = (df['high'] + df['low'] + df['close']) / 3

                tp_ma = tp_price.rolling(period).mean()

                md = (tp_price - tp_ma).abs().rolling(period).mean()

                cci = (tp_price - tp_ma) / (0.015 * md + 1e-9)

                cci_now = cci.iloc[-2]

                cci_prev = cci.iloc[-3]

                return bool(cci_now < thr

                            and cci_prev >= thr

                            and row['close'] < row['ema200']

                            and row['rsi_w'] < p.get('rsi_w_thr', 50))



            elif strategy == 'macd_zero_cross_down':

                vm = p.get('vol_mult', 1.0)

                cross_zero = (prev['macd'] >= 0) and (row['macd'] < 0)

                return bool(cross_zero

                            and row['macd_h'] < 0

                            and row['close'] < row['ema200']

                            and row['rsi_w'] < p.get('rsi_w_thr', 50)

                            and row['rsi14'] > p.get('rsi_min', 28)

                            and row['volume'] > row['vol_ma'] * vm)



            # Strategy sin logica manual: delegar a asset_pipeline.SIG_FN

            # (refactor 2026-05-14 noche — antes habia ~45 strategies del trainer

            # sin logica live, generando champions fantasma que nunca disparaban trade)

            try:

                _ap = globals().get('_AP_SIG_FNS_CACHE')

                if _ap is None:

                    import sys as _spx

                    if '/opt/sigma' not in _spx.path:

                        _spx.path.insert(0, '/opt/sigma')

                    from engine.optimization.asset_pipeline import SIG_FN as _AP_FN

                    from engine.optimization.asset_pipeline import SIG_FN_SHORT as _AP_FN_S

                    from engine.optimization.asset_pipeline import SIG_FN_ADAPTIVE as _AP_FN_A

                    _ap = {**_AP_FN, **_AP_FN_S, **_AP_FN_A}

                    globals()['_AP_SIG_FNS_CACHE'] = _ap

                sig_fn = _ap.get(strategy)

                if not sig_fn:

                    return False

                # Inyectar columnas que apply_regime_gate espera (sino bloquea shorts).

                # Aqui ya filtramos por regime upstream en recommendation, asi que

                # hacemos transparente al gate.

                _df = df.copy()

                if 'tradeable_long' not in _df.columns:

                    _df['tradeable_long'] = True

                if 'tradeable_short' not in _df.columns:

                    _df['tradeable_short'] = True

                if 'regime_range' not in _df.columns:

                    _df['regime_range'] = False

                if 'rsi_w' not in _df.columns:

                    _df['rsi_w'] = _df.get('rsi14', 50)

                _result = sig_fn(_df, p)

                _sig_ser = _result[0] if isinstance(_result, tuple) else _result

                if hasattr(_sig_ser, 'iloc') and len(_sig_ser) >= 2:

                    return bool(_sig_ser.iloc[-2] != 0)

                return False

            except Exception as _e_ap:

                # Log silencioso de la primera vez por strategy para diagnosticar

                _seen = globals().setdefault('_AP_FALLBACK_ERRORS', set())

                if strategy not in _seen:

                    _seen.add(strategy)

                    print(f'[_signal AP_FALLBACK] {strategy}: {type(_e_ap).__name__}: {_e_ap}', flush=True)

                return False

        except Exception:

            return False



    # Fetch regime

    regime = 'RANGE'

    reg_per_asset = {}

    try:

        reg_d = _compute_regime()

        bear=sum(1 for v in reg_d.values() if v.get('regime')=='BEAR')

        bull=sum(1 for v in reg_d.values() if v.get('regime')=='BULL')

        regime = 'BEAR' if bear>=3 else ('BULL' if bull>=3 else 'RANGE')

        # Regimen por activo (fallback al global si UNKNOWN/LOADING)

        for _a, _v in (reg_d or {}).items():

            _r = (_v or {}).get('regime')

            if _r in ('BULL','BEAR','RANGE'):

                reg_per_asset[_a] = _r

    except: pass



    # ── Actualizar BTC Dominance proxy (cached 30min) ───────────────────────

    try:

        _get_btc_dominance_proxy()

    except: pass



    # ── Drawdown actual del portfolio (para ajuste dinámico de Kelly) ───────

    _port_state = _load_trades()

    _port       = _port_state.get('portfolio', {})

    _equity_now = _port.get('equity', 10000)

    _peak_eq    = _port.get('peak_equity', _equity_now)

    _current_dd = round((_equity_now - _peak_eq) / _peak_eq * 100, 2) if _peak_eq > 0 else 0

    # Escala de Kelly por drawdown:

    # 0% a -5%   → Kelly normal

    # -5% a -10% → Kelly × 0.70  (reducir 30%)

    # -10% a -15%→ Kelly × 0.50  (reducir 50%)

    # > -15%     → Kelly × 0.25  (modo supervivencia)

    if _current_dd <= -15:

        _dd_kelly_mult = 0.25

    elif _current_dd <= -10:

        _dd_kelly_mult = 0.50

    elif _current_dd <= -5:

        _dd_kelly_mult = 0.70

    else:

        _dd_kelly_mult = 1.00



    # ── Cerrar trades con SL/TP tocado ANTES de procesar señales ─────────────

    _current_prices = {}

    try:

        import urllib.request as _ur2, json as _jw2

        _state2 = _load_trades()

        for _key2, _tr2 in list(_state2.get('open', {}).items()):

            if _tr2.get('status') != 'open': continue

            _sym2 = _tr2.get('sym',''); _tf2 = _tr2.get('tf','')

            if not _sym2: continue

            try:

                if _sym2 == 'XAU':

                    import yfinance as _yf_c

                    _cp2 = float(_yf_c.Ticker('GC=F').fast_info.last_price)

                else:

                    _url2 = f'https://fapi.binance.com/fapi/v1/ticker/price?symbol={_sym2}USDT'

                    _cp2  = float(_jw2.loads(_ur2.urlopen(_url2, timeout=4).read())['price'])

                _current_prices[_sym2] = _cp2

                check_auto_close(_sym2, _tf2, _cp2)

            except: pass

    except: pass



    # ── Smart Exit: trailing stop + time limit + regime exit ─────────────────

    try:

        import sys as _sys2

        _sys2.path.insert(0, str(BASE / 'engine' / 'live'))

        from smart_exit import run_smart_exit as _smart_exit

        _smart_exit(_current_prices, regime, close_trade)

    except Exception as _se_err:

        print(f'[SILENT_BUG _signal smart_exit] {type(_se_err).__name__}: {_se_err}', flush=True)



    # Load models

    # Build data_cache from persistent OHLCV cache (skip stale entries)
    global _ohlcv_cache
    _TF_TTL     = {'5m': 240, '15m': 600, '1h': 300, '4h': 1200}   # 5min / 20min ? deteccion rapida Motor 1
    _TF_TTL_CSV = {'1d': 43200, '5m': 240, '15m': 600, '1h': 1200, '4h': 3600}  # 1d=12h
    _CSV_SYMS   = {'XAU', 'XAG', 'WTI', 'HG', 'NG', 'PL'}
    _now_cs = time.time()
    data_cache = {}
    for _k, (_ts, _df) in _ohlcv_cache.items():
        _sym_k = _k[0].upper().split('/')[0]
        _ttl = _TF_TTL_CSV.get(_k[1], 600) if _sym_k in _CSV_SYMS else _TF_TTL.get(_k[1], 600)
        if _now_cs - _ts < _ttl:
            data_cache[_k] = _df

    results = []

    _paper_candidates = {}  # paper trades a abrir tras slot assignment

    tf_alias = {}  # 2026-06-11 fix: Binance usdm ya usa '15m','5m','1m' directamente; '15min'/'5min' causan BadRequest -1120



    models_dir = BASE / 'models'

    for tf_dir in sorted(models_dir.iterdir()):

        if not tf_dir.is_dir() or tf_dir.name=='archive': continue

        tf = tf_dir.name

        if tf not in {'1d','4h','1h','15m','5m','1m'}:

            continue  # ignorar TFs no estandar (2h, 3h, etc)

        for jf in sorted(tf_dir.glob('*.json')):

            if jf.name in SKIP: continue

            try:

                d = _j.loads(jf.read_text(encoding='utf-8'))

                m = d.get('metrics_oos',{})

                if not m or m.get('cagr',0)<=0: continue

                symbol   = d.get('symbol','')

                strategy = d.get('strategy','')

                params   = d.get('params',{})

                if not symbol or not strategy: continue



                sym = symbol.replace('/USDT','').replace('/USD','')

                is_short = strategy in _SIGMA_SHORTS

                is_adapt = 'adaptive' in strategy

                mtype = 'adaptive' if is_adapt else ('short' if is_short else 'long')



                # Enrich m with context for enhanced scoring

                m = {**m,

                    '_symbol': d.get('symbol', ''),

                    '_tf': d.get('tf', ''),

                    '_strategy': d.get('strategy', ''),

                    '_saved_at': d.get('saved_at', ''),

                }

                sc = score_fn(m)

                gr = grade(sc, m.get('wr', 0))

                _sym_regime = reg_per_asset.get(sym, regime)

                rec, reason = recommend(m, mtype, _sym_regime)

                dd2x = round(m.get('dd',0), 1)   # sin apalancamiento

                # cagr ya incluye funding rate real (historico de Binance Futures)

                # CAGR real del backtest OOS (sin apalancamiento)

                c2x  = round(m.get('cagr',0), 1)  # sin apalancamiento



                # Leer resultado WFT del JSON si existe

                wft_data     = d.get('wft', {})

                wft_pass_rate= wft_data.get('oos_win_rate', None)

                wft_verdict  = wft_data.get('verdict', '')

                wft_windows  = wft_data.get('n_windows', 0)



                # Check live signal

                has_signal = False

                price = 0; sl_price = 0; tp_price = 0

                try:

                    key = (symbol, tf)

                    if key not in data_cache:

                        tf_ccxt = tf_alias.get(tf, tf)

                        if sym in _CSV_SYMS:  # 2026-06-11: HG/NG/WTI/PL tambien usan CSV

                            try:

                                import pandas as _pd_x

                                _csv_x = f'/opt/sigma/models/data_{sym}_{tf}_max.csv'

                                _dfx = _pd_x.read_csv(_csv_x, index_col=0, parse_dates=True)

                                _dfx.columns = [c.lower() for c in _dfx.columns]

                                _df_xau = _feats(_dfx.tail(500))
                                data_cache[key] = _df_xau
                                _ohlcv_cache[key] = (_now_cs, _df_xau)

                            except:

                                pass

                        else:

                            raw = ex.fetch_ohlcv(symbol, tf_ccxt, limit=500)

                            if raw:

                                df = pd.DataFrame(raw, columns=['ts','open','high','low','close','volume'])

                                df['ts'] = pd.to_datetime(df['ts'], unit='ms')

                                df.set_index('ts', inplace=True)

                                _df_fetched = _feats(df)
                                data_cache[key] = _df_fetched
                                _ohlcv_cache[key] = (_now_cs, _df_fetched)

                    df = data_cache.get(key)

                    if df is not None and len(df) > 50:

                        has_signal = _signal(df, strategy, params)

                        # Computar price/sl/tp siempre para modelos validos

                        # (firing -> reales; en cola -> hipoteticos basados en close actual)

                        if has_signal:

                            # Firing: usar precio LIVE

                            try:

                                if sym in ('XAU', 'XAG'):

                                    import yfinance as _yf_p

                                    price = round(float(_yf_p.Ticker('GC=F').fast_info.last_price), 4)

                                else:

                                    import urllib.request as _ur_e, json as _j_e

                                    _url_e = f'https://fapi.binance.com/fapi/v1/ticker/price?symbol={sym}USDT'

                                    price  = round(float(_j_e.loads(_ur_e.urlopen(_url_e, timeout=3).read())['price']), 4)

                            except:

                                price = round(float(df['close'].iloc[-1]), 4)

                        else:

                            # En cola: usar close de la ultima vela (hipotetico, se refresca cada poll)

                            price = round(float(df['close'].iloc[-1]), 4)

                        # ATR de la última vela completa para SL/TP

                        atr   = float(df['atr'].iloc[-1])
                        # Guard: ATR < 0.1% del precio = cache OHLCV corrupto, no abrir trade
                        _atr_pct = atr / price * 100 if price > 0 else 0
                        if _atr_pct < 0.1:
                            print(f'[ATR_GUARD] {symbol} {tf} atr={atr:.5f} ({_atr_pct:.4f}%) INVALIDO — skip', flush=True)
                            has_signal = False

                        sl_m  = params.get('sl_mult', 2.0)

                        tp_m  = params.get('tp_mult', 3.0)

                        sl_price = round(price - atr*sl_m if mtype!='short' else price + atr*sl_m, 4)

                        tp_price = round(price + atr*tp_m if mtype!='short' else price - atr*tp_m, 4)

                except: pass



                # Auto-detectar SL/TP y bloquear re-entrada

                if has_signal and price:

                    check_auto_close(sym, tf, price)

                if is_blocked(sym, tf):

                    has_signal = False

                    sl_price = tp_price = price = 0



                # ── PAPER TRADING AUTOMÁTICO ─────────────────────────

                _short_strats = _SIGMA_SHORTS  # centralizado en utils.strategies (2026-05-14)

                direction = 'short' if strategy in _short_strats or 'short' in mtype else 'long'

                state = _load_trades()

                key   = f'{sym}_{tf}'

                # Cierre por cambio de regimen

                open_t = state['open'].get(key)

                if open_t and open_t.get('status')=='open' and price:

                    _rg_sym = reg_per_asset.get(sym, regime)

                    if (_rg_sym=='BEAR' and open_t['direction']=='long') or                        (_rg_sym=='BULL' and open_t['direction']=='short'): close_trade(sym, tf, price, 'REGIME_CHANGE')

                # Circuit breaker + abrir nuevo trade

                # Registrar candidato para paper trade (se abre solo si slot=1 o 2)

                if (has_signal and price and sl_price and tp_price

                        and key not in state.get('open', {})

                        and not check_circuit_breaker()):

                    _paper_candidates[key] = {

                        'sym':sym,'tf':tf,'dir':direction,'price':price,

                        'sl':sl_price,'tp':tp_price,'strat':strategy,

                        'grade':gr,'wr':m.get('wr',0),'cagr':m.get('cagr',0),

                        'kelly_pct': round(sc * 2.2, 2),

                    }



                # ── EV y Decay ───────────────────────────────────────────

                _wr = m.get('wr', 50)

                _ev = None

                if has_signal and price and sl_price and tp_price:

                    _sl_pct = abs(price - sl_price) / price * 100

                    _tp_pct = abs(tp_price - price) / price * 100

                    _ev = round((_wr/100 * _tp_pct - (1-_wr/100) * _sl_pct) * 2, 2)



                _decay, _live_wr, _n_live = _check_decay(sym, tf, _wr)



                # ── Regime filter: LONG en BEAR solo con ensemble≥2 y MC≥70% ─

                _mc_conf  = d.get('mc', {}).get('mc_confidence', 0) or 0

                _ens_cnt  = 1  # actualizado abajo tras ensemble detection

                _rg_sym_ok = reg_per_asset.get(sym, regime)

                _regime_ok = not (_rg_sym_ok=='BEAR' and mtype=='long') and not (_rg_sym_ok=='BULL' and mtype=='short')



                results.append({

                    'sym': sym, 'tf': tf, 'strategy': strategy, 'type': mtype,

                    'grade': gr, 'score': round(sc,4),

                    'cagr': m.get('cagr',0), 'cagr_2x': c2x,

                    'wr': m.get('wr',0), 'dd': m.get('dd',0), 'dd_2x': dd2x,

                    'trades': m.get('trades',0),

                    'recommendation': rec, 'reason': reason,

                    'signal': has_signal,

                    'price': price, 'sl': sl_price, 'tp': tp_price,

                    'regime_ok': _regime_ok,

                    'wft_pass_rate': wft_pass_rate,

                    'mc_confidence': round(_mc_conf, 1) if d.get('mc') else None,

                    'val_confidence': d.get('validation', {}).get('confidence'),

                    'corr_warning': False,

                    'eff_risk_pct': None,

                    'conf_mult':    None,

                    'val_mc':         d.get('validation', {}).get('monte_carlo', {}).get('p_pos'),

                    'val_wft':        d.get('validation', {}).get('walk_forward', {}).get('pct_positive'),

                    'mc_cagr_p05':   min(d.get('mc', {}).get('mc_cagr_p05') or 0, 999) or None,

                    'mc_dd_p95':     d.get('mc', {}).get('mc_dd_p95'),

                    'wft_verdict':   wft_verdict,

                    'wft_windows':   wft_windows,

                    'ev':            _ev,

                    'decay_warning': _decay,

                    'live_wr':       _live_wr,

                    'n_live_trades': _n_live,

                    'mc_conf_raw':   _mc_conf,

                    'htf_confirms':  True,   # actualizado tras slot assignment

                    'htf_reason':    '',

                    'htf_penalty':   False,

                    'btcd_penalty':  False,

                    'btcd_boost':    False,

                    'btcd_value':    round(_btcd_cache.get('value', 0.5), 2),

                    'current_dd_pct': _current_dd,

                    'dd_kelly_mult':  _dd_kelly_mult,

                    **_get_deriv_context(sym),

                })

            except Exception as _e_mdl:

                print(f'[SILENT_BUG _signal model_eval] {type(_e_mdl).__name__}: {_e_mdl}', flush=True)

                continue



    # Correlación entre activos: clusters que se mueven juntos

    CORR_CLUSTERS = [{'BTC','ETH','LTC'}, {'SOL','BNB'}, {'XAU','XAG'}]



    # Capacidad: 3 slots simultaneos (independiente de regimen)

    # Bonus slot reservado historicamente para 3+ A+/A; actualmente MAX_SLOTS=3 fijo.

    _ap_count = sum(1 for r in results if r.get('grade') in ('A+','A') and r.get('recommendation')=='ACTIVAR')

    MAX_SLOTS = 3  # 3 slots en todos los regimenes

    if _ap_count >= 3 and MAX_SLOTS < 3: MAX_SLOTS = 3  # bonus slot para A+/A



    # ── Trades abiertos: siempre tienen slot asignado ───────────────────────

    try:

        _open_state = _load_trades()

        _open_keys  = {

            f"{t.get('sym','').upper()}_{t.get('tf','')}": i+1

            for i, (k, t) in enumerate(

                sorted(_open_state.get('open', {}).items(),

                       key=lambda x: x[1].get('opened_at', ''))

            )

            if t.get('status') == 'open'

        }

    except Exception:

        _open_keys = {}



    # Poner modelos con trade abierto al frente del sort

    def _sort_key(r):

        k = f"{r.get('sym','').upper()}_{r.get('tf','')}"

        if k in _open_keys:

            return (2, _open_keys[k], r.get('score', 0))   # prioridad maxima

        return (int(r.get('signal', False)), 0, r.get('score', 0))



    results.sort(key=_sort_key, reverse=True)

    seen_sym   = set()

    slot_n     = 0

    slots_dirs = []

    slots_clus = []



    for r in results:

        sym_tf_key = f"{r.get('sym','').upper()}_{r.get('tf','')}"

        has_open   = sym_tf_key in _open_keys



        # Modelos con trade abierto: heredar estado SOLO si coincide direction Y strategy

        # (un trade SHORT no debe contaminar un modelo LONG del mismo sym/tf)

        if has_open:

            try:

                _ot2 = _open_state.get('open', {}).get(sym_tf_key)

                _trade_dir   = (_ot2 or {}).get('direction', '')

                _trade_strat = (_ot2 or {}).get('strategy', '')

                _model_dir   = r.get('type', '')

                _model_strat = r.get('strategy', '')

                # Solo heredar si el modelo corresponde al trade real

                if (_ot2 and _ot2.get('status') == 'open'

                        and _trade_dir == _model_dir

                        and _trade_strat == _model_strat):

                    r['signal']         = True

                    r['recommendation'] = 'ACTIVAR'

                    r['regime_ok']      = True

                    r['has_open_trade'] = True

                    r['price'] = _ot2.get('entry', 0) or r.get('price', 0)

                    r['sl']    = _ot2.get('sl', 0)    or r.get('sl', 0)

                    r['tp']    = _ot2.get('tp', 0)    or r.get('tp', 0)

                    r['open_trade_entry'] = _ot2.get('entry', 0)

                    r['open_trade_since'] = str(_ot2.get('opened_at', ''))[:16]

                else:

                    # Modelo del mismo sym/tf pero distinta direction/strategy → no heredar

                    # has_open queda como flag informativo pero NO se fuerza signal

                    r['has_open_trade'] = False

                # Cooldown: propagar info al model dict para display en dashboard

                if _ot2.get('status') == 'cooldown':

                    r['cooldown_active'] = True

                    r['cooldown_until']  = _ot2.get('cooldown_until', 0)

                    _cd_pnl = _ot2.get('pnl_pct')

                    if _cd_pnl is not None:

                        r['live_pnl_pct'] = round(float(_cd_pnl), 4)  # ultimo trade cerrado

            except Exception:

                pass



        # Paper mode: si el modelo tiene entrada valida en _paper_candidates, dar slot
        _paper_slot_ok = not LIVE_EXECUTION and (r.get('sym','')+'_'+r.get('tf','')) in _paper_candidates
        if r['recommendation'] in ('ACTIVAR','CONDICIONAL') and (r['regime_ok'] or _paper_slot_ok):

            _bear_slot2_ok = not (slot_n >= 1 and r.get('cagr', 0) < 15)

            if r['sym'] not in seen_sym and slot_n < MAX_SLOTS and (_bear_slot2_ok or has_open):

                this_dir  = r['type']

                this_clus = next((i for i,cl in enumerate(CORR_CLUSTERS)

                                  if r['sym'] in cl), -1)



                if slot_n == 2 and not has_open:

                    dir_new  = this_dir not in slots_dirs

                    clus_new = this_clus not in slots_clus or this_clus < 0

                    grade_ok = r.get('grade') in ('A+', 'A')

                    if not (dir_new or clus_new) or not grade_ok:

                        r['slot'] = 0; continue



                r['slot'] = slot_n + 1

                r['corr_warning'] = (this_dir in slots_dirs and

                                     this_clus in slots_clus and this_clus >= 0)

                if slot_n == 2:

                    r['slot3_reduced'] = True

                seen_sym.add(r['sym'])

                slots_dirs.append(this_dir)

                slots_clus.append(this_clus)

                slot_n += 1

            else:

                r['slot'] = 0

        else:

            r['slot'] = -1



    # ── Quality gate: si el sistema marcó NO_ACTIVAR, silenciar la señal ─────

    # (un modelo descartado por baja calidad NO debe contar como "señal activa")

    for r in results:

        if r.get('recommendation') == 'NO_ACTIVAR' and r.get('signal') and not r.get('has_open_trade'):

            r['signal'] = False

            r['sl']     = 0; r['tp'] = 0; r['price'] = 0



    # ── Regime filter: LONG en BEAR sin confirmación → silenciar señal ─────────

    # 2026-05-20: filter solo strict para ACTIVAR (live-ready). CONDICIONAL (paper-only)

    # permite generar data en BEAR para que el Bayesian tracker valide edge real.

    # Justificacion: el backtest YA prueba la strategy en periodos BEAR — si el OOS es

    # positivo, dejarla operar en BEAR (paper) es lo que confirma o desmiente el edge.

    # Live (binance_executor cuando se prenda) queda strict.

    for r in results:

        if regime == 'BEAR' and r.get('type') == 'long' and r.get('signal'):

            ens_c  = r.get('ensemble_count', 1)

            mc_c   = r.get('mc_conf_raw', 0) or 0

            rec_lb = r.get('recommendation', '')

            # Strict para ACTIVAR (live). Paper (CONDICIONAL) puede operar — Kelly cap 1.5% limita riesgo

            # En BEAR los shorts son favorecidos — no silenciar su señal
            if rec_lb == 'ACTIVAR' and (ens_c < 2 or mc_c < 70) and r.get('type') != 'short':

                r['signal']         = False

                r['sl']             = 0; r['tp'] = 0; r['price'] = 0

                r['regime_muted']   = True

                r['reason']         = f'BEAR + ACTIVAR — necesita ensemble≥2 y MC≥70% (actual: E{ens_c} MC{mc_c:.0f}%)'

            elif rec_lb == 'CONDICIONAL':

                # Paper trading puede operar en BEAR — solo marcar el contexto

                r['regime_paper_bear'] = True

                if r.get('reason') and 'BEAR' not in r.get('reason',''):

                    r['reason'] = (r.get('reason','') + ' | paper: BEAR LONG permitido (Kelly cap)')[:200]



    # ── Consenso multi-TF: verificar que TF mayor confirme la dirección ──────

    for r in results:

        if not r.get('signal'): continue

        direction = 'short' if r.get('type') == 'short' else 'long'

        try:

            confirms, htf_reason = _htf_confirms(r['sym'], r['tf'], direction, ex, data_cache)

            r['htf_confirms'] = confirms

            r['htf_reason']   = htf_reason

        except:

            r['htf_confirms'] = True

            r['htf_reason']   = 'check omitido'



    # Sizing dinámico por confianza de validación

    CONF_MULT = {'ALTA':1.0,'MEDIA':0.65,'BAJA':0.35,'DESCARTADO':0.0}

    for r in results:

        val_conf   = r.get('val_confidence') or ''

        conf_mult  = CONF_MULT.get(val_conf, 0.5)

        # Ensemble boost: 2 modelos coinciden → +30%, 3+ → +60%

        ens_mult   = r.get('ensemble_mult', 1.0)   # calculado por ensemble v2

        # Funding-rate Kelly multiplier v2 (2026-05-14): ASIMÉTRICO — solo SHORTS

        # Lección del backtest histórico: aplicar a longs era neto neutral (gains compensados por penalty).

        # Aplicar SOLO a shorts captura la asimetría del cripto (funding mayormente positivo = shorts ganan).

        _funding_pct = (_funding_cache.get(r.get('sym',''), {}).get('value', 0) or 0) * 100

        _direction = r.get('type', 'long')

        funding_kelly_mult = 1.00

        if _direction == 'short':

            # Para short: funding POSITIVO es FAVORABLE (cobran), NEGATIVO es DESFAVORABLE (pagan)

            if _funding_pct > 0.005:

                funding_kelly_mult = 1.10  # boost cuando shorts cobran

            elif _funding_pct < -0.005:

                funding_kelly_mult = 0.90  # penalty cuando shorts pagan

        # Para LONGS: dejar en 1.00 siempre (backtest mostró que la asimetría no nos beneficia)

        r['funding_pct'] = round(_funding_pct, 4)

        r['funding_kelly_mult'] = funding_kelly_mult

        # Quarter-Kelly nominal (~10% base) — 2026-05-12. Safeguards: CB auto DD<-5%, 3-loss, dd_kelly_mult, conf_mult BEAR 0.5

        # HRP Kelly: peso del portafolio por slot (1.5-8.0%) vs flat 5%
        _hrp_sym = r.get('sym', 'BTC').split('/')[0].upper() if isinstance(r, dict) else 'BTC'
        _hrp_tf  = r.get('tf', '15m') if isinstance(r, dict) else '15m'
        _hrp_base_risk = _read_hrp_kelly(f'{_hrp_sym}|{_hrp_tf}')
        # Stress Kelly: reduce gradual basado en deterioro reciente (independiente del DD)
        # Factores: caida de WR en ultimos 5 trades + dias sin ganar
        # Rango: 1.0 (normal) -> 0.5 (estres alto). Floor 0.5 para no duplicar efecto del DD.
        _stress_mult = 1.0
        try:
            _sh = state.get('history', [])
            _sc = [t for t in _sh if t.get('status') in ('TP_HIT','SL_HIT','TRAIL_HIT','CLOSED','MANUAL_CLOSE')]
            _r5 = _sc[-5:]
            if len(_r5) >= 3:
                _rwr  = sum(1 for t in _r5 if (t.get('pnl_pct') or 0) > 0) / len(_r5)
                _gwr  = sum(1 for t in _sc if (t.get('pnl_pct') or 0) > 0) / max(len(_sc), 1)
                _wrd  = _rwr - _gwr
                _lwd  = 999
                for _t in reversed(_sc):
                    if (_t.get('pnl_pct') or 0) > 0:
                        try:
                            _lwd = (datetime.now() - datetime.fromisoformat(str(_t.get('closed_at',''))[:19])).days
                        except Exception:
                            pass
                        break
                _wr_stress      = max(0.0, -_wrd * 2.0)
                _drought_stress = min(1.0, max(0.0, (_lwd - 3) / 10.0))
                _sidx           = _wr_stress * 0.6 + _drought_stress * 0.4
                _stress_mult    = max(0.5, 1.0 - _sidx * 0.5)
        except Exception:
            _stress_mult = 1.0
        base_risk  = (_hrp_base_risk if _hrp_base_risk else 5.0) * _dd_kelly_mult * _stress_mult  # stress+dd scaling
        # Exposure Guardian + Regime Multi (agentes 2+4)
        _exposure_mult, _exp_status = _read_exposure_gate()
        _asset_str = r.get('sym', 'BTC').split('/')[0].upper() if isinstance(r, dict) else 'BTC'
        _regime_mult = _read_regime_mult(_asset_str)
        base_risk = base_risk * _exposure_mult * _regime_mult * _read_vol_mult()

        r['eff_risk_pct'] = round(min(base_risk * conf_mult * ens_mult * funding_kelly_mult, 5.0), 2)

        r['dd_kelly_mult'] = _dd_kelly_mult
        r['stress_mult']   = _stress_mult
        r['_kelly_ledger'] = {
            'base_pct':      round(_hrp_base_risk if _hrp_base_risk else 5.0, 3),
            'dd_mult':       _dd_kelly_mult,
            'stress_mult':   _stress_mult,
            'exposure_mult': round(_exposure_mult, 3),
            'regime_mult':   round(_regime_mult, 3),
            'eff_risk_pct':  r.get('eff_risk_pct', 0),
        }

        r['conf_mult']    = conf_mult

        r['ens_mult']     = ens_mult

        # ── Correlation penalty: -40% Kelly si posición correlacionada ─────

        if r.get('corr_warning'):

            r['eff_risk_pct'] = round(r['eff_risk_pct'] * 0.60, 2)

        # ── Decay penalty: -50% Kelly si modelo está degradando en live ────

        if r.get('decay_warning'):

            r['eff_risk_pct'] = round(r['eff_risk_pct'] * 0.50, 2)

        # ── Multi-TF penalty: -35% Kelly si TF mayor no confirma ───────────

        if r.get('signal') and r.get('htf_confirms') == False:

            r['eff_risk_pct'] = round(r['eff_risk_pct'] * 0.65, 2)

            r['htf_penalty']  = True

        # ── Slot 3: Kelly 65% — menos certeza, más conservador ───────────

        if r.get('slot3_reduced'):

            r['eff_risk_pct'] = round(r['eff_risk_pct'] * 0.65, 2)

        # ── BTC Dominance filter: reducir Kelly en alts cuando BTC domina ──

        btcd = _btcd_cache.get('value', 0.5)

        if r.get('signal') and r['sym'] not in ('BTC', 'ETH'):

            if btcd < 0.35:  # BTC domina fuerte → alts en debilidad

                r['eff_risk_pct'] = round(r['eff_risk_pct'] * 0.70, 2)

                r['btcd_penalty'] = True

            elif btcd > 0.65:  # Alts dominan → boost ligero

                r['eff_risk_pct'] = round(min(r['eff_risk_pct'] * 1.15, 10.0), 2)

                r['btcd_boost']   = True



    # ── Position sizing tipo backtest (notional + risk en USD) ─────────────────

    # Formula: notional = equity × (eff_risk_pct / sl_distance_pct)

    # Garantiza: SL toca = pérdida exacta de eff_risk_pct% del equity

    # Se calcula para todos los modelos con price/sl/tp disponibles (incluye los "listos esperando setup")

    _equity_now = _port.get('equity', 10000)

    for r in results:

        _price = r.get('price', 0); _sl = r.get('sl', 0); _tp = r.get('tp', 0)

        _eff   = r.get('eff_risk_pct', 0)

        if not (_price and _sl and _eff): continue

        # SL distance: usar trade abierto si tiene sl_dist_pct_at_open, sino calcular

        _sl_dist_pct = abs(_sl - _price) / _price * 100 if _price > 0 else 0

        if r.get('has_open_trade'):

            # Si trade abierto, leer del trade_state

            try:

                _ot = _port_state.get('open', {}).get(f"{r['sym']}_{r['tf']}")

                if _ot and _ot.get('sl_dist_pct_at_open'):

                    _sl_dist_pct = _ot['sl_dist_pct_at_open']

            except: pass

        if _sl_dist_pct <= 0: continue

        _factor = _eff / _sl_dist_pct  # leverage implícito (kelly/sl%)

        r['notional_usd']  = round(_equity_now * _factor, 2)

        r['risk_usd']      = round(_equity_now * _eff / 100, 2)

        # Reward estimado si TP toca

        if _tp:

            _tp_dist_pct = abs(_tp - _price) / _price * 100

            r['reward_usd_at_tp']  = round(_equity_now * _tp_dist_pct * _factor / 100, 2)

        r['size_factor_x']  = round(_factor, 2)  # cuántas veces el equity = leverage implícito

        r['equity_used']    = _equity_now



    # ── Ensemble v2: agrupado por sym+tf, solo señales activas, ponderado por diversidad ──

    # Fuentes de señal agrupadas por tipo (cuanto más distintas, más valiosas)

    _SRC_GROUP = {

        # Precio/estructura

        'breakout':'price','pullback':'price','tma_bands':'price','mean_rev':'price',

        'breakdown':'price','pullback_short':'price','higher_highs':'price','lower_lows':'price',

        'engulfing':'price','three_candles':'price','inside_bar':'price','pin_bar':'price',

        'donchian_break':'price','linear_reg_break':'price','atr_channel':'price',

        'pivot_bounce':'price','consecutive_wick':'price','psar_flip':'price',

        # Momentum/osciladores

        'momentum':'momentum','momentum_short':'momentum','roc_momentum':'momentum',

        'dmi_trend':'momentum','aroon_cross':'momentum','trend_strength':'momentum',

        'elder_impulse':'momentum','hull_cross':'momentum','ema_ribbon':'momentum',

        'tema_cross':'momentum','wma_momentum':'momentum','open_close_cross':'momentum',

        # RSI/estocásticos

        'stoch_rsi':'oscillator','cci_reversal':'oscillator','williams_r':'oscillator',

        'mfi_reversal':'oscillator','rsi_divergence':'oscillator','rsi_trend':'oscillator',

        # MACD/trend

        'macd_divergence':'macd','supertrend':'macd','regime_adaptive':'macd',

        'volatility_breakout':'macd','keltner_breakout':'macd','squeeze_pro':'macd',

        'bb_squeeze':'macd','bb_bandwidth':'macd',

        # Volumen

        'chaikin_mf':'volume','obv_divergence':'volume','volume_exhaustion':'volume',

        'volume_climax':'volume','cvd_divergence':'volume','htf_divergence':'volume',

        # Estadístico

        'zscore_reversion':'statistical','vwap_deviation':'statistical',

        'heikin_ashi':'statistical','ichimoku':'statistical',

        # Crypto-específico

        'funding_reversal':'crypto','funding_momentum':'crypto',

    }



    from collections import defaultdict as _dd

    # Agrupar por sym+tf (no solo sym)

    _ens_by_symtf = _dd(lambda: {'long': [], 'short': []})

    for _r in results:

        if not _r.get('signal') or not _r.get('regime_ok'):

            continue

        _key  = f"{_r['sym']}_{_r['tf']}"

        _dir  = _r.get('type', 'long') if _r.get('type') in ('long','short') else 'long'

        _strat= _r.get('strategy','unknown')

        _src  = _SRC_GROUP.get(_strat, 'other')

        _score= _r.get('score', 0)

        _ens_by_symtf[_key][_dir].append((_strat, _src, _score))



    # Calcular ensemble real para cada modelo

    for _r in results:

        _key = f"{_r['sym']}_{_r['tf']}"

        _dir = _r.get('type', 'long') if _r.get('type') in ('long','short') else 'long'

        _signals = _ens_by_symtf[_key][_dir]

        _count   = len(_signals)



        # Diversidad de fuentes (cuantas fuentes DISTINTAS hay)

        _sources  = set(s[1] for s in _signals)

        _n_src    = len(_sources)



        # Multiplicador basado en count + diversidad de fuente

        if _count >= 3 and _n_src >= 3:

            _ens_mult = 1.7   # 3+ señales de 3+ fuentes distintas → máxima convicción

        elif _count >= 3 and _n_src >= 2:

            _ens_mult = 1.5   # 3+ señales de 2 fuentes

        elif _count >= 2 and _n_src >= 2:

            _ens_mult = 1.35  # 2 señales de fuentes distintas (precio+volumen, etc)

        elif _count >= 2 and _n_src == 1:

            _ens_mult = 1.15  # 2 señales pero misma fuente (menos valor)

        else:

            _ens_mult = 1.0   # señal individual



        _r['ensemble_count']    = _count

        _r['ensemble_sources']  = _n_src

        _r['ensemble_mult']     = _ens_mult

        _r['ensemble_boost']    = round(min(_count / 3.0, 1.0), 2)

        _r['ensemble_detail']   = ','.join(sorted(_sources)) if _sources else ''

    

    _cb = _load_trades().get('circuit_breaker',{}).get('active',False)



    # Abrir paper trades solo para slots 1 y 2 (después del slot assignment)

    _state = _load_trades()

    # No abrir nuevas posiciones si el sistema esta en pausa manual

    if os.path.exists('/opt/sigma/results/pausa.flag'):

        pass  # pausa activa — skip apertura

    else:

     _open_n = sum(1 for t in _state['open'].values() if t.get('status')=='open')

    for _r in sorted(results, key=lambda x: x.get('slot',0), reverse=True):

        if _r.get('slot',0) not in (1,2,3): continue

        _k = _r['sym']+'_'+_r['tf']

        if _k not in _paper_candidates or _k in _state['open']: continue

        _max_open = 3 if LIVE_EXECUTION else 5  # live=3 conservador / paper=5 para acelerar validacion
        if _open_n >= _max_open: break

        _c = _paper_candidates[_k]



        # ── AI Filter: validar entrada con Claude Haiku ───────────────────

        _ai_ok    = True

        _ai_reason= ''

        try:

            import sys as _sys3

            _sys3.path.insert(0, str(BASE / 'engine' / 'live'))

            from ai_filter import should_enter as _ai_should_enter

            _open_list = list(_state.get('open', {}).values())

            _sig_data  = next((r for r in results

                               if r.get('sym') == _c['sym'] and r.get('tf') == _c['tf']

                               and r.get('strategy') == _c.get('strat')), {})

            if not LIVE_EXECUTION:

                _sig_data = {**_sig_data, 'paper_mode': True}

            _ai_ok, _ai_reason = _ai_should_enter(_sig_data, regime, _open_list)

        except Exception as _aie:

            pass  # sin API key o error → dejar pasar



        if not _ai_ok:

            print(f"[AI FILTER] BLOQUEADO {_c['sym']} {_c['tf']} — {_ai_reason}", flush=True)

            continue



        # Champion gate: solo abrir si la estrategia es la champion del slot
        try:
            _cg2_snap = __import__('json').loads(open('/opt/sigma/results/reports/port_snapshot.json').read())
            _cg2_champs = _cg2_snap.get('champions', {})
            _cg2_key = _c['sym'] + '|' + _c['tf']
            _cg2_champ = _cg2_champs.get(_cg2_key, '')
            _cg2_strat = _cg2_champ.split('|')[0] if _cg2_champ else ''
            if _cg2_strat and _c['strat'] != _cg2_strat:
                # buscar en results el modelo champion con signal activa
                _cg2_champ_m = next((r for r in results if r.get('sym')==_c['sym'] and r.get('tf')==_c['tf'] and r.get('strategy')==_cg2_strat and r.get('signal')), None)
                if _cg2_champ_m:
                    _c = {**_c, 'strat': _cg2_strat, 'price': _cg2_champ_m.get('price', _c['price']),
                          'sl': _cg2_champ_m.get('sl', _c['sl']), 'tp': _cg2_champ_m.get('tp', _c['tp']),
                          'grade': _cg2_champ_m.get('grade', _c['grade']), 'wr': _cg2_champ_m.get('wr', _c['wr']),
                          'cagr': _cg2_champ_m.get('cagr', _c['cagr'])}
                    print(f"[CHAMPION_GATE] {_c['sym']}/{_c['tf']} usando champion {_cg2_strat}", flush=True)
                else:
                    print(f"[CHAMPION_GATE] {_c['sym']}/{_c['tf']} champion {_cg2_strat} sin signal activa - abortando", flush=True)
                    continue
        except Exception as _cg2e:
            print(f'[CHAMPION_GATE ERROR] {_cg2e}', flush=True)

        _execute_trade(_c['sym'],_c['tf'],_c['dir'],_c['price'],_c['sl'],_c['tp'],
                       strategy=_c['strat'],grade=_c['grade'],wr=_c['wr'],cagr=_c['cagr'],
                       kelly_pct=_c.get('kelly_pct', 2.2))

        _open_n += 1



    # ── Modelos con trade abierto: signal=True + datos reales ──────────────

    try:

        _ts_final = _load_trades()

        _open_final = _ts_final.get('open', {})

        for _rf in results:

            if not _rf.get('has_open_trade'):

                continue

            _kf = f"{_rf.get('sym','').upper()}_{_rf.get('tf','')}"

            _otf = _open_final.get(_kf)

            if not _otf or _otf.get('status') != 'open':

                continue

            # Solo aplicar a la entrada que coincide con la STRATEGY del trade abierto

            # (sino se duplica info entre pullback/tma_bands/momentum_short del mismo sym+tf)

            if _rf.get('strategy') != _otf.get('strategy'):

                continue

            # Forzar signal=True y datos del trade real

            _rf['signal']   = True

            _rf['price']    = _otf.get('entry') or _rf.get('price') or 0

            _rf['sl']       = _otf.get('sl')    or _rf.get('sl')    or 0

            _rf['tp']       = _otf.get('tp')    or _rf.get('tp')    or 0

            # Corregir type y strategy desde el trade real

            _trade_dir = _otf.get('direction', '')

            if _trade_dir == 'short':

                _rf['type'] = 'short'

            elif _trade_dir == 'long':

                _rf['type'] = 'long'

            if _otf.get('strategy'):

                _rf['strategy'] = _otf['strategy']

            _rf['open_trade_entry'] = _otf.get('entry', 0)

            _rf['open_trade_since'] = str(_otf.get('opened_at', ''))[:16]

    except Exception:

        pass



    # ── MULTI-TF CONSENSUS FILTER (flag-gated, default OFF — 2026-05-14) ────

    # Cuando ON: señal de TF X solo válida si TF "partner" coincide en dirección.

    # Reduce false positives ~30% según teoría (correcciones contra tendencia).

    # NO romper baseline: dejar OFF hasta validar con un activo de prueba.

    MULTI_TF_REQUIRE_CONSENSUS = False  # 2026-05-14: REVERTIDO tras backtest — filtraba 3/3 trades ganadores (-11.4% PnL)

    MULTI_TF_PAIRS = {'15m': '1h', '1h': '4h', '4h': '1h'}  # tf → partner_tf



    if MULTI_TF_REQUIRE_CONSENSUS:

        # Indexar señales activas por (sym, tf, direction) para lookup O(1)

        active_signals = {}

        for _rmt in results:

            if _rmt.get('signal') and _rmt.get('regime_ok'):

                _kmt = (_rmt.get('sym'), _rmt.get('tf'), _rmt.get('type', 'long'))

                active_signals[_kmt] = True



        # Filtrar las que no tienen consenso del partner TF

        for _rmt in results:

            if not _rmt.get('signal'):

                continue

            _sym_mt = _rmt.get('sym')

            _tf_mt  = _rmt.get('tf')

            _dir_mt = _rmt.get('type', 'long')

            _ptf    = MULTI_TF_PAIRS.get(_tf_mt)

            if not _ptf:

                continue  # sin partner definido para este TF

            _consensus = active_signals.get((_sym_mt, _ptf, _dir_mt), False)

            if not _consensus:

                _rmt['signal']            = False

                _rmt['multi_tf_filtered'] = True

                _rmt['reason']            = f'Multi-TF: sin consenso en {_ptf.upper()}'



    # ── ENSEMBLE VOTING FILTER (flag-gated, default OFF — 2026-05-14) ───────

    # Cuando ON: señal solo válida si al menos N estrategias del mismo (sym, tf, direction)

    # tienen signal=True. Múltiples estrategias confirman = más confianza.

    ENSEMBLE_REQUIRE_VOTES = False  # ← cambiar a True para activar

    ENSEMBLE_MIN_VOTES     = 2      # cuántas señales coincidentes mínimo



    if ENSEMBLE_REQUIRE_VOTES:

        # Contar señales activas por (sym, tf, direction)

        _vote_count = {}

        for _rev in results:

            if _rev.get('signal') and _rev.get('regime_ok'):

                _kev = (_rev.get('sym'), _rev.get('tf'), _rev.get('type', 'long'))

                _vote_count[_kev] = _vote_count.get(_kev, 0) + 1



        # Filtrar señales que no superan el mínimo de votos

        for _rev in results:

            if not _rev.get('signal'):

                continue

            _kev = (_rev.get('sym'), _rev.get('tf'), _rev.get('type', 'long'))

            _votes = _vote_count.get(_kev, 0)

            if _votes < ENSEMBLE_MIN_VOTES:

                _rev['signal']             = False

                _rev['ensemble_filtered']  = True

                _rev['ensemble_votes']     = _votes

                _rev['reason']             = f'Ensemble: solo {_votes} señal(es), necesita >={ENSEMBLE_MIN_VOTES}'



    # ── FUNDING RATE GATE (flag-gated, conservador — 2026-05-14) ────────────

    # Bloquea trades cuando funding está EXTREMADAMENTE en contra (overcrowded).

    # Thresholds CONSERVADORES (solo bloquea ~5% de casos extremos).

    # Funding > +0.03%/8h = ~3.3%/mes en contra para longs → señal de bull-skew extremo

    # Funding < -0.03%/8h = ~3.3%/mes en contra para shorts → bear-skew extremo

    FUNDING_GATE_ENABLED       = True   # 2026-05-14 ACTIVADO tras backtest ±0.03% (0/6 trades bloqueados)

    FUNDING_LONG_BLOCK_THR     =  0.03  # % por intervalo de 8h

    FUNDING_SHORT_BLOCK_THR    = -0.03

    # Premortem 2026-05-14: kill-switch para eventos funding extremo (Luna/FTX-like)

    FUNDING_EMERGENCY_THR      = 0.15   # |funding| > 0.15%/8h => PAUSE total + alerta



    # Detección de evento extremo (cualquier símbolo cruza el umbral)

    _emergency_sym = None

    _emergency_val = 0.0

    for _sym_chk, _f_chk in _funding_cache.items():

        _val_pct_chk = (_f_chk.get('value', 0) or 0) * 100

        if abs(_val_pct_chk) > abs(_emergency_val):

            _emergency_val = _val_pct_chk

            _emergency_sym = _sym_chk

    if _emergency_sym and abs(_emergency_val) >= FUNDING_EMERGENCY_THR:

        # Bloquea TODO y marca flag — la alerta se dispara desde marker file con cooldown

        for _rfd in results:

            _rfd['signal'] = False

            _rfd['funding_emergency'] = True

            _rfd['reason'] = f'FUNDING EMERGENCY: {_emergency_sym} funding={_emergency_val:+.3f}% >= {FUNDING_EMERGENCY_THR}%'

        _cb['funding_emergency'] = True

        _cb['emergency_sym'] = _emergency_sym

        _cb['emergency_val'] = round(_emergency_val, 4)

        # Marker file con cooldown 1h

        try:

            _flag = '/opt/sigma/state/funding_emergency.flag'

            _now = time.time()

            _last = 0

            if os.path.exists(_flag):

                _last = os.path.getmtime(_flag)

            if _now - _last > 3600:  # cooldown 1h

                with open(_flag, 'w') as _ff:

                    _ff.write(f'{_emergency_sym}|{_emergency_val:+.4f}|{int(_now)}')

        except Exception:

            pass



    if FUNDING_GATE_ENABLED:

        for _rfd in results:

            if not _rfd.get('signal'):

                continue

            _fsym = _rfd.get('sym')

            _fdir = _rfd.get('type', 'long')

            _fcache = _funding_cache.get(_fsym, {})

            _fval_pct = (_fcache.get('value', 0) or 0) * 100  # convertir a %

            _rfd['funding_pct'] = round(_fval_pct, 4)

            if _fdir == 'long' and _fval_pct > FUNDING_LONG_BLOCK_THR:

                _rfd['signal']            = False

                _rfd['funding_filtered']  = True

                _rfd['reason']            = f'Funding gate: long blocked, funding +{_fval_pct:.3f}% > {FUNDING_LONG_BLOCK_THR}%'

            elif _fdir == 'short' and _fval_pct < FUNDING_SHORT_BLOCK_THR:

                _rfd['signal']            = False

                _rfd['funding_filtered']  = True

                _rfd['reason']            = f'Funding gate: short blocked, funding {_fval_pct:+.3f}% < {FUNDING_SHORT_BLOCK_THR}%'



    # 2026-05-19: Robustness gate anti-overfit (no opera modelos con red flags estructurales)

    try:

        from utils.robustness import robustness_score as _robust_score, robustness_kelly_multiplier as _robust_kelly

        import json as _json_rb, os as _os_rb

        for _rmodel in results:

            _sym_r = _rmodel.get('sym',''); _tf_r = _rmodel.get('tf','')

            _strat_r = _rmodel.get('strategy','')

            _fp_r = '/opt/sigma/models/' + _tf_r + '/' + _sym_r.lower() + '_' + _strat_r + '.json'

            if not _os_rb.path.exists(_fp_r):

                continue

            try:

                _d_r = _json_rb.load(open(_fp_r))

                _r = _robust_score(_d_r)

                _rmodel['robustness_score'] = _r['final']

                _rmodel['robustness_action'] = _r['action']

                _rmodel['robustness_gates'] = _r.get('gates_failed', [])

                # Override recommendation si BLOCKED

                if _r['action'] == 'BLOCKED':

                    _rmodel['recommendation'] = 'NO_ACTIVAR'

                    _rmodel['signal'] = False

                    _rmodel['slot'] = 0  # 2026-05-20: limpiar slot heredado pre-robustness gate

                    _existing_reason = _rmodel.get('reason','')

                    _gates_str = ','.join(_r.get('gates_failed', [])[:2])

                    _rmodel['reason'] = f'BLOCKED por robustness ({_gates_str}) | original: {_existing_reason}'[:200]

                elif _r['action'] == 'PAPER_ONLY':

                    # En paper se sigue operando, pero kelly reducido para limitar daño si falla

                    _existing_kelly = _rmodel.get('eff_risk_pct', 5.0)

                    _rmodel['eff_risk_pct'] = round(min(_existing_kelly, 1.5), 2)

                    _rmodel['robustness_kelly_capped'] = True

                # 2026-05-20: Upgrade NO_ACTIVAR -> CONDICIONAL si robustness valida

                # Si rob=PASS_LIVE/PAPER_ONLY y rec=NO_ACTIVAR por DD/WR (no por overfit/CAGR/N), upgrade a CONDICIONAL

                # Asi se habilita paper trading; live aun requiere ACTIVAR + PASS_LIVE explicitos

                if _r['action'] in ('PASS_LIVE','PAPER_ONLY') and _rmodel.get('recommendation') == 'NO_ACTIVAR':

                    _reason_orig = _rmodel.get('reason','') or ''

                    _is_hard_block = ('BLOCKED por robustness' in _reason_orig

                                      or 'Grade D' in _reason_orig

                                      or 'insuf.' in _reason_orig

                                      or 'trades OOS' in _reason_orig

                                      or 'muy bajo' in _reason_orig)

                    if not _is_hard_block:

                        _rmodel['recommendation'] = 'CONDICIONAL'

                        _rmodel['recommendation_upgraded_by_robustness'] = True

                        _action_str = str(_r.get('action','?'))

                        _rmodel['reason'] = ('CONDICIONAL upgrade (rob=' + _action_str + ') | original: ' + _reason_orig)[:200]



                # 2026-05-20 FIX B: PASS_LIVE puede subir CONDICIONAL -> ACTIVAR si solo bloqueo es DD entre -35 y -42

                # Robustness gate ya validó (cons + mc + wft + N). DD -35 a -42 es manejable con Kelly cap.

                # Para DD < -42 mantener CONDICIONAL (paper only).

                if (_r['action'] == 'PASS_LIVE' 

                    and _rmodel.get('recommendation') == 'CONDICIONAL' 

                    and _rmodel.get('recommendation_upgraded_by_robustness')):

                    _orig_reason = _rmodel.get('reason','')

                    _dd_val = float(_rmodel.get('dd', 0) or 0)

                    _cagr_val = float(_rmodel.get('cagr', 0) or 0)

                    _grade_val = _rmodel.get('grade', 'D')

                    # Solo si la razon original era DD-only y DD entre -42 y -35, CAGR>=12, Grade A+/A/B

                    if ('DD' in _orig_reason and 'excesivo' in _orig_reason

                        and -42 <= _dd_val < -35

                        and _cagr_val >= 12

                        and _grade_val in ('A+','A','B')):

                        _rmodel['recommendation'] = 'ACTIVAR'

                        _rmodel['recommendation_promoted_to_activar'] = True

                        _rmodel['slot'] = 0  # reset slot tras promote — sera elegible en siguiente loop de slot assignment

                        _rmodel['reason'] = ('ACTIVAR promoted (PASS_LIVE rob + DD ' + ('%.1f' % _dd_val) + '% manejable) | ' + _orig_reason)[:200]

                # 2026-06-11 FIX C: 15m orgánico CONDICIONAL por DD + PASS_LIVE → ACTIVAR
                # Con umbrales TF-aware, el path rob-upgrade ya no aplica para DD -35 a -50.
                # Si tiene PASS_LIVE + CAGR/grade ok + DD en rango 15m → promover directamente.
                if (_r['action'] == 'PASS_LIVE'
                    and _rmodel.get('recommendation') == 'CONDICIONAL'
                    and not _rmodel.get('recommendation_upgraded_by_robustness')
                    and not _rmodel.get('recommendation_promoted_to_activar')):
                    _tf_c  = str(_rmodel.get('tf', ''))
                    _dd_c  = float(_rmodel.get('dd', 0) or 0)
                    _cg_c  = float(_rmodel.get('cagr', 0) or 0)
                    _gr_c  = _rmodel.get('grade', 'D')
                    _rs_c  = _rmodel.get('reason', '')
                    if (_tf_c == '15m'
                        and 'DD' in _rs_c
                        and -50 <= _dd_c < -25
                        and _cg_c >= 12
                        and _gr_c in ('A+', 'A', 'B')):
                        _rmodel['recommendation'] = 'ACTIVAR'
                        _rmodel['recommendation_promoted_to_activar'] = True
                        _rmodel['reason'] = ('ACTIVAR promoted (PASS_LIVE+15m DD ' + ('%.1f' % _dd_c) + '% TF-aware) | ' + _rs_c)[:200]

            except Exception as _e_rb_inner:

                pass

    except Exception as _e_rb:

        print(f'[ROBUSTNESS_GATE ERROR] {type(_e_rb).__name__}: {_e_rb}', flush=True)



    # 2026-05-20: segundo pass de slot assignment para PROMOTED to ACTIVAR (post-robustness)

    # Modelos que recien suben a ACTIVAR por FIX B tienen slot=0 y necesitan ser considerados.

    # Solo asignamos slots libres restantes — no quitamos slots ya asignados.

    try:

        _seen_syms_now = set()

        _slot_count_now = 0

        for _rm in results:

            if _rm.get('slot', 0) >= 1:

                _seen_syms_now.add(_rm.get('sym',''))

                _slot_count_now += 1

        _MAX_SLOTS = 3

        # Buscar promoted que quieren slot

        _promoted = [_rm for _rm in results 

                     if _rm.get('recommendation_promoted_to_activar')

                     and _rm.get('slot', 0) == 0

                     and _rm.get('regime_ok', False)

                     and _rm.get('sym','') not in _seen_syms_now]

        # Ordenar por score descendente

        _promoted.sort(key=lambda x: -(x.get('score', 0) or 0))

        for _rm in _promoted:

            if _slot_count_now >= _MAX_SLOTS: break

            _rm['slot'] = _slot_count_now + 1

            _seen_syms_now.add(_rm.get('sym',''))

            _slot_count_now += 1

            print(f'[PROMOTE_SLOT] {_rm.get("sym")} {_rm.get("tf")} {_rm.get("strategy")} -> slot {_rm["slot"]}', flush=True)

    except Exception as _e_ps:

        print(f'[PROMOTE_SLOT ERROR] {_e_ps}', flush=True)



    return {'regime':regime,'models':results,'updated':_strftime_chile('%H:%M:%S'),'circuit_breaker':_cb}





HUD_PINE      = BASE / 'results' / 'pine_scripts' / 'SIGMA_v13_COMPLETO.pine'

ENGINE_PINE   = BASE / 'results' / 'pine_scripts' / 'SIGMA_ENGINE_v1.pine'

STRATEGY_PINE = BASE / 'results' / 'pine_scripts' / 'SIGMA_ENGINE_STRATEGY_v1.pine'

UPDATE_HUD_PY = BASE / 'update_hud.py'



def _serve_file(handler, path, filename):

    if path.exists():

        body = path.read_bytes()

        handler.send_response(200)

        handler.send_header('Content-Type', 'text/plain; charset=utf-8')

        handler.send_header('Content-Length', len(body))

        handler.send_header('Content-Disposition', f'attachment; filename="{filename}"')

        handler.send_header('Access-Control-Allow-Origin', '*')

        handler.end_headers()

        handler.wfile.write(body)

    else:

        handler.send_response(404)

        handler.end_headers()

        handler.wfile.write(b'File not found')



def _send_json(handler, data):

    body = json.dumps(data, default=str).encode()

    handler.send_response(200)

    handler.send_header('Content-Type', 'application/json')

    handler.send_header('Content-Length', len(body))

    handler.send_header('Access-Control-Allow-Origin', '*')

    handler.end_headers()

    handler.wfile.write(body)





# ── Dashboard auth (simple cookie-based) ─────────────────────────────────────

_AUTH_FILE = Path('/opt/sigma/engine/config/dashboard_auth.txt')



def _read_auth_config():

    """Lee password, cookie secret y URL_TOKEN del archivo (re-lee en cada request — permite rotar sin restart)."""

    pwd, secret, url_token = '0808', 'fallback-secret-change-me', ''

    try:

        for line in _AUTH_FILE.read_text(encoding='utf-8').splitlines():

            if line.startswith('PASSWORD='):

                pwd = line.split('=',1)[1].strip()

            elif line.startswith('COOKIE_SECRET='):

                secret = line.split('=',1)[1].strip()

            elif line.startswith('URL_TOKEN='):

                url_token = line.split('=',1)[1].strip()

    except Exception:

        pass

    return pwd, secret, url_token



def _auth_token(secret):

    """Token simple: HMAC del secret. Si el secret cambia, todas las cookies se invalidan."""

    import hmac, hashlib

    return hmac.new(secret.encode(), b'sigma-dashboard', hashlib.sha256).hexdigest()[:32]



def _parse_cookies(header_value):

    out = {}

    if not header_value: return out

    for kv in header_value.split(';'):

        if '=' in kv:

            k, v = kv.split('=', 1)

            out[k.strip()] = v.strip()

    return out



def _is_authenticated(handler):

    """Devuelve True si el request está autenticado.

    Bypass localhost SOLO si no hay headers de proxy (X-Forwarded-For/X-Real-IP).

    Esto previene que nginx reverse proxy bypassee la auth."""

    client_ip = handler.client_address[0]

    has_proxy_header = bool(

        handler.headers.get('X-Forwarded-For') or

        handler.headers.get('X-Real-IP') or

        handler.headers.get('Forwarded')

    )

    # Bypass solo procesos sigma internos (mismo host, sin proxy)

    if client_ip in ('127.0.0.1', '::1', 'localhost') and not has_proxy_header:

        return True

    # Resto: verificar cookie firmada

    cookies = _parse_cookies(handler.headers.get('Cookie', ''))

    token = cookies.get('sigma_auth')

    if not token:

        return False

    _, secret, _ = _read_auth_config()

    import hmac as _hmac_cmp
    return _hmac_cmp.compare_digest(token, _auth_token(secret))



