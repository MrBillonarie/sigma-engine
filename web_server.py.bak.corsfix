.box{{background:linear-gradient(180deg,#161b22,#13181f);border:1px solid #21262d;border-radius:14px;padding:36px 32px;width:340px;box-shadow:0 20px 60px -20px #000a,0 1px 0 #ffffff05 inset}}

.title{{font-size:20px;font-weight:700;background:linear-gradient(90deg,#58a6ff,#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:-.02em;text-align:center;margin-bottom:4px}}

.sub{{font-size:11px;color:#6e7681;text-align:center;margin-bottom:24px;letter-spacing:.05em;text-transform:uppercase}}

form{{display:flex;flex-direction:column;gap:12px}}

input{{background:#0d1117;border:1px solid #30363d;border-radius:8px;padding:12px 14px;color:#e6edf3;font-size:14px;letter-spacing:.05em;text-align:center;outline:none;font-family:'JetBrains Mono',monospace;transition:border-color .2s}}

input:focus{{border-color:#58a6ff}}

button{{background:linear-gradient(180deg,#238636,#1f7a30);border:none;border-radius:8px;padding:12px;color:#fff;font-size:14px;font-weight:600;cursor:pointer;letter-spacing:.05em;transition:transform .1s}}

button:hover{{transform:translateY(-1px)}}

