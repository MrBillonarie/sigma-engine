def _render_per_model_page():

    """Subpagina con grid de mini-dashboards por modelo."""

    return """<!DOCTYPE html>

<html lang="es"><head>

<meta charset="utf-8"><title>SIGMA - Per Model Paper Trading</title>

<meta name="viewport" content="width=device-width,initial-scale=1">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">

<style>

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

body{background:radial-gradient(ellipse at top,#11161f 0%,#0a0d12 60%) fixed;color:#e6edf3;font-family:'Inter',-apple-system,'Segoe UI',sans-serif;font-size:13px;min-height:100vh}

.container{max-width:1500px;margin:0 auto;padding:20px 16px}

.mono{font-family:'JetBrains Mono',monospace}

.hdr{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid #21262d}

.hdr h1{font-size:22px;font-weight:700;background:linear-gradient(90deg,#58a6ff,#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:-.02em}

.hdr .sub{color:#6e7681;font-size:11px;letter-spacing:.1em;text-transform:uppercase;margin-top:4px;font-weight:600}

.back-btn{background:#161b22;border:1px solid #30363d;color:#8b949e;padding:8px 14px;border-radius:6px;text-decoration:none;font-size:11px;font-weight:600;transition:all .2s}

.back-btn:hover{border-color:#58a6ff;color:#58a6ff}

.summary{background:linear-gradient(180deg,#161b22,#13181f);border:1px solid #21262d;border-radius:10px;padding:14px 18px;margin-bottom:18px;display:flex;gap:28px;flex-wrap:wrap}

.summary .it{display:flex;flex-direction:column;gap:2px}

.summary .lbl{color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase;font-weight:600}

.summary .val{color:#e6edf3;font-size:15px;font-family:'JetBrains Mono',monospace;font-weight:700}

.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:14px}

.card{background:linear-gradient(180deg,#161b22 0%,#13181f 100%);border:1px solid #21262d;border-radius:10px;padding:14px;transition:all .25s;position:relative;overflow:hidden}

.card:hover{border-color:#30363d;transform:translateY(-2px);box-shadow:0 8px 24px -12px #00000080}

.card.s-OK{border-left:3px solid #00e676}

.card.s-DEGRADING{border-left:3px solid #ff9800}

.card.s-FAILING{border-left:3px solid #f85149}

.card.s-NEW,.card.s-EARLY{border-left:3px solid #30363d}

.card.retired{opacity:.55;border-left:3px solid #6e7681;border-style:dashed solid solid solid}

.card.retired:hover{opacity:.85}

.retired-tag{background:#6e768120;color:#8b949e;font-size:8px;font-weight:700;padding:2px 6px;border-radius:6px;letter-spacing:.08em;margin-left:6px}

.replaced-by{font-size:9px;color:#a78bfa;margin-top:4px;font-style:italic}

.c-hdr{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px}

.c-title{font-size:14px;font-weight:700;color:#c9d1d9;letter-spacing:-.01em}

.c-title .tf{color:#6e7681;font-weight:600;margin:0 4px}

.c-title .dir{font-size:10px;color:#6e7681;font-weight:600;margin-left:6px;letter-spacing:.05em}

.c-sub{font-size:10px;color:#6e7681;letter-spacing:.05em;margin-top:2px}

.c-status{font-size:9px;font-weight:700;letter-spacing:.1em;padding:3px 8px;border-radius:10px}

.s-OK .c-status{background:#00e67625;color:#00e676}

.s-DEGRADING .c-status{background:#ff980025;color:#ff9800}

.s-FAILING .c-status{background:#f8514925;color:#f85149}

.s-NEW .c-status,.s-EARLY .c-status{background:#21262d;color:#8b949e}

.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px;padding-top:10px;border-top:1px solid #21262d}

.kpi{display:flex;flex-direction:column;gap:1px}

.kpi-l{color:#6e7681;font-size:8px;letter-spacing:.1em;text-transform:uppercase;font-weight:600}

.kpi-v{color:#e6edf3;font-size:13px;font-family:'JetBrains Mono',monospace;font-weight:700;line-height:1.2}

.pos{color:#00e676}.neg{color:#f85149}.warn{color:#ff9800}.dim{color:#6e7681}

.compare{background:#0d1117;border:1px solid #21262d;border-radius:6px;padding:8px 10px;margin-bottom:10px;font-size:10px;color:#8b949e}

.compare-row{display:flex;justify-content:space-between;align-items:center;padding:2px 0}

.compare-l{color:#6e7681;font-weight:600;letter-spacing:.05em}

.compare-v{color:#c9d1d9;font-family:'JetBrains Mono',monospace}

.spark-wrap{height:70px;background:#0a0d12;border-radius:6px;overflow:hidden;padding:6px;margin-bottom:10px;position:relative}

.spark svg{display:block;width:100%;height:100%}

.spark-legend{position:absolute;top:4px;right:6px;font-size:8px;color:#6e7681;letter-spacing:.05em;display:flex;gap:8px}

.spark-legend .lg-live{color:#00e676}

.spark-legend .lg-bt{color:#58a6ff;opacity:.7}

.score-pill{display:inline-flex;align-items:center;justify-content:center;background:#0d1117;border:1px solid #30363d;padding:3px 9px;border-radius:11px;font-size:10px;font-weight:700;color:#c9d1d9;font-family:'JetBrains Mono',monospace;margin-left:6px}

.score-pill.high{border-color:#00e67660;color:#00e676}

.score-pill.mid{border-color:#ff980060;color:#ff9800}

.score-pill.low{border-color:#f8514960;color:#f85149}

.rank-num{display:inline-block;background:#a78bfa20;color:#a78bfa;font-size:9px;font-weight:700;padding:1px 6px;border-radius:8px;letter-spacing:.05em;margin-right:6px;font-family:'JetBrains Mono',monospace}

.expand-btn{background:none;border:none;color:#6e7681;cursor:pointer;font-size:10px;letter-spacing:.05em;font-family:inherit;padding:4px 0;width:100%;text-align:center;font-weight:600;transition:color .15s}

.expand-btn:hover{color:#58a6ff}

.detail{display:none;padding-top:10px;margin-top:10px;border-top:1px solid #21262d}

.detail.show{display:block}

.detail-row{display:flex;justify-content:space-between;font-size:10px;padding:3px 0;color:#8b949e}

.detail-row .l{color:#6e7681;font-weight:600;letter-spacing:.05em}

.detail-row .v{color:#c9d1d9;font-family:'JetBrains Mono',monospace}

.mini-trade{display:flex;justify-content:space-between;align-items:center;font-size:9px;padding:4px 6px;background:#0d1117;border-radius:4px;margin-top:4px;font-family:'JetBrains Mono',monospace}

.mini-trade.win{border-left:2px solid #00e676}

.mini-trade.loss{border-left:2px solid #f85149}

.footer-meta{display:flex;justify-content:space-between;align-items:center;font-size:9px;color:#6e7681;padding-top:8px;border-top:1px solid #21262d}

.badge-grade{display:inline-block;padding:2px 7px;border-radius:10px;font-size:9px;font-weight:700;letter-spacing:.05em;margin-left:6px}

.g-Aplus{background:#00c853;color:#000}.g-A{background:#69f0ae;color:#000}.g-B{background:#ffeb3b;color:#000}.g-C{background:#ff9800;color:#000}.g-D{background:#f85149;color:#000}

.open-tag{background:#a78bfa25;color:#a78bfa;font-size:9px;font-weight:700;padding:2px 6px;border-radius:8px;letter-spacing:.05em}

.rec-tag{font-size:8px;font-weight:700;padding:2px 6px;border-radius:6px;letter-spacing:.08em;margin-left:6px}

.rec-ACTIVAR{background:#00e67625;color:#00e676}

.rec-CONDICIONAL{background:#ffeb3b25;color:#ffeb3b}

.rec-ESPERAR{background:#58a6ff25;color:#58a6ff}

.rec-NO_ACTIVAR{background:#f8514915;color:#8b949e}

.empty{padding:32px;text-align:center;color:#6e7681;font-size:13px;grid-column:1/-1}

.fbtn,.sbtn{background:#161b22;border:1px solid #30363d;color:#8b949e;padding:5px 11px;border-radius:6px;cursor:pointer;font-size:10px;font-weight:600;letter-spacing:.05em;transition:all .15s;font-family:inherit}

.fbtn:hover,.sbtn:hover{border-color:#58a6ff;color:#58a6ff}

.fbtn.active{background:#58a6ff20;border-color:#58a6ff;color:#58a6ff}

.sbtn.active{background:#a78bfa20;border-color:#a78bfa;color:#a78bfa}

.card.hidden{display:none}

@media(max-width:600px){.grid{grid-template-columns:1fr}}

</style></head><body>

<div class="container">

  <div class="hdr">

    <div>

      <h1>SIGMA &middot; Per-Model Paper Trading</h1>

      <div class="sub">Cada modelo como sub-portfolio independiente &middot; $10k inicial &middot; sin restriccion macro</div>

    </div>

    <a href="/" class="back-btn">&larr; Volver al dashboard</a>

  </div>



  <div class="summary">

    <div class="it"><div class="lbl">Modelos tracked</div><div class="val" id="n-models">-</div></div>

    <div class="it"><div class="lbl">Equity agregado <span style="color:#444;font-size:8px">live + float</span></div><div class="val" id="eq-total">-</div></div>

    <div class="it"><div class="lbl">P&L flotante total</div><div class="val" id="float-total">-</div></div>

    <div class="it"><div class="lbl">Return promedio <span style="color:#444;font-size:8px">incl float</span></div><div class="val" id="ret-avg">-</div></div>

    <div class="it"><div class="lbl">Mejor modelo</div><div class="val" id="best">-</div></div>

    <div class="it"><div class="lbl">Peor modelo</div><div class="val" id="worst">-</div></div>

    <div class="it"><div class="lbl">Trades cerrados</div><div class="val" id="n-trades">-</div></div>

    <div class="it"><div class="lbl">Operando ahora</div><div class="val" id="n-open">-</div></div>

    <div class="it"><div class="lbl">Estados</div><div class="val" id="status-summary">-</div></div>

  </div>



  <!-- TRADES EN CURSO de TODOS los modelos -->

  <div style="background:linear-gradient(180deg,#161b22,#13181f);border:1px solid #21262d;border-radius:10px;padding:12px 14px;margin-bottom:16px;overflow-x:auto">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">

      <span style="color:#c9d1d9;font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase">&#9889; Trades en curso <span style="color:#6e7681;font-size:10px;margin-left:8px">todos los modelos &middot; live</span></span>

      <span style="color:#444;font-size:10px"><span style="display:inline-block;width:6px;height:6px;background:#00e676;border-radius:50%;margin-right:4px;animation:pulse 1.5s infinite"></span>refresh 15s</span>

    </div>

    <div id="active-trades-wrap"><div style="padding:14px;text-align:center;color:#6e7681;font-size:11px">Cargando...</div></div>

  </div>

  <style>@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}</style>



  <!-- Filtros y orden -->

  <div style="display:flex;gap:8px;margin-bottom:8px;flex-wrap:wrap;align-items:center">

    <span style="color:#6e7681;font-size:10px;letter-spacing:.1em;text-transform:uppercase;font-weight:600;margin-right:6px">Filtrar:</span>

    <button class="fbtn active" data-filter="all">Todos</button>

    <button class="fbtn" data-filter="ACTIVAR">Activar</button>

    <button class="fbtn" data-filter="CONDICIONAL">Condicional</button>

    <button class="fbtn" data-filter="ESPERAR">Esperar</button>

    <button class="fbtn" data-filter="NO_ACTIVAR">No activar</button>

    <span style="color:#444;margin:0 6px">|</span>

    <button class="fbtn" data-filter="short">Solo shorts</button>

    <button class="fbtn" data-filter="long">Solo longs</button>

    <button class="fbtn" data-filter="with_trades">Con trades</button>

    <span style="color:#444;margin:0 6px">|</span>

    <button class="fbtn" data-filter="active_only">Solo activos</button>

    <button class="fbtn" data-filter="retired">Solo retired</button>

  </div>

  <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;align-items:center">

    <span style="color:#6e7681;font-size:10px;letter-spacing:.1em;text-transform:uppercase;font-weight:600;margin-right:6px">Ordenar por:</span>

    <button class="sbtn active" data-sort="score">Score</button>

    <button class="sbtn" data-sort="return">Return live</button>

    <button class="sbtn" data-sort="cagr_bt">CAGR backtest</button>

    <button class="sbtn" data-sort="wr_delta">&Delta; WR vs bt</button>

    <button class="sbtn" data-sort="trades">Trades</button>

    <button class="sbtn" data-sort="sharpe">Sharpe</button>

    <button class="sbtn" data-sort="days_idle">Sin operar</button>

  </div>




  <div id="motors-matrix" style="margin-bottom:16px;display:grid;grid-template-columns:1fr 1fr;gap:12px">
    <div id="motor1-card" style="background:#161b22;border:1px solid #21262d;border-radius:10px;padding:14px 16px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
        <span style="color:#58a6ff;font-weight:700;font-size:12px;letter-spacing:.08em;text-transform:uppercase">Motor 1 — Crypto</span>
        <span id="m1-pct" style="font-family:monospace;font-size:13px;font-weight:700;color:#e6edf3">-</span>
      </div>
      <div id="m1-bar" style="height:4px;background:#21262d;border-radius:2px;margin-bottom:10px;overflow:hidden">
        <div id="m1-bar-fill" style="height:100%;background:linear-gradient(90deg,#58a6ff,#a78bfa);border-radius:2px;width:0%;transition:width .6s"></div>
      </div>
      <div id="m1-grid" style="display:grid;grid-template-columns:repeat(5,1fr);gap:4px;font-family:monospace;font-size:10px"></div>
    </div>
    <div id="motor2-card" style="background:#161b22;border:1px solid #21262d;border-radius:10px;padding:14px 16px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
        <span style="color:#ffa657;font-weight:700;font-size:12px;letter-spacing:.08em;text-transform:uppercase">SIGMA MACRO — Metals &amp; Energy</span>
        <span id="m2-pct" style="font-family:monospace;font-size:13px;font-weight:700;color:#e6edf3">-</span>
      </div>
      <div id="m2-bar" style="height:4px;background:#21262d;border-radius:2px;margin-bottom:10px;overflow:hidden">
        <div id="m2-bar-fill" style="height:100%;background:linear-gradient(90deg,#ffa657,#ff7b72);border-radius:2px;width:0%;transition:width .6s"></div>
      </div>
      <div id="m2-grid" style="display:grid;grid-template-columns:repeat(5,1fr);gap:4px;font-family:monospace;font-size:10px"></div>
    </div>
  </div>
  <script>
  (function(){
    fetch('/api/motors').then(r=>r.json()).then(d=>{
      function renderMotor(m, gridId, pctId, barId){
        var g = document.getElementById(gridId);
        var pct = d[m] ? d[m].coverage_pct : 0;
        var filled = d[m] ? d[m].filled_slots : 0;
        var total  = d[m] ? d[m].total_slots : 0;
        document.getElementById(pctId).textContent = pct.toFixed(0)+'% ('+filled+'/'+total+')';
        document.getElementById(barId+'-fill').style.width = Math.min(pct,100)+'%';
        if(!d[m]) return;
        var tfs = d[m].timeframes;
        var assets = d[m].assets;
        // header row
        var hdr = '<div style="color:#6e7681;padding:2px 4px"></div>';
        tfs.forEach(function(tf){ hdr += '<div style="color:#6e7681;padding:2px 4px;text-align:center">'+tf+'</div>'; });
        g.innerHTML = hdr;
        // asset rows
        assets.forEach(function(sym){
          g.innerHTML += '<div style="color:#8b949e;padding:2px 4px;font-weight:700">'+sym+'</div>';
          tfs.forEach(function(tf){
            var key = sym+'/'+tf;
            var hasL = d[m].active_slots.indexOf(key+'/long')>=0;
            var hasS = d[m].active_slots.indexOf(key+'/short')>=0;
            var txt = (hasL?'L':'-')+(hasS?'S':'-');
            var col = (hasL&&hasS)?'#00e676':((hasL||hasS)?'#ffa657':'#6e7681');
            g.innerHTML += '<div style="padding:2px 4px;text-align:center;color:'+col+'">'+txt+'</div>';
          });
        });
      }
      renderMotor('motor1','m1-grid','m1-pct','m1-bar');
      renderMotor('motor2','m2-grid','m2-pct','m2-bar');
    }).catch(function(){});
  })();
  </script>
  <div class="grid" id="grid">

    <div class="empty">Cargando modelos...</div>

  </div>



  <div style="margin-top:16px;padding:12px 16px;background:#0d1117;border:1px solid #21262d;border-radius:8px;font-size:10px;color:#8b949e;line-height:1.6">

    <div style="font-weight:700;color:#c9d1d9;letter-spacing:.05em;text-transform:uppercase;margin-bottom:6px">Leyenda de estado</div>

    <span class="c-status" style="background:#21262d;color:#8b949e;font-weight:700">NEW / EARLY</span> sin trades o menos de 5 &middot;

    <span class="c-status" style="background:#00e67625;color:#00e676;font-weight:700">OK</span> WR live al menos 85% del backtest &middot;

    <span class="c-status" style="background:#ff980025;color:#ff9800;font-weight:700">DEGRADING</span> WR live 60-85% &middot;

    <span class="c-status" style="background:#f8514925;color:#f85149;font-weight:700">FAILING</span> WR live menos del 60% del backtest &mdash; considerar rotar

  </div>

</div>



<script>

function sparkSVG(curve, cagrBt, initial) {

  if (!curve || curve.length < 2) {

    // Curve plana cuando no hay trades — mostrar solo la baseline + backtest projection

    initial = initial || 10000;

    let proj = '';

    if (cagrBt && cagrBt > 0) {

      // Proyectar 30 dias en frente a CAGR backtest (visual placeholder)

      const projEnd = initial * (1 + (cagrBt/100/12));  // 1 mes

      const yProj = 50 - ((projEnd - initial)/Math.max(projEnd-initial, 1))*40;

      proj = `<line x1="0" y1="50" x2="100" y2="${yProj.toFixed(1)}" stroke="#58a6ff" stroke-width="1" stroke-dasharray="2,2" opacity="0.5"/>`;

    }

    return `<svg viewBox="0 0 100 60" preserveAspectRatio="none">

      <line x1="0" y1="50" x2="100" y2="50" stroke="#21262d" stroke-width="1" stroke-dasharray="3,3"/>

      ${proj}

    </svg>`;

  }

  const min = Math.min(...curve), max = Math.max(...curve);

  const range = Math.max(max - min, initial*0.01 || 1);

  const last = curve[curve.length-1];

  const first = curve[0];

  const color = last >= first ? '#00e676' : '#f85149';

  const fill  = last >= first ? '#00e67620' : '#f8514920';

  const pts = curve.map((v,i) => {

    const x = (i/(curve.length-1))*100;

    const y = 55 - ((v-min)/range)*48;

    return x.toFixed(1)+','+y.toFixed(1);

  }).join(' ');

  // Backtest projection line (referencia)

  let bt = '';

  if (cagrBt && cagrBt > 0 && curve.length > 1) {

    // Linea desde inicial al esperado: usar cagrBt/12 por mes proyectado, escala curve

    const days = curve.length; // proxy: 1 punto = 1 trade aprox

    const expected = (initial||10000) * (1 + (cagrBt/100) * (days/365));

    const yExp = 55 - ((expected-min)/range)*48;

    bt = `<line x1="0" y1="55" x2="100" y2="${yExp.toFixed(1)}" stroke="#58a6ff" stroke-width="1" stroke-dasharray="2,2" opacity="0.55"/>`;

  }

  return `<svg viewBox="0 0 100 60" preserveAspectRatio="none">

    <polyline points="${pts}" fill="none" stroke="${color}" stroke-width="1.5" stroke-linejoin="round"/>

    <polyline points="0,60 ${pts} 100,60" fill="${fill}" stroke="none"/>

    ${bt}

  </svg>`;

}



function gradeBadge(g) {

  if (!g || g==='?') return '';

  const cls = g==='A+' ? 'g-Aplus' : 'g-'+g.replace(/[^A-Z]/g,'');

  return `<span class="badge-grade ${cls}">${g}</span>`;

}



let _cachedArr = [];

let _currentSort = 'score';



const SORT_FNS = {

  score:     (a,b) => b.score - a.score,

  return:    (a,b) => b.return_pct - a.return_pct,

  cagr_bt:   (a,b) => (b.cagr_backtest||0) - (a.cagr_backtest||0),

  wr_delta:  (a,b) => (b.wr_delta||-999) - (a.wr_delta||-999),

  trades:    (a,b) => b.trades_closed - a.trades_closed,

  sharpe:    (a,b) => (b.sharpe||0) - (a.sharpe||0),

  days_idle: (a,b) => (b.days_since_last||0) - (a.days_since_last||0),

};



function scoreClass(s) {

  return s >= 60 ? 'high' : s >= 30 ? 'mid' : 'low';

}



function renderCard(m, rank) {

  const retC = m.return_pct >= 0 ? 'pos' : 'neg';

  const wrC  = m.trades_closed===0 ? 'dim' : m.wr >= 65 ? 'pos' : m.wr >= 50 ? 'warn' : 'neg';

  const pfC  = m.pf >= 2 ? 'pos' : m.pf >= 1.5 ? 'warn' : m.pf > 0 ? 'neg' : 'dim';

  const ddC  = m.max_dd_pct >= -5 ? 'pos' : m.max_dd_pct >= -10 ? 'warn' : 'neg';

  const deltaC = m.wr_delta >= -5 ? 'pos' : m.wr_delta >= -15 ? 'warn' : 'neg';

  const shC  = m.sharpe >= 1 ? 'pos' : m.sharpe >= 0 ? 'warn' : 'neg';

  const isShort = (m.strategy||'').includes('short') || (m.strategy||'').includes('breakdown');

  const dirIcon = isShort ? '&darr;' : '&uarr;';

  const stratShort = (m.strategy||'').replace('_', ' ');

  const daysTxt = m.days_since_last == null ? '-' : (m.days_since_last==0 ? 'hoy' : m.days_since_last+'d');

  const rec = m.recommendation || '?';

  const recTag = rec !== '?' ? `<span class="rec-tag rec-${rec}">${rec}</span>` : '';

  const dataAttrs = `data-rec="${rec}" data-dir="${isShort?'short':'long'}" data-has-trades="${m.trades_closed>0||m.has_open?'1':'0'}" data-key="${m.sym}_${m.tf}_${m.strategy}"`;

  const rankTag = rank ? `<span class="rank-num">#${rank}</span>` : '';

  // Trade list para detail

  let tradesHtml = '<div style="color:#6e7681;font-size:10px;text-align:center;padding:6px">Sin trades aun</div>';

  if (m.history_recent && m.history_recent.length > 0) {

    tradesHtml = m.history_recent.slice().reverse().map(t => {

      const cls = (t.pnl_pct||0) >= 0 ? 'win' : 'loss';

      const reason = (t.reason||'?').substring(0,8);

      const dateShort = (t.closed_at||'').substring(5,16).replace('-','/');

      return `<div class="mini-trade ${cls}">

        <span>${dateShort}</span>

        <span class="dim">${reason}</span>

        <span style="color:${(t.pnl_pct||0)>=0?'#00e676':'#f85149'};font-weight:700">${(t.pnl_pct||0)>=0?'+':''}${(t.pnl_pct||0).toFixed(2)}%</span>

      </div>`;

    }).join('');

  }



  const retiredCls = m.retired ? ' retired' : '';

  const retiredTag = m.retired ? '<span class="retired-tag">RETIRED</span>' : '';

  const replacedByLine = (m.retired && m.replaced_by) ? `<div class="replaced-by">&rarr; Reemplazado por ${m.replaced_by}</div>` : '';

  const dataRetired = m.retired ? 'data-retired="1"' : 'data-retired="0"';



  return `<div class="card s-${m.status}${retiredCls}" ${dataAttrs} ${dataRetired}>

    <div class="c-hdr">

      <div>

        <div class="c-title">${rankTag}<b>${m.sym}</b><span class="tf">${m.tf.toUpperCase()}</span><span class="dir">${dirIcon} ${isShort?'SHORT':'LONG'}</span></div>

        <div class="c-sub">${stratShort} ${gradeBadge(m.grade_backtest)}${recTag}${retiredTag}</div>

        ${replacedByLine}

      </div>

      <div style="display:flex;flex-direction:column;gap:4px;align-items:flex-end">

        <div class="c-status">${m.status}</div>

        <span class="score-pill ${scoreClass(m.score)}">${m.score.toFixed(0)}</span>

        ${m.has_open?'<div class="open-tag">OPEN</div>':''}

      </div>

    </div>



    <div class="spark-wrap">

      <div class="spark-legend">

        <span class="lg-live">live</span>

        ${m.cagr_backtest>0?'<span class="lg-bt">bt proj</span>':''}

      </div>

      ${sparkSVG(m.equity_curve, m.cagr_backtest, m.initial)}

    </div>



    <div class="kpis">

      <div class="kpi"><div class="kpi-l">Equity${m.has_open?' <span style="color:#a78bfa;font-size:7px">+flt</span>':''}</div><div class="kpi-v">$${(m._equity_efectivo||m.equity).toLocaleString('en-US',{maximumFractionDigits:0})}</div></div>

      <div class="kpi"><div class="kpi-l">Return${m.has_open?' <span style="color:#a78bfa;font-size:7px">+flt</span>':''}</div><div class="kpi-v ${(m._equity_efectivo||m.equity)>=m.initial?'pos':'neg'}">${(((m._equity_efectivo||m.equity)/m.initial-1)*100>=0?'+':'')}${(((m._equity_efectivo||m.equity)/m.initial-1)*100).toFixed(2)}%</div></div>

      <div class="kpi"><div class="kpi-l">Trades</div><div class="kpi-v">${m.trades_closed}${m.has_open?' <span style="color:#a78bfa;font-size:8px">+1</span>':''}</div></div>

      <div class="kpi"><div class="kpi-l">DD</div><div class="kpi-v ${ddC}">${m.max_dd_pct.toFixed(1)}%</div></div>

      <div class="kpi"><div class="kpi-l">WR live</div><div class="kpi-v ${wrC}">${m.trades_closed>0?m.wr.toFixed(0)+'%':'-'}</div></div>

      <div class="kpi"><div class="kpi-l">PF</div><div class="kpi-v ${pfC}">${m.pf>0?m.pf.toFixed(2):'-'}</div></div>

      <div class="kpi"><div class="kpi-l">Sharpe</div><div class="kpi-v ${shC}">${m.trades_closed>=2?m.sharpe.toFixed(1):'-'}</div></div>

      <div class="kpi"><div class="kpi-l">&Delta;WR vs bt</div><div class="kpi-v ${deltaC}">${m.trades_closed>0&&m.wr_backtest>0?(m.wr_delta>=0?'+':'')+m.wr_delta.toFixed(0)+'pp':'-'}</div></div>

    </div>



    <button class="expand-btn" onclick="toggleDetail(this)">Mostrar detalle &#x25BC;</button>

    <div class="detail">

      <div class="detail-row"><span class="l">CAGR backtest</span><span class="v ${m.cagr_backtest>=15?'pos':'dim'}">${m.cagr_backtest?(m.cagr_backtest>=0?'+':'')+m.cagr_backtest.toFixed(1)+'%':'-'}</span></div>

      <div class="detail-row"><span class="l">WR backtest</span><span class="v">${m.wr_backtest>0?m.wr_backtest.toFixed(0)+'%':'-'}</span></div>

      <div class="detail-row"><span class="l">DD backtest</span><span class="v">${m.dd_backtest?m.dd_backtest.toFixed(1)+'%':'-'}</span></div>

      <div class="detail-row"><span class="l">Mejor trade</span><span class="v pos">${m.best_pct>0?'+':''}${m.best_pct.toFixed(2)}%</span></div>

      <div class="detail-row"><span class="l">Peor trade</span><span class="v neg">${m.worst_pct.toFixed(2)}%</span></div>

      <div class="detail-row"><span class="l">Hold promedio</span><span class="v">${m.avg_hold_h>0?m.avg_hold_h.toFixed(1)+'h':'-'}</span></div>

      <div class="detail-row"><span class="l">Trades/mes proyect.</span><span class="v">${m.trades_per_month>0?m.trades_per_month.toFixed(1):'-'}</span></div>

      <div class="detail-row"><span class="l">Ultimo trade</span><span class="v">${daysTxt}</span></div>

      <div class="detail-row"><span class="l">Wins/Losses</span><span class="v">${m.wins}W / ${m.losses}L</span></div>

      <div style="margin-top:8px;font-size:9px;color:#6e7681;letter-spacing:.1em;text-transform:uppercase;font-weight:600">Trades recientes</div>

      ${tradesHtml}

    </div>

  </div>`;

}



function applyFilterSort(arr) {

  const fbtn = document.querySelector('.fbtn.active');

  const f = fbtn ? fbtn.dataset.filter : 'all';

  let filtered = arr.filter(m => {

    if (f === 'all') return !m.retired; // por defecto oculta retired

    if (f === 'retired') return m.retired;

    if (f === 'active_only') return !m.retired;

    const isShort = (m.strategy||'').includes('short') || (m.strategy||'').includes('breakdown');

    if (f === 'short') return isShort && !m.retired;

    if (f === 'long') return !isShort && !m.retired;

    if (f === 'with_trades') return m.trades_closed > 0 || m.has_open;

    return m.recommendation === f && !m.retired;

  });

  const sortFn = SORT_FNS[_currentSort] || SORT_FNS.score;

  filtered.sort(sortFn);

  return filtered;

}



async function _fetchLivePrices(syms) {

  const prices = {};

  await Promise.all(syms.map(async sym => {

    try {

      const r = await fetch(`https://fapi.binance.com/fapi/v1/ticker/price?symbol=${sym}USDT`);

      const d = await r.json();

      prices[sym] = parseFloat(d.price);

    } catch(e) { prices[sym] = null; }

  }));

  return prices;

}



function toggleTradeDetail(key) {

  const det = document.getElementById('detail-' + key);

  const car = document.getElementById('caret-' + key);

  if (!det) return;

  const open = det.style.display !== 'none';

  det.style.display = open ? 'none' : 'table-row';

  if (car) car.textContent = open ? '▶' : '▼';

}



async function renderActiveTrades(precachedPrices) {

  const opens = _cachedArr.filter(m => m.has_open && m.open);

  const wrap = document.getElementById('active-trades-wrap');

  if (opens.length === 0) {

    wrap.innerHTML = '<div style="padding:14px;text-align:center;color:#6e7681;font-size:11px">Ningun modelo operando en este momento</div>';

    return;

  }

  const syms = [...new Set(opens.map(m => m.sym))];

  const prices = precachedPrices || await _fetchLivePrices(syms);

  const LEVERAGE_EXCHANGE = 5;

  // Estilos compartidos del dashboard

  const TD = 'padding:8px 6px;border-bottom:1px solid #161b22;font-family:\\'JetBrains Mono\\',monospace';

  const TDR = TD + ';text-align:right';

  const TDC = TD + ';text-align:center';

  const TH = 'background:#161b22;color:#8b949e;font-weight:600;letter-spacing:.05em;text-transform:uppercase;font-size:9px;padding:8px 6px;border-bottom:1px solid #21262d;text-align:left';

  const THR = TH + ';text-align:right';

  const THC = TH + ';text-align:center';



  function gradeC(g) {

    if (g==='A+') return '#00c853'; if (g==='A') return '#69f0ae';

    if (g==='B') return '#ffeb3b'; if (g==='C') return '#ff9800'; return '#f85149';

  }

  function stratShort(s) {

    return (s||'').replace('_short','↓').replace('momentum','MOM').replace('breakdown','BRK').replace('breakout','BRK↑').replace('tma_bands','TMA').replace('ichimoku','ICH').replace('pullback','PB').replace('_',' ').substring(0,12);

  }



  let html = `<table style="width:100%;border-collapse:collapse;font-size:12px">

    <thead><tr>

      <th style="${TH}">Dir</th>

      <th style="${TH}">Activo</th>

      <th style="${TH}">TF</th>

      <th style="${TH}">Estrategia</th>

      <th style="${THC}">Grade</th>

      <th style="${THR}" title="Win rate del backtest OOS">WR bt</th>

      <th style="${THR}" title="CAGR del backtest OOS">CAGR bt</th>

      <th style="${THR}" title="Score canónico del modelo">Score</th>

      <th style="${THR}">Entrada</th>

      <th style="${THR}">Live</th>

      <th style="${THR}">SL</th>

      <th style="${THR}">TP</th>

      <th style="${THR}">RR</th>

      <th style="${THR}" title="Posicion nominal en USD (equity x leverage implicito)">Posición $</th>

      <th style="${THR}" title="MARGEN — lo que sale del wallet con leverage ${LEVERAGE_EXCHANGE}x">Margen $</th>

      <th style="${THR}" title="Apalancamiento del trade">Lev</th>

      <th style="${THR}">P&L live</th>

      <th style="${THR}">Hora</th>

    </tr></thead><tbody>`;



  for (const m of opens) {

    const t = m.open;

    const isLong = t.direction !== 'short';

    const dirC = isLong ? '#00e676' : '#f85149';

    const live = prices[m.sym] || t.entry;

    const eq = m.equity || 10000;

    const kelly = t.kelly_pct || 5;

    const slDistPct = t.sl_dist_pct_at_open || (t.entry>0 ? Math.abs(t.sl-t.entry)/t.entry*100 : 0);

    const notional = slDistPct > 0 ? eq * (kelly/slDistPct) : 0;

    const margen = notional / LEVERAGE_EXCHANGE;

    const riskUsd = eq * kelly / 100;

    const rewardUsd = (t.tp && t.entry) ? notional * Math.abs(t.tp-t.entry)/t.entry : 0;

    // PnL flotante con formula del backtest
    // Si no hay precio live (commodities/CSV), usar pnl_pct del backend
    let pnl = 0;
    const hasLivePrice = prices[m.sym] && prices[m.sym] !== t.entry;
    if (hasLivePrice && t.entry) {
      const move = isLong ? (live-t.entry)/t.entry*100 : (t.entry-live)/t.entry*100;
      pnl = move * (kelly/Math.max(slDistPct,0.01));
    } else if (t.pnl_pct != null) {
      pnl = t.pnl_pct;  // fallback: PnL calculado por el watcher en el servidor
    }

    const pnlCol = pnl >= 0 ? '#00e676' : '#f44336';

    const slHit = isLong ? (live<=t.sl) : (live>=t.sl);

    const tpHit = isLong ? (live>=t.tp) : (live<=t.tp);

    const rStyle = `background:rgba(${isLong?'0,230,118':'248,81,73'},0.05);border-left:3px solid ${slHit?'#f44336':tpHit?'#00c853':dirC}`;

    const rn = (t.sl && t.tp) ? Math.abs(t.tp-t.entry)/Math.abs(t.entry-t.sl) : 0;

    const rrC = rn>=2?'#00c853':rn>=1.5?'#69f0ae':'#ff9800';

    const grade = m.grade_backtest || '?';

    const gC = gradeC(grade);

    const notionalTitle = `Si SL toca: -$${Math.round(riskUsd).toLocaleString()} (-${kelly}%). Si TP toca: +$${Math.round(rewardUsd).toLocaleString()} (+${rewardUsd>0?(rewardUsd/eq*100).toFixed(1):0}%)`;

    const margenTitle = `MARGEN — wallet con leverage ${LEVERAGE_EXCHANGE}x. Notional/${LEVERAGE_EXCHANGE} = $${Math.round(margen).toLocaleString()}`;

    const horaTxt = (t.opened_at||'').substring(11,16);



    html += `<tr style="${rStyle}">

      <td style="${TD};cursor:pointer" onclick="toggleTradeDetail('${m.sym}_${m.tf}')" title="Click para ver detalle del modelo"><span style="color:#6e7681;margin-right:4px;font-size:10px" id="caret-${m.sym}_${m.tf}">▶</span><span style="background:${dirC};color:#000;padding:2px 8px;border-radius:4px;font-weight:bold;font-size:11px">${isLong?'L':'S'}</span></td>

      <td style="${TD}"><b style="color:#c9d1d9">${m.sym}</b></td>

      <td style="${TD};color:#6a737d">${m.tf.toUpperCase()}</td>

      <td style="${TD};color:#8b949e">${stratShort(m.strategy||'')}</td>

      <td style="${TDC}"><span style="background:${gC};color:#000;padding:1px 7px;border-radius:8px;font-weight:bold;font-size:11px">${grade}</span></td>

      <td style="${TDR};color:#8b949e">${(m.wr_backtest!=null && m.wr_backtest>0)?m.wr_backtest.toFixed(0)+'%':'-'}</td>

      <td style="${TDR};color:${(m.cagr_backtest>0)?'#00e676':'#f85149'};font-weight:600">${(m.cagr_backtest!=null)?(m.cagr_backtest>=0?'+':'')+m.cagr_backtest.toFixed(1)+'%':'-'}</td>

      <td style="${TDR};color:#a78bfa;font-weight:600">${(m.score!=null)?m.score.toFixed(3):'-'}</td>

      <td style="${TDR};color:#8b949e">${t.entry}</td>

      <td style="${TDR};color:#e6edf3;font-weight:bold">${live?live.toFixed(live<100?4:2):'-'}</td>

      <td style="${TDR};color:#f85149">${t.sl}</td>

      <td style="${TDR};color:#00e676">${t.tp}</td>

      <td style="${TDR};color:${rrC};font-weight:bold">${rn>0?rn.toFixed(1)+':1':'-'}</td>

      <td style="${TDR};color:#a78bfa;font-weight:600" title="${notionalTitle}">${notional>0?'$'+Math.round(notional).toLocaleString():'-'}</td>

      <td style="${TDR};color:#00e676;font-weight:700;font-size:13px" title="${margenTitle}">${margen>0?'$'+Math.round(margen).toLocaleString():'-'}</td>

      <td style="${TDR};color:#ff9800;font-weight:700;font-size:13px" title="Apalancamiento del trade: notional/margen = ${LEVERAGE_EXCHANGE}x">${notional>0?LEVERAGE_EXCHANGE+'x':'-'}</td>

      <td style="${TDR};color:${pnlCol};font-weight:bold;font-size:13px">${pnl>=0?'+':''}${pnl.toFixed(2)}%</td>

      <td style="${TD};color:#444;font-size:10px">${horaTxt}</td>

    </tr>

    <tr id="detail-${m.sym}_${m.tf}" style="display:none;background:#0a0e13">

      <td colspan="18" style="padding:14px 18px;border-bottom:1px solid #21262d">

        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;font-size:11px">

          <div><div style="color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase">PF bt</div><div style="color:#c9d1d9;font-weight:700;font-size:14px">${(m.pf_backtest!=null)?m.pf_backtest.toFixed(2):'-'}</div></div>

          <div><div style="color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase">DD bt</div><div style="color:#f85149;font-weight:700;font-size:14px">${(m.dd_backtest!=null)?m.dd_backtest.toFixed(1)+'%':'-'}</div></div>

          <div><div style="color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase">Trades muestra</div><div style="color:#c9d1d9;font-weight:700;font-size:14px">${(m.trades_backtest!=null)?m.trades_backtest:(m.trades_closed||'-')}</div></div>

          <div><div style="color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase">Trades/mes</div><div style="color:#c9d1d9;font-weight:700;font-size:14px">${(m.trades_per_month!=null)?m.trades_per_month.toFixed(1):'-'}</div></div>

          <div><div style="color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase">WR live</div><div style="color:${(m.wr>=m.wr_backtest*0.85)?'#00e676':'#ff9800'};font-weight:700;font-size:14px">${(m.trades_closed>0)?m.wr.toFixed(0)+'%':'sin muestra'}</div></div>

          <div><div style="color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase">&Delta; WR vs bt</div><div style="color:${(m.wr_delta>=-15)?'#00e676':'#f85149'};font-weight:700;font-size:14px">${(m.wr_delta!=null && m.trades_closed>0)?(m.wr_delta>=0?'+':'')+m.wr_delta.toFixed(0)+'pp':'-'}</div></div>

          <div><div style="color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase">Sharpe live</div><div style="color:#c9d1d9;font-weight:700;font-size:14px">${(m.sharpe!=null && m.sharpe!=0)?m.sharpe.toFixed(2):'-'}</div></div>

          <div><div style="color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase">Status live</div><div style="color:#c9d1d9;font-weight:700;font-size:14px">${m.status||'-'}</div></div>

          <div><div style="color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase">Avg hold</div><div style="color:#c9d1d9;font-weight:700;font-size:14px">${(m.avg_hold_h!=null && m.avg_hold_h>0)?m.avg_hold_h.toFixed(1)+'h':'-'}</div></div>

          <div><div style="color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase">Best trade</div><div style="color:#00e676;font-weight:700;font-size:14px">${(m.best_pct!=null && m.best_pct!=0)?(m.best_pct>=0?'+':'')+m.best_pct.toFixed(2)+'%':'-'}</div></div>

          <div><div style="color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase">Worst trade</div><div style="color:#f85149;font-weight:700;font-size:14px">${(m.worst_pct!=null && m.worst_pct!=0)?(m.worst_pct>=0?'+':'')+m.worst_pct.toFixed(2)+'%':'-'}</div></div>

          <div><div style="color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase">Equity modelo</div><div style="color:#c9d1d9;font-weight:700;font-size:14px">${m.equity?('$'+Math.round(m.equity).toLocaleString()):'-'}</div></div>

          <div style="grid-column:span 4"><div style="color:#6e7681;font-size:9px;letter-spacing:.1em;text-transform:uppercase">Recomendación · razón</div><div style="color:#c9d1d9;font-weight:600;font-size:12px;margin-top:2px"><span style="color:#a78bfa">${m.recommendation||'-'}</span> <span style="color:#6e7681">— ${m.reason||''}</span></div></div>

        </div>

      </td>

    </tr>`;

  }

  html += '</tbody></table>';

  wrap.innerHTML = html;

}



function renderAll() {

  const arr = applyFilterSort(_cachedArr);

  let html = '';

  let rank = 1;

  for (const m of arr) {

    html += renderCard(m, _currentSort === 'score' ? rank++ : null);

  }

  document.getElementById('grid').innerHTML = html || '<div class="empty">Sin modelos que coincidan con el filtro.</div>';

}



function toggleDetail(btn) {

  const detail = btn.nextElementSibling;

  detail.classList.toggle('show');

  btn.innerHTML = detail.classList.contains('show') ? 'Ocultar detalle &#x25B2;' : 'Mostrar detalle &#x25BC;';

}



async function load() {

  try {

    const r = await fetch('/api/per_model_stats');

    const d = await r.json();

    _cachedArr = Object.values(d);

    if (_cachedArr.length === 0) {

      document.getElementById('grid').innerHTML = '<div class="empty">Inicializando per-model state. Espera 30s y refresca.</div>';

      return;

    }



    // ── FETCH LIVE PRICES para todos los modelos con trade abierto ─────

    const openModels = _cachedArr.filter(m => m.has_open && m.open);

    const syms = [...new Set(openModels.map(m => m.sym))];

    const livePrices = syms.length > 0 ? await _fetchLivePrices(syms) : {};

    // Calcular flotante por modelo y total

    let floatTotal = 0;

    let floatTotalPct = 0;

    for (const m of _cachedArr) {

      m._float_pct = 0; m._float_usd = 0; m._equity_efectivo = m.equity;

      if (m.has_open && m.open) {

        const live = livePrices[m.sym];

        const isShort = m.open.direction === 'short';

        if (live && m.open.entry) {

          const move = isShort ? (m.open.entry - live)/m.open.entry*100 : (live - m.open.entry)/m.open.entry*100;

          const sl_d = m.open.sl_dist_pct_at_open || 1;

          const kelly = m.open.kelly_pct || 5;

          const eqPct = move * (kelly/Math.max(sl_d, 0.01));

          m._float_pct = eqPct;

          m._float_usd = m.equity * eqPct / 100;

          m._equity_efectivo = m.equity + m._float_usd;

        }

      }

      floatTotal += m._float_usd;

    }



    // ── SUMMARY con equity efectivo (realized + flotante) ────────────

    const totalEqEfectivo = _cachedArr.reduce((s,m) => s+m._equity_efectivo, 0);

    const totalInitial = _cachedArr.reduce((s,m) => s+m.initial, 0);

    const avgRetEfectivo = _cachedArr.reduce((s,m) =>

      s + ((m._equity_efectivo/m.initial - 1) * 100), 0) / _cachedArr.length;

    const totalTrades = _cachedArr.reduce((s,m) => s+m.trades_closed, 0);



    // Best/Worst basado en equity efectivo (incluye flotante)

    const activeOrTraded = _cachedArr.filter(m => m.trades_closed > 0 || m.has_open);

    let best = null, worst = null;

    if (activeOrTraded.length > 0) {

      best  = activeOrTraded.reduce((a,b) => b._equity_efectivo > a._equity_efectivo ? b : a);

      worst = activeOrTraded.reduce((a,b) => b._equity_efectivo < a._equity_efectivo ? b : a);

    }



    const statusCounts = {OK:0,DEGRADING:0,FAILING:0,EARLY:0,NEW:0};

    _cachedArr.forEach(m => { statusCounts[m.status] = (statusCounts[m.status]||0)+1; });



    document.getElementById('n-models').textContent = _cachedArr.length;

    document.getElementById('eq-total').textContent = '$'+totalEqEfectivo.toLocaleString('en-US',{maximumFractionDigits:0});

    document.getElementById('eq-total').className = 'val ' + (totalEqEfectivo >= totalInitial ? 'pos' : 'neg');

    const floatTotalCls = floatTotal > 0 ? 'pos' : floatTotal < 0 ? 'neg' : 'dim';

    document.getElementById('float-total').textContent = (floatTotal>=0?'+$':'-$')+Math.abs(floatTotal).toLocaleString('en-US',{maximumFractionDigits:0});

    document.getElementById('float-total').className = 'val ' + floatTotalCls;

    document.getElementById('ret-avg').textContent = (avgRetEfectivo>=0?'+':'')+avgRetEfectivo.toFixed(2)+'%';

    document.getElementById('ret-avg').className = 'val ' + (avgRetEfectivo>=0?'pos':'neg');

    if (best) {

      const retE = (best._equity_efectivo/best.initial - 1) * 100;

      const floatStr = best.has_open ? ' <span style="color:#a78bfa;font-size:9px">(float)</span>' : '';

      document.getElementById('best').innerHTML = best.sym+' '+best.tf+' '+(retE>=0?'+':'')+retE.toFixed(1)+'%'+floatStr;

      document.getElementById('best').className = 'val ' + (retE>=0?'pos':'neg');

    } else {

      document.getElementById('best').textContent = '-';

    }

    if (worst) {

      const retE = (worst._equity_efectivo/worst.initial - 1) * 100;

      const floatStr = worst.has_open ? ' <span style="color:#a78bfa;font-size:9px">(float)</span>' : '';

      document.getElementById('worst').innerHTML = worst.sym+' '+worst.tf+' '+(retE>=0?'+':'')+retE.toFixed(1)+'%'+floatStr;

      document.getElementById('worst').className = 'val ' + (retE>=0?'pos':'neg');

    } else {

      document.getElementById('worst').textContent = '-';

    }

    document.getElementById('n-trades').textContent = totalTrades;

    const nOpen = openModels.length;

    document.getElementById('n-open').textContent = nOpen;

    document.getElementById('n-open').className = 'val ' + (nOpen > 0 ? 'pos' : 'dim');

    document.getElementById('status-summary').textContent = `${statusCounts.OK}OK / ${statusCounts.DEGRADING}DG / ${statusCounts.FAILING}FL / ${statusCounts.EARLY+statusCounts.NEW}NEW`;

    document.getElementById('status-summary').style.fontSize = '12px';



    renderAll();

    renderActiveTrades(livePrices);  // reusar mismas precios cacheados

  } catch(e) {

    document.getElementById('grid').innerHTML = '<div class="empty">Error: '+e.message+'</div>';

  }

}

load();

setInterval(load, 15000);



// Filtros

document.querySelectorAll('.fbtn').forEach(b => {

  b.addEventListener('click', () => {

    document.querySelectorAll('.fbtn').forEach(x => x.classList.remove('active'));

    b.classList.add('active');

    renderAll();

  });

});



// Sort

document.querySelectorAll('.sbtn').forEach(b => {

  b.addEventListener('click', () => {

    document.querySelectorAll('.sbtn').forEach(x => x.classList.remove('active'));

    b.classList.add('active');

    _currentSort = b.dataset.sort;

    renderAll();

  });

});

</script>

</body></html>"""



# ── /Per-model page ──────────────────────────────────────────────────────────



class Handler(http.server.SimpleHTTPRequestHandler):

    def _gate(self):

        """Devuelve True si el request debe pasar; sino sirve la página de login."""

        # Path siempre permitidos (sin auth): login y archivos estáticos del browser

        if self.path.startswith('/login') or self.path == '/favicon.ico' or self.path.startswith('/api/public'):

            return True

        if _is_authenticated(self):

            return True

        # Token en URL: ?token=SECRETO → setea cookie y redirige a ruta limpia

        import urllib.parse as _up_gate

        _parsed = _up_gate.urlparse(self.path)

        _qs = dict(_up_gate.parse_qsl(_parsed.query))

        _url_tok = _qs.get('token', '')

        if _url_tok:

            _, _secret, _valid_tok = _read_auth_config()

            if _valid_tok and _url_tok == _valid_tok:

                _cookie_tok = _auth_token(_secret)

                _dest = _parsed.path or '/'

                self.send_response(302)

                self.send_header('Location', _dest)

                self.send_header('Set-Cookie', f'sigma_auth={_cookie_tok}; Path=/; Max-Age=7776000; HttpOnly; SameSite=Lax')

                self.send_header('Cache-Control', 'no-store')

                self.end_headers()

                return False

        # No autenticado → mostrar login

        html = _render_login_page().encode('utf-8')

        self.send_response(200)

        self.send_header('Content-Type', 'text/html; charset=utf-8')

        self.send_header('Content-Length', str(len(html)))

        self.send_header('Cache-Control', 'no-store')

        self.end_headers()

        self.wfile.write(html)

        return False



    def do_GET(self):

        # ── Public endpoint (no auth) — for SIGMA FIRE mobile app ─────────────────
        if self.path == '/api/public':
            try:
                import json as _j, pathlib as _pl
                _cache_p = _pl.Path('/opt/sigma/results/signals_cache.json')
                _cache = _j.loads(_cache_p.read_text()) if _cache_p.exists() else {}
                _signals = [m for m in _cache.get('models', []) if m.get('signal')]
                _ts_p = _pl.Path('/opt/sigma/results/trade_state.json')
                _open_trades = []
                _history = []
                _port = {}
                _real_wr = None; _real_pf = None; _n_trades = 0
                if _ts_p.exists():
                    _ts = _j.loads(_ts_p.read_text())
                    _open_trades = [v for v in _ts.get('open', {}).values() if v.get('status') == 'open']
                    _all_hist = _ts.get('history', [])
                    _history = _all_hist[-20:]
                    _port = _ts.get('portfolio', {})
                    _n_trades = len(_all_hist)
                    if _all_hist:
                        _win_t = [t for t in _all_hist if (t.get('pnl_pct') or 0) > 0]
                        _loss_t = [t for t in _all_hist if (t.get('pnl_pct') or 0) < 0]
                        _real_wr = round(len(_win_t) / _n_trades * 100, 1)
                        _gp = sum(t.get('pnl_dollar', 0) or 0 for t in _win_t)
                        _gl = abs(sum(t.get('pnl_dollar', 0) or 0 for t in _loss_t))
                        _real_pf = round(_gp / _gl, 2) if _gl > 0 else None
                _perf_p = _pl.Path('/opt/sigma/results/reports/performance_tracker.json')
                if _perf_p.exists() and not _port:
                    _port = _j.loads(_perf_p.read_text()).get('portfolio', {})
                _top_models = sorted(
                    [m for m in _cache.get('models', []) if m.get('grade') in ('A+', 'A')],
                    key=lambda x: x.get('score', 0), reverse=True
                )[:12]
                _return_pct = round((_port.get('equity', 10000) / _port.get('initial_capital', 10000) - 1) * 100, 2) if _port.get('initial_capital') else 0
                _body = _j.dumps({
                    'regime': _cache.get('regime', 'UNKNOWN'),
                    'signals': _signals,
                    'top_models': _top_models,
                    'portfolio': {**_port, 'return_pct': _return_pct, 'wr': _real_wr, 'pf': _real_pf, 'n_trades': _n_trades},
                    'open_trades': _open_trades,
                    'history': _history,
                    'updated': _cache.get('updated', ''),
                }, ensure_ascii=False).encode('utf-8')
            except Exception as _e:
                _body = ('{"error":"' + str(_e)[:100] + '"}').encode('utf-8')
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('Content-Length', len(_body))
            self.send_header('Access-Control-Allow-Origin', '*')
            self.end_headers()
            self.wfile.write(_body)
            return

        if not self._gate(): return

        if self.path == '/api/regime':

            _send_json(self, get_regime())



        elif self.path == '/api/training_live':

            # Counter publico para landing page — backtesting en vivo

            try:

                import subprocess as _sp

                from pathlib import Path as _Path

                _r = _sp.run(['bash','-c','ps -eo cmd | grep asset_pipeline.py | grep -v grep | wc -l'],

                             capture_output=True, text=True, timeout=5)

                n_trials_active = int((_r.stdout or '0').strip())



                n_models_total = 0

                for _tf in ['1d','5m','15m','1h','4h']:

                    _p = _Path('/opt/sigma/models/' + _tf)

                    if _p.exists():

                        n_models_total += len(list(_p.glob('*.json')))



                n_operativos = 0

                n_pass_live = 0

                n_blocked = 0

                _regime = '?'

                try:

                    _sc = json.load(open('/opt/sigma/results/signals_cache.json'))

                    for _m in _sc.get('models', []):

                        _rc = _m.get('recommendation','')

                        _rb = _m.get('robustness_action','')

                        if _rc in ('ACTIVAR','CONDICIONAL') and _rb != 'BLOCKED':

                            n_operativos += 1

                        if _rb == 'PASS_LIVE':

                            n_pass_live += 1

                        if _rb == 'BLOCKED':

                            n_blocked += 1

                    _regime = _sc.get('regime','?')

                except Exception:

                    pass



                _port_cagr = 0.0

                try:

                    _snap = json.load(open('/opt/sigma/results/reports/port_snapshot.json'))

                    _port_cagr = _snap.get('port_cagr', 0.0)

                except Exception:

                    pass



                _send_json(self, {

                    'trials_active': n_trials_active,

                    'models_total_trained': n_models_total,

                    'models_operativos': n_operativos,

                    'models_pass_live': n_pass_live,

                    'models_blocked': n_blocked,

                    'regime': _regime,

                    'port_cagr': _port_cagr,

                    'updated_at': time.strftime('%Y-%m-%d %H:%M:%S'),

                })

            except Exception as _e_tl:

                _send_json(self, {'error': str(_e_tl)})

            return



        elif self.path == '/api/stats':

            # Auto-healing: 503 si cache stale > 120s para que el cron reinicie sigma-web

            _ok_ts = _signals_cache.get('_last_compute_ok_ts', 0) if _signals_cache else 0

            _age = (time.time() - _ok_ts) if _ok_ts else 999999

            if _ok_ts and _age > 120:

                self.send_response(503)

                self.send_header('Content-Type', 'application/json')

                self.end_headers()

                import json as _j503

                self.wfile.write(_j503.dumps({'error':'cache_stale','age_s':round(_age,1)}).encode())

            else:

                _send_json(self, get_live_stats())



        elif self.path == '/download/engine':

            # Actualiza modelos antes de descargar

            try:

                subprocess.run(

                    ['/opt/sigma_env/bin/python', str(UPDATE_HUD_PY)],

                    cwd=str(BASE), capture_output=True, timeout=30

                )

            except Exception:

                pass

            _serve_file(self, ENGINE_PINE, 'SIGMA_ENGINE_v1.pine')



        elif self.path == '/download/strategy':

            _serve_file(self, STRATEGY_PINE, 'SIGMA_ENGINE_STRATEGY_v1.pine')



        elif self.path == '/download/terminal':

            _serve_file(self, HUD_PINE, 'SIGMA_v13_COMPLETO.pine')



        elif self.path.startswith('/download/model/'):

            import urllib.parse as _up_dlm

            fname = _up_dlm.unquote(self.path.split('/download/model/')[-1])

            _dlm_base = (BASE / 'results' / 'pine_scripts').resolve()

            fpath = (_dlm_base / fname).resolve()

            if not fpath.is_relative_to(_dlm_base):
                self.send_response(403); self.end_headers(); self.wfile.write(b"Forbidden")
            else:
                _serve_file(self, fpath, fname)

        elif self.path == '/download/hud':

            # Backward compat → redirige al engine

            _serve_file(self, ENGINE_PINE, 'SIGMA_ENGINE_v1.pine')



        elif self.path == '/api/hud_info':

            info = {'available': False, 'models': 0, 'updated': '—'}

            if HUD_PINE.exists():

                import re

                src = HUD_PINE.read_text(encoding='utf-8')

                ts_match = re.search(r'[Aa]ctualizado\s*[:\s]+(\d{2}/\d{2}/\d{4}\s+\d{2}:\d{2}[^\n]*)', src)

                try:

                    from pathlib import Path as _P2

                    import json as _j2

                    n_models = sum(1 for f in (_P2('/opt/sigma/models')).glob('*/*.json')

                                   if 'archive' not in str(f)

                                   and _j2.loads(f.read_text()).get('metrics_oos',{}).get('cagr',0)>0)

                except:

                    n_models = len(re.findall(r'str\.contains\(_tk,"(?:ETH|SOL|BNB|LTC|BTC|XRP)"', src)) // 2

                info = {

                    'available': True,

                    'models':    n_models,

                    'updated':   ''.join(c for c in (ts_match.group(1) if ts_match else '—') if ord(c) < 128).strip() if ts_match else '—',

                    'size_kb':   round(HUD_PINE.stat().st_size / 1024, 1),

                }

            _send_json(self, info)



        elif self.path == '/api/new_records':

            # Modelos guardados en las últimas 24h

            try:

                import glob, json as _json

                records = []

                for jf in glob.glob(str(BASE / 'models' / '**' / '*.json'), recursive=True):

                    if 'archive' in jf or 'config' in jf: continue

                    try:

                        import os

                        mtime = os.path.getmtime(jf)

                        if time.time() - mtime < 86400:  # últimas 24h

                            d = _json.loads(open(jf).read())

                            m = d.get('metrics_oos', {})

                            if m.get('cagr', 0) > 0:

                                records.append({

                                    'file': os.path.basename(jf),

                                    'symbol': d.get('symbol',''),

                                    'tf': d.get('tf',''),

                                    'strategy': d.get('strategy',''),

                                    'cagr': m.get('cagr',0),

                                    'wr': m.get('wr',0),

                                    'saved_at': d.get('saved_at',''),

                                })

                    except: pass

                _send_json(self, {'records': sorted(records, key=lambda x: x['saved_at'], reverse=True)})

            except Exception as e:

                _send_json(self, {'records': [], 'error': str(e)})



        elif self.path == '/api/regime_changes':

            _send_json(self, {'changes': _regime_changes})



        elif self.path == '/api/risk_status':

            _send_json(self, get_risk_status())



        elif self.path == '/api/trades':

            try:

                _send_json(self, get_trade_summary())

            except Exception as _te:

                print(f'[API/trades ERROR] {_te}', flush=True)

                _send_json(self, {'open':[],'history':[],'stats':{},'portfolio':{},'live_readiness':{'score':0,'level':'ERROR','checks':[]}})







        elif self.path == '/api/pine_html':

            try:

                import time as _ti

                pine_dir = BASE / 'results' / 'pine_scripts'

                models = []

                now = _ti.time()

                for fname in sorted(pine_dir.glob('SIGMA_*_CAGR*.pine')):

                    name = fname.stem; parts = name.split('_')

                    try:

                        sym = parts[1]; tf = parts[2].lower()

                        ci = next(i for i,p in enumerate(parts) if p.startswith('CAGR'))

                        strategy = '_'.join(parts[3:ci])

                        cagr = float(parts[ci].replace('CAGR','').replace('pct',''))

                        stat = fname.stat()

                        age_min = (now - stat.st_mtime) / 60

                        age_h = age_min / 60

                        age_str = _dt.fromtimestamp(stat.st_mtime, tz=_TZ_CL).strftime('%H:%M')

                        models.append({'sym':sym,'tf':tf,'strategy':strategy,'cagr':cagr,

                                       'age_str':age_str,'age_min':age_min,

                                       'mtime':stat.st_mtime,'fname':fname.name,

                                       'is_new':age_min<120})

                    except: pass

                models.sort(key=lambda x: -x['mtime'])



                SC = {'BTC':'#f7931a','ETH':'#627eea','LTC':'#bfbbbb','SOL':'#9945ff','BNB':'#f3ba2f','XAU':'#FFD700'}

                SM = {'momentum_short':'MOM↓','breakdown':'BDN↓','pullback_short':'PBK↓',

                      'breakout':'BRK↑','tma_bands':'TMA','mean_rev':'MRV',

                      'regime_adaptive':'RAD','momentum':'MOM↑','pullback':'PBK↑'}



                def cagr_col(v):

                    return '#00c853' if v>=40 else '#69f0ae' if v>=20 else '#8bc48b' if v>=0 else '#f44336'



                new_count = sum(1 for m in models if m['is_new'])

                nb = (f'<span style="background:#00c853;color:#000;padding:1px 6px;'

                      f'border-radius:8px;font-size:9px;font-weight:bold;margin-left:6px">'

                      f'+{new_count} new</span>') if new_count else ''



                rows = ''

                for m in models:

                    sc = SC.get(m['sym'], '#58a6ff')

                    strat = SM.get(m['strategy'], m['strategy'])

                    cc = cagr_col(m['cagr'])

                    dot = ('<span style="display:inline-block;width:7px;height:7px;'

                           'background:#00c853;border-radius:50%;'

                           'animation:pulse 1.5s infinite"></span>'

                           if m['is_new'] else

                           '<span style="display:inline-block;width:7px;height:7px;'

                           'background:#21262d;border-radius:50%"></span>')

                    cagr_txt = f'+{m["cagr"]:.0f}%' if m['cagr'] > 0 else f'{m["cagr"]:.0f}%'

                    bg = 'background:rgba(0,200,83,0.03)' if m['is_new'] else ''

                    rows += (

                        f'<tr style="border-bottom:1px solid #0d1117;{bg}">'

                        f'<td style="padding:4px 8px;width:16px">{dot}</td>'

                        f'<td style="padding:4px 6px;color:#555;font-size:10px;'

                        f'font-family:monospace;white-space:nowrap">{m["age_str"]}</td>'

                        f'<td style="padding:4px 6px">'

                        f'<b style="color:{sc};font-size:11px">{m["sym"]}</b></td>'

                        f'<td style="padding:4px 4px;color:#555;font-size:10px">'

                        f'{m["tf"].upper()}</td>'

                        f'<td style="padding:4px 6px;color:#6a737d;font-size:10px">'

                        f'{strat}</td>'

                        f'<td style="padding:4px 8px;text-align:right">'

                        f'<b style="color:{cc};font-size:11px">{cagr_txt}</b></td>'

                        f'<td style="padding:4px 8px;text-align:right">'

                        f'<a href="/{m["fname"]}" download="{m["fname"]}" '

                        f'style="color:#58a6ff;font-size:12px;text-decoration:none">&#11015;</a>'

                        f'</td></tr>'

                    )



                TH = ('padding:3px 6px;color:#333;font-size:9px;text-transform:uppercase;'

                      'letter-spacing:.8px;border-bottom:2px solid #21262d;font-weight:500')

                ts = _strftime_chile('%H:%M')

                html = (

                    f'<div style="background:#0d1117;border:1px solid #21262d;'

                    f'border-radius:8px;padding:12px 14px;margin:16px 0">'

                    f'<div style="display:flex;justify-content:space-between;'

                    f'align-items:center;margin-bottom:8px">'

                    f'<span style="color:#c9d1d9;font-weight:700;font-size:12px">'

                    f'&#127794; Pine Scripts &#8212; &#218;ltimas actualizaciones{nb}</span>'

                    f'<span style="color:#333;font-size:10px">{len(models)} modelos &middot; {ts}</span>'

                    f'</div>'

                    f'<table style="width:100%;border-collapse:collapse">'

                    f'<thead><tr>'

                    f'<th style="{TH};width:16px"></th>'

                    f'<th style="{TH}">Cu&#225;ndo</th>'

                    f'<th style="{TH}">Activo</th>'

                    f'<th style="{TH}">TF</th>'

                    f'<th style="{TH}">Estrategia</th>'

                    f'<th style="{TH};text-align:right">CAGR</th>'

                    f'<th style="{TH};text-align:right">Pine</th>'

                    f'</tr></thead>'

                    f'<tbody>{rows}</tbody>'

                    f'</table>'

                    f'<div style="margin-top:6px;color:#30363d;font-size:10px">'

                    f'&#9432; Ordenado por &#250;ltima actualizaci&#243;n &middot; '

                    f'Verde = generado hace &lt;2h por el optimizador</div>'

                    f'</div>'

                )

                self.send_response(200)

                self.send_header('Content-Type', 'text/html; charset=utf-8')

                self.send_header('Cache-Control', 'no-cache')

                self.end_headers()

                self.wfile.write(html.encode('utf-8'))

            except Exception as e:

                self.send_response(500)

                self.end_headers()

                self.wfile.write(str(e).encode())



        elif self.path == '/api/pine_status':

            try:

                import time as _ti, re as _re, glob as _gl

                pine_dir = BASE / 'results' / 'pine_scripts'

                models = []

                now = _ti.time()

                for fname in sorted(pine_dir.glob('SIGMA_*_CAGR*.pine')):

                    name = fname.stem

                    parts = name.split('_')

                    try:

                        sym = parts[1]; tf = parts[2].lower()

                        cagr_idx = next(i for i,p in enumerate(parts) if p.startswith('CAGR'))

                        strategy = '_'.join(parts[3:cagr_idx])

                        cagr_str = parts[cagr_idx].replace('CAGR','').replace('pct','')

                        cagr = float(cagr_str) if cagr_str.lstrip('-').isdigit() else 0

                        stat = fname.stat()

                        age_min = (now - stat.st_mtime) / 60

                        age_h = age_min / 60

                        age_str = _dt.fromtimestamp(stat.st_mtime, tz=_TZ_CL).strftime('%H:%M')

                        models.append({

                            'sym': sym, 'tf': tf, 'strategy': strategy,

                            'cagr': cagr, 'size_kb': round(stat.st_size/1024, 1),

                            'age_str': age_str, 'age_min': age_min,

                            'mtime': stat.st_mtime, 'fname': fname.name,

                            'is_new': age_min < 120,

                        })

                    except: pass

                # Sort by most recently updated first

                models.sort(key=lambda x: -x['mtime'])



                # Scrape recent NUEVO MEJOR events from pipeline logs

                events = []

                rep = BASE / 'results' / 'reports'

                pat = _re.compile(

                    r'\[(\d{2}:\d{2}:\d{2})\]\s+\[(\w+)/USDT\s+(\w+)\]\s+NUEVO MEJOR:\s+'

                    r'(\w+)(?:\s+score=[\d.]+)?\s+OOS\s+([+-]?\d+\.?\d*)%'

                    r'(?:\s+WR(\d+)%)?'

                )

                for log in sorted(rep.glob('*_pipeline.log'))[-12:]:

                    try:

                        lines = log.read_text(encoding='utf-8', errors='replace').splitlines()

                        for line in lines[-300:]:

                            m = pat.search(line)

                            if m:

                                events.append({

                                    'time': m.group(1),

                                    'sym': m.group(2),

                                    'tf': m.group(3).lower(),

                                    'strategy': m.group(4),

                                    'oos': float(m.group(5)),

                                    'wr': int(m.group(6)) if m.group(6) else None,

                                })

                    except: pass

                # Deduplicate by sym+tf+strategy, keep last occurrence

                seen = {}

                for ev in events:

                    k = f"{ev['sym']}_{ev['tf']}_{ev['strategy']}"

                    seen[k] = ev

                recent_events = list(seen.values())[-20:]



                _send_json(self, {

                    'models': models, 'total': len(models),

                    'events': recent_events,

                    'updated': _strftime_chile('%H:%M'),

                })

            except Exception as e:

                _send_json(self, {'models': [], 'total': 0, 'events': [], 'updated': '--', 'error': str(e)})





        elif self.path == '/api/trainer_status':

            try:

                log_path = BASE / 'results/reports/trainer.log'

                lines = log_path.read_text(encoding='utf-8', errors='replace').splitlines()

                recent = [l for l in lines if l.strip()][-40:]

                db_total = 0

                try:

                    import sqlite3 as _sq

                    c = _sq.connect(str(DB))

                    db_total = c.execute('SELECT COUNT(*) FROM runs').fetchone()[0]

                    rate_hr  = c.execute("SELECT COUNT(*) FROM runs WHERE ts > datetime('now','-1 hours')").fetchone()[0]

                    c.close()

                except: rate_hr = 0

                # Leer optuna_rate desde el cache compartido (background thread — no bloquea)
                optuna_rate = _live_stats_cache.get('optuna_rate_hr', 0)

                _send_json(self, {'lines': recent, 'db_total': db_total, 'rate_hr': rate_hr, 'optuna_rate_hr': optuna_rate})

            except Exception as e:

                _send_json(self, {'lines': [str(e)], 'db_total': 0, 'rate_hr': 0})



        elif self.path == '/api/m2_prices':
            _send_json(self, _M2_PRICES_CACHE)

        elif self.path == '/api/signals':

            if _signals_cache:

                _resp_sig = dict(_signals_cache)

                _ok_ts_sig = _resp_sig.get('_last_compute_ok_ts', 0)

                _age_sig = (time.time() - _ok_ts_sig) if _ok_ts_sig else 999999

                _resp_sig['cache_age_s'] = round(_age_sig, 1)

                _resp_sig['cache_stale'] = _age_sig > 60

                _send_json(self, _resp_sig)

            else:

                _send_json(self, {'regime': 'LOADING', 'models': [], 'updated': '?', 'cache_stale': True, 'cache_age_s': None})



        elif self.path == '/api/per_model_stats':

            try:

                _send_json(self, get_per_model_stats())

            except Exception as _epm:

                _send_json(self, {'error': str(_epm)})



        elif self.path == '/api/notifications':

            try:

                _send_json(self, {'events': get_recent_notifications(50)})

            except Exception as _en:

                _send_json(self, {'events': [], 'error': str(_en)})

        elif self.path == '/api/pipeline_events':

            try:

                import json as _pj

                _pev_file = Path('/opt/sigma/results/reports/pipeline_events.jsonl')

                _events = []

                if _pev_file.exists():

                    _lines = _pev_file.read_text(encoding='utf-8').splitlines()

                    for _l in _lines[-80:]:

                        try: _events.append(_pj.loads(_l))

                        except: pass

                _send_json(self, {'events': list(reversed(_events))})

            except Exception as _eph:

                _send_json(self, {'events': [], 'error': str(_eph)})



        elif self.path == '/models' or self.path == '/models.html':

            try:

                html = _render_per_model_page().encode('utf-8')

                self.send_response(200)

                self.send_header('Content-Type', 'text/html; charset=utf-8')

                self.send_header('Content-Length', str(len(html)))

                self.send_header('Cache-Control', 'no-store')

                self.end_headers()

                self.wfile.write(html)

            except Exception as _eep:

                self.send_response(500); self.end_headers()

                self.wfile.write(f'render error: {_eep}'.encode())



        elif self.path == '/api/ibkr_positions':

            # IBKR positions (privacy-filtered: solo ratios, no USD)

            try:

                import json as _jib

                from pathlib import Path as _Pib

                _pp = _Pib('/opt/sigma/ibkr/positions.json')

                if _pp.exists():

                    _send_json(self, _jib.loads(_pp.read_text()))

                else:

                    _send_json(self, {'positions': [], 'n_positions': 0, 'status': 'no_data'})

            except Exception as _eib:

                _send_json(self, {'error': str(_eib)})



        elif self.path == '/api/health':

            try:

                import sqlite3 as _sq_h, subprocess as _sp_h

                from datetime import datetime as _dh, timedelta as _td_h, timezone as _tz_h

                _hres = {'ts': time.time(), 'status': 'ok'}

                _checks = []

                _ok = _signals_cache.get('_last_compute_ok_ts', 0) if _signals_cache else 0

                _age = (time.time() - _ok) if _ok else 999999

                _hres['cache'] = {

                    'updated': _signals_cache.get('updated','?') if _signals_cache else '?',

                    'age_s': round(_age, 1),

                    'stale': _age > 60,

                    'duration_s': _signals_cache.get('_last_compute_duration_s', 0) if _signals_cache else 0,

                    'models_count': len(_signals_cache.get('models', [])) if _signals_cache else 0,

                    'regime': _signals_cache.get('regime','?') if _signals_cache else '?'

                }

                _checks.append(('cache_fresh', _age <= 60))

                try:

                    _ts = _load_trades()

                    _port = _ts.get('portfolio', {})

                    _hres['portfolio'] = {

                        'equity': _port.get('equity', 0),

                        'initial': _port.get('initial_capital', 10000),

                        'peak': _port.get('peak_equity', 0),

                        'return_pct': round((_port.get('equity',10000)/10000 - 1)*100, 2),

                        'max_dd_pct': _port.get('max_dd_pct', 0),

                        'open_count': len(_ts.get('open', {})),

                        'history_count': len(_ts.get('history', [])),

                        'cb_active': _ts.get('circuit_breaker', {}).get('active', False)

                    }

                    _checks.append(('cb_not_tripped', not _ts.get('circuit_breaker', {}).get('active', False)))

                except Exception as _e:

                    _hres['portfolio'] = {'error': str(_e)}

                try:

                    _con = _sq_h.connect('file:/opt/sigma/models/sigma.db?mode=ro', uri=True, timeout=5)

                    _con.execute('PRAGMA busy_timeout=5000')

                    _cut = (_dh.now(_tz_h.utc).replace(tzinfo=None) - _td_h(hours=1)).strftime('%Y-%m-%d %H:%M:%S')

                    _n = _con.execute('SELECT COUNT(*) FROM runs WHERE ts >= ?', (_cut,)).fetchone()[0]

                    _total = _con.execute('SELECT COUNT(*) FROM runs').fetchone()[0]

                    _con.close()

                    _hres['trainer'] = {'runs_last_hour': _n, 'total_runs': _total}

                    _checks.append(('trainer_active', _n > 100))

                except Exception as _e:

                    _hres['trainer'] = {'error': str(_e)}

                _hres['services'] = {}

                for _svc in ['sigma-web','sigma-pipeline','sigma-trainer','sigma-paper-trader','sigma-telegram']:

                    try:

                        _r = _sp_h.run(['systemctl','is-active',_svc], capture_output=True, text=True, timeout=3)

                        _hres['services'][_svc] = _r.stdout.strip()

                    except: _hres['services'][_svc] = 'unknown'

                _checks.append(('all_services_active', all(v=='active' for v in _hres['services'].values())))

                try:

                    _pm = _load_per_model()

                    _opens_pm = sum(1 for m in _pm.values() if m.get('open'))

                    _hist_pm = sum(len(m.get('history') or []) for m in _pm.values())

                    _hres['per_model'] = {'total': len(_pm), 'opens': _opens_pm, 'history': _hist_pm}

                except: pass

                _failed = [k for k, v in _checks if not v]

                _hres['status'] = 'ok' if not _failed else 'degraded'

                _hres['failed_checks'] = _failed

                _hres['checks_total'] = len(_checks)

                _hres['checks_passed'] = sum(1 for _, v in _checks if v)

                _send_json(self, _hres)

            except Exception as _eh:

                _send_json(self, {'status': 'error', 'error': str(_eh)})

        elif self.path == '/api/performance':
            try:
                import json as _json2, os as _os2
                _fp = "/opt/sigma/results/reports/performance_tracker.json"
                _d  = _json2.load(open(_fp)) if _os2.path.exists(_fp) else {"error":"not_computed_yet"}
                _send_json(self, _d)
            except Exception as _ex:
                _send_json(self, {"error": str(_ex)})

        elif self.path == '/api/portfolio_risk':
            try:
                import json as _json3, os as _os3
                _fp = "/opt/sigma/results/reports/portfolio_risk.json"
                _d  = _json3.load(open(_fp)) if _os3.path.exists(_fp) else {"error":"not_computed_yet"}
                _send_json(self, _d)
            except Exception as _ex:
                _send_json(self, {"error": str(_ex)})


        elif self.path == '/api/motors':
            try:
                import glob as _mg
                def _motor_coverage(syms, tfs):
                    import os as _os_mc
                    total = len(syms) * len(tfs) * 2
                    filled = 0
                    for s in syms:
                        for tf in tfs:
                            td = f'/opt/sigma/models/{tf}'
                            if not _os_mc.path.isdir(td): continue
                            has_long  = bool([f for f in _mg.glob(f'{td}/{s.lower()}_*.json') if 'short' not in _os_mc.path.basename(f)])
                            has_short = bool(_mg.glob(f'{td}/{s.lower()}_*short*.json'))
                            if has_long:  filled += 1
                            if has_short: filled += 1
                    return total, filled

                m1_t, m1_f = _motor_coverage(['BTC','ETH','SOL','BNB','LTC'], ['5m','15m','1h','4h'])
                m2_t, m2_f = _motor_coverage(['XAU','XAG','WTI','HG','NG','PL'], ['1d','4h','1h','15m'])
                _send_json(self, {
                    'motor1': {'name':'Crypto','assets':['BTC','ETH','SOL','BNB','LTC'],
                               'timeframes':['5m','15m','1h','4h'],
                               'total_slots':m1_t,'filled_slots':m1_f,
                               'coverage_pct':round(100*m1_f/m1_t,1) if m1_t else 0},
                    'motor2': {'name':'SIGMA MACRO','assets':['XAU','XAG','WTI','HG','NG','PL'],
                               'timeframes':['1d','4h','1h','15m'],
                               'total_slots':m2_t,'filled_slots':m2_f,
                               'coverage_pct':round(100*m2_f/m2_t,1) if m2_t else 0},
                    'total': {'slots':m1_t+m2_t,'filled':m1_f+m2_f,
                              'coverage_pct':round(100*(m1_f+m2_f)/(m1_t+m2_t),1) if (m1_t+m2_t) else 0},
                })
            except Exception as _em:
                print(f'[MOTORS ERROR] {_em}', flush=True)
                _send_json(self, {'error': str(_em)})

        elif self.path == '/api/risk_budget':
            try:
                import json as _jrb, os as _orb
                _fp = "/opt/sigma/results/reports/risk_budget.json"
                _d  = _jrb.load(open(_fp)) if _orb.path.exists(_fp) else {"error":"not_computed_yet"}
                _send_json(self, _d)
            except Exception as _ex:
                _send_json(self, {"error": str(_ex)})

        elif self.path == '/api/signals/stream':

            # SSE: empuja al browser cuando _signals_cache se actualiza

            try:

                self.send_response(200)

                self.send_header('Content-Type', 'text/event-stream; charset=utf-8')

                self.send_header('Cache-Control', 'no-cache')

                self.send_header('X-Accel-Buffering', 'no')

                self.send_header('Connection', 'keep-alive')

                self.end_headers()

            except Exception:

                return

            last_ts = 0

            last_hb = time.time()

            try:

                while True:

                    now = time.time()

                    cur_ts = _signals_ts

                    if cur_ts != last_ts and _signals_cache:

                        upd = _signals_cache.get('updated', '')

                        payload = '{"updated":"' + str(upd) + '","ts":' + str(cur_ts) + '}'

                        msg = ('data: ' + payload + chr(10) + chr(10)).encode('utf-8')

                        self.wfile.write(msg)

                        self.wfile.flush()

                        last_ts = cur_ts

                        last_hb = now

                    elif now - last_hb > 15:

                        self.wfile.write((': hb' + chr(10) + chr(10)).encode('utf-8'))

                        self.wfile.flush()

                        last_hb = now

                    time.sleep(0.3)

            except (BrokenPipeError, ConnectionResetError, ConnectionAbortedError, OSError):

                pass

            return



        elif self.path.startswith('/api/lsr/'):

            # LSR (Long/Short Ratio) read-only. Solo recoleccion, no integra al pipeline.

            try:

                import sqlite3 as _sq_lsr

                from urllib.parse import urlparse as _up_lsr, parse_qs as _pq_lsr

                _parsed = _up_lsr(self.path)

                _parts = _parsed.path.split('/')

                # /api/lsr/<symbol>/<tf>  -> ['', 'api', 'lsr', '<symbol>', '<tf>']

                if len(_parts) >= 5 and _parts[3] and _parts[4]:

                    _sym = _parts[3].upper()

                    _tf = _parts[4]

                    _qs = _pq_lsr(_parsed.query or '')

                    try:

                        _limit = max(1, min(500, int(_qs.get('limit', ['24'])[0])))

                    except Exception:

                        _limit = 24

                    _out = {'symbol': _sym, 'tf': _tf, 'limit': _limit}

                    _conn_lsr = _sq_lsr.connect('/opt/sigma/results/lsr.db')

                    _c_lsr = _conn_lsr.cursor()

                    for _kind in ('top_acct', 'top_pos', 'global'):

                        _c_lsr.execute(

                            'SELECT ts, long_ratio, short_ratio, ls_ratio FROM lsr '

                            'WHERE symbol=? AND tf=? AND kind=? ORDER BY ts DESC LIMIT ?',

                            (_sym, _tf, _kind, _limit)

                        )

                        _out[_kind] = [

                            {'ts': r[0], 'long': r[1], 'short': r[2], 'lsr': r[3]}

                            for r in _c_lsr.fetchall()

                        ]

                    _conn_lsr.close()

                    _send_json(self, _out)

                else:

                    _send_json(self, {'error': 'usage: /api/lsr/<symbol>/<tf>?limit=N'})

            except Exception as _elsr:

                _send_json(self, {'error': str(_elsr)})



        elif self.path.startswith('/api/oi/'):

            # OI (Open Interest) read-only. Solo recoleccion, no integra al pipeline.

            try:

                import sqlite3 as _sq_oi

                from urllib.parse import urlparse as _up_oi, parse_qs as _pq_oi

                _parsed = _up_oi(self.path)

                _parts = _parsed.path.split('/')

                # /api/oi/<symbol>/<tf>

                if len(_parts) >= 5 and _parts[3] and _parts[4]:

                    _sym = _parts[3].upper()

                    _tf = _parts[4]

                    _qs = _pq_oi(_parsed.query or '')

                    try:

                        _limit = max(1, min(500, int(_qs.get('limit', ['24'])[0])))

                    except Exception:

                        _limit = 24

                    _conn_oi = _sq_oi.connect('/opt/sigma/results/oi.db')

                    _c_oi = _conn_oi.cursor()

                    _c_oi.execute(

                        'SELECT ts, sum_open_interest, sum_open_interest_value FROM oi '

                        'WHERE symbol=? AND tf=? ORDER BY ts DESC LIMIT ?',

                        (_sym, _tf, _limit)

                    )

                    _rows = [

                        {'ts': r[0], 'oi_base': r[1], 'oi_usdt': r[2]}

                        for r in _c_oi.fetchall()

                    ]

                    _conn_oi.close()

                    _send_json(self, {'symbol': _sym, 'tf': _tf, 'limit': _limit, 'data': _rows})

                else:

                    _send_json(self, {'error': 'usage: /api/oi/<symbol>/<tf>?limit=N'})

            except Exception as _eoi:

                _send_json(self, {'error': str(_eoi)})



        elif self.path == '/api/fng' or self.path.startswith('/api/fng?'):

            # F&G crypto Fear & Greed. Read-only.

            try:

                import sqlite3 as _sq_fng

                from urllib.parse import urlparse as _up_fng, parse_qs as _pq_fng

                _parsed = _up_fng(self.path)

                _qs = _pq_fng(_parsed.query or '')

                try:

                    _limit = max(1, min(100, int(_qs.get('limit', ['7'])[0])))

